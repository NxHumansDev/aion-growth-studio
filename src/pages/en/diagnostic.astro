---
import Layout from '../../layouts/Layout.astro';

const lang = 'en';
---

<Layout title="Free Digital Visibility Diagnostic — AION" description="Analyze your digital presence for free in 2 minutes. Get a full report with score, AI visibility and real growth opportunities." lang={lang}>
  <div class="diag-bg min-h-screen relative flex flex-col">
    <div class="absolute inset-0 diag-dots pointer-events-none"></div>

    <!-- Header -->
    <nav class="relative z-10 flex items-center justify-between px-6 md:px-12 py-5">
      <a href="/en/">
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" class="h-30 md:h-36 w-auto brightness-0 invert" />
      </a>
      <div class="flex items-center gap-2">
        <a href="/es/diagnostico" class="text-sm font-medium text-white/60 hover:text-white transition-colors">ES</a>
        <span class="text-white/40 text-sm">|</span>
        <a href="/en/diagnostic" class="text-sm font-medium text-white">EN</a>
      </div>
    </nav>

    <!-- Steps indicator -->
    <div class="relative z-10 flex justify-center pt-4 pb-2">
      <div class="flex items-center gap-2">
        <div id="step-dot-1" class="step-dot active"></div>
        <div class="w-8 h-px bg-white/20"></div>
        <div id="step-dot-2" class="step-dot"></div>
        <div class="w-8 h-px bg-white/20"></div>
        <div id="step-dot-3" class="step-dot"></div>
      </div>
    </div>

    <!-- Card container -->
    <div class="relative z-10 flex-1 flex items-start justify-center px-4 py-6 md:py-10">
      <div class="w-full max-w-md">

        <!-- STEP 1: Only URL (low friction) -->
        <div id="step-1" class="step-card bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 md:p-10 shadow-2xl">
          <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-cyan-500/10 border border-cyan-400/20 rounded-full text-cyan-300 text-xs font-medium mb-4">
              <span class="w-2 h-2 bg-cyan-400 rounded-full"></span>
              Free · No signup · 2 minutes
            </div>
            <h1 class="text-2xl md:text-3xl font-bold text-white mb-3">Analyze your digital visibility</h1>
            <p class="text-sm text-slate-200 leading-relaxed">Get a full report with score, web performance, AI visibility and real growth opportunities.</p>
          </div>

          <!-- Quick teaser of benefits -->
          <div class="mb-6 grid grid-cols-2 gap-3">
            <div class="p-3 bg-white/5 border border-white/10 rounded-lg text-center">
              <svg class="w-6 h-6 mx-auto text-cyan-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
              <p class="text-xs text-slate-300">Digital Score</p>
            </div>
            <div class="p-3 bg-white/5 border border-white/10 rounded-lg text-center">
              <svg class="w-6 h-6 mx-auto text-emerald-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
              <p class="text-xs text-slate-300">AI Visibility</p>
            </div>
            <div class="p-3 bg-white/5 border border-white/10 rounded-lg text-center">
              <svg class="w-6 h-6 mx-auto text-blue-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10a4 4 0 11-8 0 4 4 0 018 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <p class="text-xs text-slate-300">Web Performance</p>
            </div>
            <div class="p-3 bg-white/5 border border-white/10 rounded-lg text-center">
              <svg class="w-6 h-6 mx-auto text-orange-300 mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              <p class="text-xs text-slate-300">Growth Ops</p>
            </div>
          </div>

          <div class="space-y-4">
            <div>
              <label for="url" class="block text-sm font-medium text-slate-200 mb-2">Your website *</label>
              <div class="relative">
                <input type="text" id="url" name="url" required placeholder="example.com"
                  class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-all"
                  inputmode="url" autocomplete="url" />
                <span id="url-status" class="absolute right-3 top-1/2 -translate-y-1/2 text-sm"></span>
              </div>
              <p id="url-feedback" class="text-xs text-slate-400 mt-1 hidden"></p>
            </div>
            <button id="btn-step1" type="button"
              class="w-full py-3 bg-white text-[#0B1B3D] font-semibold text-sm rounded-xl hover:bg-cyan-300 hover:scale-[1.02] transition-all duration-300 shadow-lg disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
              aria-label="Analyze my website">
              Analyze my website →
            </button>
          </div>

          <div id="error-step1" class="hidden mt-4 p-4 bg-red-500/10 border border-red-400/20 rounded-xl text-sm text-red-300 text-center" role="alert"></div>

          <p class="text-center text-xs text-slate-400 mt-5">
            By continuing you accept our <a href="/en/" class="text-slate-300 underline hover:text-white transition-colors">privacy policy</a>
          </p>
        </div>

        <!-- STEP 2: Name + Email (after showing value) -->
        <div id="step-2" class="step-card hidden bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 md:p-10 shadow-2xl">
          <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-blue-500/10 border border-blue-400/20 rounded-full text-blue-300 text-xs font-medium mb-4">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Your website is being analyzed
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-3">Get results via email</h2>
            <p class="text-sm text-slate-200 leading-relaxed">We'll send you a detailed report with personalized recommendations. What's your name?</p>
          </div>

          <div class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-slate-200 mb-2">Your name *</label>
              <input type="text" id="name" name="name" required placeholder="John Smith"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-all"
                autocomplete="name" />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-slate-200 mb-2">Your email *</label>
              <input type="email" id="email" name="email" required placeholder="john@company.com"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-all"
                autocomplete="email" />
              <p id="email-feedback" class="text-xs text-slate-400 mt-1 hidden"></p>
            </div>
            <button id="btn-step2" type="button"
              class="w-full py-3 bg-white text-[#0B1B3D] font-semibold text-sm rounded-xl hover:bg-cyan-300 hover:scale-[1.02] transition-all duration-300 shadow-lg disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
              aria-label="Continue">
              Continue →
            </button>
          </div>

          <div id="error-step2" class="hidden mt-4 p-4 bg-red-500/10 border border-red-400/20 rounded-xl text-sm text-red-300 text-center" role="alert"></div>

          <p class="text-center text-xs text-slate-400 mt-5">
            By continuing you accept our <a href="/en/" class="text-slate-300 underline hover:text-white transition-colors">privacy policy</a>
          </p>
        </div>

        <!-- STEP 3: Competitor selection with better copy -->
        <div id="step-3" class="step-card hidden bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 md:p-10 shadow-2xl">
          <div class="text-center mb-6">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-400/20 rounded-full text-emerald-300 text-xs font-medium mb-4">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Data saved
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Who is your competition?</h2>
            <p class="text-sm text-slate-200 leading-relaxed">Add 1-3 competitors so we can show you how you compare in visibility, rankings and digital strategy. (Optional)</p>
          </div>

          <div id="competitor-list" class="space-y-2 mb-6"></div>

          <!-- Manual competitors -->
          <div class="mb-6 p-4 bg-white/3 border border-white/10 rounded-xl">
            <label class="block text-sm font-medium text-slate-200 mb-3">Add competitors manually</label>
            <div class="flex gap-2 mb-3">
              <input type="text" id="manual-competitor-input" placeholder="competitor.com"
                class="flex-1 px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-all"
                inputmode="url" />
              <button id="btn-add-competitor" type="button"
                class="px-4 py-3 bg-white/10 border border-white/20 text-slate-200 font-medium text-sm rounded-xl hover:bg-white/20 transition-all shrink-0"
                aria-label="Add competitor">
                + Add
              </button>
            </div>
            <div id="manual-competitors-list" class="flex flex-wrap gap-2"></div>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row">
            <button id="btn-start-audit" type="button"
              class="flex-1 py-3 bg-white text-[#0B1B3D] font-semibold text-sm rounded-xl hover:bg-cyan-300 hover:scale-[1.02] transition-all duration-300 shadow-lg disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100"
              aria-label="Start analysis">
              Start analysis →
            </button>
            <button id="btn-skip-step3" type="button"
              class="flex-1 py-3 border border-white/20 text-slate-300 font-medium text-sm rounded-xl hover:bg-white/5 transition-all"
              aria-label="Skip comparison">
              Skip for now
            </button>
          </div>

          <div id="error-step3" class="hidden mt-4 p-4 bg-red-500/10 border border-red-400/20 rounded-xl text-sm text-red-300 text-center" role="alert"></div>
        </div>

      </div>
    </div>

    <!-- Footer -->
    <div class="relative z-10 text-center py-6 text-xs text-slate-500">
      <a href="/en/" class="hover:text-slate-300 transition-colors">AION Growth Studio</a>
      <span class="mx-2">·</span>
      <a href="mailto:hola@aiongrowth.studio" class="hover:text-slate-300 transition-colors">hola@aiongrowth.studio</a>
    </div>
  </div>
</Layout>

<style>
  .diag-bg {
    background: linear-gradient(160deg, #0B1B3D 0%, #1A5490 50%, #0B1B3D 100%);
  }
  .diag-dots {
    background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .step-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,0.2); transition: all 0.3s;
  }
  .step-dot.active { background: #22d3ee; box-shadow: 0 0 8px #22d3ee88; }
  .step-dot.done { background: #10b981; }
  .bg-white\/3 { background-color: rgba(255,255,255,0.03); }
  .competitor-card {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 12px; border-radius: 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    cursor: pointer; transition: all 0.2s;
  }
  .competitor-card:hover { background: rgba(255,255,255,0.07); }
  .competitor-card.selected { background: rgba(34,211,238,0.08); border-color: rgba(34,211,238,0.4); }
</style>

<script>
  let userData: { url: string; name: string; email: string } = { url: '', name: '', email: '' };
  let competitorsPromise: Promise<any> | null = null;
  let competitorsResult: any = null;
  let selectedCompetitors: string[] = [];
  let manualCompetitors: string[] = [];

  function renderManualCompetitors() {
    const list = document.getElementById('manual-competitors-list');
    if (!list) return;
    list.innerHTML = manualCompetitors.map(url => `
      <div class="flex items-center gap-1.5 px-3 py-1.5 bg-white/10 border border-white/15 rounded-lg">
        <span class="text-xs text-slate-200 truncate max-w-[160px]">${url}</span>
        <button onclick="removeManualCompetitor('${url}')" class="text-slate-400 hover:text-white text-sm leading-none ml-1 shrink-0">×</button>
      </div>
    `).join('');
  }

  (window as any).removeManualCompetitor = function(url: string) {
    manualCompetitors = manualCompetitors.filter(u => u !== url);
    renderManualCompetitors();
  };

  function addManualCompetitor() {
    const input = document.getElementById('manual-competitor-input') as HTMLInputElement;
    const val = input.value.trim().replace(/^https?:\/\//, '').replace(/\/$/, '');
    if (!val || manualCompetitors.includes(val)) { input.value = ''; return; }
    manualCompetitors.push(val);
    renderManualCompetitors();
    input.value = '';
  }

  document.getElementById('btn-add-competitor')?.addEventListener('click', addManualCompetitor);
  document.getElementById('manual-competitor-input')?.addEventListener('keydown', (e: any) => {
    if (e.key === 'Enter') { e.preventDefault(); addManualCompetitor(); }
  });

  function showStep(n: number) {
    [1, 2, 3].forEach(i => {
      const el = document.getElementById(`step-${i}`);
      if (el) el.classList.toggle('hidden', i !== n);
      const dot = document.getElementById(`step-dot-${i}`);
      if (dot) {
        dot.classList.remove('active', 'done');
        if (i < n) dot.classList.add('done');
        else if (i === n) dot.classList.add('active');
      }
    });
  }

  function showError(id: string, msg: string) {
    const el = document.getElementById(id);
    if (el) { el.textContent = msg; el.classList.remove('hidden'); }
  }

  function hideError(id: string) {
    const el = document.getElementById(id);
    if (el) el.classList.add('hidden');
  }

  function setBtn(id: string, text: string, disabled: boolean) {
    const btn = document.getElementById(id) as HTMLButtonElement;
    if (btn) { btn.textContent = text; btn.disabled = disabled; }
  }

  // Real-time URL validation
  const urlInput = document.getElementById('url') as HTMLInputElement;
  if (urlInput) {
    urlInput.addEventListener('input', () => {
      const value = urlInput.value.trim();
      const feedback = document.getElementById('url-feedback');
      const status = document.getElementById('url-status');
      
      if (value.length > 0) {
        const isValid = /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(value.replace(/^https?:\/\//, '').replace(/\/$/, ''));
        if (feedback && status) {
          if (isValid) {
            feedback.textContent = '✓ Valid URL';
            feedback.classList.add('text-emerald-400');
            feedback.classList.remove('text-red-400', 'hidden');
            status.textContent = '✓';
            status.classList.add('text-emerald-400');
            status.classList.remove('text-red-400');
          } else {
            feedback.textContent = 'Invalid format (e.g., example.com)';
            feedback.classList.add('text-red-400');
            feedback.classList.remove('text-emerald-400', 'hidden');
            status.textContent = '✗';
            status.classList.add('text-red-400');
            status.classList.remove('text-emerald-400');
          }
        }
      } else {
        if (feedback) feedback.classList.add('hidden');
        if (status) status.textContent = '';
      }
    });
  }

  // STEP 1: Validate URL + move to Step 2
  document.getElementById('btn-step1')?.addEventListener('click', async () => {
    hideError('error-step1');

    const url = (document.getElementById('url') as HTMLInputElement).value.trim();
    if (!url) return showError('error-step1', 'Please enter your website URL.');
    
    // Validate basic format
    const isValid = /^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$/.test(url.replace(/^https?:\/\//, '').replace(/\/$/, ''));
    if (!isValid) return showError('error-step1', 'Please enter a valid URL (e.g., example.com).');

    userData = { ...userData, url };
    showStep(2);
  });

  // STEP 2: Validate name + email, then detect competitors + move to Step 3
  document.getElementById('btn-step2')?.addEventListener('click', async () => {
    hideError('error-step2');

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();

    if (!name) return showError('error-step2', 'Please enter your name.');
    if (!email || !email.includes('@')) return showError('error-step2', 'Please enter a valid email.');

    userData = { ...userData, name, email };
    setBtn('btn-step2', 'Looking for competitors…', true);

    // Start competitor detection in background
    const listEl = document.getElementById('competitor-list');
    if (listEl) listEl.innerHTML = `<p class="text-xs text-slate-400 text-center py-2 animate-pulse">⏳ Analyzing your website…</p>`;

    competitorsResult = null;
    competitorsPromise = fetch('/api/audit/find-competitors', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url: userData.url }),
    })
      .then(r => r.json())
      .then(data => {
        competitorsResult = data;
        renderStep3();
        return data;
      })
      .catch(() => {
        competitorsResult = { competitors: [] };
        renderStep3();
      });

    showStep(3);
  });

  function renderStep3() {
    const competitors = competitorsResult?.competitors || [];
    const listEl = document.getElementById('competitor-list');
    selectedCompetitors = [];

    if (listEl) {
      if (competitors.length === 0) {
        listEl.innerHTML = `<p class="text-xs text-slate-400 text-center py-2">No competitors were automatically detected. You can add one manually.</p>`;
      } else {
        listEl.innerHTML = competitors.map((c: any, i: number) => `
          <div class="competitor-card" data-url="${c.url}" data-idx="${i}" onclick="toggleCompetitor(this)">
            <div class="w-5 h-5 rounded border border-white/30 flex items-center justify-center shrink-0 mt-0.5 check-icon">
              <span class="hidden text-cyan-400 text-xs">✓</span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-white truncate">${c.name}</p>
              <p class="text-xs text-slate-400 truncate">${c.url}</p>
              ${c.why ? `<p class="text-xs text-slate-500 mt-0.5 italic">${c.why}</p>` : ''}
            </div>
          </div>
        `).join('');
      }
    }
  }

  (window as any).toggleCompetitor = function(el: HTMLElement) {
    const url = el.getAttribute('data-url') || '';
    const check = el.querySelector('.check-icon span') as HTMLElement;
    const isSelected = el.classList.contains('selected');
    if (isSelected) {
      el.classList.remove('selected');
      if (check) check.classList.add('hidden');
      selectedCompetitors = selectedCompetitors.filter(u => u !== url);
    } else {
      el.classList.add('selected');
      if (check) check.classList.remove('hidden');
      if (!selectedCompetitors.includes(url)) selectedCompetitors.push(url);
    }
  };

  async function startAudit(withCompetitors: boolean) {
    hideError('error-step3');
    setBtn('btn-start-audit', 'Starting…', true);
    setBtn('btn-skip-step3', '…', true);

    const allCompetitors = withCompetitors
      ? [...selectedCompetitors, ...manualCompetitors]
      : [];

    try {
      const res = await fetch('/api/audit/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          url: userData.url,
          email: userData.email,
          name: userData.name,
          selectedCompetitors: allCompetitors,
        }),
      });

      const result = await res.json();

      if (res.ok && result.audit_id) {
        window.location.href = `/en/audit/${result.audit_id}`;
      } else {
        showError('error-step3', result.error || 'An error occurred. Please try again.');
        setBtn('btn-start-audit', 'Start analysis →', false);
        setBtn('btn-skip-step3', 'Skip for now', false);
      }
    } catch {
      showError('error-step3', 'Connection error. Please try again.');
      setBtn('btn-start-audit', 'Start analysis →', false);
      setBtn('btn-skip-step3', 'Skip for now', false);
    }
  }

  document.getElementById('btn-start-audit')?.addEventListener('click', () => startAudit(true));
  document.getElementById('btn-skip-step3')?.addEventListener('click', () => startAudit(false));
</script>
