---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { getAuditPage } from '../../../lib/audit/supabase-storage';

const { id } = Astro.params;
const lang = 'en';

let auditUrl = '';
let initialStatus = 'processing';

if (id) {
  try {
    const audit = await getAuditPage(id);
    auditUrl = audit.url;
    initialStatus = audit.status;
  } catch {
    // Page not found or Notion error — show loading state
  }
}

const domain = auditUrl ? new URL(auditUrl).hostname.replace(/^www\./, '') : '';
---

<Layout
  title={`Analyzing ${domain || 'your website'} — AION`}
  description="Digital visibility analysis in progress"
  lang={lang}
>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />

<style>
  *, *::before, *::after { box-sizing: border-box; }
  body {
    background: #000e41 !important;
    color: #fff;
    font-family: 'Inter', system-ui, sans-serif;
    margin: 0;
    min-height: 100vh;
  }
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 20;
    user-select: none;
    line-height: 1;
  }

  .phase-card {
    background: #fff;
    border-radius: 0.75rem;
    overflow: hidden;
    transition: box-shadow 0.25s;
  }
  .phase-card.active {
    box-shadow: 0 0 0 2px #000e41, 0 8px 24px rgba(0,14,65,0.14);
    background: #edf4ff;
  }
  .phase-card.done   { background: #f4fff7; }
  .phase-card.pending { opacity: 0.6; }

  .phase-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.125rem;
  }
  .phase-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    background: #e8ecf4;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.25s;
  }
  .phase-card.active .phase-icon { background: #000e41; }
  .phase-card.done   .phase-icon { background: #e1f5ea; }
  .phase-icon .material-symbols-outlined {
    font-size: 16px;
    color: #8a8f9a;
    transition: color 0.25s;
  }
  .phase-card.active .phase-icon .material-symbols-outlined { color: #69ff87; }
  .phase-card.done   .phase-icon .material-symbols-outlined { color: #22c55e; }

  .phase-title {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #1a1a2e;
    flex: 1;
    line-height: 1.3;
  }
  .phase-card.pending .phase-title { color: #6b7280; }
  .phase-card.active  .phase-title { color: #000e41; }
  .phase-card.done    .phase-title { color: #166534; }

  .phase-meta {
    font-size: 0.7rem;
    color: #9ca3af;
    flex-shrink: 0;
    text-align: right;
  }
  .phase-card.active .phase-meta { color: #4b6baf; }
  .phase-card.done   .phase-meta { color: #86efac; }

  .phase-modules {
    display: none;
    padding: 0 1.125rem 1rem;
    gap: 0.5rem;
  }
  .phase-card.active .phase-modules,
  .phase-card.done   .phase-modules {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }
  @media (max-width: 480px) {
    .phase-card.active .phase-modules,
    .phase-card.done   .phase-modules { grid-template-columns: 1fr; }
  }

  .phase-module-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.5rem;
    border-radius: 0.375rem;
    font-size: 0.7375rem;
    color: #374151;
    background: rgba(255,255,255,0.5);
  }
  .phase-card.active .phase-module-item { color: #1e3a5f; }
  .phase-module-item .mod-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #d1d5db;
    flex-shrink: 0;
  }
  .phase-module-item.running .mod-dot {
    background: #000e41;
    animation: pulse-dot 1.2s ease-in-out infinite;
  }
  .phase-module-item.done .mod-dot { background: #22c55e; }

  .mod-spinner {
    width: 14px; height: 14px;
    border-radius: 50%;
    border: 2px solid rgba(105,255,135,0.2);
    border-top-color: #69ff87;
    animation: spin 0.8s linear infinite;
    flex-shrink: 0;
  }
  .phase-spinner {
    width: 6px; height: 6px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,14,65,0.2);
    border-top-color: #000e41;
    animation: spin 0.8s linear infinite;
    flex-shrink: 0;
  }

  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50%       { transform: scale(1.7); opacity: 0.4; }
  }

  .phases-list { display: flex; flex-direction: column; gap: 0.625rem; }

  @media (max-width: 640px) {
    .hero-headline { font-size: 1.875rem !important; }
    .hero-section-inner { padding: 1.5rem 1.25rem 2rem !important; }
    .phases-section-inner { padding: 2rem 1.25rem !important; }
  }
</style>

<!-- ═══════════════════════════ DARK HERO SECTION ══════════════ -->
<section style="background:linear-gradient(135deg,#000e41 0%,#001260 60%,#000e41 100%);min-height:52vh;position:relative;">

  <nav style="padding:1.5rem 2rem;display:flex;justify-content:space-between;align-items:center;max-width:72rem;margin:0 auto;">
    <a href="/en/" style="display:inline-flex;align-items:center;text-decoration:none;height:3rem;overflow:hidden;">
      <img src="/images/aion-logo-dark.png" alt="AION Growth Studio" style="height:6rem;width:auto;" onerror="this.style.display='none';this.nextElementSibling.style.display='inline'" />
      <span style="display:none;font-size:1rem;font-weight:800;color:#fff;letter-spacing:-0.02em;">AION</span>
    </a>
    <div style="display:flex;align-items:center;gap:0.625rem;">
      <div style="width:8px;height:8px;border-radius:50%;background:#69ff87;animation:pulse-dot 1.4s ease-in-out infinite;"></div>
      <span style="font-size:0.75rem;color:rgba(255,255,255,0.55);font-weight:500;letter-spacing:0.04em;">Analysis active</span>
    </div>
  </nav>

  <div class="hero-section-inner" style="max-width:72rem;margin:0 auto;padding:1.5rem 2rem 4rem;">

    <div id="proc-card">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.375rem 0.875rem;border-radius:9999px;background:#00300e;color:#3ce36a;font-size:0.6875rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:1.75rem;">
        <span style="width:6px;height:6px;border-radius:50%;background:#3ce36a;animation:pulse-dot 1.2s ease-in-out infinite;display:inline-block;"></span>
        Analysis in progress
      </div>
      <h1 class="hero-headline" style="font-size:clamp(2rem,4.5vw,3.25rem);font-weight:800;color:#fff;letter-spacing:-0.03em;line-height:1.1;margin:0 0 0.875rem;max-width:36rem;">
        Analyzing your digital<br/>
        <span style="color:#69ff87;">infrastructure.</span>
      </h1>
      {domain && (
        <p style="font-size:0.9375rem;color:rgba(183,196,255,0.65);font-family:'Inter',monospace;margin:0 0 2.5rem;letter-spacing:0.01em;">{domain}</p>
      )}
      <div style="max-width:44rem;">
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.5rem;">
          <p id="progress-narrative" style="font-size:0.875rem;color:rgba(255,255,255,0.55);margin:0;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;transition:opacity 0.3s;line-height:1.5;"></p>
          <span id="progress-pct" style="font-size:0.875rem;color:#69ff87;font-weight:700;font-variant-numeric:tabular-nums;margin-left:1rem;flex-shrink:0;letter-spacing:0.02em;">0%</span>
        </div>
        <div style="height:3px;background:rgba(255,255,255,0.08);border-radius:9999px;overflow:hidden;margin-bottom:2rem;">
          <div id="progress-bar" style="height:100%;width:0;background:linear-gradient(90deg,#69ff87,#3ce36a);transition:width 0.7s ease;border-radius:9999px;"></div>
        </div>
        <div id="current-phase-pill" style="display:inline-flex;align-items:center;gap:0.75rem;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.08);border-radius:9999px;padding:0.625rem 1.125rem;">
          <span class="mod-spinner"></span>
          <span id="current-phase-label" style="font-size:0.8125rem;color:rgba(255,255,255,0.8);font-weight:500;">Starting…</span>
        </div>
      </div>
    </div>

    <div id="complete-card" style="display:none;">
      <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.375rem 0.875rem;border-radius:9999px;background:#00300e;color:#3ce36a;font-size:0.6875rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:1.75rem;">
        <span class="material-symbols-outlined" style="font-size:14px;color:#3ce36a;">check_circle</span>
        Analysis complete
      </div>
      <h2 style="font-size:clamp(2rem,4.5vw,3.25rem);font-weight:800;color:#fff;letter-spacing:-0.03em;line-height:1.1;margin:0 0 1rem;">
        Your report is ready!
      </h2>
      <p style="font-size:1rem;color:rgba(221,225,255,0.55);margin:0 0 2rem;font-weight:300;">Redirecting to your full report…</p>
      <a id="report-btn" href="#"
        style="display:inline-flex;align-items:center;gap:0.5rem;background:#69ff87;color:#001905;border-radius:0.375rem;padding:0.875rem 1.75rem;font-weight:700;font-size:0.75rem;text-decoration:none;text-transform:uppercase;letter-spacing:0.1em;transition:filter 0.2s;"
        onmouseover="this.style.filter='brightness(1.08)'" onmouseout="this.style.filter='none'">
        View full report →
      </a>
    </div>

    <div id="sidebar-cta" style="display:none;"><a id="sidebar-report-link" href="#"></a></div>

  </div>
</section>

<!-- ═══════════════════════ LIGHT PHASES SECTION ══════════════ -->
<section style="background:#edf4ff;">
  <div class="phases-section-inner" style="max-width:72rem;margin:0 auto;padding:3.5rem 2rem 4rem;">

    <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:2rem;">
      <span style="font-size:0.6875rem;font-weight:600;color:#43474d;text-transform:uppercase;letter-spacing:0.2em;">Analysis phases</span>
      <div style="display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;">
        <h2 style="font-size:1.75rem;font-weight:800;color:#000e41;letter-spacing:-0.02em;margin:0;">Parallel analysis</h2>
        <p style="font-size:0.875rem;color:#43474d;margin:0;font-weight:500;">
          <span id="phases-done-count" style="font-weight:800;color:#000e41;">0</span>
          <span style="color:#43474d;"> / 5 phases completed</span>
        </p>
      </div>
      <p style="font-size:0.9rem;color:#43474d;margin:0;max-width:40rem;line-height:1.6;">Each phase groups modules that run in parallel for maximum speed. Results are processed as a batch when each phase completes.</p>
    </div>

    <div class="phases-list">

      <div class="phase-card pending" id="phase-crawl">
        <div class="phase-header">
          <div class="phase-icon"><span class="material-symbols-outlined">travel_explore</span></div>
          <div style="flex:1;"><div class="phase-title">Initial exploration</div></div>
          <div class="phase-meta">1 module</div>
        </div>
        <div class="phase-modules">
          <div class="phase-module-item" id="pm-crawl"><span class="mod-dot"></span>Technical SEO analysis</div>
        </div>
      </div>

      <div class="phase-card pending" id="phase-ssl">
        <div class="phase-header">
          <div class="phase-icon"><span class="material-symbols-outlined">speed</span></div>
          <div style="flex:1;"><div class="phase-title">Technical & SEO analysis</div></div>
          <div class="phase-meta">8 modules · parallel</div>
        </div>
        <div class="phase-modules">
          <div class="phase-module-item" id="pm-ssl"><span class="mod-dot"></span>SSL/HTTPS security</div>
          <div class="phase-module-item" id="pm-pagespeed"><span class="mod-dot"></span>Web performance (PageSpeed)</div>
          <div class="phase-module-item" id="pm-seo"><span class="mod-dot"></span>Organic SEO & authority</div>
          <div class="phase-module-item" id="pm-seo_pages"><span class="mod-dot"></span>Top organic pages</div>
          <div class="phase-module-item" id="pm-traffic"><span class="mod-dot"></span>Estimated traffic</div>
          <div class="phase-module-item" id="pm-gbp"><span class="mod-dot"></span>Google Business Profile</div>
          <div class="phase-module-item" id="pm-techstack"><span class="mod-dot"></span>Tech stack</div>
          <div class="phase-module-item" id="pm-content_cadence"><span class="mod-dot"></span>Content cadence</div>
        </div>
      </div>

      <div class="phase-card pending" id="phase-sector">
        <div class="phase-header">
          <div class="phase-icon"><span class="material-symbols-outlined">category</span></div>
          <div style="flex:1;"><div class="phase-title">Sector & online presence</div></div>
          <div class="phase-meta">5 modules · parallel</div>
        </div>
        <div class="phase-modules">
          <div class="phase-module-item" id="pm-sector"><span class="mod-dot"></span>Sector detection</div>
          <div class="phase-module-item" id="pm-content"><span class="mod-dot"></span>Content analysis</div>
          <div class="phase-module-item" id="pm-conversion"><span class="mod-dot"></span>Conversion capability</div>
          <div class="phase-module-item" id="pm-reputation"><span class="mod-dot"></span>Online reputation</div>
          <div class="phase-module-item" id="pm-competitors"><span class="mod-dot"></span>Competitor analysis</div>
        </div>
      </div>

      <div class="phase-card pending" id="phase-competitor_traffic">
        <div class="phase-header">
          <div class="phase-icon"><span class="material-symbols-outlined">leaderboard</span></div>
          <div style="flex:1;"><div class="phase-title">Competitive data, social & AI</div></div>
          <div class="phase-meta">7 modules · parallel</div>
        </div>
        <div class="phase-modules">
          <div class="phase-module-item" id="pm-competitor_traffic"><span class="mod-dot"></span>Competitor traffic</div>
          <div class="phase-module-item" id="pm-competitor_pagespeed"><span class="mod-dot"></span>Competitor performance</div>
          <div class="phase-module-item" id="pm-keyword_gap"><span class="mod-dot"></span>Keyword gap</div>
          <div class="phase-module-item" id="pm-geo"><span class="mod-dot"></span>AI visibility (GEO)</div>
          <div class="phase-module-item" id="pm-instagram"><span class="mod-dot"></span>Instagram / Social media</div>
          <div class="phase-module-item" id="pm-linkedin"><span class="mod-dot"></span>LinkedIn company page</div>
          <div class="phase-module-item" id="pm-meta_ads"><span class="mod-dot"></span>Meta Ads</div>
        </div>
      </div>

      <div class="phase-card pending" id="phase-score">
        <div class="phase-header">
          <div class="phase-icon"><span class="material-symbols-outlined">grade</span></div>
          <div style="flex:1;"><div class="phase-title">Final diagnosis & score</div></div>
          <div class="phase-meta">3 steps · sequential</div>
        </div>
        <div class="phase-modules">
          <div class="phase-module-item" id="pm-score"><span class="mod-dot"></span>Score calculation</div>
          <div class="phase-module-item" id="pm-insights"><span class="mod-dot"></span>Executive diagnosis (AI)</div>
          <div class="phase-module-item" id="pm-qa"><span class="mod-dot"></span>Quality control</div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════ ERROR STATE ═══════════════════════ -->
<div id="error-state" style="display:none;background:#000e41;padding:6rem 2rem;text-align:center;">
  <div style="width:3.5rem;height:3.5rem;margin:0 auto 1.5rem;border-radius:50%;background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.25);display:flex;align-items:center;justify-content:center;">
    <svg width="24" height="24" fill="none" stroke="#fca5a5" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
  </div>
  <h2 style="font-size:1.25rem;font-weight:700;color:#fff;margin:0 0 0.5rem;">Analysis could not be completed</h2>
  <p style="color:rgba(255,255,255,0.5);font-size:0.9rem;margin:0 0 2rem;max-width:28rem;margin-left:auto;margin-right:auto;">An error occurred while analyzing your website. Please try again.</p>
  <a href="/en/diagnostic"
    style="display:inline-block;background:#69ff87;color:#001905;border-radius:0.375rem;padding:0.75rem 1.75rem;font-weight:700;font-size:0.75rem;text-decoration:none;text-transform:uppercase;letter-spacing:0.1em;">
    New analysis
  </a>
</div>

</Layout>

<script define:vars={{ auditId: id, initialStatus, domain }}>

  const PHASES = [
    {
      id: 'crawl',
      cardId: 'phase-crawl',
      label: 'Initial exploration',
      narrative: 'Scanning technical structure and content signals…',
      entrySteps: ['crawl'],
      modules: ['crawl'],
    },
    {
      id: 'ssl',
      cardId: 'phase-ssl',
      label: 'Technical & SEO analysis',
      narrative: 'Running 8 analyses in parallel: performance, SEO, traffic…',
      entrySteps: ['ssl'],
      modules: ['ssl', 'pagespeed', 'seo', 'seo_pages', 'traffic', 'gbp', 'techstack', 'content_cadence'],
    },
    {
      id: 'sector',
      cardId: 'phase-sector',
      label: 'Sector & online presence',
      narrative: 'Identifying sector, content quality and mapping competitors…',
      entrySteps: ['sector'],
      modules: ['sector', 'content', 'conversion', 'reputation', 'competitors'],
    },
    {
      id: 'competitor_traffic',
      cardId: 'phase-competitor_traffic',
      label: 'Competitive data, social & AI',
      narrative: 'Analyzing competitor traffic, AI visibility and social media…',
      entrySteps: ['competitor_traffic'],
      modules: ['competitor_traffic', 'competitor_pagespeed', 'keyword_gap', 'geo', 'instagram', 'linkedin', 'meta_ads'],
    },
    {
      id: 'score',
      cardId: 'phase-score',
      label: 'Final diagnosis & score',
      narrative: 'Calculating digital health score and generating executive diagnosis…',
      entrySteps: ['score', 'insights', 'qa'],
      modules: ['score', 'insights', 'qa'],
    },
  ];

  const stepToPhase = {};
  for (const phase of PHASES) {
    for (const m of phase.modules) stepToPhase[m] = phase;
    for (const s of phase.entrySteps) stepToPhase[s] = phase;
  }

  const completedModules = new Set();
  let activePhaseId = null;

  function setProgress(pct) {
    const bar = document.getElementById('progress-bar');
    const label = document.getElementById('progress-pct');
    if (bar) bar.style.width = `${pct}%`;
    if (label) label.textContent = `${pct}%`;
  }

  function setNarrative(text) {
    const el = document.getElementById('progress-narrative');
    if (!el || !text) return;
    el.style.opacity = '0';
    setTimeout(() => { el.textContent = text; el.style.opacity = '1'; }, 200);
  }

  function setPhaseLabel(text) {
    const el = document.getElementById('current-phase-label');
    if (el) el.textContent = text;
  }

  function updatePhasesDoneCount() {
    const done = document.querySelectorAll('.phase-card.done').length;
    const el = document.getElementById('phases-done-count');
    if (el) el.textContent = done;
  }

  function setModuleDot(moduleKey, state) {
    const el = document.getElementById(`pm-${moduleKey}`);
    if (!el) return;
    el.classList.remove('running', 'done');
    if (state) el.classList.add(state);
    const dot = el.querySelector('.mod-dot');
    const existingSpinner = el.querySelector('.phase-spinner');
    if (state === 'running') {
      if (!existingSpinner && dot) {
        const spinner = document.createElement('span');
        spinner.className = 'phase-spinner';
        el.replaceChild(spinner, dot);
      }
    } else if (existingSpinner) {
      const newDot = document.createElement('span');
      newDot.className = 'mod-dot';
      el.replaceChild(newDot, existingSpinner);
    }
  }

  function activatePhase(phase) {
    if (!phase || activePhaseId === phase.id) return;
    activePhaseId = phase.id;
    const card = document.getElementById(phase.cardId);
    if (card) {
      card.classList.remove('pending', 'done');
      card.classList.add('active');
    }
    for (const m of phase.modules) {
      if (!completedModules.has(m)) setModuleDot(m, 'running');
    }
    setNarrative(phase.narrative);
    setPhaseLabel(phase.label);
  }

  function completePhase(phase) {
    if (!phase) return;
    const card = document.getElementById(phase.cardId);
    if (card) {
      card.classList.remove('active', 'pending');
      card.classList.add('done');
      const iconEl = card.querySelector('.phase-icon .material-symbols-outlined');
      if (iconEl) iconEl.textContent = 'check_circle';
    }
    for (const m of phase.modules) setModuleDot(m, 'done');
    updatePhasesDoneCount();
    if (activePhaseId === phase.id) activePhaseId = null;
  }

  function showResults() {
    const reportUrl = `/en/audit/${auditId}/report`;
    const procCard = document.getElementById('proc-card');
    const completeCard = document.getElementById('complete-card');
    if (procCard) procCard.style.display = 'none';
    if (completeCard) completeCard.style.display = 'block';
    const reportBtn = document.getElementById('report-btn');
    if (reportBtn) reportBtn.href = reportUrl;
    const sidebarCta = document.getElementById('sidebar-cta');
    if (sidebarCta) sidebarCta.style.display = 'block';
    const reportLink = document.getElementById('sidebar-report-link');
    if (reportLink) reportLink.href = reportUrl;
    window.location.href = reportUrl;
  }

  function showError() {
    document.getElementById('proc-card')?.style.setProperty('display', 'none');
    document.getElementById('error-state')?.style.setProperty('display', 'block');
  }

  async function poll() {
    try {
      const res = await fetch(`/api/audit/${auditId}/status`);
      if (!res.ok) { showError(); return; }
      const data = await res.json();

      if (data.progress) setProgress(data.progress);

      if (data.module_completed) {
        const keys = String(data.module_completed).split(',').map(k => k.trim()).filter(Boolean);
        for (const key of keys) {
          completedModules.add(key);
          const phase = stepToPhase[key];
          if (phase && phase.modules.every(m => completedModules.has(m))) {
            completePhase(phase);
          } else {
            setModuleDot(key, 'done');
          }
        }
      }

      if (data.status === 'completed') {
        setProgress(100);
        for (const phase of PHASES) completePhase(phase);
        showResults();
        return;
      }

      if (data.status === 'error') { showError(); return; }

      if (data.currentStep) {
        const nextPhase = stepToPhase[data.currentStep];
        if (nextPhase && !nextPhase.modules.every(m => completedModules.has(m))) {
          activatePhase(nextPhase);
        }
      }

      setTimeout(poll, 2000);
    } catch (err) {
      console.error('Poll error:', err);
      setTimeout(poll, 3000);
    }
  }

  if (initialStatus === 'completed') {
    poll();
  } else if (initialStatus === 'error') {
    showError();
  } else {
    activatePhase(PHASES[0]);
    setProgress(2);
    setTimeout(poll, 1500);
  }
</script>
