          <div class="flex items-center gap-3 mb-1">
            <span class="text-2xl font-bold ${scoreColor}">${tsScore}/100</span>
            <span class="text-xs ${scoreColor}">${scoreLabel}</span>
            ${ts.cms ? `<span class="ml-auto px-2 py-0.5 bg-white/10 text-slate-300 text-xs rounded-full">CMS: ${ts.cms}</span>` : ''}
          </div>
          <p class="text-xs text-slate-500 mb-4">Score reflects which tool categories are active. Each category contributes up to the indicated points.</p>
          ${scoreExplainHtml}
        </div>
      `);
    }

    // ── Conversion Capability ──────────────────────────────────────
    if (results.conversion && !results.conversion.skipped) {
      const cv = results.conversion;
      const cvScore = cv.funnelScore ?? 0;
      const scoreColor = cvScore >= 70 ? 'text-emerald-400' : cvScore >= 40 ? 'text-amber-400' : 'text-red-400';

      const checks = [
        { label: 'Contact form', ok: cv.hasContactForm, detail: cv.hasContactForm ? `${cv.formCount} form(s), ${cv.formFieldCount} fields` : 'Not detected' },
        { label: 'Clear CTAs', ok: cv.hasCTA, detail: cv.hasCTA ? `${cv.ctaCount} element(s) with conversion intent` : 'No CTAs detected' },
        { label: 'Lead magnet', ok: cv.hasLeadMagnet, detail: cv.hasLeadMagnet ? 'Detected (download, demo, free resource…)' : 'Not detected' },
        { label: 'Social proof / testimonials', ok: cv.hasTestimonials, detail: cv.hasTestimonials ? 'Detected' : 'No visible testimonials' },
        { label: 'Visible pricing', ok: cv.hasPricing, detail: cv.hasPricing ? 'Pricing section detected' : 'No pricing page' },
        { label: 'Video content', ok: cv.hasVideo, detail: cv.hasVideo ? 'Present' : 'No video detected' },
        { label: 'Live chat', ok: cv.hasChatWidget, detail: cv.hasChatWidget ? 'Active' : 'No live chat detected' },
      ];

      const checksHtml = checks.map(c => `
        <div class="flex items-start gap-3 py-2 border-b border-white/5 last:border-0">
          <span class="${c.ok ? 'text-emerald-400' : 'text-red-400'} mt-0.5 shrink-0 text-sm">${c.ok ? '✓' : '✗'}</span>
          <div>
            <p class="text-xs font-medium text-slate-200">${c.label}</p>
            <p class="text-xs text-slate-500">${c.detail}</p>
          </div>
        </div>`).join('');

      const llmHtml = cv.summary ? `
        <div class="mt-4 pt-4 border-t border-white/10">
          <p class="text-xs text-slate-300 italic leading-relaxed mb-3">${cv.summary}</p>
          ${cv.strengths?.length ? `<p class="text-xs font-semibold text-emerald-400 mb-1">Strengths:</p><ul class="mb-3">${cv.strengths.map(s => `<li class="text-xs text-slate-300 mb-0.5">· ${s}</li>`).join('')}</ul>` : ''}
          ${cv.weaknesses?.length ? `<p class="text-xs font-semibold text-amber-400 mb-1">Priority gaps:</p><ul>${cv.weaknesses.map(w => `<li class="text-xs text-slate-300 mb-0.5">· ${w}</li>`).join('')}</ul>` : ''}
        </div>` : '';

      sections.push(`
        <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
          <h3 class="text-base font-semibold text-white mb-1">🎯 Conversion capability</h3>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl font-bold ${scoreColor}">${cvScore}/100</span>
            <span class="text-xs ${scoreColor}">${cvScore >= 70 ? 'Well-configured funnel' : cvScore >= 40 ? 'Basic funnel, room to improve' : 'Weak funnel — high priority'}</span>
          </div>
          ${checksHtml}
          ${llmHtml}
        </div>
      `);
    }

    container.innerHTML = sections.join('');
  }

  function formatNum(n) {
    if (n == null) return '—';
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
    if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
    return String(n);
  }

  function buildRows(rows) {
    return rows.map(r =>
      `<div class="flex gap-3 py-2 border-b border-white/5 last:border-0">
        <span class="text-xs text-slate-400 w-36 shrink-0">${r.label}</span>
        <span class="text-xs text-slate-200 flex-1">${r.value}</span>
      </div>`
    ).join('');
  }

  function buildSection(title, rows) {
    return `
      <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
        <h3 class="text-base font-semibold text-white mb-4">${title}</h3>
        ${buildRows(rows)}
      </div>
    `;
  }

  function showError() {
    document.getElementById('processing-state').classList.add('hidden');
    document.getElementById('error-state').classList.remove('hidden');
  }

  async function poll() {
    try {
      const res = await fetch(`/api/audit/${auditId}/status`);
      if (!res.ok) { showError(); return; }
      const data = await res.json();

      setProgress(data.progress || 0);

      if (data.module_completed) {
        completedModules.add(data.module_completed);
        MODULES.forEach((key, i) => {
          if (completedModules.has(key)) markModule(key, 'done');
          else if (i === completedModules.size) markModule(key, 'running');
        });
      }

      if (data.status === 'completed') {
        setProgress(100);
        MODULES.forEach(key => markModule(key, 'done'));
        showResults(data);
        return;
      }

      if (data.status === 'error') { showError(); return; }

      const nextIdx = completedModules.size;
      if (nextIdx < MODULES.length) markModule(MODULES[nextIdx], 'running');

      setTimeout(poll, 2000);
    } catch (err) {
      console.error('Poll error:', err);
      setTimeout(poll, 3000);
    }
  }

  if (initialStatus === 'completed') {
    poll();
  } else if (initialStatus === 'error') {
    showError();
  } else {
    markModule(MODULES[0], 'running');
    setProgress(2);
    setTimeout(poll, 1500);
  }
</script>
