---
export const prerender = false;
import { getAuditPage } from '../../../../lib/audit/notion';
import { computeHealthScore, scoreColor, scoreLabel, scoreEmoji } from '../../../../lib/audit/report/health-score';
import {
  diagnosisHealthSummary,
  diagnosisSEO,
  diagnosisGEO,
  diagnosisTrafficMix,
  diagnosisPageSpeed,
  diagnosisFunnel,
  diagnosisTechStack,
  diagnosisCompetitiveGap,
  diagnosisSchema,
} from '../../../../lib/audit/report/diagnostics';

const { id } = Astro.params;

let audit: any = null;

try {
  audit = await getAuditPage(id!);
} catch {}

if (!audit || audit.status !== 'completed') {
  return Astro.redirect(`/en/audit/${id}`);
}

const r = audit.results;
const domain = new URL(audit.url).hostname.replace(/^www\./, '');
const auditDate = new Date().toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });

const health = computeHealthScore(r);

const crawl = r.crawl || {};
const seo = (!r.seo?.skipped && r.seo) ? r.seo : null;
const geo = (!r.geo?.skipped && r.geo) ? r.geo : null;
const traffic = (!r.traffic?.skipped && r.traffic) ? r.traffic : null;
const ps = (!r.pagespeed?.skipped && r.pagespeed) ? r.pagespeed : null;
const ssl = (!r.ssl?.skipped && r.ssl) ? r.ssl : null;
const ctItems: any[] = r.competitor_traffic?.items || [];
const kg = (!r.keyword_gap?.skipped && r.keyword_gap?.items?.length) ? r.keyword_gap : null;
const ts = (!r.techstack?.skipped && r.techstack) ? r.techstack : null;
const cv = (!r.conversion?.skipped && r.conversion) ? r.conversion : null;
const cc = (!r.content_cadence?.skipped && (r.content_cadence?.totalPosts ?? 0) >= 3) ? r.content_cadence : null;
const rep = (!r.reputation?.skipped && r.reputation?.reputationLevel && r.reputation.reputationLevel !== 'no_data') ? r.reputation : null;
const metaAds = (!r.meta_ads?.skipped && r.meta_ads) ? r.meta_ads : null;
const qa = r.qa || null;
const qaSuppressed: string[] = qa?.suppressedSections || [];
const insights = r.insights || {};
const seoPages = (!r.seo_pages?.skipped && r.seo_pages?.pages?.length) ? r.seo_pages : null;
const sector = r.sector?.sector || audit.sector || '';
const hreflangAlts: any[] = crawl.hreflangAlternates || [];
const content = (!r.content?.skipped && r.content) ? r.content : null;

// ── Paid (Google Ads) computed data ──────────────────────────────
const clientPaidKw = seo?.paidKeywordsTotal ?? 0;
const clientPaidEtv = seo?.paidTrafficEstimate ?? 0;
const compPaidItems: any[] = ctItems.filter((c: any) => (c.paidKeywordsTotal ?? 0) > 0);
const anyoneInvestsPaid = clientPaidKw > 0 || compPaidItems.length > 0;
const leaderPaid: any = compPaidItems.reduce((best: any, c: any) =>
  (c.paidTrafficEstimate ?? 0) > (best?.paidTrafficEstimate ?? 0) ? c : best, null);
const totalPaidEtv = clientPaidEtv + compPaidItems.reduce((s: number, c: any) => s + (c.paidTrafficEstimate ?? 0), 0);
const clientSovPaid = totalPaidEtv > 0 ? Math.round((clientPaidEtv / totalPaidEtv) * 100) : null;
const totalOrgEtv = (seo?.organicTrafficEstimate ?? 0) + ctItems.reduce((s: number, c: any) => s + (c.organicTrafficEstimate ?? 0), 0);
const clientSovOrg = totalOrgEtv > 0 ? Math.round(((seo?.organicTrafficEstimate ?? 0) / totalOrgEtv) * 100) : null;

// ── Impact projection computed data ──────────────────────────────
const pos4to10 = seo?.keywordsPos4to10 ?? 0;
const ownEtvForImpact = seo?.organicTrafficEstimate ?? 0;
const ownPaidCostForImpact = seo?.estimatedAdsCost ?? 0;
const projTrafficBase = pos4to10 > 0 ? pos4to10 * 150 : 0;
const projTrafficMin = Math.round(projTrafficBase * 0.5);
const projTrafficMax = Math.round(projTrafficBase * 1.5);
const projAdsValue = (projTrafficBase > 0 && ownEtvForImpact > 0 && ownPaidCostForImpact > 0)
  ? Math.round((projTrafficBase / ownEtvForImpact) * ownPaidCostForImpact) : null;
const geoMissedQueries = geo?.queries?.filter((q: any) => !q.isBrandQuery && !q.mentioned).length ?? 0;
const geoTotalQueries = geo?.queries?.filter((q: any) => !q.isBrandQuery).length ?? 0;
const hasTrendLossImpact = seo != null && (seo.trendLost ?? 0) > (seo.trendUp ?? 0);
const repTotalReviews = rep?.totalReviews ?? 0;
const hasAnyImpactProjection = projTrafficBase > 0 || geoMissedQueries > 0 || (repTotalReviews > 0 && repTotalReviews < 50) || hasTrendLossImpact;

// ── Business type (must be declared before schema lookup) ─────────
const businessType: string = crawl.businessType || 'unknown';

function fmt(n: number | undefined | null): string {
  if (n == null) return '—';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return Math.round(n / 1_000) + 'K';
  return String(n);
}

function cwvEmoji(metric: string, value: number): string {
  const thresholds: Record<string, [number, number]> = {
    lcp: [2500, 4000], cls: [0.1, 0.25], fcp: [1800, 3000], ttfb: [800, 1800],
  };
  const [good, poor] = thresholds[metric] || [50, 90];
  if (value <= good) return '🟢';
  if (value <= poor) return '🟡';
  return '🔴';
}

// ── Competitor benchmark table data ──────────────────────────────
interface BenchRow { label: string; etv: number | null; ads: number | null; kw10: number | null; isOwn: boolean }
const benchRows: BenchRow[] = [];
if (seo) {
  benchRows.push({ label: `★ ${domain}`, etv: seo.organicTrafficEstimate ?? null, ads: seo.estimatedAdsCost ?? null, kw10: seo.keywordsTop10 ?? null, isOwn: true });
}
for (const c of ctItems) {
  benchRows.push({ label: c.domain, etv: c.organicTrafficEstimate ?? null, ads: c.estimatedAdsCost ?? null, kw10: c.keywordsTop10 ?? null, isOwn: false });
}
if (benchRows.length > 1) {
  const compRowsForAvg = benchRows.filter(r => !r.isOwn);
  const avg = (vals: (number | null)[]) => {
    const nums = vals.filter((v) => v != null) as number[];
    return nums.length ? Math.round(nums.reduce((a, b) => a + b, 0) / nums.length) : null;
  };
  benchRows.push({ label: 'Sector average', etv: avg(compRowsForAvg.map(r => r.etv)), ads: avg(compRowsForAvg.map(r => r.ads)), kw10: avg(compRowsForAvg.map(r => r.kw10)), isOwn: false });
}

// ── Gate: only show competitor table if at least one competitor has real data
function rowHasData(row: BenchRow): boolean {
  return row.etv != null || row.kw10 != null;
}
const compTableRows = benchRows.filter(r => !r.isOwn && r.label !== 'Sector average');
const hasEnoughCompetitorData = compTableRows.some(rowHasData);

const maxETV = Math.max(...benchRows.map(r => r.etv || 0), 1);
const maxADS = Math.max(...benchRows.map(r => r.ads || 0), 1);
const maxKW = Math.max(...benchRows.map(r => r.kw10 || 0), 1);

// ── Trend alert ───────────────────────────────────────────────────
const hasTrendAlert = seo != null
  && seo.trendLost != null
  && seo.trendUp != null
  && seo.trendLost > (seo.trendUp ?? 0);

const channelColors: Record<string, string> = {
  organic: '#1A4B8C', direct: '#64748b', social: '#7c3aed',
  referral: '#0891b2', paid: '#d97706', email: '#16a34a',
};
const channelLabels: Record<string, string> = {
  organic: 'Organic', direct: 'Direct', social: 'Social',
  referral: 'Referral', paid: 'Paid', email: 'Email',
};
const channels = traffic?.channels || {};
const totalVisits = Object.values(channels).reduce((s: number, c: any) => s + (c.visits || 0), 0);
const channelSegments = Object.entries(channels)
  .sort(([, a]: any, [, b]: any) => (b.visits || 0) - (a.visits || 0))
  .map(([key, ch]: [string, any]) => ({
    key, label: channelLabels[key] || key, visits: ch.visits || 0,
    pct: totalVisits > 0 ? Math.round((ch.visits / totalVisits) * 100) : 0,
    color: channelColors[key] || '#94a3b8',
  }));

// ── Schema audit ─────────────────────────────────────────────────
const schemaTypes: string[] = crawl.schemaTypes || [];
const RECOMMENDED_SCHEMAS_EN: Record<string, string[]> = {
  ecommerce: ['Organization', 'WebSite', 'Product', 'Offer', 'BreadcrumbList'],
  saas: ['Organization', 'WebSite', 'SoftwareApplication', 'FAQPage'],
  b2b: ['Organization', 'WebSite', 'Service', 'FAQPage', 'BreadcrumbList'],
  local: ['LocalBusiness', 'Organization', 'GeoCoordinates', 'OpeningHoursSpecification'],
  media: ['Organization', 'WebSite', 'Article', 'BreadcrumbList'],
  unknown: ['Organization', 'WebSite', 'BreadcrumbList'],
};
const recommendedSchemas = RECOMMENDED_SCHEMAS_EN[businessType] || RECOMMENDED_SCHEMAS_EN.unknown;
const presentLower = schemaTypes.map((t: string) => t.toLowerCase());
const missingSchemas = recommendedSchemas.filter(s => !presentLower.includes(s.toLowerCase()));
const diagSchema = diagnosisSchema(schemaTypes.length ? schemaTypes : undefined, businessType);

// EN diagnostic texts
const diagSEO = diagnosisSEO(seo, ctItems);
const diagGEO = diagnosisGEO(geo);
const diagTraffic = diagnosisTrafficMix(traffic);
const diagPS = diagnosisPageSpeed(ps);
const diagFunnel = diagnosisFunnel(cv);
const diagStack = diagnosisTechStack(ts);
const diagGap = diagnosisCompetitiveGap(seo, ctItems, kg);
const diagSummary = diagnosisHealthSummary(health);

const btLabels: Record<string, string> = {
  ecommerce: 'E-commerce',
  saas: 'SaaS / Software',
  b2b: 'B2B · Lead Generation',
  local: 'Local Business',
  media: 'Media / Content',
};
const btLabel = btLabels[businessType] || '';
const btObjectives: Record<string, string> = {
  ecommerce: 'maximize online sales',
  saas: 'increase trial activations and reduce churn',
  b2b: 'generate qualified leads and shorten the sales cycle',
  local: 'capture local demand and improve your Google reputation',
  media: 'grow your organic audience and monetize it',
  unknown: 'improve your digital presence and conversion',
};
const btObjective = btObjectives[businessType] || btObjectives.unknown;

// ── Sector benchmarks ─────────────────────────────────────────────
const sectorAvgKW = ctItems.length > 0 ? Math.round(ctItems.reduce((s: number, c: any) => s + (c.keywordsTop10 || 0), 0) / ctItems.length) : null;

// ── Competitive rank (by organic traffic) ────────────────────────
const ownETV = seo?.organicTrafficEstimate || 0;
const avgETV = ctItems.length > 0
  ? ctItems.reduce((s: number, c: any) => s + (c.organicTrafficEstimate || 0), 0) / ctItems.length
  : 0;
const allETVs = [...ctItems.map((c: any) => c.organicTrafficEstimate || 0), ownETV].sort((a, b) => b - a);
const ownRank = allETVs.indexOf(ownETV) + 1;
const totalPlayers = allETVs.length;
const trafficGap = Math.max(0, Math.round(avgETV - ownETV));

// ── Fallback initiatives ──────────────────────────────────────────
const fallbackInitiatives = [
  { key: 'visibility', label: 'Organic visibility', score: health.visibilidad, action: 'Develop an SEO content plan targeting keywords in the competitive gap to capture organic demand.' },
  ...(health.competitividad !== null ? [{ key: 'competitiveness', label: 'Competitive positioning', score: health.competitividad, action: 'Analyse the keyword gap vs competitors and build a content plan to recover positions.' }] : []),
  { key: 'experience', label: 'Web performance', score: health.experiencia, action: 'Optimise images and reduce blocking JavaScript to improve Core Web Vitals and user experience.' },
  { key: 'conversion', label: 'Conversion', score: health.conversion, action: 'Implement a lead capture funnel with optimised forms, clear CTAs and social proof.' },
].sort((a, b) => a.score - b.score).slice(0, 3);

// ── Stack impact descriptions ─────────────────────────────────────
const stackItems = ts ? [
  { key: 'analytics', label: 'Analytics', tools: ts.analytics,
    presentNote: 'Measurement foundation in place. You have data to make decisions.',
    missingNote: "You don't know what works or where your customers come from. Every marketing decision is a guess." },
  { key: 'tagManager', label: 'Tag Manager', tools: ts.tagManager,
    presentNote: 'Tag Manager installed: add tools without touching code.',
    missingNote: 'Every tracking change requires code modification. Slows experimentation and increases costs.' },
  { key: 'conversionPixels', label: 'Conversion pixels', tools: ts.conversionPixels,
    presentNote: 'Active pixels: you can run remarketing and optimise paid campaigns.',
    missingNote: 'No pixels (Meta, Google Ads): you cannot retarget visitors who leave without converting.' },
  { key: 'crmAutomation', label: 'CRM / Automation', tools: ts.crmAutomation,
    presentNote: 'Active CRM: leads managed in a scalable, automated way.',
    missingNote: "No CRM: leads managed manually. At scale, this creates missed follow-ups and lost revenue." },
  { key: 'chatSupport', label: 'Chat / Support', tools: ts.chatSupport,
    presentNote: 'Chat available: visitors can resolve doubts in real time.',
    missingNote: "No chat: a potential customer with a question leaves. Most don't come back." },
  { key: 'heatmaps', label: 'Heatmaps', tools: ts.heatmaps,
    presentNote: 'Heatmaps active: you know exactly what users do on the page.',
    missingNote: "No session recordings: you don't know which parts of your site capture attention." },
] : [];

// ── Display helpers ─────────────────────────────────────────────────────────────────
function cwvDot(value: number, good: number, poor: number): string {
  return value <= good ? '#10B981' : value <= poor ? '#F59E0B' : '#EF4444';
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Digital Growth Report — {domain} — AION Growth Studio</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'DM Sans', system-ui, sans-serif; background: #0A0F1E; color: #F9FAFB; margin: 0; }
    .report { max-width: 860px; margin: 0 auto; background: #0A0F1E; }
    .section { padding: 2rem 2.5rem; border-bottom: 1px solid #1F2937; }
    .section:last-child { border-bottom: none; }
    h2 { font-size: 1.125rem; font-weight: 700; color: #F9FAFB; margin: 0 0 0.25rem; display: flex; align-items: center; gap: 0.5rem; }
    h3 { font-size: 0.9375rem; font-weight: 600; color: #E5E7EB; margin: 0 0 0.5rem; display: flex; align-items: center; gap: 0.375rem; }
    p { margin: 0 0 0.75rem; line-height: 1.65; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    th { text-align: left; padding: 0.5rem 0.75rem; background: #1C2333; color: #6B7280; font-weight: 600; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; border-bottom: 1px solid #1F2937; }
    td { padding: 0.625rem 0.75rem; border-bottom: 1px solid #1F2937; vertical-align: middle; color: #D1D5DB; }
    tr:last-child td { border-bottom: none; }
    tr.own-row td { background: rgba(59,130,246,0.08); font-weight: 600; color: #F9FAFB; }
    tr.avg-row td { color: #6B7280; font-style: italic; font-size: 0.8rem; }
    .badge { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.2rem 0.6rem; border-radius: 9999px; font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    .badge-green { background: rgba(16,185,129,0.15); color: #10B981; border: 1px solid rgba(16,185,129,0.3); }
    .badge-amber { background: rgba(245,158,11,0.15); color: #F59E0B; border: 1px solid rgba(245,158,11,0.3); }
    .badge-red { background: rgba(239,68,68,0.15); color: #EF4444; border: 1px solid rgba(239,68,68,0.3); }
    .badge-blue { background: rgba(59,130,246,0.15); color: #60A5FA; border: 1px solid rgba(59,130,246,0.3); }
    .num { font-family: 'DM Mono', monospace; }
    .pillar-score { font-size: 1.75rem; font-weight: 700; line-height: 1; font-family: 'DM Mono', monospace; }
    .pillar-label { font-size: 0.68rem; font-weight: 600; color: #6B7280; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
    .sub-section { margin-top: 1.75rem; padding-top: 1.75rem; border-top: 1px solid #1F2937; }
    .diag-text { font-size: 0.9rem; color: #9CA3AF; line-height: 1.75; background: #111827; border-left: 3px solid #3B82F6; padding: 0.875rem 1rem; border-radius: 0 0.5rem 0.5rem 0; margin: 0.75rem 0 1rem; }
    .initiative-card { border: 1px solid #1F2937; border-radius: 0.75rem; padding: 1.25rem; margin-bottom: 1rem; background: #111827; }
    .initiative-num { display: inline-flex; align-items: center; justify-content: center; width: 1.75rem; height: 1.75rem; border-radius: 9999px; background: #3B82F6; color: #fff; font-size: 0.8rem; font-weight: 700; margin-right: 0.5rem; }
    .check-row { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.375rem 0; border-bottom: 1px solid #1C2333; font-size: 0.875rem; color: #D1D5DB; }
    .check-row:last-child { border-bottom: none; }
    .check-ok { color: #10B981; font-size: 1rem; flex-shrink: 0; }
    .check-no { color: #EF4444; font-size: 1rem; flex-shrink: 0; }
    .bar-wrap { display: flex; align-items: center; gap: 0.5rem; }
    .bar-bg { flex: 1; height: 6px; background: #1F2937; border-radius: 9999px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 9999px; transition: width 0.9s ease; }
    .icon { flex-shrink: 0; }
    .reveal { opacity: 0; transform: translateY(14px); transition: opacity 0.5s ease, transform 0.5s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    @media (max-width: 640px) { .section { padding: 1.5rem 1.25rem; } }
    @media print {
      body { background: #fff !important; color: #000 !important; }
      .no-print { display: none !important; }
      .report { max-width: 100%; }
      .section { page-break-inside: avoid; }
      .initiative-card { page-break-inside: avoid; }
    }
  </style>
</head>
<body>
  <div class="no-print" style="background:#0A0F1E;padding:0.75rem 2rem;display:flex;align-items:center;justify-content:space-between;">
    <a href={`/en/audit/${id}`} style="color:#9CA3AF;font-size:0.8rem;text-decoration:none;">← Back to analysis</a>
    <button onclick="window.print()" style="background:#3B82F6;color:#fff;border:none;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.8rem;cursor:pointer;display:flex;align-items:center;gap:0.375rem;">
      <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
      Print / PDF
    </button>
  </div>

  <div class="report">
    <!-- ── HERO COMBINADO (Cover + Score) ──────────────────────────── -->
    <div style="background:linear-gradient(135deg,#0A0F1E 0%,#1E3A5F 100%);color:#fff;padding:1.5rem 2rem 2rem;position:relative;overflow:hidden;">
      <!-- Background glow -->
      <div style={`position:absolute;inset:0;background:radial-gradient(ellipse at 80% 20%,${scoreColor(health.total)}15 0%,transparent 50%);pointer-events:none;`}></div>
      
      <!-- Header row: Logo + Date -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;position:relative;">
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:28px;filter:brightness(0) invert(1);opacity:0.9;" />
        <span style="color:#9CA3AF;font-size:0.7rem;">{auditDate}</span>
      </div>
      
      <!-- Main content: Left info + Right score -->
      <div style="display:flex;align-items:flex-start;gap:2rem;position:relative;">
        <!-- Left: Domain info -->
        <div style="flex:1;min-width:0;">
          <p style="font-size:0.65rem;font-weight:600;color:#06B6D4;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.35rem;">Digital Visibility Report</p>
          <h1 style="font-size:1.5rem;font-weight:800;margin:0 0 0.5rem;line-height:1.15;">{domain}</h1>
          <div style="display:flex;align-items:center;flex-wrap:wrap;gap:0.4rem;margin-bottom:1rem;">
            {sector && <span style="color:#9CA3AF;font-size:0.75rem;">{sector}</span>}
            {btLabel && (
              <>
                <span style="color:#9CA3AF;font-size:0.7rem;">|</span>
                <span style="color:#9CA3AF;font-size:0.7rem;">{btLabel}</span>
              </>
            )}
          </div>
          
          <!-- Quick stats row -->
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;">
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Est. Traffic</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'DM Mono',monospace;">{fmt(seo?.organicTrafficEstimate)}</p>
            </div>
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Keywords Top10</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'DM Mono',monospace;">{fmt(seo?.keywordsTop10)}</p>
            </div>
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#9CA3AF;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Keywords Top 3</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'DM Mono',monospace;">{fmt(seo?.keywordsTop3)}</p>
            </div>
          </div>
        </div>
        
        <!-- Right: Score gauge -->
        <div style="text-align:center;flex-shrink:0;">
          <div style="position:relative;width:110px;height:110px;">
            <svg viewBox="0 0 36 36" style="width:110px;height:110px;transform:rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="2.5"/>
