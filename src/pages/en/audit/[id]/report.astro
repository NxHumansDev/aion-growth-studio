              <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;">
                {channelSegments.map(c => (
                  <span style={`display:inline-flex;align-items:center;gap:4px;font-size:11px;color:#5A6478;`}>
                    <span style={`width:8px;height:8px;border-radius:50%;background:${c.color};display:inline-block;`}></span>
                    {c.label} {c.pct}%
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Technical checklist -->
          <div style="margin-bottom:20px;">
            <hr class="section-divider" />
            <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">Technical SEO checklist</div>
            <div class="grid-2" style="gap:8px;">
              <div class="metric-card" style={`border-left:3px solid ${ssl?.valid?'#1D9E75':'#E24B4A'};`}>
                <div style={`font-size:12px;font-weight:600;color:${ssl?.valid?'#1D9E75':'#E24B4A'};`}>{ssl?.valid ? '✓ SSL / HTTPS active' : '✗ SSL not detected'}</div>
                <div class="metric-sub">{ssl?.issuer ? `Issuer: ${ssl.issuer}` : ssl?.valid ? 'Valid certificate' : 'Implement HTTPS urgently'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${crawl.hasRobotsTxt?'#1D9E75':'#BA7517'};`}>
                <div style={`font-size:12px;font-weight:600;color:${crawl.hasRobotsTxt?'#1D9E75':'#BA7517'};`}>{crawl.hasRobotsTxt ? '✓ robots.txt present' : '✗ robots.txt not found'}</div>
                <div class="metric-sub">{crawl.hasRobotsTxt ? 'Crawl directives configured' : 'Add a robots.txt to control crawling'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${crawl.hasSitemap?'#1D9E75':'#BA7517'};`}>
                <div style={`font-size:12px;font-weight:600;color:${crawl.hasSitemap?'#1D9E75':'#BA7517'};`}>{crawl.hasSitemap ? '✓ XML Sitemap detected' : '✗ XML Sitemap not found'}</div>
                <div class="metric-sub">{crawl.hasSitemap ? 'Sitemap available for indexing' : 'Generate and submit sitemap.xml to Google Search Console'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${crawl.hasCanonical?'#1D9E75':'#BA7517'};`}>
                <div style={`font-size:12px;font-weight:600;color:${crawl.hasCanonical?'#1D9E75':'#BA7517'};`}>{crawl.hasCanonical ? '✓ Canonical tags detected' : '? Canonical tags unverified'}</div>
                <div class="metric-sub">{crawl.hasCanonical ? 'Canonical URLs configured' : 'Verify URLs have rel=canonical'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${(ps?.mobile?.performance??0)>=50?'#1D9E75':'#E24B4A'};`}>
                <div style={`font-size:12px;font-weight:600;color:${(ps?.mobile?.performance??0)>=50?'#1D9E75':'#E24B4A'};`}>{(ps?.mobile?.performance??0)>=50 ? '✓ Mobile-friendly' : '✗ Mobile issues detected'}</div>
                <div class="metric-sub">{ps ? `Mobile score: ${ps.mobile?.performance ?? '—'}/100` : 'No mobile performance data'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${gbp?'#1D9E75':'#5A6478'};`}>
                <div style={`font-size:12px;font-weight:600;color:${gbp?'#1D9E75':'#5A6478'};`}>{gbp ? '✓ Google Business Profile detected' : '— Google Business Profile not detected'}</div>
                <div class="metric-sub">{gbp ? `${gbp.rating ? `Rating: ${gbp.rating}★` : ''} ${gbp.reviewCount ? `(${gbp.reviewCount} reviews)` : ''}` : 'Claim your Google Maps listing if applicable'}</div>
              </div>
            </div>
          </div>

          <!-- Tech Stack -->
          <div style="margin-bottom:20px;">
            <hr class="section-divider" />
            <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">Measurement stack & tools</div>
            <div class="grid-3" style="gap:8px;">
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.analytics.detected?'#1D9E75':'#E24B4A'};`}></div>
                <div>
                  <div class="tech-name">Analytics</div>
                  {techStackMapped.analytics.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">{techStackMapped.analytics.tool || 'Detected'}</div>
                    : <div class="tech-tool" style="color:#A32D2D;">You don't know how many visitors you get or what works</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.tagManager.detected?'#1D9E75':'#BA7517'};`}></div>
                <div>
                  <div class="tech-name">Tag Manager</div>
                  {techStackMapped.tagManager.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">{techStackMapped.tagManager.tool || 'Detected'}</div>
                    : <div class="tech-tool" style="color:#8A5015;">Every new tool requires developer work to install</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.metaPixel.detected?'#1D9E75':'#BA7517'};`}></div>
                <div>
                  <div class="tech-name">Meta Pixel</div>
                  {techStackMapped.metaPixel.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">Active</div>
                    : <div class="tech-tool" style="color:#8A5015;">You can't retarget visitors who leave without converting</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.googleAdsPixel.detected?'#1D9E75':'#BA7517'};`}></div>
                <div>
                  <div class="tech-name">Google Ads Pixel</div>
                  {techStackMapped.googleAdsPixel.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">Active</div>
                    : <div class="tech-tool" style="color:#8A5015;">You can't measure which conversions your campaigns generate</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.chat.detected?'#1D9E75':'#5A6478'};`}></div>
                <div>
                  <div class="tech-name">Chat / Support</div>
                  {techStackMapped.chat.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">{techStackMapped.chat.tool || 'Detected'}</div>
                    : <div class="tech-tool" style="color:#5A6478;">A prospect with a question leaves. Most never come back</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.heatmaps.detected?'#1D9E75':'#5A6478'};`}></div>
                <div>
                  <div class="tech-name">Heatmaps / CRO</div>
                  {techStackMapped.heatmaps.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">{techStackMapped.heatmaps.tool || 'Detected'}</div>
                    : <div class="tech-tool" style="color:#5A6478;">You don't know where users click or where they drop off</div>}
                </div>
              </div>
            </div>
            <p style="font-size:11px;color:#9CA3AF;margin-top:10px;font-style:italic;">Analysis based on public HTML. Tools loaded via Tag Manager or server-side may not be detected.</p>
          </div>

          <!-- Schema markup -->
          <div style="margin-bottom:20px;">
            <hr class="section-divider" />
            <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Schema Markup</div>
            <div class="callout callout-blue" style="margin-bottom:14px;font-size:12px;">
              <strong>What is Schema Markup?</strong> It's invisible code that tells Google what type of business you are, what services you offer, and how to contact you. Implementing it correctly can generate rich results in Google (with stars, opening hours, FAQs) that significantly increase click-through rates.
            </div>
            {schemaTypes.length > 0 && (
              <div style="margin-bottom:10px;">
                <div style="font-size:0.72rem;color:#5A6478;margin-bottom:6px;">Detected types:</div>
                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                  {schemaTypes.map((t: string) => (
                    <span class="tag" style="background:#E1F5EE;color:#1D9E75;">{t}</span>
                  ))}
                </div>
              </div>
            )}
            {missingSchemas.length > 0 && (
              <div>
                <div style="font-size:0.72rem;color:#5A6478;margin-bottom:6px;">Recommended{btLabelForSchema ? ` for ${btLabelForSchema}` : ''} and not detected:</div>
                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                  {missingSchemas.map((s: string) => (
                    <span class="tag" style="background:#FCEBEB;color:#E24B4A;">{s}</span>
                  ))}
                </div>
              </div>
            )}
            {schemaTypes.length === 0 && missingSchemas.length === 0 && (
              <div class="callout callout-amber">No structured schemas detected. Implementing Schema Markup improves appearance in search results.</div>
            )}
          </div>

          <!-- Conversion signals -->
          {cv && (
            <div style="margin-bottom:4px;">
              <hr class="section-divider" />
              <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Conversion signals</div>
              <div class="grid-2" style="gap:8px;">
                <div class="metric-card" style={`border-left:3px solid ${cv.hasContactForm?'#1D9E75':'#E24B4A'};`}>
                  <div style={`font-size:12px;font-weight:600;color:${cv.hasContactForm?'#1D9E75':'#E24B4A'};`}>{cv.hasContactForm ? '✓ Contact form present' : '✗ No contact form'}</div>
                  <div class="metric-sub">Key element for lead capture</div>
                </div>
                {cv.hasCTA != null && (
                  <div class="metric-card" style={`border-left:3px solid ${cv.hasCTA?'#1D9E75':'#BA7517'};`}>
                    <div style={`font-size:12px;font-weight:600;color:${cv.hasCTA?'#1D9E75':'#BA7517'};`}>{cv.hasCTA ? '✓ CTAs detected' : '✗ CTAs not visible'}</div>
                    <div class="metric-sub">Call to action on homepage</div>
                  </div>
                )}
                {cv.hasTestimonials != null && (
                  <div class="metric-card" style={`border-left:3px solid ${cv.hasTestimonials?'#1D9E75':'#BA7517'};`}>
                    <div style={`font-size:12px;font-weight:600;color:${cv.hasTestimonials?'#1D9E75':'#BA7517'};`}>{cv.hasTestimonials ? '✓ Testimonials / social proof' : '? No social proof detected'}</div>
                    <div class="metric-sub">Social proof increases conversion</div>
                  </div>
                )}
                {cv.funnelScore != null && (
                  <div class="metric-card">
                    <div class="metric-value" style={`color:${(cv.funnelScore??0)>=60?'#1D9E75':(cv.funnelScore??0)>=35?'#BA7517':'#E24B4A'};`}>{cv.funnelScore}/100</div>
                    <div class="metric-label">Funnel Score</div>
                    <div class="metric-sub">Funnel optimization index</div>
                  </div>
                )}
              </div>
            </div>
          )}
        </div>

        <!-- ═══════════════════════════════════════════════════════════
             BLOCK 5 · #plan · Action Plan
        ═══════════════════════════════════════════════════════════ -->
        <div id="plan" class="report-block reveal">
          <div class="block-title">Action Plan</div>
          <div class="block-subtitle">Concrete actions ordered by impact and effort for {domain}</div>

          <!-- Quick wins -->
          <div style="margin-bottom:20px;">
            <div style="font-size:0.85rem;font-weight:700;color:#1D9E75;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;display:flex;align-items:center;gap:8px;">
              <span style="width:3px;height:16px;background:#1D9E75;border-radius:2px;display:inline-block;"></span>
              Quick Wins — Results in 30 days
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              {displayQuickWins.map((win: any, idx: number) => (
                <div class="plan-win-card">
                  <div class="plan-win-num" style="background:#EAF3DE;color:#27500A;">{idx + 1}</div>
                  <div style="flex:1;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;flex-wrap:wrap;">
                      <div class="plan-win-text" style="font-weight:700;font-size:13px;">{typeof win === 'string' ? win : win.title}</div>
                      {typeof win !== 'string' && win.impact && (
                        <span class="tag" style={`background:${win.impact==='high'?'#FCEBEB':'#FAEEDA'};color:${win.impact==='high'?'#791F1F':'#633806'};font-size:10px;`}>
                          {win.impact === 'high' ? 'High impact' : 'Medium impact'}
                        </span>
                      )}
                    </div>
                    {typeof win !== 'string' && win.problem && (
                      <div style="font-size:12px;color:#5A6478;line-height:1.5;">{win.problem}</div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <hr class="section-divider" />

          <!-- Strategic actions -->
          <div style="margin-bottom:20px;">
            <div style="font-size:0.85rem;font-weight:700;color:#1A4B8C;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;display:flex;align-items:center;gap:8px;">
              <span style="width:3px;height:16px;background:#1A4B8C;border-radius:2px;display:inline-block;"></span>
              Strategic Initiatives — Results in 90 days
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              {displayStrategic.map((action: any, idx: number) => (
                <div class="plan-strategic-card">
                  <div class="plan-strategic-num">{idx + 1}</div>
                  <div>
                    <div class="plan-strategic-title">{action.title}</div>
                    <div class="plan-strategic-desc">{action.description}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <hr class="section-divider" />

          <!-- CTA card — dashboard onboarding -->
          <div style="border:2px solid #4A7FD4;border-radius:12px;padding:24px;text-align:center;margin-top:32px;">
            <h3 style="font-size:1.1rem;font-weight:700;color:#1A1A2E;margin-bottom:8px;">
              Want us to monitor this every month?
            </h3>
            <p style="font-size:0.875rem;color:#5A6478;margin-bottom:16px;">
              Connect your tools, choose your plan, and receive this analysis every month — updated with
              real data, trends, and a prioritized action plan.
            </p>
            <a href="/dashboard/onboarding" style="display:inline-block;background:#1A4B8C;color:#fff;padding:12px 28px;border-radius:8px;font-weight:700;text-decoration:none;font-size:0.95rem;">
              Get started →
            </a>
            <p style="font-size:11px;color:#9CA3AF;margin-top:12px;">No commitment. Cancel anytime.</p>
          </div>
        </div>

      </div>
      <!-- END .report -->

      <!-- CTA SECTION (dark) -->
      <div class="cta-section no-print">
        <div class="cta-inner">
          <div style="display:grid;grid-template-columns:1fr auto;gap:24px;align-items:center;flex-wrap:wrap;">
            <div>
              <div style="font-size:1.25rem;font-weight:700;color:#fff;margin-bottom:8px;">
                Turn the {domain} diagnosis into a real growth plan
              </div>
              <p style="font-size:0.875rem;color:rgba(255,255,255,0.7);line-height:1.6;max-width:600px;">
                Our team can help you prioritize, execute, and measure each action in this report. No ambiguity — with defined milestones, timelines, and success metrics.
              </p>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;min-width:180px;">
              <a href={`mailto:hello@aion.es?subject=Report ${domain} — Request proposal`}
                 style="background:#4A7FD4;color:#fff;padding:0.625rem 1.5rem;border-radius:8px;text-decoration:none;font-size:0.875rem;font-weight:600;text-align:center;white-space:nowrap;">
                Request proposal
              </a>
              <a href="https://aion.es"
                 style="background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.2);padding:0.625rem 1.5rem;border-radius:8px;text-decoration:none;font-size:0.875rem;font-weight:500;text-align:center;">
                Learn about AION
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- FOOTER STRIP -->
      <div class="footer-strip">
        <div class="footer-strip-left">
          <img src="/logo-aion-dark.png" height="20" alt="AION" style="height:20px;filter:brightness(0) invert(1);opacity:0.7;" />
          <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;margin-left:8px;">Confidential report generated on {auditDate}</span>
        </div>
        <div style="color:rgba(255,255,255,0.35);font-size:0.7rem;">{domain}</div>
      </div>

    </div>
    <!-- END .main-content -->
  </div>
  <!-- END .layout -->

  <script define:vars={{ scoreTotal: health.total }}>
    const counter = document.getElementById('score-counter');
    const ring = document.getElementById('score-ring');
    if (counter && scoreTotal > 0) {
      const duration = 1400;
      const start = performance.now();
      const animate = (now) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * scoreTotal);
        counter.textContent = current;
        if (ring) ring.setAttribute('stroke-dasharray', eased * scoreTotal + ', 100');
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
    }
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
    const barObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.querySelectorAll('.bar-fill[data-width]').forEach(bar => {
            bar.style.width = bar.getAttribute('data-width') + '%';
          });
          barObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('table').forEach(t => barObs.observe(t));
  </script>
</body>
</html>
