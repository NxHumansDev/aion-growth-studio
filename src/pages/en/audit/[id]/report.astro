---
export const prerender = false;
import { getAuditPage } from '../../../../lib/audit/notion';
import { computeHealthScore, scoreColor, scoreLabel, scoreEmoji } from '../../../../lib/audit/report/health-score';
import {
  diagnosisHealthSummary,
  diagnosisSEO,
  diagnosisGEO,
  diagnosisTrafficMix,
  diagnosisPageSpeed,
  diagnosisFunnel,
  diagnosisTechStack,
  diagnosisCompetitiveGap,
  diagnosisSchema,
} from '../../../../lib/audit/report/diagnostics';

const { id } = Astro.params;

let audit: any = null;

try {
  audit = await getAuditPage(id!);
} catch {}

if (!audit || audit.status !== 'completed') {
  return Astro.redirect(`/en/audit/${id}`);
}

const r = audit.results;
const domain = new URL(audit.url).hostname.replace(/^www\./, '');
const auditDate = new Date().toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });

const health = computeHealthScore(r);

const crawl = r.crawl || {};
const seo = (!r.seo?.skipped && r.seo) ? r.seo : null;
const geo = (!r.geo?.skipped && r.geo) ? r.geo : null;
const traffic = (!r.traffic?.skipped && r.traffic) ? r.traffic : null;
const ps = (!r.pagespeed?.skipped && r.pagespeed) ? r.pagespeed : null;
const gbp = (!r.gbp?.skipped && r.gbp?.found) ? r.gbp : null;
const ssl = (!r.ssl?.skipped && r.ssl) ? r.ssl : null;
const ctItems: any[] = r.competitor_traffic?.items || [];
const competitors: any[] = r.competitors?.competitors || [];
const kg = (!r.keyword_gap?.skipped && r.keyword_gap?.items?.length) ? r.keyword_gap : null;
const ts = (!r.techstack?.skipped && r.techstack) ? r.techstack : null;
const cv = (!r.conversion?.skipped && r.conversion) ? r.conversion : null;
const insights = r.insights || {};
const seoPages = (!r.seo_pages?.skipped && r.seo_pages?.pages?.length) ? r.seo_pages : null;
const sector = r.sector?.sector || audit.sector || '';
const hreflangAlts: any[] = crawl.hreflangAlternates || [];

function fmt(n: number | undefined | null): string {
  if (n == null) return '—';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return Math.round(n / 1_000) + 'K';
  return String(n);
}

function cwvEmoji(metric: string, value: number): string {
  const thresholds: Record<string, [number, number]> = {
    lcp: [2500, 4000], cls: [0.1, 0.25], fcp: [1800, 3000], ttfb: [800, 1800],
  };
  const [good, poor] = thresholds[metric] || [50, 90];
  if (value <= good) return '🟢';
  if (value <= poor) return '🟡';
  return '🔴';
}

interface BenchRow { label: string; dr: number | null; etv: number | null; kw10: number | null; isOwn: boolean }
const benchRows: BenchRow[] = [];
if (seo) {
  benchRows.push({ label: `★ ${domain}`, dr: seo.domainRank ?? null, etv: seo.organicTrafficEstimate ?? null, kw10: seo.keywordsTop10 ?? null, isOwn: true });
}
for (const c of ctItems) {
  benchRows.push({ label: c.domain, dr: c.domainRank ?? null, etv: c.organicTrafficEstimate ?? null, kw10: c.keywordsTop10 ?? null, isOwn: false });
}
if (benchRows.length > 1) {
  const compRows = benchRows.filter(r => !r.isOwn);
  const avg = (vals: (number | null)[]) => {
    const nums = vals.filter((v) => v != null) as number[];
    return nums.length ? Math.round(nums.reduce((a, b) => a + b, 0) / nums.length) : null;
  };
  benchRows.push({ label: 'Sector average', dr: avg(compRows.map(r => r.dr)), etv: avg(compRows.map(r => r.etv)), kw10: avg(compRows.map(r => r.kw10)), isOwn: false });
}

const maxDR = Math.max(...benchRows.map(r => r.dr || 0), 1);
const maxETV = Math.max(...benchRows.map(r => r.etv || 0), 1);
const maxKW = Math.max(...benchRows.map(r => r.kw10 || 0), 1);

const channelColors: Record<string, string> = {
  organic: '#1A4B8C', direct: '#64748b', social: '#7c3aed',
  referral: '#0891b2', paid: '#d97706', email: '#16a34a',
};
const channelLabels: Record<string, string> = {
  organic: 'Organic', direct: 'Direct', social: 'Social',
  referral: 'Referral', paid: 'Paid', email: 'Email',
};
const channels = traffic?.channels || {};
const totalVisits = Object.values(channels).reduce((s: number, c: any) => s + (c.visits || 0), 0);
const channelSegments = Object.entries(channels)
  .sort(([, a]: any, [, b]: any) => (b.visits || 0) - (a.visits || 0))
  .map(([key, ch]: [string, any]) => ({
    key, label: channelLabels[key] || key, visits: ch.visits || 0,
    pct: totalVisits > 0 ? Math.round((ch.visits / totalVisits) * 100) : 0,
    color: channelColors[key] || '#94a3b8',
  }));

// ── Schema audit ─────────────────────────────────────────────────
const schemaTypes: string[] = crawl.schemaTypes || [];
const RECOMMENDED_SCHEMAS_EN: Record<string, string[]> = {
  ecommerce: ['Organization', 'WebSite', 'Product', 'Offer', 'BreadcrumbList'],
  saas: ['Organization', 'WebSite', 'SoftwareApplication', 'FAQPage'],
  b2b: ['Organization', 'WebSite', 'Service', 'FAQPage', 'BreadcrumbList'],
  local: ['LocalBusiness', 'Organization', 'GeoCoordinates', 'OpeningHoursSpecification'],
  media: ['Organization', 'WebSite', 'Article', 'BreadcrumbList'],
  unknown: ['Organization', 'WebSite', 'BreadcrumbList'],
};
const recommendedSchemas = RECOMMENDED_SCHEMAS_EN[businessType] || RECOMMENDED_SCHEMAS_EN.unknown;
const presentLower = schemaTypes.map((t: string) => t.toLowerCase());
const missingSchemas = recommendedSchemas.filter(s => !presentLower.includes(s.toLowerCase()));
const diagSchema = diagnosisSchema(schemaTypes.length ? schemaTypes : undefined, businessType);

// EN diagnostic texts (reuse same functions — they output Spanish, acceptable for v1)
const diagSEO = diagnosisSEO(seo, ctItems);
const diagGEO = diagnosisGEO(geo);
const diagTraffic = diagnosisTrafficMix(traffic);
const diagPS = diagnosisPageSpeed(ps);
const diagFunnel = diagnosisFunnel(cv);
const diagStack = diagnosisTechStack(ts);
const diagGap = diagnosisCompetitiveGap(seo, ctItems, kg);
const diagSummary = diagnosisHealthSummary(health);

// ── Business type ─────────────────────────────────────────────────
const businessType: string = crawl.businessType || 'unknown';
const btLabels: Record<string, string> = {
  ecommerce: 'E-commerce',
  saas: 'SaaS / Software',
  b2b: 'B2B · Lead Generation',
  local: 'Local Business',
  media: 'Media / Content',
};
const btLabel = btLabels[businessType] || '';
const btObjectives: Record<string, string> = {
  ecommerce: 'maximize online sales',
  saas: 'increase trial activations and reduce churn',
  b2b: 'generate qualified leads and shorten the sales cycle',
  local: 'capture local demand and improve your Google reputation',
  media: 'grow your organic audience and monetize it',
  unknown: 'improve your digital presence and conversion',
};
const btObjective = btObjectives[businessType] || btObjectives.unknown;

// ── Personalized CTA data ─────────────────────────────────────────
const avgETV = ctItems.length > 0
  ? ctItems.reduce((s: number, c: any) => s + (c.organicTrafficEstimate || 0), 0) / ctItems.length
  : 0;
const ownETV = seo?.organicTrafficEstimate || 0;
const trafficGap = Math.max(0, Math.round(avgETV - ownETV));
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Digital Growth Report — {domain} — AION Growth Studio</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #f8fafc; color: #0f172a; margin: 0; }
    .report { max-width: 900px; margin: 0 auto; background: #fff; }
    .section { padding: 2rem 2.5rem; border-bottom: 1px solid #e2e8f0; }
    .section:last-child { border-bottom: none; }
    h2 { font-size: 1.25rem; font-weight: 700; color: #0f172a; margin: 0 0 0.25rem; }
    h3 { font-size: 1rem; font-weight: 600; color: #1e293b; margin: 0 0 0.5rem; }
    p { margin: 0 0 0.75rem; line-height: 1.65; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    th { text-align: left; padding: 0.5rem 0.75rem; background: #f1f5f9; color: #475569; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
    td { padding: 0.625rem 0.75rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    tr.own-row td { background: #eff6ff; font-weight: 600; }
    tr.avg-row td { background: #f8fafc; color: #64748b; font-style: italic; font-size: 0.8rem; }
    .pillar-card { border-radius: 0.75rem; padding: 1rem; text-align: center; border: 1px solid #e2e8f0; }
    .num { font-family: 'Space Grotesk', system-ui, sans-serif; }
    .pillar-score { font-size: 1.75rem; font-weight: 700; line-height: 1; font-family: 'Space Grotesk', system-ui, sans-serif; }
    .pillar-label { font-size: 0.7rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
    .sub-section { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #f1f5f9; }
    .diag-text { font-size: 0.9375rem; color: #334155; line-height: 1.7; background: #f8fafc; border-left: 3px solid #1A4B8C; padding: 0.875rem 1rem; border-radius: 0 0.5rem 0.5rem 0; margin: 0.75rem 0 1rem; }
    .initiative-card { border: 1px solid #e2e8f0; border-radius: 0.75rem; padding: 1.25rem; margin-bottom: 1rem; }
    .initiative-num { display: inline-flex; align-items: center; justify-content: center; width: 1.75rem; height: 1.75rem; border-radius: 9999px; background: #1A4B8C; color: #fff; font-size: 0.8rem; font-weight: 700; margin-right: 0.5rem; }
    .check-row { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.375rem 0; border-bottom: 1px solid #f8fafc; font-size: 0.875rem; }
    .check-row:last-child { border-bottom: none; }
    .check-ok { color: #16a34a; }
    .check-no { color: #dc2626; }
    .bar-wrap { display: flex; align-items: center; gap: 0.5rem; }
    .bar-bg { flex: 1; height: 0.5rem; background: #f1f5f9; border-radius: 9999px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 9999px; }
    @media print {
      body { background: #fff; }
      .no-print { display: none !important; }
      .report { max-width: 100%; }
      .section { page-break-inside: avoid; }
      .initiative-card { page-break-inside: avoid; }
    }
  </style>
</head>
<body>
  <div class="no-print" style="background:#0B1B3D;padding:0.75rem 2rem;display:flex;align-items:center;justify-content:space-between;">
    <a href={`/en/audit/${id}`} style="color:#94a3b8;font-size:0.8rem;text-decoration:none;">← Back to analysis</a>
    <button onclick="window.print()" style="background:#1A4B8C;color:#fff;border:none;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.8rem;cursor:pointer;display:flex;align-items:center;gap:0.375rem;">
      <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
      Print / PDF
    </button>
  </div>

  <div class="report">
    <!-- ── HERO COMBINADO (Cover + Score) ──────────────────────────── -->
    <div style="background:linear-gradient(135deg,#0B1B3D 0%,#1A4B8C 100%);color:#fff;padding:1.5rem 2rem 2rem;position:relative;overflow:hidden;">
      <!-- Background glow -->
      <div style={`position:absolute;inset:0;background:radial-gradient(ellipse at 80% 20%,${scoreColor(health.total)}15 0%,transparent 50%);pointer-events:none;`}></div>
      
      <!-- Header row: Logo + Date -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;position:relative;">
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:28px;filter:brightness(0) invert(1);opacity:0.9;" />
        <span style="color:#94a3b8;font-size:0.7rem;">{auditDate}</span>
      </div>
      
      <!-- Main content: Left info + Right score -->
      <div style="display:flex;align-items:flex-start;gap:2rem;position:relative;">
        <!-- Left: Domain info -->
        <div style="flex:1;min-width:0;">
          <p style="font-size:0.65rem;font-weight:600;color:#67e8f9;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.35rem;">Digital Visibility Report</p>
          <h1 style="font-size:1.5rem;font-weight:800;margin:0 0 0.5rem;line-height:1.15;">{domain}</h1>
          <div style="display:flex;align-items:center;flex-wrap:wrap;gap:0.4rem;margin-bottom:1rem;">
            {sector && <span style="color:#cbd5e1;font-size:0.75rem;">{sector}</span>}
            {btLabel && (
              <>
                <span style="color:#475569;font-size:0.7rem;">|</span>
                <span style="color:#94a3b8;font-size:0.7rem;">{btLabel}</span>
              </>
            )}
          </div>
          
          <!-- Quick stats row -->
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;">
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Est. Traffic</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'Space Grotesk',sans-serif;">{fmt(seo?.organicTrafficEstimate)}</p>
            </div>
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Keywords Top10</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'Space Grotesk',sans-serif;">{fmt(seo?.keywordsTop10)}</p>
            </div>
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Domain Rank</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'Space Grotesk',sans-serif;">{seo?.domainRank ?? '--'}</p>
            </div>
          </div>
        </div>
        
        <!-- Right: Score gauge -->
        <div style="text-align:center;flex-shrink:0;">
          <div style="position:relative;width:110px;height:110px;">
            <svg viewBox="0 0 36 36" style="width:110px;height:110px;transform:rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="2.5"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke={scoreColor(health.total)} stroke-width="2.5" stroke-linecap="round" stroke-dasharray={`${health.total}, 100`}/>
            </svg>
            <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
              <span style="font-size:2rem;font-weight:800;color:#fff;font-family:'Space Grotesk',sans-serif;line-height:1;">{health.total}</span>
              <span style="font-size:0.6rem;color:#94a3b8;">/100</span>
            </div>
          </div>
          <p style="font-size:0.65rem;color:#67e8f9;text-transform:uppercase;letter-spacing:0.08em;margin:0.5rem 0 0;font-weight:600;">AEO Score</p>
        </div>
      </div>
      
      {hreflangAlts.length > 0 && (
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:0.375rem;padding:0.5rem 0.75rem;font-size:0.7rem;color:#cbd5e1;margin-top:1rem;">
          This analysis covers {domain}. {hreflangAlts.length} additional versions detected: {hreflangAlts.slice(0, 3).map((a: any) => a.domain).join(', ')}.
        </div>
      )}
    </div>

    <!-- ── PILLAR STRIP ──────────────────────────────────────────────── -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid #e2e8f0;">
      {[
        { label: 'Visibility', value: health.visibilidad, desc: 'Can they find you?' },
        { label: 'Competitiveness', value: health.competitividad, desc: 'vs sector' },
        { label: 'Experience', value: health.experiencia, desc: 'When they arrive' },
        { label: 'Conversion', value: health.conversion, desc: 'Do they convert?' },
      ].map((p, i) => (
        <div style={`padding:1.25rem 1rem;text-align:center;${i < 3 ? 'border-right:1px solid #e2e8f0;' : ''}`}>
          <div class="pillar-score" style={`color:${scoreColor(p.value)}`}>{p.value}</div>
          <div class="pillar-label">{p.label}</div>
          <div style="font-size:0.65rem;color:#94a3b8;margin-top:0.125rem;">{p.desc}</div>
        </div>
      ))}
    </div>

    <!-- Executive summary -->
    {insights.bullets?.length > 0 && (
      <div class="section" style="background:#f8fafc;">
        <h2 style="margin:0 0 1rem;">Executive Summary</h2>
        </div>
        <div style="display:flex;flex-direction:column;gap:0.125rem;">
          {insights.bullets.map((b: string) => (
            <div style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.625rem 0;border-bottom:1px solid #f1f5f9;">
              <span style="color:#1A4B8C;font-weight:700;font-size:1rem;flex-shrink:0;margin-top:0.1rem;">→</span>
              <p style="margin:0;font-size:0.9375rem;color:#334155;line-height:1.7;">{b}</p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Block 2: Visibility -->
    <div class="section">
      <h2>Can people find you?</h2>
      <p style="color:#64748b;font-size:0.875rem;margin:0 0 1rem;">Visibility in search engines, AI assistants and acquisition channels</p>

      <h3>🔗 Organic search (SEO)</h3>
      <div class="diag-text">{diagSEO}</div>
      {seo && (
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0.75rem;margin-bottom:1rem;">
          {[
            { label: 'Domain Rank', value: seo.domainRank ?? '—', color: scoreColor(seo.domainRank ?? 0) },
            { label: 'Org. traffic/mo', value: fmt(seo.organicTrafficEstimate), color: '#0f172a' },
            { label: 'Keywords top 10', value: fmt(seo.keywordsTop10), color: '#0f172a' },
            { label: 'Referring domains', value: fmt(seo.referringDomains), color: '#0f172a' },
          ].map((m) => (
            <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.5rem;padding:0.75rem;text-align:center;">
              <div style={`font-size:1.25rem;font-weight:700;color:${m.color}`}>{m.value}</div>
              <div style="font-size:0.7rem;color:#64748b;margin-top:0.125rem;">{m.label}</div>
            </div>
          ))}
        </div>
      )}
      {seoPages && (
        <div style="margin-top:0.75rem;">
          <p style="font-size:0.8rem;font-weight:600;color:#475569;margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.05em;">Top organic pages</p>
          <table>
            <thead><tr><th>Page</th><th style="text-align:right;">Est. traffic/mo</th><th style="text-align:right;">Keywords</th></tr></thead>
            <tbody>
              {seoPages.pages.map((p: any) => (
                <tr>
                  <td style="font-size:0.8rem;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title={p.pageAddress}>
                    {p.pageAddress.replace(/^https?:\/\/[^/]+/, '') || '/'}
                  </td>
                  <td style="text-align:right;font-size:0.8rem;">{p.trafficEstimate != null ? fmt(p.trafficEstimate) + '/mo' : '—'}</td>
                  <td style="text-align:right;font-size:0.8rem;">{p.keywords ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <!-- GEO -->
      <div class="sub-section">
        <h3>🤖 AI Visibility (GEO)</h3>
        <p style="font-size:0.875rem;color:#64748b;margin-bottom:0.75rem;">When someone asks ChatGPT or Perplexity about services like yours, do you appear in the answer? We simulated real queries.</p>
        {geo && geo.queries?.length > 0 ? (
          <>
            <table style="margin-bottom:0.75rem;">
              <thead><tr><th>Simulated query</th><th style="text-align:center;">Mentioned?</th><th>Score pts</th></tr></thead>
              <tbody>
                {geo.queries.slice(0, 5).map((q: any) => (
                  <tr>
                    <td style="font-size:0.8rem;color:#334155;max-width:280px;">{q.query}</td>
                    <td style="text-align:center;">{q.mentioned ? '✅' : '❌'}</td>
                    <td style="font-size:0.8rem;color:#64748b;">{q.pts ?? '—'} pts</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <div class="diag-text">{diagGEO}</div>
          </>
        ) : (
          <p style="color:#94a3b8;font-size:0.875rem;">GEO data not available for this analysis.</p>
        )}
      </div>

      <!-- Traffic mix -->
      {traffic && channelSegments.length > 0 && (
        <div class="sub-section">
          <h3>📊 Traffic channel mix</h3>
          <div class="diag-text">{diagTraffic}</div>
          <div style="display:flex;height:28px;border-radius:0.5rem;overflow:hidden;margin-bottom:0.75rem;">
            {channelSegments.map((ch) => (
              <div title={`${ch.label}: ${ch.pct}%`} style={`width:${ch.pct}%;background:${ch.color};`}></div>
            ))}
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
            {channelSegments.map((ch) => (
              <div style="display:flex;align-items:center;gap:0.375rem;font-size:0.8rem;color:#475569;">
                <span style={`width:10px;height:10px;border-radius:2px;background:${ch.color};display:inline-block;`}></span>
                {ch.label} <strong>{ch.pct}%</strong>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Block 3: Competitive benchmark -->
    <div class="section">
      <h2>How do you compare to competitors?</h2>
      <p style="color:#64748b;font-size:0.875rem;margin:0 0 1rem;">Relative positioning against detected competitors in your sector</p>
      {diagGap && <div class="diag-text">{diagGap}</div>}
      {benchRows.length > 1 && (
        <>
          <div style="overflow-x:auto;">
            <table>
              <thead><tr><th>Brand</th><th>DR</th><th>Org. traffic/mo</th><th>Keywords top 10</th></tr></thead>
              <tbody>
                {benchRows.map((row) => (
                  <tr class={row.isOwn ? 'own-row' : row.label === 'Sector average' ? 'avg-row' : ''}>
                    <td style={row.isOwn ? 'color:#1A4B8C;font-weight:700;' : ''}>{row.label}</td>
                    <td>
                      <div class="bar-wrap">
                        <div class="bar-bg"><div class="bar-fill" style={`width:${Math.round(((row.dr||0)/maxDR)*100)}%;background:${row.isOwn?'#1A4B8C':'#94a3b8'}`}></div></div>
                        <span style="font-size:0.8rem;width:2rem;text-align:right;">{row.dr ?? '—'}</span>
                      </div>
                    </td>
                    <td>
                      <div class="bar-wrap">
                        <div class="bar-bg"><div class="bar-fill" style={`width:${Math.round(((row.etv||0)/maxETV)*100)}%;background:${row.isOwn?'#1A4B8C':'#94a3b8'}`}></div></div>
                        <span style="font-size:0.8rem;width:3rem;text-align:right;">{fmt(row.etv)}</span>
                      </div>
                    </td>
                    <td>
                      <div class="bar-wrap">
                        <div class="bar-bg"><div class="bar-fill" style={`width:${Math.round(((row.kw10||0)/maxKW)*100)}%;background:${row.isOwn?'#1A4B8C':'#94a3b8'}`}></div></div>
                        <span style="font-size:0.8rem;width:3rem;text-align:right;">{fmt(row.kw10)}</span>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {benchRows.every((r: any) => r.dr == null && r.etv == null && r.kw10 == null) ? (
            <p style="font-size:0.8rem;color:#f59e0b;background:#fffbeb;border:1px solid #fde68a;padding:0.5rem 0.75rem;border-radius:0.375rem;margin-top:0.75rem;">
              ⚠️ DataForSEO has no organic traffic data for these domains. Metrics will appear in the next analysis with updated parameters.
            </p>
          ) : (
            <p style="font-size:0.75rem;color:#94a3b8;margin-top:0.5rem;">DR = Domain Rank (0-100). DataForSEO estimates.</p>
          )}
        </>
      )}
      {kg && (
        <div class="sub-section">
          <h3>🔑 Keyword gap — ranking opportunities</h3>
          <p style="font-size:0.875rem;color:#334155;margin-bottom:0.75rem;">Keywords in <strong>{kg.competitor}</strong>'s top 10 where you don't rank.</p>
          <table>
            <thead><tr><th>Keyword</th><th style="text-align:right;">Searches/mo</th><th style="text-align:right;">Competitor position</th></tr></thead>
            <tbody>
              {kg.items.map((item: any) => (
                <tr>
                  <td style="font-size:0.875rem;">{item.keyword}</td>
                  <td style="text-align:right;font-size:0.8rem;">{item.searchVolume != null ? fmt(item.searchVolume)+'/mo' : '—'}</td>
                  <td style="text-align:right;font-size:0.8rem;">{item.competitorPosition ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <!-- Block 4: Experience & Conversion -->
    <div class="section">
      <h2>What happens when they arrive?</h2>
      <p style="color:#64748b;font-size:0.875rem;margin:0 0 1rem;">Web performance, tools and conversion capability</p>

      {ps && ps.mobile && (
        <>
          <h3>⚡ Web performance (PageSpeed)</h3>
          <div class="diag-text">{diagPS}</div>
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1rem;">
            {[
              { label: 'Performance', value: ps.mobile.performance },
              { label: 'Accessibility', value: ps.mobile.accessibility },
              { label: 'SEO Lighthouse', value: ps.mobile.seo },
              { label: 'Best Practices', value: ps.mobile.bestPractices },
            ].map((g) => {
              const color = g.value >= 90 ? '#22c55e' : g.value >= 50 ? '#f59e0b' : '#ef4444';
              return (
                <div style="text-align:center;">
                  <div style="position:relative;width:80px;height:80px;margin:0 auto;">
                    <svg width="80" height="80" viewBox="0 0 36 36" style="transform:rotate(-90deg)">
                      <circle cx="18" cy="18" r="15.9" fill="none" stroke="#e2e8f0" stroke-width="3"/>
                      <circle cx="18" cy="18" r="15.9" fill="none" stroke={color}
                        stroke-width="3" stroke-linecap="round" stroke-dasharray={`${g.value}, 100`} />
                    </svg>
                    <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
                      <span style={`font-size:1rem;font-weight:800;color:${color}`}>{g.value}</span>
                    </div>
                  </div>
                  <div style="font-size:0.7rem;color:#64748b;font-weight:500;margin-top:0.25rem;">{g.label}</div>
                  <div style="font-size:0.65rem;color:#94a3b8;">Mobile</div>
                </div>
              );
            })}
          </div>
        </>
      )}

      <!-- Schema Markup -->
      <div class="sub-section">
        <h3>🔖 Structured Data (Schema Markup)</h3>
        <div class="diag-text">{diagSchema}</div>
        {schemaTypes.length > 0 && (
          <div style="margin-bottom:0.75rem;">
            <p style="font-size:0.75rem;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.5rem;">Detected ({schemaTypes.length})</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.375rem;">
              {schemaTypes.map((t: string) => (
                <span style="font-size:0.7rem;background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0;border-radius:0.375rem;padding:0.125rem 0.5rem;font-weight:500;">{t}</span>
              ))}
            </div>
          </div>
        )}
        {missingSchemas.length > 0 && (
          <div>
            <p style="font-size:0.75rem;font-weight:600;color:#475569;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.5rem;">Recommended for your business type — not found</p>
            <div style="display:flex;flex-wrap:wrap;gap:0.375rem;">
              {missingSchemas.map((t: string) => (
                <span style="font-size:0.7rem;background:#fff7ed;color:#c2410c;border:1px solid #fed7aa;border-radius:0.375rem;padding:0.125rem 0.5rem;font-weight:500;">✗ {t}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      {ts && (
        <div class="sub-section">
          <h3>🛠️ Marketing stack maturity</h3>
          <div class="diag-text">{diagStack}</div>
        </div>
      )}

      {cv && (
        <div class="sub-section">
          <h3>🎯 Conversion capability</h3>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;">
            <span style={`font-size:1.5rem;font-weight:800;color:${scoreColor(cv.funnelScore ?? 0)}`}>{cv.funnelScore ?? 0}/100</span>
          </div>
          <div class="diag-text">{diagFunnel}</div>
          {[
            { label: 'Contact form', ok: cv.hasContactForm },
            { label: 'Clear CTAs', ok: cv.hasCTA },
            { label: 'Lead magnet', ok: cv.hasLeadMagnet },
            { label: 'Testimonials / social proof', ok: cv.hasTestimonials },
            { label: 'Visible pricing', ok: cv.hasPricing },
            { label: 'Video content', ok: cv.hasVideo },
            { label: 'Live chat', ok: cv.hasChatWidget },
          ].map((c) => (
            <div class="check-row">
              <span class={c.ok ? 'check-ok' : 'check-no'}>{c.ok ? '✓' : '✗'}</span>
              <span style="font-size:0.875rem;">{c.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Block 5: Action plan -->
    <div class="section">
      <h2>What to do, in what order?</h2>
      <p style="color:#64748b;font-size:0.875rem;margin:0 0 1.5rem;">Priority initiatives ordered by impact/effort ratio</p>
      {insights.initiatives?.length > 0
        ? insights.initiatives.map((init: any, i: number) => (
            <div class="initiative-card">
              <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.75rem;">
                <span class="initiative-num">{i + 1}</span>
                <h3 style="margin:0;font-size:1rem;">{init.title}</h3>
              </div>
              <p style="font-size:0.9rem;color:#334155;line-height:1.65;margin:0;">{init.description}</p>
            </div>
          ))
        : [health.visibilidad, health.competitividad, health.experiencia, health.conversion]
            .map((s, i) => ({ score: s, label: ['Visibility','Competitiveness','Experience','Conversion'][i] }))
            .sort((a, b) => a.score - b.score)
            .slice(0, 3)
            .map((item, i) => (
              <div class="initiative-card">
                <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.75rem;">
                  <span class="initiative-num">{i + 1}</span>
                  <h3 style="margin:0;font-size:1rem;">Improve: {item.label} ({item.score}/100)</h3>
                </div>
                <p style="font-size:0.9rem;color:#334155;line-height:1.65;margin:0;">This pillar has the most room for improvement and represents a direct growth opportunity.</p>
              </div>
            ))
      }
      {insights.bullets?.length > 0 && (
        <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #f1f5f9;">
          <h3 style="margin-bottom:0.75rem;">Key diagnostic findings</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            {insights.bullets.map((b: string) => (
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.9rem;color:#334155;line-height:1.6;">
                <span style="color:#1A4B8C;font-weight:700;margin-top:0.1rem;flex-shrink:0;">→</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- Personalized CTA -->
    <div class="no-print" style="padding:3.5rem 2.5rem;background:linear-gradient(135deg,#0B1B3D 0%,#1A4B8C 60%,#0e7490 100%);text-align:center;color:#fff;">
      <p style="font-size:0.7rem;font-weight:600;color:#67e8f9;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 1rem;">Next step</p>
      {trafficGap > 500 ? (
        <h2 class="num" style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;line-height:1.2;">
          Your competitors get ~{fmt(trafficGap)} more visits/month than you.
        </h2>
      ) : (
        <h2 class="num" style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;line-height:1.2;">
          Your business has clear digital growth opportunities.
        </h2>
      )}
      <p style="font-size:1rem;color:rgba(255,255,255,0.75);max-width:480px;margin:0 auto 2rem;line-height:1.6;">
        We can help you {btObjective} with a concrete action plan. No fluff.
      </p>
      <a
        href="mailto:hola@aiongrowth.studio"
        style="display:inline-flex;align-items:center;gap:0.5rem;background:#fff;color:#0B1B3D;font-weight:700;font-size:0.95rem;padding:0.875rem 2rem;border-radius:0.75rem;text-decoration:none;"
      >
        Talk to AION →
      </a>
      <p style="font-size:0.75rem;color:rgba(255,255,255,0.4);margin:1rem 0 0;">No commitment · Response within 24h</p>
    </div>

    <!-- Footer -->
    <div style="padding:1.5rem 2.5rem;background:#0B1B3D;color:#94a3b8;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
      <div>
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:32px;filter:brightness(0) invert(1);margin-bottom:0.25rem;display:block;" />
        <p style="font-size:0.7rem;margin:0;">Report generated {auditDate} · aiongrowth.studio</p>
      </div>
      <div style="text-align:right;">
        <p style="font-size:0.75rem;margin:0 0 0.25rem;">hola@aiongrowth.studio</p>
      </div>
    </div>
  </div>
</body>
</html>
