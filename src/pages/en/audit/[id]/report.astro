                <p style="font-weight:700;color:#F9FAFB;margin:0;font-size:0.95rem;">{(ts.maturityScore ?? 0) >= 70 ? 'Mature stack' : (ts.maturityScore ?? 0) >= 40 ? 'Basic setup' : 'Significant gaps'} — {ts.maturityScore ?? 0}/100</p>
                {ts.cms && <p style="font-size:0.8rem;color:#6B7280;margin:0.25rem 0 0;">CMS detected: <strong>{ts.cms}</strong></p>}
              </div>
            </div>
          ) : (
            <div style="background:rgba(59,130,246,0.07);border:1px solid rgba(59,130,246,0.25);border-radius:0.5rem;padding:0.75rem 1rem;margin-bottom:0.875rem;">
              {ts.cms && <p style="font-size:0.8rem;font-weight:600;color:#60A5FA;margin:0 0 0.25rem;">CMS detected: {ts.cms}</p>}
              <p style="font-size:0.875rem;color:#60A5FA;margin:0;line-height:1.6;">
                No marketing tools were detected in the public HTML. This is common in corporate sites where tools are loaded dynamically (GTM, async JavaScript) or server-side. The analysis below reflects what is visible in the source code.
              </p>
            </div>
          )}

          <p style="font-size:0.75rem;color:#6B7280;background:#111827;border:1px solid #1F2937;border-radius:0.375rem;padding:0.5rem 0.75rem;margin-bottom:0.875rem;line-height:1.5;">
            ℹ️ Analysis based on public HTML code. Tools loaded dynamically (GTM, async JS) or configured server-side may not appear here.
          </p>

          {stackItems.filter((s: any) => s.tools?.length > 0).length > 0 && (
            <div style="margin-bottom:0.875rem;">
              <p style="font-size:0.775rem;font-weight:700;color:#10B981;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.5rem;">✅ What you have</p>
              <div style="display:flex;flex-direction:column;gap:0.375rem;">
                {stackItems.filter((s: any) => s.tools?.length > 0).map((s: any) => (
                  <div style="font-size:0.875rem;color:#D1D5DB;">
                    <span style="font-weight:600;">{s.label}:</span> <span style="color:#6B7280;">{s.tools.join(', ')}</span>
                    <span style="color:#9CA3AF;font-size:0.8rem;"> — {s.presentNote}</span>
                  </div>
                ))}
              </div>
            </div>
          )}

          {stackItems.filter((s: any) => !s.tools?.length).length > 0 && (
            <div>
              <p style="font-size:0.775rem;font-weight:700;color:#F59E0B;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.5rem;">⚠️ Not detected in public HTML</p>
              <div style="display:flex;flex-direction:column;gap:0.5rem;">
                {stackItems.filter((s: any) => !s.tools?.length).map((s: any) => (
                  <div style="background:#111827beb;border:1px solid rgba(245,158,11,0.3);border-radius:0.375rem;padding:0.5rem 0.75rem;font-size:0.85rem;">
                    <span style="font-weight:600;color:#FCD34D;">{s.label} not detected in public HTML:</span>
                    <span style="color:#78350f;"> {s.missingNote}</span>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      )}

      {cv && (
        <div class="sub-section">
          <h3>🎯 Conversion capability</h3>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.75rem;">
            <span style={`font-size:1.5rem;font-weight:800;color:${scoreColor(cv.funnelScore ?? 0)}`}>{cv.funnelScore ?? 0}/100</span>
          </div>
          <div class="diag-text">{diagFunnel}</div>
          {[
            { label: 'Contact form', ok: cv.hasContactForm },
            { label: 'Clear CTAs', ok: cv.hasCTA },
            { label: 'Lead magnet', ok: cv.hasLeadMagnet },
            { label: 'Testimonials / social proof', ok: cv.hasTestimonials },
            { label: 'Visible pricing', ok: cv.hasPricing },
            { label: 'Video content', ok: cv.hasVideo },
            { label: 'Live chat', ok: cv.hasChatWidget },
          ].map((c) => (
            <div class="check-row">
              <span class={c.ok ? 'check-ok' : 'check-no'}>{c.ok ? '✓' : '✗'}</span>
              <span style="font-size:0.875rem;">{c.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Block 5: Action plan -->
    <div class="section">
      <h2>What to do, in what order?</h2>
      <p style="color:#6B7280;font-size:0.875rem;margin:0 0 1.5rem;">Priority initiatives ordered by impact/effort ratio</p>
      {insights.initiatives?.length > 0
        ? insights.initiatives.map((init: any, i: number) => (
            <div class="initiative-card">
              <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.75rem;">
                <span class="initiative-num">{i + 1}</span>
                <h3 style="margin:0;font-size:1rem;">{init.title}</h3>
              </div>
              <p style="font-size:0.9rem;color:#D1D5DB;line-height:1.65;margin:0 0 0.875rem;">{init.description}</p>
              <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                <span style={`font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:${i === 0 ? 'rgba(16,185,129,0.1)' : 'rgba(245,158,11,0.1)'};color:${i === 0 ? '#10B981' : '#F59E0B'};border:1px solid ${i === 0 ? 'rgba(16,185,129,0.3)' : 'rgba(245,158,11,0.3)'};`}>
                  Impact {i === 0 ? '🟢 High' : i === 1 ? '🟡 Medium-high' : '🟡 Medium'}
                </span>
                <span style="font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:#1C2333;color:#9CA3AF;border:1px solid #1F2937;">
                  Timeline {i === 0 ? '1-2 months' : i === 1 ? '2-4 months' : '3-6 months'}
                </span>
              </div>
            </div>
          ))
        : fallbackInitiatives.map((item, i) => (
            <div class="initiative-card">
              <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.75rem;">
                <span class="initiative-num">{i + 1}</span>
                <h3 style="margin:0;font-size:1rem;">Improve: {item.label} ({item.score}/100)</h3>
              </div>
              <p style="font-size:0.9rem;color:#D1D5DB;line-height:1.65;margin:0 0 0.875rem;">{item.action}</p>
              <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                <span style={`font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:${item.score < 40 ? 'rgba(239,68,68,0.1)' : 'rgba(245,158,11,0.1)'};color:${item.score < 40 ? '#EF4444' : '#F59E0B'};border:1px solid ${item.score < 40 ? 'rgba(239,68,68,0.3)' : 'rgba(245,158,11,0.3)'};`}>
                  Impact {item.score < 40 ? '🟢 High' : '🟡 Medium'}
                </span>
                <span style="font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:#1C2333;color:#9CA3AF;border:1px solid #1F2937;">
                  Timeline {i === 0 ? '1-2 months' : '2-4 months'}
                </span>
              </div>
            </div>
          ))
      }
      {insights.bullets?.length > 0 && (
        <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #1F2937;">
          <h3 style="margin-bottom:0.75rem;">Key diagnostic findings</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            {insights.bullets.map((b: string) => (
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.9rem;color:#D1D5DB;line-height:1.6;">
                <span style="color:#3B82F6;font-weight:700;margin-top:0.1rem;flex-shrink:0;">→</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- Block 6: Impact Projection -->
    {hasAnyImpactProjection && (
      <div class="section">
        <h2>📈 Your detected growth potential</h2>
        <p style="color:#6B7280;font-size:0.875rem;margin:0 0 1.5rem;">Based exclusively on the data in this analysis, not on generic estimates.</p>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;margin-bottom:1.25rem;">

          {projTrafficBase > 0 && (
            <div style="background:#111827;border:1px solid #1F2937;border-top:3px solid #3B82F6;border-radius:0.75rem;padding:1.25rem;">
              <p style="font-size:0.65rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.625rem;">Keywords one step from page one</p>
              <p style="font-family:'DM Mono',monospace;font-size:1.625rem;font-weight:500;color:#F9FAFB;margin:0 0 0.375rem;line-height:1;">+{fmt(projTrafficMin)}–{fmt(projTrafficMax)}</p>
              <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 0.75rem;line-height:1.55;">
                estimated visits/mo · {fmt(pos4to10)} keywords in positions 4-10
                {projAdsValue != null && projAdsValue > 0 && <> · ~{fmt(projAdsValue)}€/mo ad equivalent</>}
              </p>
              <span style="display:inline-block;background:rgba(59,130,246,0.1);color:#60A5FA;border:1px solid rgba(59,130,246,0.25);border-radius:9999px;font-size:0.65rem;font-weight:600;padding:0.175rem 0.6rem;">60-90 days</span>
            </div>
          )}

          {geoMissedQueries > 0 && (
            <div style="background:#111827;border:1px solid #1F2937;border-top:3px solid #6366F1;border-radius:0.75rem;padding:1.25rem;">
              <p style="font-size:0.65rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.625rem;">Invisible in AI search</p>
              <p style="font-family:'DM Mono',monospace;font-size:1.625rem;font-weight:500;color:#F9FAFB;margin:0 0 0.375rem;line-height:1;">{geoMissedQueries}/{geoTotalQueries}</p>
              <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 0.75rem;line-height:1.55;">
                queries without your brand in ChatGPT · GEO strategy can close this gap
              </p>
              <span style="display:inline-block;background:rgba(99,102,241,0.1);color:#A5B4FC;border:1px solid rgba(99,102,241,0.25);border-radius:9999px;font-size:0.65rem;font-weight:600;padding:0.175rem 0.6rem;">3-6 months</span>
            </div>
          )}

          {repTotalReviews > 0 && repTotalReviews < 50 && (
            <div style="background:#111827;border:1px solid #1F2937;border-top:3px solid #F59E0B;border-radius:0.75rem;padding:1.25rem;">
              <p style="font-size:0.65rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.625rem;">Reputation below trust threshold</p>
              <p style="font-family:'DM Mono',monospace;font-size:1.625rem;font-weight:500;color:#F9FAFB;margin:0 0 0.375rem;line-height:1;">{repTotalReviews}/50</p>
              <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 0.75rem;line-height:1.55;">
                reviews — top 25% local visibility starts at 50 verified reviews
              </p>
              <span style="display:inline-block;background:rgba(245,158,11,0.1);color:#F59E0B;border:1px solid rgba(245,158,11,0.25);border-radius:9999px;font-size:0.65rem;font-weight:600;padding:0.175rem 0.6rem;">Ongoing</span>
            </div>
          )}

          {hasTrendLossImpact && seo && (
            <div style="background:#111827;border:1px solid #1F2937;border-top:3px solid #EF4444;border-radius:0.75rem;padding:1.25rem;">
              <p style="font-size:0.65rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.625rem;">Visibility loss that can be stopped</p>
              <p style="font-family:'DM Mono',monospace;font-size:1.625rem;font-weight:500;color:#F9FAFB;margin:0 0 0.375rem;line-height:1;">−{fmt(seo.trendLost)}</p>
              <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 0.75rem;line-height:1.55;">
                keywords lost vs {fmt(seo.trendUp)} gained · reversible with technical and content optimisation
              </p>
              <span style="display:inline-block;background:rgba(239,68,68,0.1);color:#FCA5A5;border:1px solid rgba(239,68,68,0.25);border-radius:9999px;font-size:0.65rem;font-weight:600;padding:0.175rem 0.6rem;">60 days</span>
            </div>
          )}
        </div>

        <p style="font-size:0.7rem;color:#9CA3AF;line-height:1.5;background:#111827;border:1px solid #1F2937;border-radius:0.375rem;padding:0.625rem 0.875rem;">
          Projections are estimates based on industry benchmarks and the specific data of this domain. Actual results depend on execution and external factors such as algorithm changes or competitor movements.
        </p>
      </div>
    )}

    <!-- Personalized CTA -->
    <div class="no-print" style="padding:3.5rem 2.5rem;background:linear-gradient(135deg,#0A0F1E 0%,#1E3A5F 100%);text-align:center;color:#fff;">
      <p style="font-size:0.7rem;font-weight:600;color:#06B6D4;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 1rem;">Next step</p>
      {trafficGap > 500 ? (
        <h2 class="num" style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;line-height:1.2;">
          Your competitors get ~{fmt(trafficGap)} more visits/month than you.
        </h2>
      ) : (
        <h2 class="num" style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;line-height:1.2;">
          Your business has clear digital growth opportunities.
        </h2>
      )}
      <p style="font-size:1rem;color:rgba(255,255,255,0.75);max-width:480px;margin:0 auto 2rem;line-height:1.6;">
        We can help you {btObjective} with a concrete action plan. No fluff.
      </p>
      <a
        href="mailto:hola@aiongrowth.studio"
        style="display:inline-flex;align-items:center;gap:0.5rem;background:#fff;color:#0A0F1E;font-weight:700;font-size:0.95rem;padding:0.875rem 2rem;border-radius:0.75rem;text-decoration:none;"
      >
        Talk to AION →
      </a>
      <p style="font-size:0.75rem;color:rgba(255,255,255,0.4);margin:1rem 0 0;">No commitment · Response within 24h</p>
    </div>

    <!-- Footer -->
    <div style="padding:1.5rem 2.5rem;background:#0A0F1E;color:#9CA3AF;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
      <div>
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:32px;filter:brightness(0) invert(1);margin-bottom:0.25rem;display:block;" />
        <p style="font-size:0.7rem;margin:0;">Report generated {auditDate} · aiongrowth.studio</p>
      </div>
      <div style="text-align:right;">
        <p style="font-size:0.75rem;margin:0 0 0.25rem;">hola@aiongrowth.studio</p>
      </div>
    </div>
  </div>

  <script define:vars={{ scoreTotal: health.total }}>
    // Score counter + ring animation
    const counter = document.getElementById('score-counter');
    const ring = document.getElementById('score-ring');
    if (counter && scoreTotal > 0) {
      const duration = 1400;
      const start = performance.now();
      const animate = (now) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * scoreTotal);
        counter.textContent = current;
        if (ring) ring.setAttribute('stroke-dasharray', eased * scoreTotal + ', 100');
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
    }

    // Scroll reveal
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('visible'); revealObserver.unobserve(e.target); }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

    // Bar fill animation (uses data-width attribute)
    const barObserver = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.querySelectorAll('.bar-fill').forEach((bar) => {
            const w = bar.getAttribute('data-width') || '0';
            bar.style.width = w + '%';
          });
          barObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.2 });
    document.querySelectorAll('table').forEach((t) => barObserver.observe(t));
  </script>
</body>
</html>
