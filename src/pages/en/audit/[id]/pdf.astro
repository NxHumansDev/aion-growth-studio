---
export const prerender = false;
import { getAuditPage } from '../../../../lib/audit/supabase-storage';
import { computeHealthScore, scoreColor, scoreLabel } from '../../../../lib/audit/report/health-score';

const { id } = Astro.params;
let audit: any = null;
let error = '';
try { audit = await getAuditPage(id!); } catch (e: any) { error = e.message || 'Error.'; }
if (!audit || audit.status !== 'completed') { return Astro.redirect(`/en/audit/${id}`); }

const r = audit.results;
const domain = new URL(audit.url).hostname.replace(/^www\./, '');
const auditDate = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
const health = computeHealthScore(r);

// Data shortcuts
const crawl = r.crawl || {};
const seo = (!r.seo?.skipped && r.seo) ? r.seo : null;
const geo = (!r.geo?.skipped && r.geo) ? r.geo : null;
const traffic = (!r.traffic?.skipped && r.traffic) ? r.traffic : null;
const ps = (!r.pagespeed?.skipped && r.pagespeed) ? r.pagespeed : null;
const gbp = (!r.gbp?.skipped && r.gbp?.found) ? r.gbp : null;
const ssl = (!r.ssl?.skipped && r.ssl) ? r.ssl : null;
const ctItemsRaw: any[] = r.competitor_traffic?.items || [];
const ctItems: any[] = ctItemsRaw.filter((c: any) => !c.apiError && (c.organicTrafficEstimate != null || c.keywordsTop10 != null));
const hasCompetitorData = ctItems.length > 0;
const kg = (!r.keyword_gap?.skipped && r.keyword_gap?.items?.length) ? r.keyword_gap : null;
const ts = (!r.techstack?.skipped && r.techstack) ? r.techstack : null;
const cv = (!r.conversion?.skipped && r.conversion) ? r.conversion : null;
const metaAds = (!r.meta_ads?.skipped && r.meta_ads) ? r.meta_ads : null;
const qa = r.qa || null;
const qaSuppressed: string[] = qa?.suppressedSections || [];
const insights = r.insights || {};
const ga = (r.growth_agent || null) as any;
const gaActions: any[] = ga?.prioritizedActions || [];
const gaExec = ga?.executiveSummary || null;
const linkedin = (!r.linkedin?.skipped && r.linkedin?.found) ? r.linkedin : null;
const instagram = (!r.instagram?.skipped && r.instagram?.found) ? r.instagram : null;
const sector = r.sector?.sector || audit.sector || '';
const businessType: string = crawl.businessType || 'unknown';
const compPS = (r.competitor_pagespeed && !r.competitor_pagespeed?.skipped) ? r.competitor_pagespeed : null;
const kwGap = kg;

// Helpers
function fmt(n: number | undefined | null): string {
  if (n == null) return '—';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return Math.round(n / 1_000) + 'K';
  return String(n);
}

type AreaStatus = 'good' | 'medium' | 'bad';
const ss = (v: number): AreaStatus => v >= 60 ? 'good' : v >= 35 ? 'medium' : 'bad';

function statusStyle(s: AreaStatus): { bg: string; fg: string; label: string } {
  if (s === 'good') return { bg: '#E1F5EE', fg: '#085041', label: 'Good' };
  if (s === 'medium') return { bg: '#FAEEDA', fg: '#633806', label: 'Medium' };
  return { bg: '#FCEBEB', fg: '#791F1F', label: 'Poor' };
}

// Semaphore
const statusByArea: { area: string; status: AreaStatus; summary: string }[] = [
  { area: 'Organic SEO', status: ss(health.visibilidad ?? 0), summary: seo ? `${fmt(seo.keywordsTop10)} top 10 keywords, ~${fmt(seo.organicTrafficEstimate)} visits/mo` : 'No SEO data' },
  { area: 'AI Visibility', status: ss(geo?.mentionRate ?? 0), summary: geo ? `Mentioned in ${geo.mentionRate ?? 0}% of AI queries` : 'No GEO data' },
  { area: 'Paid Ads', status: (seo?.paidKeywordsTotal ?? 0) > 0 ? 'good' : 'bad', summary: (seo?.paidKeywordsTotal ?? 0) > 0 ? `${fmt(seo?.paidKeywordsTotal)} sponsored kw` : 'No paid activity detected' },
  { area: 'Benchmark', status: hasCompetitorData ? ss(health.competitividad ?? 0) : 'bad', summary: hasCompetitorData ? `${ctItems.length} competitors with data` : 'No competitor data' },
  { area: 'Web & Speed', status: ss(ps?.mobile?.performance ?? 0), summary: ps ? `Mobile score: ${ps.mobile?.performance ?? '—'}/100` : 'No PageSpeed data' },
  { area: 'Conversion', status: ss(cv?.funnelScore ?? health.conversion ?? 0), summary: cv ? `Funnel score: ${cv.funnelScore ?? '—'}/100` : 'No data' },
  { area: 'Measurement', status: ss(ts?.maturityScore ?? health.measurement ?? 0), summary: ts ? (ts.analytics?.length ? ts.analytics.join(', ') : 'Not detected in static HTML') : 'No data' },
];

const heroStatus = statusStyle(ss(health.total));
const analyticsDetection: string = (ts as any)?.analyticsDetection || 'none';

// Tech stack
const techStackMapped = {
  analytics: { detected: (ts?.analytics?.length ?? 0) > 0, tool: ts?.analytics?.[0] as string | undefined },
  tagManager: { detected: (ts?.tagManager?.length ?? 0) > 0, tool: ts?.tagManager?.[0] as string | undefined },
  metaPixel: { detected: ts?.conversionPixels?.some((p: string) => /meta|facebook|fbq/i.test(p)) ?? false },
  googleAdsPixel: { detected: ts?.conversionPixels?.some((p: string) => /google.*ads|doubleclick/i.test(p)) ?? false },
  chat: { detected: (ts?.chatSupport?.length ?? 0) > 0, tool: ts?.chatSupport?.[0] as string | undefined },
  heatmaps: { detected: (ts?.heatmaps?.length ?? 0) > 0, tool: ts?.heatmaps?.[0] as string | undefined },
};

// Schema
const schemaTypes: string[] = crawl.schemaTypes || [];
const RECOMMENDED_SCHEMAS: Record<string, string[]> = {
  ecommerce: ['Organization', 'WebSite', 'Product', 'Offer', 'BreadcrumbList'],
  saas: ['Organization', 'WebSite', 'SoftwareApplication', 'FAQPage'],
  b2b: ['Organization', 'WebSite', 'Service', 'FAQPage', 'BreadcrumbList'],
  local: ['LocalBusiness', 'Organization', 'GeoCoordinates', 'OpeningHoursSpecification'],
  media: ['Organization', 'WebSite', 'Article', 'BreadcrumbList'],
  unknown: ['Organization', 'WebSite', 'BreadcrumbList'],
};
const recommendedSchemas = RECOMMENDED_SCHEMAS[businessType] || RECOMMENDED_SCHEMAS.unknown;
const presentLower = schemaTypes.map((t: string) => t.toLowerCase());
const missingSchemas = recommendedSchemas.filter(s => !presentLower.includes(s.toLowerCase()));

// Keyword data
const kwGapItems: any[] = kwGap?.items?.slice(0, 8) || [];
const seoToAiGap: any[] = (seo?.topKeywords || []).slice(0, 5);

// Paid
const clientPaidKw = seo?.paidKeywordsTotal ?? 0;
const compPaidItems: any[] = ctItems.filter((c: any) => (c.paidKeywordsTotal ?? 0) > 0);

// Traffic
const ownETV = seo?.organicTrafficEstimate || 0;
const avgETV = hasCompetitorData ? ctItems.reduce((s: number, c: any) => s + (c.organicTrafficEstimate || 0), 0) / ctItems.length : 0;
const trafficGap = hasCompetitorData ? Math.max(0, Math.round(avgETV - ownETV)) : 0;

// Business type labels
const btLabels: Record<string, string> = { ecommerce: 'E-commerce', saas: 'SaaS / Software', b2b: 'B2B · Lead Gen', local: 'Local Business', media: 'Media / Content' };
const btLabel = btLabels[businessType] || '';

// CWV
function cwvStatus(metric: string, value: number): { color: string; label: string } {
  const t: Record<string, [number, number]> = { lcp: [2500, 4000], cls: [0.1, 0.25], fcp: [1800, 3000], ttfb: [800, 1800] };
  const [good, poor] = t[metric] || [50, 90];
  return value <= good ? { color: '#1D9E75', label: 'Good' } : value <= poor ? { color: '#BA7517', label: 'Needs work' } : { color: '#E24B4A', label: 'Slow' };
}

// Quick wins / strategic
const quickWins: string[] = insights?.bullets?.slice(0, 3) || [];
const strategicActions: any[] = insights?.initiatives?.slice(0, 4) || [];
interface QuickWin { title: string; problem: string; impact: 'high' | 'medium'; }
const fallbackQuickWins: QuickWin[] = [
  !techStackMapped.analytics.detected ? { title: 'Install Google Analytics 4 & Tag Manager', problem: analyticsDetection === 'none' ? 'Not detected in public HTML — if already installed via GTM or consent tool, ignore this.' : 'Without tracking you cannot know what works.', impact: analyticsDetection === 'none' ? 'medium' : 'high' } : null,
  ps && (ps.mobile?.performance || 0) < 50 ? { title: `Improve mobile load speed (now ${ps.mobile?.lcp != null ? (ps.mobile.lcp / 1000).toFixed(1) + 's' : 'slow'})`, problem: 'Every extra second reduces conversions 10–20%.', impact: 'high' } : null,
  !crawl.hasRobotsTxt ? { title: 'Add robots.txt', problem: 'Without robots.txt Google may crawl irrelevant pages.', impact: 'medium' } : null,
  !cv?.hasContactForm ? { title: 'Add a visible contact form', problem: 'Without a form visitors have no clear path to convert.', impact: 'high' } : null,
  geo && (geo.mentionRate || 0) < 30 ? { title: 'Create structured FAQs for AI visibility', problem: `Your brand appears in only ${geo.mentionRate ?? 0}% of AI queries.`, impact: 'medium' } : null,
  missingSchemas.length > 0 ? { title: `Add Schema Markup (${missingSchemas.slice(0, 2).join(', ')})`, problem: 'Without structured data Google cannot show rich results.', impact: 'medium' } : null,
  seo && (seo.keywordsPos4to10 || 0) > 0 ? { title: `Optimise ${fmt(seo.keywordsPos4to10)} keywords in position 4–10`, problem: 'These already have traction. A content refresh could move them to top 3.', impact: 'high' } : null,
].filter(Boolean) as QuickWin[];
const displayQuickWins: QuickWin[] = quickWins.length > 0
  ? quickWins.map((w: string) => ({ title: w, problem: '', impact: 'medium' as const }))
  : fallbackQuickWins.slice(0, 4);
const fallbackStrategic = [
  { title: 'SEO Content Strategy', description: 'Build a content plan targeting keyword gaps to capture incremental organic demand without increasing paid budget.' },
  { title: 'Generative AI Presence', description: 'Optimise your structured content so that ChatGPT, Perplexity and Gemini mention you in key sector queries before competitors.' },
  { title: 'Conversion Funnel Optimisation', description: 'Improve conversion rates with clearer CTAs, visible social proof and A/B tested lead capture forms.' },
  { title: 'Multi-channel Measurement & Attribution', description: 'Implement GA4 + full conversion pixels to measure real ROI per channel and make data-driven decisions.' },
];
const displayStrategic = strategicActions.length > 0 ? strategicActions : fallbackStrategic.slice(0, 4);

// GEO engines
const crossModel: any[] = geo?.crossModel || [];
const geoEngines = [...new Set(crossModel.map((e: any) => e.name))];
const geoEngineNames: string[] = geo?.queries?.[0]?.engines?.map((e: any) => e.name) || geoEngines;

// Competitor all-zero GEO check
const allCompGeoZero = (geo?.competitorMentions?.length ?? 0) > 0 && geo.competitorMentions.every((cm: any) => (cm.mentionRate ?? 0) === 0);

// SVG builders
function polarXY(cx: number, cy: number, r: number, angleDeg: number): [number, number] {
  const rad = (angleDeg - 90) * Math.PI / 180;
  return [cx + r * Math.cos(rad), cy + r * Math.sin(rad)];
}

function buildGauge(score: number, size: 'large' | 'small' = 'large'): string {
  const s = size === 'large' ? 100 : 72;
  const cx = s / 2, cy = s / 2, r = size === 'large' ? 36 : 26, sw = size === 'large' ? 8 : 6;
  const color = score >= 60 ? '#1D9E75' : score >= 35 ? '#BA7517' : '#E24B4A';
  const startDeg = 135, totalArc = 270;
  const filledEnd = startDeg + (score / 100) * totalArc;
  function arc(from: number, to: number): string {
    const [x1, y1] = polarXY(cx, cy, r, from);
    const [x2, y2] = polarXY(cx, cy, r, to);
    const large = (to - from) > 180 ? 1 : 0;
    return `M ${x1.toFixed(2)} ${y1.toFixed(2)} A ${r} ${r} 0 ${large} 1 ${x2.toFixed(2)} ${y2.toFixed(2)}`;
  }
  const fs = size === 'large' ? 22 : 15;
  return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}"><path d="${arc(startDeg, startDeg + totalArc)}" fill="none" stroke="#E5E7EB" stroke-width="${sw}" stroke-linecap="round"/>${score > 0 ? `<path d="${arc(startDeg, filledEnd)}" fill="none" stroke="${color}" stroke-width="${sw}" stroke-linecap="round"/>` : ''}
<text x="${cx}" y="${cy + fs * 0.38}" text-anchor="middle" font-size="${fs}" font-weight="600" fill="#1A1A2E" font-family="Inter,sans-serif">${score}</text></svg>`;
}

function buildRadarChart(labels: string[], datasets: Array<{ label: string; color: string; values: number[] }>): string {
  const cx = 110, cy = 110, size = 220, maxR = 76, n = labels.length;
  function pt(value: number, i: number): [number, number] {
    return polarXY(cx, cy, (value / 100) * maxR, (i / n) * 360);
  }
  let gridSvg = '';
  for (const level of [20, 40, 60, 80, 100]) {
    const pts = Array.from({ length: n }, (_, i) => { const [x, y] = polarXY(cx, cy, (level / 100) * maxR, (i / n) * 360); return `${x.toFixed(1)},${y.toFixed(1)}`; }).join(' ');
    gridSvg += `<polygon points="${pts}" fill="none" stroke="#E5E7EB" stroke-width="0.8"/>`;
  }
  let axesSvg = '';
  for (let i = 0; i < n; i++) {
    const [x, y] = polarXY(cx, cy, maxR, (i / n) * 360);
    axesSvg += `<line x1="${cx}" y1="${cy}" x2="${x.toFixed(1)}" y2="${y.toFixed(1)}" stroke="#E5E7EB" stroke-width="0.8"/>`;
  }
  let labelSvg = '';
  for (let i = 0; i < n; i++) {
    const [x, y] = polarXY(cx, cy, maxR + 16, (i / n) * 360);
    labelSvg += `<text x="${x.toFixed(1)}" y="${y.toFixed(1)}" text-anchor="middle" dominant-baseline="middle" font-size="9" fill="#5A6478" font-family="Inter,sans-serif">${labels[i]}</text>`;
  }
  let dataSvg = '';
  for (const ds of datasets) {
    const pts = ds.values.map((v, i) => { const [x, y] = pt(Math.min(v, 100), i); return `${x.toFixed(1)},${y.toFixed(1)}`; }).join(' ');
    dataSvg += `<polygon points="${pts}" fill="${ds.color}22" stroke="${ds.color}" stroke-width="1.5" opacity="0.9"/>`;
  }
  return `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}">${gridSvg}${axesSvg}${labelSvg}${dataSvg}</svg>`;
}

// Radar data
const maxKW = Math.max(seo?.keywordsTop10 || 0, ...ctItems.map((c: any) => c.keywordsTop10 || 0), 1);
const maxFollowers = Math.max(linkedin?.followers || 0, instagram?.followers || 0, ...(linkedin?.competitors || []).map((c: any) => c.followers || 0), ...(instagram?.competitors || []).map((c: any) => c.followers || 0), 1);
const radarColors = ['#1A4B8C', '#D85A30', '#888780'];
const radarDatasets = [
  {
    label: domain, color: radarColors[0], values: [
      Math.round(((seo?.keywordsTop10 || 0) / maxKW) * 100),
      geo?.mentionRate ?? 0,
      (seo?.paidKeywordsTotal || 0) > 0 ? 80 : 20,
      Math.round((Math.max(linkedin?.followers || 0, instagram?.followers || 0) / maxFollowers) * 100),
      ps?.mobile?.performance ?? 0,
    ]
  },
  ...ctItems.slice(0, 2).map((ct: any, idx: number) => ({
    label: ct.name || ct.domain,
    color: radarColors[idx + 1],
    values: [
      Math.round(((ct.keywordsTop10 || 0) / maxKW) * 100),
      geo?.competitorMentions?.[idx]?.mentionRate ?? 0,
      (ct.paidKeywordsTotal || 0) > 0 ? 80 : 20,
      Math.round((Math.max((linkedin?.competitors || [])[idx]?.followers || 0, (instagram?.competitors || [])[idx]?.followers || 0) / maxFollowers) * 100),
      compPS?.items?.[idx]?.mobileScore ?? 0,
    ],
  })),
];
const radarSvg = buildRadarChart(['SEO', 'GEO/AI', 'Paid', 'Social', 'Web'], radarDatasets);

const psGaugeMobile = ps ? buildGauge(ps.mobile?.performance ?? 0, 'small') : '';
const psGaugeDesktop = ps ? buildGauge(ps.desktop?.performance ?? 0, 'small') : '';
const scoreSvg = buildGauge(health.total, 'large');
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PDF Report — {domain}</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Inter',sans-serif;font-size:9pt;color:#1A1A2E;background:#fff;line-height:1.4;}
    @page{size:A4 portrait;margin:15mm 18mm 12mm 18mm;}
    .page{min-height:247mm;padding-bottom:8mm;position:relative;}
    .page-break{page-break-before:always;}
    .no-break{page-break-inside:avoid;}

    .doc-header{display:flex;align-items:center;justify-content:space-between;border-bottom:1.5px solid #1A4B8C;padding-bottom:5px;margin-bottom:12px;}
    .doc-header-brand{font-size:10pt;font-weight:700;color:#1A4B8C;letter-spacing:0.04em;}
    .doc-header-meta{font-size:7.5pt;color:#5A6478;text-align:right;}
    .doc-footer{position:absolute;bottom:0;left:0;right:0;display:flex;align-items:center;justify-content:space-between;border-top:0.5px solid #E5E7EB;padding-top:4px;font-size:7pt;color:#9CA3AF;}

    h1{font-size:14pt;font-weight:700;color:#1A1A2E;margin-bottom:4px;}
    h2{font-size:11pt;font-weight:700;color:#1A1A2E;margin-bottom:4px;margin-top:12px;}
    h3{font-size:9pt;font-weight:700;color:#1A4B8C;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:6px;}
    p{font-size:8.5pt;color:#5A6478;line-height:1.5;}

    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
    .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
    .grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;}
    .flex-row{display:flex;gap:10px;align-items:flex-start;}

    .card{background:#F8F9FB;border-radius:6px;border:0.5px solid #E5E7EB;padding:10px;}
    .metric-card{background:#fff;border-radius:6px;border:0.5px solid #E5E7EB;padding:8px 10px;}
    .metric-val{font-size:18pt;font-weight:600;color:#1A4B8C;line-height:1.1;}
    .metric-lbl{font-size:7.5pt;color:#5A6478;margin-top:2px;}

    .badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:999px;font-size:7.5pt;font-weight:600;}
    .tag{display:inline-flex;align-items:center;padding:1px 6px;border-radius:3px;font-size:7.5pt;font-weight:500;}

    table{width:100%;border-collapse:collapse;font-size:8pt;}
    th{text-align:left;padding:5px 7px;font-size:7pt;text-transform:uppercase;letter-spacing:0.05em;background:#F8F9FB;color:#5A6478;border-bottom:1px solid #E5E7EB;}
    td{padding:5px 7px;border-bottom:1px solid #F0F0F0;color:#1A1A2E;vertical-align:middle;}
    tr:last-child td{border-bottom:none;}
    tr.own-row td{background:#EBF2FF;font-weight:600;color:#1A4B8C;}

    .callout{padding:8px 10px;border-radius:5px;font-size:7.5pt;line-height:1.5;}
    .callout-blue{background:#EBF2FF;border-left:2px solid #4A7FD4;color:#1A4B8C;}
    .callout-green{background:#E1F5EE;border-left:2px solid #1D9E75;color:#1D9E75;}
    .callout-amber{background:#FAEEDA;border-left:2px solid #BA7517;color:#BA7517;}
    .callout-red{background:#FCEBEB;border-left:2px solid #E24B4A;color:#E24B4A;}

    .sep{border:none;border-top:0.5px solid #E5E7EB;margin:8px 0;}
    .tech-row{display:flex;align-items:center;gap:6px;padding:5px 8px;background:#F8F9FB;border-radius:4px;border:0.5px solid #E5E7EB;font-size:7.5pt;}
    .tech-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
    .check-row{display:flex;align-items:flex-start;gap:6px;padding:5px 8px;background:#fff;border-radius:4px;border:0.5px solid #E5E7EB;}
    .plan-card{display:flex;gap:8px;align-items:flex-start;padding:8px 10px;background:#F8F9FB;border-radius:6px;border:0.5px solid #E5E7EB;}
    .plan-num{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:8pt;font-weight:700;flex-shrink:0;}

    .cover-score-row{display:flex;gap:20px;align-items:center;margin-bottom:12px;}
    .verdict-box{flex:1;}
    .section-bar{width:3px;height:14px;border-radius:2px;display:inline-block;margin-right:6px;vertical-align:middle;}
  </style>
</head>
<body>

<!-- PAGE 1 — COVER -->
<div class="page no-break">
  <div class="doc-header">
    <div class="doc-header-brand">AION Growth Studio</div>
    <div class="doc-header-meta">
      <div style="font-weight:600;color:#1A1A2E;">{domain}</div>
      <div>Digital Presence Report · {auditDate}</div>
    </div>
  </div>

  <div style="margin-bottom:14px;">
    <div style="font-size:7.5pt;font-weight:600;color:#5A6478;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:4px;">DIGITAL DIAGNOSTIC REPORT</div>
    <h1 style="font-size:16pt;">{domain}</h1>
    {sector && <span class="tag" style="background:#EBF2FF;color:#1A4B8C;margin-right:4px;">{sector}</span>}
    {btLabel && <span class="tag" style="background:#F3F4F6;color:#5A6478;">{btLabel}</span>}
  </div>

  <div class="cover-score-row no-break">
    <div style="display:flex;flex-direction:column;align-items:center;gap:4px;flex-shrink:0;">
      <div set:html={scoreSvg} />
      <div style="font-size:7pt;font-weight:600;color:#5A6478;text-align:center;">Digital Score</div>
      <span class="badge" style={`background:${heroStatus.bg};color:${heroStatus.fg};`}>{heroStatus.label}</span>
    </div>
    <div class="verdict-box">
      <div style="font-size:11pt;font-weight:700;color:#1A1A2E;margin-bottom:4px;line-height:1.3;">{scoreLabel(health.total)} — {domain}</div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-top:6px;">
        <div class="metric-card"><div class="metric-val" style="font-size:14pt;">{health.visibilidad ?? 0}</div><div class="metric-lbl">Visibility</div></div>
        <div class="metric-card"><div class="metric-val" style="font-size:14pt;">{health.competitividad ?? '—'}</div><div class="metric-lbl">Benchmark</div></div>
        <div class="metric-card"><div class="metric-val" style="font-size:14pt;">{health.experiencia ?? 0}</div><div class="metric-lbl">Experience</div></div>
        <div class="metric-card"><div class="metric-val" style="font-size:14pt;">{health.total}</div><div class="metric-lbl">Global Score</div></div>
      </div>
    </div>
  </div>

  <hr class="sep" />

  <div class="no-break">
    <h3 style="margin-bottom:8px;">Status by area</h3>
    <table>
