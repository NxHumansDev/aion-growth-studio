---
export const prerender = false;
/**
 * Public RADAR pricing page — accessible without login.
 * This is where audit → conversion CTAs land.
 * After selecting a plan, redirects to mock checkout.
 */

// Check if user came from an audit (pass auditId for linking later)
const auditId = Astro.url.searchParams.get('audit') || '';
const email = Astro.url.searchParams.get('email') || '';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AION Radar — Monitoriza tu presencia digital</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <style>
    * { box-sizing: border-box; margin: 0; }
    body { font-family: 'Inter', sans-serif; background: #f7f9ff; color: #1a1a2e; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; vertical-align: middle; }
  </style>
</head>
<body>

  <!-- Nav -->
  <nav style="background:white;border-bottom:1px solid #e2e8f0;padding:0 32px;height:64px;display:flex;align-items:center;justify-content:space-between;">
    <a href="/es/" style="display:inline-flex;align-items:center;text-decoration:none;height:3rem;overflow:hidden;">
      <img src="/images/aion-logo-full.png" alt="AION Growth Studio" style="height:6rem;width:auto;" />
    </a>
    <a href="/login" style="font-size:13px;color:#1A4B8C;font-weight:600;text-decoration:none;">Acceder</a>
  </nav>

  <!-- Hero -->
  <section style="background:linear-gradient(135deg, #000e41 0%, #001f70 100%);color:white;padding:80px 32px 60px;text-align:center;">
    <div style="max-width:700px;margin:0 auto;">
      <div style="display:inline-flex;align-items:center;gap:8px;background:rgba(105,255,135,0.15);padding:6px 16px;border-radius:999px;margin-bottom:24px;">
        <span class="material-symbols-outlined" style="font-size:18px;color:#69ff87;">radar</span>
        <span style="font-size:12px;font-weight:700;color:#69ff87;text-transform:uppercase;letter-spacing:0.08em;">AION Radar</span>
      </div>
      <h1 style="font-size:40px;font-weight:900;letter-spacing:-0.04em;line-height:1.15;margin-bottom:16px;">
        Tu web, monitorizada<br/>cada semana. <span style="color:#69ff87;">Automáticamente.</span>
      </h1>
      <p style="font-size:17px;color:#94a3b8;line-height:1.6;max-width:550px;margin:0 auto;">
        Radar analiza tu presencia digital, detecta cambios, compara con tus competidores y te dice exactamente qué hacer. Cada semana.
      </p>
    </div>
  </section>

  <!-- Pricing -->
  <section style="max-width:1000px;margin:-40px auto 0;padding:0 24px 60px;position:relative;z-index:1;">
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">

      <!-- Radar -->
      <div style="background:white;border-radius:16px;padding:32px;box-shadow:0 4px 24px rgba(0,0,0,0.08);display:flex;flex-direction:column;">
        <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;background:#d6e3ff;color:#1a4b8c;font-size:13px;font-weight:700;width:fit-content;margin-bottom:20px;">
          <span class="material-symbols-outlined" style="font-size:16px;">radar</span>
          Radar
        </div>
        <p style="font-size:42px;font-weight:900;letter-spacing:-0.04em;">49€<span style="font-size:14px;font-weight:400;color:#94a3b8;">/mes</span></p>
        <p style="font-size:13px;color:#64748b;margin:8px 0 24px;">Para empresas que quieren entender su presencia digital</p>
        <div style="flex:1;display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
          {['Resumen semanal automatizado', 'Score global + 6 pilares', 'Evolución temporal (sparklines)', 'Comparativa con 3 competidores', 'Recomendaciones semanales IA', 'Plan estratégico con seguimiento'].map(f => (
            <div style="display:flex;align-items:flex-start;gap:8px;">
              <span class="material-symbols-outlined" style="font-size:16px;color:#1D9E75;flex-shrink:0;margin-top:1px;">check</span>
              <span style="font-size:13px;color:#434750;">{f}</span>
            </div>
          ))}
        </div>
        <a href={`/es/radar/checkout?plan=radar&audit=${auditId}&email=${email}`}
          style="display:block;text-align:center;padding:14px;background:#1A4B8C;color:white;border-radius:10px;font-size:15px;font-weight:700;text-decoration:none;transition:background 0.15s;"
          onmouseover="this.style.background='#0e3a6e'" onmouseout="this.style.background='#1A4B8C'">
          Empezar con Radar
        </a>
      </div>

      <!-- Señales (próximamente) -->
      <div style="background:white;border-radius:16px;padding:32px;box-shadow:0 4px 24px rgba(0,0,0,0.08);position:relative;display:flex;flex-direction:column;">
        <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;background:#d6e3ff;color:#205db0;font-size:13px;font-weight:700;width:fit-content;margin-bottom:20px;">
          <span class="material-symbols-outlined" style="font-size:16px;">bolt</span>
          Señales
        </div>
        <p style="font-size:42px;font-weight:900;letter-spacing:-0.04em;">149€<span style="font-size:14px;font-weight:400;color:#94a3b8;">/mes</span></p>
        <p style="font-size:13px;color:#64748b;margin:8px 0 24px;">Para empresas que quieren actuar con datos</p>
        <div style="flex:1;display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
          {['Todo lo de Radar', 'Alertas en tiempo real', 'SEO Oportunidades (keyword gap)', 'Paid Intelligence', 'Briefs de contenido IA', 'Historial de evolución detallado'].map(f => (
            <div style="display:flex;align-items:flex-start;gap:8px;">
              <span class="material-symbols-outlined" style="font-size:16px;color:#1D9E75;flex-shrink:0;margin-top:1px;">check</span>
              <span style="font-size:13px;color:#434750;">{f}</span>
            </div>
          ))}
        </div>
        <div style="background:#f0f4ff;border-radius:8px;padding:10px;text-align:center;font-size:11px;color:#64748b;margin-bottom:12px;">Próximamente</div>
        <button disabled style="display:block;width:100%;text-align:center;padding:14px;background:#94a3b8;color:white;border-radius:10px;font-size:15px;font-weight:700;border:none;cursor:not-allowed;opacity:0.6;">
          Disponible pronto
        </button>
      </div>

      <!-- Palancas -->
      <div style="background:white;border-radius:16px;padding:32px;box-shadow:0 4px 24px rgba(0,0,0,0.08);display:flex;flex-direction:column;">
        <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:999px;background:#ede9fe;color:#7c3aed;font-size:13px;font-weight:700;width:fit-content;margin-bottom:20px;">
          <span class="material-symbols-outlined" style="font-size:16px;">rocket_launch</span>
          Palancas
        </div>
        <p style="font-size:42px;font-weight:900;letter-spacing:-0.04em;">349€<span style="font-size:14px;font-weight:400;color:#94a3b8;">/mes</span></p>
        <p style="font-size:13px;color:#64748b;margin:8px 0 24px;">Para empresas que quieren ejecución asistida</p>
        <div style="flex:1;display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
          {['Todo lo de Señales', 'Optimización técnica avanzada', 'Generador de contenido IA', 'Schema Markup automático', 'Advisor IA personalizado 24/7', 'SLA de respuesta prioritario'].map(f => (
            <div style="display:flex;align-items:flex-start;gap:8px;">
              <span class="material-symbols-outlined" style="font-size:16px;color:#1D9E75;flex-shrink:0;margin-top:1px;">check</span>
              <span style="font-size:13px;color:#434750;">{f}</span>
            </div>
          ))}
        </div>
        <div style="background:#f0f4ff;border-radius:8px;padding:10px;text-align:center;font-size:11px;color:#64748b;margin-bottom:12px;">Próximamente</div>
        <button disabled style="display:block;width:100%;text-align:center;padding:14px;background:#94a3b8;color:white;border-radius:10px;font-size:15px;font-weight:700;border:none;cursor:not-allowed;opacity:0.6;">
          Disponible pronto
        </button>
      </div>
    </div>

    <!-- Trust signals -->
    <div style="text-align:center;margin-top:40px;display:flex;justify-content:center;gap:32px;color:#94a3b8;font-size:13px;">
      <span style="display:flex;align-items:center;gap:6px;"><span class="material-symbols-outlined" style="font-size:16px;">lock</span> Pago seguro</span>
      <span style="display:flex;align-items:center;gap:6px;"><span class="material-symbols-outlined" style="font-size:16px;">block</span> Sin permanencia</span>
      <span style="display:flex;align-items:center;gap:6px;"><span class="material-symbols-outlined" style="font-size:16px;">schedule</span> Cancela cuando quieras</span>
    </div>
  </section>

</body>
</html>
