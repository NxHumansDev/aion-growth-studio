---
import Layout from '../../layouts/Layout.astro';

const lang = 'es';
---

<Layout title="Diagnóstico Gratuito de Visibilidad Digital — AION" description="Analiza gratis tu presencia digital en 2 minutos. Obtén un informe completo con score, visibilidad en IA y oportunidades de crecimiento." lang={lang}>
  <div class="diag-bg min-h-screen relative flex flex-col">
    <div class="absolute inset-0 diag-dots pointer-events-none"></div>

    <!-- Header -->
    <nav class="relative z-10 flex items-center justify-between px-6 md:px-12 py-5">
      <a href="/es/">
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" class="h-10 md:h-12 w-auto" />
      </a>
      <div class="flex items-center gap-2">
        <a href="/es/diagnostico" class="text-sm font-medium text-white">ES</a>
        <span class="text-white/40 text-sm">|</span>
        <a href="/en/diagnostic" class="text-sm font-medium text-white/60 hover:text-white transition-colors">EN</a>
      </div>
    </nav>

    <!-- Steps indicator -->
    <div class="relative z-10 flex justify-center pt-4 pb-2">
      <div class="flex items-center gap-2">
        <div id="step-dot-1" class="step-dot active"></div>
        <div class="w-8 h-px bg-white/20"></div>
        <div id="step-dot-3" class="step-dot"></div>
      </div>
    </div>

    <!-- Card container -->
    <div class="relative z-10 flex-1 flex items-start justify-center px-4 py-6 md:py-10">
      <div class="w-full max-w-md">

        <!-- STEP 1: URL + Nombre + Email -->
        <div id="step-1" class="step-card bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 md:p-10 shadow-2xl">
          <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-cyan-500/10 border border-cyan-400/20 rounded-full text-cyan-300 text-xs font-medium mb-4">
              <span class="w-2 h-2 bg-cyan-400 rounded-full"></span>
              Gratuito · Sin registro · 2 minutos
            </div>
            <h1 class="text-2xl md:text-3xl font-bold text-white mb-3">Analiza tu visibilidad digital</h1>
            <p class="text-sm text-slate-300 leading-relaxed">Obtén un informe completo con score, rendimiento web, visibilidad en IA y oportunidades reales de crecimiento.</p>
          </div>

          <div class="space-y-4">
            <div>
              <label for="url" class="block text-xs font-medium text-slate-300 mb-1.5">Tu web *</label>
              <input type="text" id="url" name="url" required placeholder="miempresa.com"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-all" />
            </div>
            <div>
              <label for="name" class="block text-xs font-medium text-slate-300 mb-1.5">Tu nombre *</label>
              <input type="text" id="name" name="name" required placeholder="María García"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-all" />
            </div>
            <div>
              <label for="email" class="block text-xs font-medium text-slate-300 mb-1.5">Tu email *</label>
              <input type="email" id="email" name="email" required placeholder="maria@miempresa.com"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-all" />
            </div>
            <button id="btn-step1" type="button"
              class="w-full py-3 bg-white text-[#0B1B3D] font-semibold text-sm rounded-xl hover:bg-cyan-300 hover:scale-[1.02] transition-all duration-300 shadow-lg">
              Analizar mi web →
            </button>
          </div>

          <div id="error-step1" class="hidden mt-4 p-4 bg-red-500/10 border border-red-400/20 rounded-xl text-sm text-red-300 text-center"></div>

          <p class="text-center text-xs text-slate-500 mt-5">
            Al continuar aceptas nuestra <a href="/es/" class="underline hover:text-slate-300">política de privacidad</a>
          </p>
        </div>

        <!-- STEP 3: Selección de competidores -->
        <div id="step-3" class="step-card hidden bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl p-8 md:p-10 shadow-2xl">
          <div class="text-center mb-6">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-400/20 rounded-full text-emerald-300 text-xs font-medium mb-4">
              <span>✅</span>
              Competidores detectados
            </div>
            <h2 class="text-xl md:text-2xl font-bold text-white mb-2">¿Con quién quieres compararte?</h2>
            <p class="text-sm text-slate-300">Selecciona los que consideras competencia directa. Puedes saltarte este paso.</p>
          </div>

          <!-- Detected competitors -->
          <div id="competitor-list" class="space-y-2 mb-5"></div>

          <!-- Manual competitors -->
          <div class="mb-5">
            <label class="block text-xs font-medium text-slate-300 mb-1.5">O añade competidores manualmente</label>
            <div class="flex gap-2">
              <input type="text" id="manual-competitor-input" placeholder="competidor.com"
                class="flex-1 px-4 py-3 bg-white/5 border border-white/10 rounded-xl text-sm text-white placeholder-slate-500 outline-none focus:border-cyan-400/50 focus:bg-white/10 transition-all" />
              <button id="btn-add-competitor" type="button"
                class="px-4 py-3 bg-white/10 border border-white/20 text-white font-medium text-sm rounded-xl hover:bg-white/20 transition-all shrink-0">
                + Añadir
              </button>
            </div>
            <div id="manual-competitors-list" class="flex flex-wrap gap-2 mt-2"></div>
          </div>

          <div class="flex gap-3">
            <button id="btn-skip-step3" type="button"
              class="flex-1 py-3 border border-white/20 text-white/70 font-medium text-sm rounded-xl hover:bg-white/5 transition-all">
              Omitir comparativa
            </button>
            <button id="btn-start-audit" type="button"
              class="flex-1 py-3 bg-white text-[#0B1B3D] font-semibold text-sm rounded-xl hover:bg-cyan-300 transition-all duration-300 shadow-lg">
              Iniciar análisis →
            </button>
          </div>

          <div id="error-step3" class="hidden mt-4 p-4 bg-red-500/10 border border-red-400/20 rounded-xl text-sm text-red-300 text-center"></div>
        </div>

      </div>
    </div>

    <!-- Footer -->
    <div class="relative z-10 text-center py-6 text-xs text-slate-500">
      <a href="/es/" class="hover:text-slate-300 transition-colors">AION Growth Studio</a>
      <span class="mx-2">·</span>
      <a href="mailto:hola@aiongrowth.studio" class="hover:text-slate-300 transition-colors">hola@aiongrowth.studio</a>
    </div>
  </div>
</Layout>

<style>
  .diag-bg {
    background: linear-gradient(160deg, #0B1B3D 0%, #1A5490 50%, #0B1B3D 100%);
  }
  .diag-dots {
    background-image: radial-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 32px 32px;
  }
  .step-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    transition: all 0.3s;
  }
  .step-dot.active {
    background: #22d3ee;
    box-shadow: 0 0 8px #22d3ee88;
  }
  .step-dot.done {
    background: #10b981;
  }
  .bg-white\/3 { background-color: rgba(255,255,255,0.03); }
  .competitor-card {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 12px;
    border-radius: 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    cursor: pointer;
    transition: all 0.2s;
  }
  .competitor-card:hover { background: rgba(255,255,255,0.07); }
  .competitor-card.selected {
    background: rgba(34,211,238,0.08);
    border-color: rgba(34,211,238,0.4);
  }
</style>

<script>
  // State
  let userData: { url: string; name: string; email: string } = { url: '', name: '', email: '' };
  let competitorsPromise: Promise<any> | null = null;
  let competitorsResult: any = null;
  let selectedCompetitors: string[] = [];
  let manualCompetitors: string[] = [];

  function renderManualCompetitors() {
    const list = document.getElementById('manual-competitors-list');
    if (!list) return;
    list.innerHTML = manualCompetitors.map(url => `
      <div class="flex items-center gap-1.5 px-3 py-1.5 bg-white/10 border border-white/15 rounded-lg">
        <span class="text-xs text-slate-200 truncate max-w-[160px]">${url}</span>
        <button onclick="removeManualCompetitor('${url}')" class="text-slate-400 hover:text-white text-sm leading-none ml-1 shrink-0">×</button>
      </div>
    `).join('');
  }

  (window as any).removeManualCompetitor = function(url: string) {
    manualCompetitors = manualCompetitors.filter(u => u !== url);
    renderManualCompetitors();
  };

  function addManualCompetitor() {
    const input = document.getElementById('manual-competitor-input') as HTMLInputElement;
    const val = input.value.trim().replace(/^https?:\/\//, '').replace(/\/$/, '');
    if (!val || manualCompetitors.includes(val)) { input.value = ''; return; }
    manualCompetitors.push(val);
    renderManualCompetitors();
    input.value = '';
  }

  document.getElementById('btn-add-competitor')?.addEventListener('click', addManualCompetitor);
  document.getElementById('manual-competitor-input')?.addEventListener('keydown', (e: any) => {
    if (e.key === 'Enter') { e.preventDefault(); addManualCompetitor(); }
  });

  // UI helpers
  function showStep(n: number) {
    [1, 3].forEach(i => {
      const el = document.getElementById(`step-${i}`);
      if (el) el.classList.toggle('hidden', i !== n);
      const dot = document.getElementById(`step-dot-${i}`);
      if (dot) {
        dot.classList.remove('active', 'done');
        if (i < n) dot.classList.add('done');
        else if (i === n) dot.classList.add('active');
      }
    });
  }

  function showError(id: string, msg: string) {
    const el = document.getElementById(id);
    if (el) { el.textContent = msg; el.classList.remove('hidden'); }
  }

  function hideError(id: string) {
    const el = document.getElementById(id);
    if (el) el.classList.add('hidden');
  }

  function setBtn(id: string, text: string, disabled: boolean) {
    const btn = document.getElementById(id) as HTMLButtonElement;
    if (btn) { btn.textContent = text; btn.disabled = disabled; }
  }

  // STEP 1: Validate + go to step 3 (competitors, skip social step)
  document.getElementById('btn-step1')?.addEventListener('click', async () => {
    hideError('error-step1');

    const url = (document.getElementById('url') as HTMLInputElement).value.trim();
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();

    if (!url) return showError('error-step1', 'Introduce la URL de tu web.');
    if (!name) return showError('error-step1', 'Introduce tu nombre.');
    if (!email || !email.includes('@')) return showError('error-step1', 'Introduce un email válido.');

    userData = { url, name, email };

    // Show loading state in competitor list
    const listEl = document.getElementById('competitor-list');
    if (listEl) listEl.innerHTML = `<p class="text-xs text-slate-400 text-center py-2 animate-pulse">⏳ Buscando competidores…</p>`;

    // Start competitor detection in background
    competitorsResult = null;
    competitorsPromise = fetch('/api/audit/find-competitors', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url }),
    })
      .then(r => r.json())
      .then(data => {
        competitorsResult = data;
        renderStep3();
        return data;
      })
      .catch(() => {
        competitorsResult = { competitors: [] };
        renderStep3();
      });

    showStep(3);
  });

  function renderStep3() {
    const competitors = competitorsResult?.competitors || [];
    const listEl = document.getElementById('competitor-list');
    selectedCompetitors = [];

    if (listEl) {
      if (competitors.length === 0) {
        listEl.innerHTML = `<p class="text-xs text-slate-400 text-center py-2">No se detectaron competidores automáticamente. Puedes añadir uno manualmente abajo.</p>`;
      } else {
        listEl.innerHTML = competitors.map((c: any, i: number) => `
          <div class="competitor-card" data-url="${c.url}" data-idx="${i}" onclick="toggleCompetitor(this)">
            <div class="w-5 h-5 rounded border border-white/30 flex items-center justify-center shrink-0 mt-0.5 check-icon">
              <span class="hidden text-cyan-400 text-xs">✓</span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-white truncate">${c.name}</p>
              <p class="text-xs text-slate-400 truncate">${c.url}</p>
              ${c.why ? `<p class="text-xs text-slate-500 mt-0.5 italic">${c.why}</p>` : ''}
            </div>
          </div>
        `).join('');
      }
    }

    showStep(3);
  }

  (window as any).toggleCompetitor = function(el: HTMLElement) {
    const url = el.getAttribute('data-url') || '';
    const check = el.querySelector('.check-icon span') as HTMLElement;
    const isSelected = el.classList.contains('selected');

    if (isSelected) {
      el.classList.remove('selected');
      if (check) check.classList.add('hidden');
      selectedCompetitors = selectedCompetitors.filter(u => u !== url);
    } else {
      el.classList.add('selected');
      if (check) check.classList.remove('hidden');
      if (!selectedCompetitors.includes(url)) selectedCompetitors.push(url);
    }
  };

  // STEP 3: Start audit
  async function startAudit(withCompetitors: boolean) {
    hideError('error-step3');
    setBtn('btn-start-audit', 'Iniciando…', true);
    setBtn('btn-skip-step3', '…', true);

    const allCompetitors = withCompetitors
      ? [...selectedCompetitors, ...manualCompetitors]
      : [];

    try {
      const res = await fetch('/api/audit/start', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          url: userData.url,
          email: userData.email,
          name: userData.name,
          selectedCompetitors: allCompetitors,
        }),
      });

      const result = await res.json();

      if (res.ok && result.audit_id) {
        window.location.href = `/es/audit/${result.audit_id}`;
      } else {
        showError('error-step3', result.error || 'Ha ocurrido un error. Por favor, inténtalo de nuevo.');
        setBtn('btn-start-audit', 'Iniciar análisis →', false);
        setBtn('btn-skip-step3', 'Omitir comparativa', false);
      }
    } catch {
      showError('error-step3', 'Error de conexión. Por favor, inténtalo de nuevo.');
      setBtn('btn-start-audit', 'Iniciar análisis →', false);
      setBtn('btn-skip-step3', 'Omitir comparativa', false);
    }
  }

  document.getElementById('btn-start-audit')?.addEventListener('click', () => startAudit(true));
  document.getElementById('btn-skip-step3')?.addEventListener('click', () => startAudit(false));
</script>
