  <!-- END .layout -->

  <script define:vars={{ scoreTotal: health.total }}>
    const counter = document.getElementById('score-counter');
    const ring = document.getElementById('score-ring');
    if (counter && scoreTotal > 0) {
      const duration = 1400;
      const start = performance.now();
      const animate = (now) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * scoreTotal);
        counter.textContent = current;
        if (ring) ring.setAttribute('stroke-dasharray', eased * scoreTotal + ', 100');
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
    }
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

    // Nav active state tracking
    const navLinks = document.querySelectorAll('#report-nav a[data-section]');
    const sections = ['hero', 'seo', 'ia', 'autoridad', 'competidores', 'experiencia', 'plan'];
    const sectionEls = sections.map(id => document.getElementById(id)).filter(Boolean);

    const visGroup = new Set(['seo', 'ia', 'autoridad']);

    let currentActive = 'hero';
    function setActive(sectionId) {
      if (sectionId === currentActive) return;
      currentActive = sectionId;
      navLinks.forEach(link => {
        const linkSection = link.getAttribute('data-section');
        link.classList.toggle('nav-active', linkSection === sectionId || (visGroup.has(sectionId) && linkSection === 'seo' && link.getAttribute('href') === '#seo'));
      });
    }

    const navObs = new IntersectionObserver((entries) => {
      let topmost = null;
      let topmostTop = Infinity;
      entries.forEach(e => {
        if (e.isIntersecting && e.boundingClientRect.top < topmostTop) {
          topmostTop = e.boundingClientRect.top;
          topmost = e.target.id;
        }
      });
      if (topmost) setActive(topmost);
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    sectionEls.forEach(el => navObs.observe(el));

    // ── Mobile carousel pagination ──────────────────────────────────
    if (window.innerWidth <= 768) {
      const report = document.querySelector('.report');
      const pages = report ? report.querySelectorAll(':scope > .carousel-page') : [];
      const dotsContainer = document.getElementById('carousel-dots');

      if (report && pages.length > 0 && dotsContainer) {
        // Create dots (clickable to navigate)
        pages.forEach(function(page, i) {
          var dot = document.createElement('div');
          dot.className = 'dot' + (i === 0 ? ' active' : '');
          dot.addEventListener('click', function() {
            page.scrollIntoView({ behavior:'smooth', inline:'start', block:'nearest' });
          });
          dotsContainer.appendChild(dot);
        });

        // Update dots on scroll
        var dots = dotsContainer.querySelectorAll('.dot');
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var idx = Array.from(pages).indexOf(entry.target);
              dots.forEach(function(d, i) {
                d.classList.toggle('active', i === idx);
              });
            }
          });
        }, { root: report, threshold: 0.5 });

        pages.forEach(function(page) { observer.observe(page); });

        // Make reveal elements visible immediately on mobile (no scroll-trigger)
        document.querySelectorAll('.carousel-page .reveal').forEach(function(el) {
          el.classList.add('visible');
        });
      }
    }
  </script>

  <!-- Mobile pagination dots -->
  <nav class="mobile-dots mobile-only" id="carousel-dots"></nav>
</body>
</html>
