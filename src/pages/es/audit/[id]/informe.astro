              <p style="font-size:0.9rem;color:#334155;line-height:1.65;margin:0 0 0.875rem;">{init.description}</p>
              <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                <span style={`font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:${impactTags[0].bg};color:${impactTags[0].color};border:1px solid ${impactTags[0].color}40;`}>Impacto {impactTags[0].label}</span>
                <span style="font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;">Plazo {i === 0 ? '1-2 meses' : i === 1 ? '2-4 meses' : '3-6 meses'}</span>
              </div>
            </div>
          );
        })
      ) : (
        fallbackInitiatives.map((item, i) => (
          <div class="initiative-card">
            <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.75rem;">
              <span class="initiative-num">{i + 1}</span>
              <h3 style="margin:0;font-size:1rem;">Mejorar: {item.label} ({item.score}/100)</h3>
            </div>
            <p style="font-size:0.75rem;color:#64748b;margin:0 0 0.5rem;">
              {item.key === 'conversion' ? `Tu funnel score es ${item.score}/100. Cada visita que no convierte es un lead perdido.`
                : item.key === 'visibilidad' ? `Tu score de visibilidad es ${item.score}/100. Estás dejando demanda orgánica a la competencia.`
                : item.key === 'competitividad' ? `Tu posición competitiva es ${item.score}/100. Los competidores superan tus métricas clave.`
                : `Tu score de experiencia es ${item.score}/100. El rendimiento técnico afecta conversión directamente.`}
            </p>
            <p style="font-size:0.9rem;color:#334155;line-height:1.65;margin:0 0 0.875rem;">{item.action}</p>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
              <span style={`font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:${item.score < 40 ? '#fef2f2' : '#fffbeb'};color:${item.score < 40 ? '#dc2626' : '#d97706'};border:1px solid ${item.score < 40 ? '#fca5a580' : '#fde68a80'};`}>Impacto {item.score < 40 ? '🟢 Alto' : '🟡 Medio'}</span>
              <span style="font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:#f1f5f9;color:#475569;border:1px solid #e2e8f0;">Plazo {i === 0 ? '1-2 meses' : '2-4 meses'}</span>
            </div>
          </div>
        ))
      )}

      {insights.bullets?.length > 0 && (
        <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #f1f5f9;">
          <h3 style="margin-bottom:0.75rem;">Hallazgos clave del diagnóstico</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            {insights.bullets.map((b: string) => (
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.9rem;color:#334155;line-height:1.6;">
                <span style="color:#1A4B8C;font-weight:700;margin-top:0.1rem;flex-shrink:0;">→</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- ── CTA PERSONALIZADO ─────────────────────────────────────── -->
    <div class="no-print" style="padding:3.5rem 2.5rem;background:linear-gradient(135deg,#0B1B3D 0%,#1A4B8C 60%,#0e7490 100%);text-align:center;color:#fff;">
      <p style="font-size:0.7rem;font-weight:600;color:#67e8f9;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 1rem;">Siguiente paso</p>
      {trafficGap > 500 ? (
        <h2 class="num" style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;line-height:1.2;">
          Tu competencia genera ~{fmt(trafficGap)} visitas/mes más que tú.
        </h2>
      ) : (
        <h2 class="num" style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;line-height:1.2;">
          Este diagnóstico es una foto de hoy.
        </h2>
      )}
      <p style="font-size:1rem;color:rgba(255,255,255,0.75);max-width:520px;margin:0 auto 2rem;line-height:1.6;">
        Podemos ayudarte a {btObjective} con un plan de acción concreto. Sin humo.
      </p>
      <!-- Dos CTAs -->
      <div style="display:flex;align-items:stretch;justify-content:center;gap:1rem;flex-wrap:wrap;max-width:640px;margin:0 auto;">
        <!-- CTA 1: Radar plan -->
        <div style="flex:1;min-width:240px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);border-radius:1rem;padding:1.25rem 1.5rem;text-align:left;">
          <p style="font-size:0.65rem;font-weight:700;color:#67e8f9;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.375rem;">Plan Radar</p>
          <p style="font-size:1.1rem;font-weight:700;color:#fff;margin:0 0 0.5rem;line-height:1.3;">Informe mensual de evolución</p>
          <p style="font-size:0.8rem;color:rgba(255,255,255,0.65);margin:0 0 1rem;line-height:1.5;">GA4 real, benchmark competitivo actualizado, tendencias y deck ejecutivo mensual.</p>
          <a
            href="mailto:hola@aiongrowth.studio?subject=Plan Radar — {domain}"
            style="display:inline-flex;align-items:center;gap:0.375rem;background:#1A4B8C;color:#fff;font-weight:700;font-size:0.85rem;padding:0.625rem 1.25rem;border-radius:0.625rem;text-decoration:none;"
          >
            Ver plan Radar →
          </a>
        </div>
        <!-- CTA 2: Growth Advisor -->
        <div style="flex:1;min-width:240px;background:#fff;border-radius:1rem;padding:1.25rem 1.5rem;text-align:left;">
          <p style="font-size:0.65rem;font-weight:700;color:#1A4B8C;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.375rem;">Growth Advisor</p>
          <p style="font-size:1.1rem;font-weight:700;color:#0B1B3D;margin:0 0 0.5rem;line-height:1.3;">Sesión gratuita de revisión</p>
          <p style="font-size:0.8rem;color:#475569;margin:0 0 1rem;line-height:1.5;">15 minutos para revisar tu diagnóstico, resolver dudas y explorar cómo avanzar.</p>
          <a
            href="mailto:hola@aiongrowth.studio?subject=Sesión Growth Advisor — {domain}"
            style="display:inline-flex;align-items:center;gap:0.375rem;background:#0B1B3D;color:#fff;font-weight:700;font-size:0.85rem;padding:0.625rem 1.25rem;border-radius:0.625rem;text-decoration:none;"
          >
            Hablar con un advisor →
          </a>
        </div>
      </div>
      <p style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin:1.5rem 0 0;">Sin compromiso · Respuesta en menos de 24h</p>
    </div>

    <!-- ── FOOTER ──────────────────────────────────────────────────── -->
    <div style="padding:1.5rem 2.5rem;background:#0B1B3D;color:#94a3b8;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
      <div>
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:32px;filter:brightness(0) invert(1);margin-bottom:0.25rem;display:block;" />
        <p style="font-size:0.7rem;margin:0;">Diagnóstico generado el {auditDate} · aiongrowth.studio</p>
      </div>
      <div style="text-align:right;">
        <p style="font-size:0.75rem;margin:0 0 0.25rem;">hola@aiongrowth.studio</p>
      </div>
    </div>
  </div>
</body>
</html>
