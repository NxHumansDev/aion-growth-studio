              </div>
              <div style="font-size:2rem;font-weight:900;color:#e2e0fc;letter-spacing:-0.02em;">{health.visibilidad ?? 0}<span style="font-size:0.82rem;font-weight:500;color:#8d909b;">/100</span></div>
              <div style="height:4px;background:rgba(141,144,155,0.15);border-radius:4px;overflow:hidden;">
                <div style={`height:100%;width:${health.visibilidad ?? 0}%;background:linear-gradient(90deg,#69FF87,#5dd1a4);border-radius:4px;`}></div>
              </div>
              <div style="display:flex;justify-content:space-between;font-size:0.65rem;color:#8d909b;">
                <span>SEO: {visSeoSub}</span>
                <span>GEO: {visGeoSub}</span>
