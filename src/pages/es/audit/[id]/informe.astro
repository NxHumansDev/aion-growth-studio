                <span style="font-size:0.78rem;font-weight:600;color:#e2e0fc;">Apariciones en prensa</span>
              </div>
              <div style="font-size:1.5rem;font-weight:900;color:#e2e0fc;margin-bottom:4px;">{newsCountEs > 0 ? newsCountEs : '—'}</div>
              {newsCountEs > 0 ? (
                <div style="font-size:0.82rem;color:#c3c6d2;">
                  Menciones en Google News en los ultimos 3 meses.
                  {newsCountEs >= 5 ? ' Buena cobertura.' : newsCountEs >= 2 ? ' Cobertura moderada.' : ' Cobertura baja.'}
                </div>
              ) : (
                <div style="font-size:0.82rem;color:#8d909b;">Sin cobertura detectada en Google News.</div>
              )}
            </div>
          </div>

          <!-- Reviews -->
          {ratingSources.length > 0 && (
            <div class="surface-card" style="margin-bottom:1.5rem;">
              <div style="display:flex;align-items:center;gap:20px;margin-bottom:12px;flex-wrap:wrap;">
                <div>
                  <div style={`font-size:2.5rem;font-weight:900;color:${(repRaw.combinedRating ?? 0) >= 4.0 ? '#69FF87' : (repRaw.combinedRating ?? 0) >= 3.0 ? '#ffb4ab' : '#ffb4ab'};line-height:1;letter-spacing:-0.02em;`}>{repRaw.combinedRating ?? '—'}</div>
                  <div style="font-size:0.65rem;color:#8d909b;">/5 ponderado</div>
                </div>
                <div style="flex:1;min-width:200px;">
                  <div style="font-size:0.82rem;font-weight:700;color:#e2e0fc;margin-bottom:6px;">Reputacion online ({fmt(repRaw.totalReviews ?? 0)} resenas)</div>
                  <div style="display:flex;flex-wrap:wrap;gap:8px;">
                    {ratingSources.map((src: any) => (
                      <div style="display:flex;align-items:center;gap:6px;background:rgba(51,51,72,0.5);border-radius:8px;padding:5px 12px;">
                        <span style="font-size:0.75rem;font-weight:700;color:#e2e0fc;">{src.name}</span>
                        <span style={`font-size:0.75rem;font-weight:800;color:${src.rating >= 4.0 ? '#69FF87' : src.rating >= 3.0 ? '#ffb4ab' : '#ffb4ab'};`}>{src.rating}</span>
                        <span style="font-size:0.65rem;color:#8d909b;">({fmt(src.reviews)})</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
              <div style="font-size:0.78rem;color:#c3c6d2;line-height:1.5;">
                {(repRaw.combinedRating ?? 0) >= 4.2 ? 'Excelente reputacion online. Las valoraciones refuerzan la confianza de nuevos clientes.' : (repRaw.combinedRating ?? 0) >= 3.5 ? 'Buena reputacion con margen de mejora.' : 'Reputacion que necesita atencion.'}
              </div>
            </div>
          )}

          <!-- Social -->
          <div class="grid-2" style="margin-bottom:1.5rem;">
            <div class="glass-card" style={(linkedin?.followers ?? 0) > 0 ? 'border-left:3px solid #0077B5;' : ''}>
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                <span class="material-symbols-outlined" style="color:#0077B5;">group</span>
                <span style="font-size:0.72rem;color:#8d909b;">LinkedIn</span>
              </div>
              <div style="font-size:1.5rem;font-weight:900;color:#e2e0fc;">{(linkedin?.followers ?? 0) > 0 ? fmt(linkedin?.followers) : '—'}</div>
              {(linkedin?.followers ?? 0) > 0 ? (
                <div>
                  {linkedin?.employees && (
                    <div style="font-size:0.82rem;color:#c3c6d2;margin-top:4px;">{fmt(linkedin.employees)} empleados</div>
                  )}
                  <div style="font-size:0.72rem;color:#8d909b;margin-top:4px;">
                    {isB2B ? 'Canal principal de autoridad profesional en B2B.' : 'Presencia profesional activa.'}
                  </div>
                </div>
              ) : (
                <div style="font-size:0.72rem;color:#8d909b;margin-top:4px;">No se ha detectado perfil de empresa.</div>
