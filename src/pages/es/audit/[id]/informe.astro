              <hr class="section-divider" />
              <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">PageSpeed</div>
              <div class="callout callout-blue" style="margin-bottom:14px;font-size:12px;">
                <strong>¿Qué es PageSpeed?</strong> Google mide la velocidad de tu web en móvil y escritorio. Un score bajo (rojo) penaliza tu posición en buscadores y hace que los usuarios abandonen antes de ver tu propuesta de valor. El score ideal es <strong>70+</strong>. Los factores más importantes son el tiempo de carga de la imagen principal (LCP), la estabilidad visual (CLS) y la interactividad (FCP).
              </div>
              <div class="grid-2" style="max-width:400px;">
                <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
                  <div set:html={psGaugeMobile} />
                  <div style="font-size:12px;color:#5A6478;font-weight:600;">Móvil</div>
                  <span class="status-badge" style={`background:${statusStyle(ss(ps.mobile?.performance??0)).bg};color:${statusStyle(ss(ps.mobile?.performance??0)).fg};font-size:10px;`}>
                    {statusStyle(ss(ps.mobile?.performance??0)).label}
                  </span>
                </div>
                <div style="display:flex;flex-direction:column;align-items:center;gap:6px;">
                  <div set:html={psGaugeDesktop} />
                  <div style="font-size:12px;color:#5A6478;font-weight:600;">Escritorio</div>
                  <span class="status-badge" style={`background:${statusStyle(ss(ps.desktop?.performance??0)).bg};color:${statusStyle(ss(ps.desktop?.performance??0)).fg};font-size:10px;`}>
                    {statusStyle(ss(ps.desktop?.performance??0)).label}
                  </span>
                </div>
              </div>

              <!-- Core Web Vitals -->
              {(ps.mobile?.lcp != null || ps.mobile?.cls != null || ps.mobile?.fcp != null) && (
                <div style="margin-top:14px;">
                  <div style="font-size:0.72rem;font-weight:600;color:#5A6478;margin-bottom:8px;">Core Web Vitals (Móvil)</div>
                  <div class="grid-3" style="max-width:480px;">
                    {ps.mobile?.lcp != null && (() => {
                      const st = cwvStatus('lcp', ps.mobile.lcp);
                      return (
                        <div class="metric-card" style={`border-left:3px solid ${st.color};`}>
                          <div style={`font-size:16px;font-weight:600;color:${st.color};`}>{(ps.mobile.lcp/1000).toFixed(1)}s</div>
                          <div class="metric-label">LCP</div>
                          <div style={`font-size:10px;color:${st.color};margin-top:2px;`}>{st.label}</div>
                        </div>
                      );
                    })()}
                    {ps.mobile?.cls != null && (() => {
                      const st = cwvStatus('cls', ps.mobile.cls);
                      return (
                        <div class="metric-card" style={`border-left:3px solid ${st.color};`}>
                          <div style={`font-size:16px;font-weight:600;color:${st.color};`}>{ps.mobile.cls.toFixed(3)}</div>
                          <div class="metric-label">CLS</div>
                          <div style={`font-size:10px;color:${st.color};margin-top:2px;`}>{st.label}</div>
                        </div>
                      );
                    })()}
                    {ps.mobile?.fcp != null && (() => {
                      const st = cwvStatus('fcp', ps.mobile.fcp);
                      return (
                        <div class="metric-card" style={`border-left:3px solid ${st.color};`}>
                          <div style={`font-size:16px;font-weight:600;color:${st.color};`}>{(ps.mobile.fcp/1000).toFixed(1)}s</div>
                          <div class="metric-label">FCP</div>
                          <div style={`font-size:10px;color:${st.color};margin-top:2px;`}>{st.label}</div>
                        </div>
                      );
                    })()}
                  </div>
                </div>
              )}
            </div>
          )}

          <!-- Channel mix -->
          {channelSegments.length > 0 && (
            <div style="margin-bottom:20px;">
              <hr class="section-divider" />
              <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">Mix de canales de tráfico</div>
              <div set:html={channelBarSvg} />
              <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px;">
                {channelSegments.map(c => (
                  <span style={`display:inline-flex;align-items:center;gap:4px;font-size:11px;color:#5A6478;`}>
                    <span style={`width:8px;height:8px;border-radius:50%;background:${c.color};display:inline-block;`}></span>
                    {c.label} {c.pct}%
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Technical checklist -->
          <div style="margin-bottom:20px;">
            <hr class="section-divider" />
            <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">Checklist técnico SEO</div>
            <div class="grid-2" style="gap:8px;">
              <div class="metric-card" style={`border-left:3px solid ${ssl?.valid?'#1D9E75':'#E24B4A'};`}>
                <div style={`font-size:12px;font-weight:600;color:${ssl?.valid?'#1D9E75':'#E24B4A'};`}>{ssl?.valid ? '✓ SSL / HTTPS activo' : '✗ SSL no detectado'}</div>
                <div class="metric-sub">{ssl?.issuer ? `Emisor: ${ssl.issuer}` : ssl?.valid ? 'Certificado válido' : 'Implementa HTTPS urgentemente'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${crawl.hasRobotsTxt?'#1D9E75':'#BA7517'};`}>
                <div style={`font-size:12px;font-weight:600;color:${crawl.hasRobotsTxt?'#1D9E75':'#BA7517'};`}>{crawl.hasRobotsTxt ? '✓ robots.txt presente' : '✗ robots.txt no encontrado'}</div>
                <div class="metric-sub">{crawl.hasRobotsTxt ? 'Directivas de rastreo configuradas' : 'Añade un robots.txt para controlar el rastreo'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${crawl.hasSitemap?'#1D9E75':'#BA7517'};`}>
                <div style={`font-size:12px;font-weight:600;color:${crawl.hasSitemap?'#1D9E75':'#BA7517'};`}>{crawl.hasSitemap ? '✓ Sitemap XML detectado' : '✗ Sitemap XML no encontrado'}</div>
                <div class="metric-sub">{crawl.hasSitemap ? 'Sitemap disponible para indexación' : 'Genera y envía un sitemap.xml a Google Search Console'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${crawl.hasCanonical?'#1D9E75':'#BA7517'};`}>
                <div style={`font-size:12px;font-weight:600;color:${crawl.hasCanonical?'#1D9E75':'#BA7517'};`}>{crawl.hasCanonical ? '✓ Canonical tags detectadas' : '? Canonical tags no verificadas'}</div>
                <div class="metric-sub">{crawl.hasCanonical ? 'URLs canónicas configuradas' : 'Verifica que las URLs tienen rel=canonical'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${(ps?.mobile?.performance??0)>=50?'#1D9E75':'#E24B4A'};`}>
                <div style={`font-size:12px;font-weight:600;color:${(ps?.mobile?.performance??0)>=50?'#1D9E75':'#E24B4A'};`}>{(ps?.mobile?.performance??0)>=50 ? '✓ Friendly para móvil' : '✗ Problemas en móvil'}</div>
                <div class="metric-sub">{ps ? `Score móvil: ${ps.mobile?.performance ?? '—'}/100` : 'Sin datos de rendimiento móvil'}</div>
              </div>
              <div class="metric-card" style={`border-left:3px solid ${gbp?'#1D9E75':'#5A6478'};`}>
                <div style={`font-size:12px;font-weight:600;color:${gbp?'#1D9E75':'#5A6478'};`}>{gbp ? '✓ Google Business Profile detectado' : '— Google Business Profile no detectado'}</div>
                <div class="metric-sub">{gbp ? `${gbp.rating ? `Rating: ${gbp.rating}★` : ''} ${gbp.reviewCount ? `(${gbp.reviewCount} reseñas)` : ''}` : 'Reclama tu ficha en Google Maps si aplica'}</div>
              </div>
            </div>
          </div>

          <!-- Tech Stack -->
          <div style="margin-bottom:20px;">
            <hr class="section-divider" />
            <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">Stack de medición y herramientas</div>
            <div class="grid-3" style="gap:8px;">
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.analytics.detected?'#1D9E75':'#E24B4A'};`}></div>
                <div>
                  <div class="tech-name">Analytics</div>
                  {techStackMapped.analytics.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">{techStackMapped.analytics.tool || 'Detectado'}</div>
                    : <div class="tech-tool" style="color:#A32D2D;">No sabes cuántas visitas recibes ni qué funciona</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.tagManager.detected?'#1D9E75':'#BA7517'};`}></div>
                <div>
                  <div class="tech-name">Tag Manager</div>
                  {techStackMapped.tagManager.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">{techStackMapped.tagManager.tool || 'Detectado'}</div>
                    : <div class="tech-tool" style="color:#8A5015;">Cada nueva herramienta requiere intervención técnica</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.metaPixel.detected?'#1D9E75':'#BA7517'};`}></div>
                <div>
                  <div class="tech-name">Meta Pixel</div>
                  {techStackMapped.metaPixel.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">Activo</div>
                    : <div class="tech-tool" style="color:#8A5015;">No puedes reimpactar visitantes que se van sin convertir</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.googleAdsPixel.detected?'#1D9E75':'#BA7517'};`}></div>
                <div>
                  <div class="tech-name">Google Ads Pixel</div>
                  {techStackMapped.googleAdsPixel.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">Activo</div>
                    : <div class="tech-tool" style="color:#8A5015;">No puedes medir qué conversiones generan tus campañas</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.chat.detected?'#1D9E75':'#5A6478'};`}></div>
                <div>
                  <div class="tech-name">Chat / Soporte</div>
                  {techStackMapped.chat.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">{techStackMapped.chat.tool || 'Detectado'}</div>
                    : <div class="tech-tool" style="color:#5A6478;">Un potencial cliente con una duda se va. La mayoría no vuelve</div>}
                </div>
              </div>
              <div class="tech-item">
                <div class="tech-dot" style={`background:${techStackMapped.heatmaps.detected?'#1D9E75':'#5A6478'};`}></div>
                <div>
                  <div class="tech-name">Heatmaps / CRO</div>
                  {techStackMapped.heatmaps.detected
                    ? <div class="tech-tool" style="color:#1D9E75;">{techStackMapped.heatmaps.tool || 'Detectado'}</div>
                    : <div class="tech-tool" style="color:#5A6478;">No sabes dónde hacen clic los usuarios ni dónde abandonan</div>}
                </div>
              </div>
            </div>
            <p style="font-size:11px;color:#9CA3AF;margin-top:10px;font-style:italic;">Análisis basado en código HTML público. Herramientas cargadas vía Tag Manager o configuradas en servidor pueden no detectarse.</p>
          </div>

          <!-- Schema markup -->
          <div style="margin-bottom:20px;">
            <hr class="section-divider" />
            <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Schema Markup</div>
            <div class="callout callout-blue" style="margin-bottom:14px;font-size:12px;">
              <strong>¿Qué es Schema Markup?</strong> Es un código invisible que le dice a Google qué tipo de negocio eres, qué servicios ofreces y cómo contactarte. Implementarlo correctamente puede dar lugar a resultados enriquecidos en Google (con estrellas, horarios, FAQs) que aumentan significativamente el CTR.
            </div>
            {schemaTypes.length > 0 && (
              <div style="margin-bottom:10px;">
                <div style="font-size:0.72rem;color:#5A6478;margin-bottom:6px;">Tipos detectados:</div>
                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                  {schemaTypes.map((t: string) => (
                    <span class="tag" style="background:#E1F5EE;color:#1D9E75;">{t}</span>
                  ))}
                </div>
              </div>
            )}
            {missingSchemas.length > 0 && (
              <div>
                <div style="font-size:0.72rem;color:#5A6478;margin-bottom:6px;">Recomendados{btLabelForSchema ? ` para ${btLabelForSchema}` : ''} y no detectados:</div>
                <div style="display:flex;flex-wrap:wrap;gap:6px;">
                  {missingSchemas.map((s: string) => (
                    <span class="tag" style="background:#FCEBEB;color:#E24B4A;">{s}</span>
                  ))}
                </div>
              </div>
            )}
            {schemaTypes.length === 0 && missingSchemas.length === 0 && (
              <div class="callout callout-amber">No se han detectado schemas estructurados. Implementar Schema Markup mejora la apariencia en resultados de búsqueda.</div>
            )}
          </div>

          <!-- Conversion signals -->
          {cv && (
            <div style="margin-bottom:4px;">
              <hr class="section-divider" />
              <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Señales de conversión</div>
              <div class="grid-2" style="gap:8px;">
                <div class="metric-card" style={`border-left:3px solid ${cv.hasContactForm?'#1D9E75':'#E24B4A'};`}>
                  <div style={`font-size:12px;font-weight:600;color:${cv.hasContactForm?'#1D9E75':'#E24B4A'};`}>{cv.hasContactForm ? '✓ Formulario de contacto' : '✗ Sin formulario de contacto'}</div>
                  <div class="metric-sub">Elemento clave para captación de leads</div>
                </div>
                {cv.hasCTA != null && (
                  <div class="metric-card" style={`border-left:3px solid ${cv.hasCTA?'#1D9E75':'#BA7517'};`}>
                    <div style={`font-size:12px;font-weight:600;color:${cv.hasCTA?'#1D9E75':'#BA7517'};`}>{cv.hasCTA ? '✓ CTAs detectados' : '✗ CTAs poco visibles'}</div>
                    <div class="metric-sub">Call to action en página principal</div>
                  </div>
                )}
                {cv.hasTestimonials != null && (
                  <div class="metric-card" style={`border-left:3px solid ${cv.hasTestimonials?'#1D9E75':'#BA7517'};`}>
                    <div style={`font-size:12px;font-weight:600;color:${cv.hasTestimonials?'#1D9E75':'#BA7517'};`}>{cv.hasTestimonials ? '✓ Testimonios / prueba social' : '? Sin prueba social detectada'}</div>
                    <div class="metric-sub">La prueba social aumenta la conversión</div>
                  </div>
                )}
                {cv.funnelScore != null && (
                  <div class="metric-card">
                    <div class="metric-value" style={`color:${(cv.funnelScore??0)>=60?'#1D9E75':(cv.funnelScore??0)>=35?'#BA7517':'#E24B4A'};`}>{cv.funnelScore}/100</div>
                    <div class="metric-label">Funnel Score</div>
                    <div class="metric-sub">Índice de optimización del embudo</div>
                  </div>
                )}
              </div>
            </div>
          )}
        </div>

        <!-- ═══════════════════════════════════════════════════════════
             BLOCK 5 · #plan · Plan de Acción
        ═══════════════════════════════════════════════════════════ -->
        <div id="plan" class="report-block reveal">
          <div class="block-title">Plan de Acción</div>
          <div class="block-subtitle">Acciones concretas ordenadas por impacto y esfuerzo para {domain}</div>

          <!-- Quick wins -->
          <div style="margin-bottom:20px;">
            <div style="font-size:0.85rem;font-weight:700;color:#1D9E75;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;display:flex;align-items:center;gap:8px;">
              <span style="width:3px;height:16px;background:#1D9E75;border-radius:2px;display:inline-block;"></span>
              Quick Wins — Resultados en 30 días
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              {displayQuickWins.map((win: any, idx: number) => (
                <div class="plan-win-card">
                  <div class="plan-win-num" style="background:#EAF3DE;color:#27500A;">{idx + 1}</div>
                  <div style="flex:1;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px;flex-wrap:wrap;">
                      <div class="plan-win-text" style="font-weight:700;font-size:13px;">{typeof win === 'string' ? win : win.title}</div>
                      {typeof win !== 'string' && win.impact && (
                        <span class="tag" style={`background:${win.impact==='alto'?'#FCEBEB':'#FAEEDA'};color:${win.impact==='alto'?'#791F1F':'#633806'};font-size:10px;`}>
                          Impacto {win.impact}
                        </span>
                      )}
                    </div>
                    {typeof win !== 'string' && win.problem && (
                      <div style="font-size:12px;color:#5A6478;line-height:1.5;">{win.problem}</div>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <hr class="section-divider" />

          <!-- Strategic actions -->
          <div style="margin-bottom:20px;">
            <div style="font-size:0.85rem;font-weight:700;color:#1A4B8C;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;display:flex;align-items:center;gap:8px;">
              <span style="width:3px;height:16px;background:#1A4B8C;border-radius:2px;display:inline-block;"></span>
              Iniciativas Estratégicas — Resultados en 90 días
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              {displayStrategic.map((action: any, idx: number) => (
                <div class="plan-strategic-card">
                  <div class="plan-strategic-num">{idx + 1}</div>
                  <div>
                    <div class="plan-strategic-title">{action.title}</div>
                    <div class="plan-strategic-desc">{action.description}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <hr class="section-divider" />

          <!-- CTA card -->
          <div style="border:1px solid #4A7FD4;border-radius:10px;padding:24px;background:#F0F6FF;">
            <div style="font-size:1rem;font-weight:700;color:#1A4B8C;margin-bottom:8px;">¿Quieres que monitorizemos esto cada mes?</div>
            <p style="font-size:0.84rem;color:#5A6478;line-height:1.6;margin-bottom:0;">
              Con <strong style="color:#1A4B8C;">Radar</strong>, recibirás un informe mensual con la evolución de todos estos indicadores, alertas cuando algo cambie, y una llamada de revisión con tu Growth Advisor. Sin sorpresas — con métricas de éxito definidas desde el primer día.
            </p>
          </div>
        </div>

      </div>
      <!-- END .report -->

      <!-- CTA SECTION (dark) -->
      <div class="cta-section no-print">
        <div class="cta-inner">
          <div style="display:grid;grid-template-columns:1fr auto;gap:24px;align-items:center;flex-wrap:wrap;">
            <div>
              <div style="font-size:1.25rem;font-weight:700;color:#fff;margin-bottom:8px;">
                Convierte el diagnóstico de {domain} en un plan de crecimiento real
              </div>
              <p style="font-size:0.875rem;color:rgba(255,255,255,0.7);line-height:1.6;max-width:600px;">
                Nuestro equipo puede ayudarte a priorizar, ejecutar y medir cada acción de este informe. Sin ambigüedades — con hitos, plazos y métricas de éxito definidas.
              </p>
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;min-width:180px;">
              <a href={`mailto:hola@aion.es?subject=Diagnóstico ${domain} — Solicito propuesta`}
                 style="background:#4A7FD4;color:#fff;padding:0.625rem 1.5rem;border-radius:8px;text-decoration:none;font-size:0.875rem;font-weight:600;text-align:center;white-space:nowrap;">
                Solicitar propuesta
              </a>
              <a href="https://aion.es"
                 style="background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.8);border:1px solid rgba(255,255,255,0.2);padding:0.625rem 1.5rem;border-radius:8px;text-decoration:none;font-size:0.875rem;font-weight:500;text-align:center;">
                Conocer AION
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- FOOTER STRIP -->
      <div class="footer-strip">
        <div class="footer-strip-left">
          <img src="/logo-aion-dark.png" height="20" alt="AION" style="height:20px;filter:brightness(0) invert(1);opacity:0.7;" />
          <span style="color:rgba(255,255,255,0.4);font-size:0.7rem;margin-left:8px;">Informe confidencial generado el {auditDate}</span>
        </div>
        <div style="color:rgba(255,255,255,0.35);font-size:0.7rem;">{domain}</div>
      </div>

    </div>
    <!-- END .main-content -->
  </div>
  <!-- END .layout -->

  <script define:vars={{ scoreTotal: health.total }}>
    const counter = document.getElementById('score-counter');
    const ring = document.getElementById('score-ring');
    if (counter && scoreTotal > 0) {
      const duration = 1400;
      const start = performance.now();
      const animate = (now) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * scoreTotal);
        counter.textContent = current;
        if (ring) ring.setAttribute('stroke-dasharray', eased * scoreTotal + ', 100');
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
    }
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));
    const barObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.querySelectorAll('.bar-fill[data-width]').forEach(bar => {
            bar.style.width = bar.getAttribute('data-width') + '%';
          });
          barObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('table').forEach(t => barObs.observe(t));
  </script>
</body>
</html>
