                { label: 'Visibilidad IA (GEO)', value: visGeoSub, weight: '25%' },
                { label: 'Reputacion', value: r.score?.breakdown?.reputation ?? brandAuthorityScoreEs, weight: '10%' },
              ].map(sub => {
                const c = sub.value >= 70 ? '#69FF87' : sub.value >= 40 ? '#ffb4ab' : '#ffb4ab';
                return (
                  <div style="flex:1;min-width:160px;">
