                </div>
              ) : (
                <div style="font-size:0.82rem;color:#8d909b;">No se ha detectado seccion de blog ni articulos publicados.</div>
              )}
            </div>

            <div class="glass-card" style={newsCountEs > 0 ? 'border-left:3px solid #aac7ff;' : ''}>
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
