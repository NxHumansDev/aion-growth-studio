              </div>
              <div style="display:flex;align-items:center;gap:8px;">
                <span class="material-symbols-outlined" style="font-size:16px;color:#69FF87;">lightbulb</span>
                Recomendaciones personalizadas con IA
              </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:12px;width:100%;max-width:300px;margin-top:8px;">
              <a href="/dashboard/onboarding"
                 style="background:#69ff87;color:#002108;padding:0.85rem 1.75rem;border-radius:9999px;text-decoration:none;font-size:0.92rem;font-weight:700;text-align:center;">
                Activar AION Radar
              </a>
              <p style="font-size:0.72rem;color:#8d909b;">Desde 149€/mes · Sin permanencia · Cancela cuando quieras</p>
            </div>
            <p style="font-size:0.68rem;color:#8d909b;margin-top:8px;">Informe confidencial · {domain} · {auditDate}</p>
          </div>
