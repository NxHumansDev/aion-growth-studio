                </div>
              </div>

              {showGiantCalloutEs && (
                <div class="callout callout-warning" style="margin-bottom:12px;">
                  <strong>Contexto del score:</strong> tu visibilidad SEO se mide frente a {giantCompNamesEs} — competidores de referencia del sector con una media de {fmt(Math.round(avgCompKWes))} keywords en top 10. Con {fmt(seo?.keywordsTop10)} keywords y ~{fmt(seo?.organicTrafficEstimate)} visitas/mes, tu posicion organica es <strong>solida para tu tamano</strong>.
                </div>
              )}

              {(seo.estimatedAdsCost ?? 0) > 0 && (
                <div class="callout callout-info" style="margin-bottom:12px;">
                  Tus keywords top 10 equivalen a <strong>~{fmt(seo.estimatedAdsCost)}EUR/mes</strong> en Google Ads — estas generando trafico organico de alto valor.
                </div>
              )}

              {(seo?.keywordsPos4to10 ?? pos4to10Keywords.length) > 0 && (
                <div class="callout callout-success" style="margin-bottom:12px;">
                  Tienes <strong>{fmt(seo?.keywordsPos4to10 ?? pos4to10Keywords.length)} keywords entre posicion 4-10</strong> — a un buen articulo del top 3. Optimizar esas URLs puede multiplicar el trafico sin coste adicional.
                </div>
