---
export const prerender = false;
import { getAuditPage } from '../../../../lib/audit/notion';
import { computeHealthScore, scoreColor, scoreLabel, scoreEmoji } from '../../../../lib/audit/report/health-score';
import {
  diagnosisHealthSummary,
  diagnosisSEO,
  diagnosisGEO,
  diagnosisTrafficMix,
  diagnosisPageSpeed,
  diagnosisFunnel,
  diagnosisTechStack,
  diagnosisCompetitiveGap,
  diagnosisSchema,
} from '../../../../lib/audit/report/diagnostics';

const { id } = Astro.params;

let audit: any = null;
let error = '';

try {
  audit = await getAuditPage(id!);
} catch (e: any) {
  error = e.message || 'No se pudo cargar el análisis.';
}

if (!audit || audit.status !== 'completed') {
  return Astro.redirect(`/es/audit/${id}`);
}

const r = audit.results;
const domain = new URL(audit.url).hostname.replace(/^www\./, '');
const auditDate = new Date().toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });

// ── Scores ───────────────────────────────────────────────────────
const health = computeHealthScore(r);

// ── Data shortcuts ────────────────────────────────────────────────
const crawl = r.crawl || {};
const seo = (!r.seo?.skipped && r.seo) ? r.seo : null;
const geo = (!r.geo?.skipped && r.geo) ? r.geo : null;
const traffic = (!r.traffic?.skipped && r.traffic) ? r.traffic : null;
const ps = (!r.pagespeed?.skipped && r.pagespeed) ? r.pagespeed : null;
const gbp = (!r.gbp?.skipped && r.gbp?.found) ? r.gbp : null;
const ssl = (!r.ssl?.skipped && r.ssl) ? r.ssl : null;
const ctItems: any[] = r.competitor_traffic?.items || [];
const competitors: any[] = r.competitors?.competitors || [];
const kg = (!r.keyword_gap?.skipped && r.keyword_gap?.items?.length) ? r.keyword_gap : null;
const ts = (!r.techstack?.skipped && r.techstack) ? r.techstack : null;
const cv = (!r.conversion?.skipped && r.conversion) ? r.conversion : null;
const insights = r.insights || {};
const seoPages = (!r.seo_pages?.skipped && r.seo_pages?.pages?.length) ? r.seo_pages : null;
const sector = r.sector?.sector || audit.sector || '';
const linkedin = (!r.linkedin?.skipped && r.linkedin?.found) ? r.linkedin : null;
const instagram = (!r.instagram?.skipped && r.instagram?.found) ? r.instagram : null;
const content = (!r.content?.skipped && r.content) ? r.content : null;

// ── Hreflang / multi-domain ────────────────────────────────────────
const hreflangAlts: any[] = crawl.hreflangAlternates || [];

// ── Helpers ───────────────────────────────────────────────────────
function fmt(n: number | undefined | null): string {
  if (n == null) return '—';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return Math.round(n / 1_000) + 'K';
  return String(n);
}

function cwvColor(metric: string, value: number): string {
  const thresholds: Record<string, [number, number]> = {
    lcp: [2500, 4000],
    cls: [0.1, 0.25],
    fcp: [1800, 3000],
    ttfb: [800, 1800],
  };
  const [good, poor] = thresholds[metric] || [50, 90];
  if (value <= good) return 'text-emerald-600';
  if (value <= poor) return 'text-amber-500';
  return 'text-red-500';
}

function cwvEmoji(metric: string, value: number): string {
  const thresholds: Record<string, [number, number]> = {
    lcp: [2500, 4000], cls: [0.1, 0.25], fcp: [1800, 3000], ttfb: [800, 1800],
  };
  const [good, poor] = thresholds[metric] || [50, 90];
  if (value <= good) return '🟢';
  if (value <= poor) return '🟡';
  return '🔴';
}

// ── Competitor benchmark table data ──────────────────────────────
interface BenchRow { label: string; etv: number | null; ads: number | null; kw10: number | null; isOwn: boolean }
const benchRows: BenchRow[] = [];
if (seo) {
  benchRows.push({
    label: `★ ${domain}`,
    etv: seo.organicTrafficEstimate ?? null,
    ads: seo.estimatedAdsCost ?? null,
    kw10: seo.keywordsTop10 ?? null,
    isOwn: true,
  });
}
for (const c of ctItems) {
  benchRows.push({ label: c.domain, etv: c.organicTrafficEstimate ?? null, ads: c.estimatedAdsCost ?? null, kw10: c.keywordsTop10 ?? null, isOwn: false });
}
// Sector average row
if (benchRows.length > 1) {
  const compRowsForAvg = benchRows.filter(r => !r.isOwn);
  const avg = (vals: (number | null)[]) => {
    const nums = vals.filter((v) => v != null) as number[];
    return nums.length ? Math.round(nums.reduce((a, b) => a + b, 0) / nums.length) : null;
  };
  benchRows.push({
    label: 'Media sector',
    etv: avg(compRowsForAvg.map(r => r.etv)),
    ads: avg(compRowsForAvg.map(r => r.ads)),
    kw10: avg(compRowsForAvg.map(r => r.kw10)),
    isOwn: false,
  });
}

// ── Gate: only show competitor table if at least one competitor has real data
function rowHasData(row: BenchRow): boolean {
  return row.etv != null || row.kw10 != null;
}
const compTableRows = benchRows.filter(r => !r.isOwn && r.label !== 'Media sector');
const hasEnoughCompetitorData = compTableRows.some(rowHasData);

// ── Max values for bar widths ─────────────────────────────────────
const maxETV = Math.max(...benchRows.map(r => r.etv || 0), 1);
const maxADS = Math.max(...benchRows.map(r => r.ads || 0), 1);
const maxKW = Math.max(...benchRows.map(r => r.kw10 || 0), 1);

// ── Trend alert ───────────────────────────────────────────────────
const hasTrendAlert = seo != null
  && seo.trendLost != null
  && seo.trendUp != null
  && seo.trendLost > (seo.trendUp ?? 0);

// ── Channel bar data ──────────────────────────────────────────────
const channelColors: Record<string, string> = {
  organic: '#1A4B8C', direct: '#64748b', social: '#7c3aed',
  referral: '#0891b2', paid: '#d97706', email: '#16a34a',
};
const channelLabels: Record<string, string> = {
  organic: 'Orgánico', direct: 'Directo', social: 'Social',
  referral: 'Referral', paid: 'Paid', email: 'Email',
};
const channels = traffic?.channels || {};
const totalVisits = Object.values(channels).reduce((s: number, c: any) => s + (c.visits || 0), 0);
const channelSegments = Object.entries(channels)
  .sort(([, a]: any, [, b]: any) => (b.visits || 0) - (a.visits || 0))
  .map(([key, ch]: [string, any]) => ({
    key,
    label: channelLabels[key] || key,
    visits: ch.visits || 0,
    pct: totalVisits > 0 ? Math.round((ch.visits / totalVisits) * 100) : 0,
    color: channelColors[key] || '#94a3b8',
  }));

// ── Schema audit ─────────────────────────────────────────────────
// ── Business type ─────────────────────────────────────────────────
const businessType: string = crawl.businessType || 'unknown';

const schemaTypes: string[] = crawl.schemaTypes || [];
const RECOMMENDED_SCHEMAS_ES: Record<string, string[]> = {
  ecommerce: ['Organization', 'WebSite', 'Product', 'Offer', 'BreadcrumbList'],
  saas: ['Organization', 'WebSite', 'SoftwareApplication', 'FAQPage'],
  b2b: ['Organization', 'WebSite', 'Service', 'FAQPage', 'BreadcrumbList'],
  local: ['LocalBusiness', 'Organization', 'GeoCoordinates', 'OpeningHoursSpecification'],
  media: ['Organization', 'WebSite', 'Article', 'BreadcrumbList'],
  unknown: ['Organization', 'WebSite', 'BreadcrumbList'],
};
const recommendedSchemas = RECOMMENDED_SCHEMAS_ES[businessType] || RECOMMENDED_SCHEMAS_ES.unknown;
const presentLower = schemaTypes.map((t: string) => t.toLowerCase());
const missingSchemas = recommendedSchemas.filter(s => !presentLower.includes(s.toLowerCase()));

// ── Diagnostic texts ──────────────────────────────────────────────
const diagSchema = diagnosisSchema(schemaTypes.length ? schemaTypes : undefined, businessType);
const diagSEO = diagnosisSEO(seo, ctItems);
const diagGEO = diagnosisGEO(geo);
const diagTraffic = diagnosisTrafficMix(traffic);
const diagPS = diagnosisPageSpeed(ps);
const diagFunnel = diagnosisFunnel(cv);
const diagStack = diagnosisTechStack(ts);
const diagGap = diagnosisCompetitiveGap(seo, ctItems, kg);
const diagSummary = diagnosisHealthSummary(health);
const btLabels: Record<string, string> = {
  ecommerce: 'E-commerce',
  saas: 'SaaS / Software',
  b2b: 'B2B · Captación de leads',
  local: 'Negocio local',
  media: 'Media / Contenido',
};
const btLabel = btLabels[businessType] || '';
const btObjectives: Record<string, string> = {
  ecommerce: 'maximizar tus ventas online',
  saas: 'incrementar activaciones y reducir churn',
  b2b: 'generar leads cualificados y acortar el ciclo de venta',
  local: 'capturar demanda local y mejorar tu reputación en Google',
  media: 'crecer tu audiencia orgánica y monetizarla',
  unknown: 'mejorar tu presencia digital y conversión',
};
const btObjective = btObjectives[businessType] || btObjectives.unknown;

// ── Fallback initiatives (when insights module has no data) ───────
const fallbackInitiatives = [
  { key: 'visibilidad', label: 'Visibilidad orgánica', score: health.visibilidad, action: 'Desarrollar un plan de contenido SEO atacando las keywords del gap competitivo para capturar demanda orgánica.' },
  ...(health.competitividad !== null ? [{ key: 'competitividad', label: 'Posicionamiento competitivo', score: health.competitividad, action: 'Analizar el gap de keywords frente a competidores y establecer un plan de contenidos para recuperar posiciones.' }] : []),
  { key: 'experiencia', label: 'Rendimiento web', score: health.experiencia, action: 'Optimizar imágenes y reducir JavaScript bloqueante para mejorar los Core Web Vitals y la experiencia de usuario.' },
  { key: 'conversion', label: 'Conversión', score: health.conversion, action: 'Implementar un funnel de captación con formularios optimizados, CTAs claros y prueba social.' },
].sort((a, b) => a.score - b.score).slice(0, 3);

// ── Sector benchmarks (from competitors) ─────────────────────────
const sectorAvgKW = ctItems.length > 0 ? Math.round(ctItems.reduce((s: number, c: any) => s + (c.keywordsTop10 || 0), 0) / ctItems.length) : null;

// ── Competitive rank (by organic traffic) ────────────────────────
const ownETV = seo?.organicTrafficEstimate || 0;
const avgETV = ctItems.length > 0
  ? ctItems.reduce((s: number, c: any) => s + (c.organicTrafficEstimate || 0), 0) / ctItems.length
  : 0;
const allETVs = [...ctItems.map((c: any) => c.organicTrafficEstimate || 0), ownETV].sort((a, b) => b - a);
const ownRank = allETVs.indexOf(ownETV) + 1;
const totalPlayers = allETVs.length;

// ── LinkedIn data ─────────────────────────────────────────────────
const liEmployees = parseInt(linkedin?.employees?.replace(/[^\d]/g, '') || '0') || 0;
const liFollowers = linkedin?.followers || 0;
const liRatio = liEmployees > 0 ? Math.round((liFollowers / liEmployees) * 100) : 0;

// ── Stack impact descriptions ─────────────────────────────────────
const stackItems = ts ? [
  { key: 'analytics', label: 'Analytics', tools: ts.analytics,
    presentNote: 'Base de medición instalada. Tienes datos para tomar decisiones.',
    missingNote: 'No sabes qué funciona ni de dónde vienen tus clientes. Cada decisión de marketing es una apuesta.' },
  { key: 'tagManager', label: 'Tag Manager', tools: ts.tagManager,
    presentNote: 'Tag Manager instalado: añades herramientas sin tocar código.',
    missingNote: 'Cada cambio de tracking requiere modificar código. Ralentiza la experimentación y encarece el mantenimiento.' },
  { key: 'conversionPixels', label: 'Píxeles de conversión', tools: ts.conversionPixels,
    presentNote: 'Píxeles activos: puedes hacer remarketing y optimizar campañas de pago.',
    missingNote: 'Sin píxeles (Meta, Google Ads): no puedes reimpactar a visitantes que se van sin convertir. Dinero en paid media que no se puede optimizar.' },
  { key: 'crmAutomation', label: 'CRM / Automatización', tools: ts.crmAutomation,
    presentNote: 'CRM activo: leads gestionados de forma escalable y automatizada.',
    missingNote: 'Sin CRM: los leads se gestionan manualmente. A escala, esto genera pérdidas y falta de seguimiento.' },
  { key: 'chatSupport', label: 'Chat / Soporte', tools: ts.chatSupport,
    presentNote: 'Chat disponible: los visitantes pueden resolver dudas en tiempo real.',
    missingNote: 'Sin chat: un potencial cliente con una duda se va. La mayoría no vuelve.' },
  { key: 'heatmaps', label: 'Mapas de calor', tools: ts.heatmaps,
    presentNote: 'Mapas de calor activos: sabes exactamente qué hacen los usuarios.',
    missingNote: 'Sin grabaciones de sesión: no sabes qué partes de tu web captan atención y cuáles se ignoran.' },
] : [];

// ── Conversion impact descriptions ────────────────────────────────
const convItems = cv ? [
  { label: 'Formulario de contacto', ok: cv.hasContactForm, impact: 'Sin captura de datos — visitante que se va, lead perdido para siempre' },
  { label: 'CTAs claros', ok: cv.hasCTA, impact: 'Sin dirección explícita, el visitante no sabe qué se espera de él' },
  { label: 'Lead magnet', ok: cv.hasLeadMagnet, impact: 'Sin incentivo: la mayoría no da sus datos sin algo a cambio' },
  { label: 'Testimonios / prueba social', ok: cv.hasTestimonials, impact: 'Genera confianza y reduce la fricción de compra' },
  { label: 'Precios visibles', ok: cv.hasPricing, impact: 'Sin precios: el usuario debe preguntar antes de decidir — añade fricción' },
  { label: 'Contenido en vídeo', ok: cv.hasVideo, impact: 'El vídeo convierte hasta 3× más que texto — también mejora el tiempo en página' },
  { label: 'Chat en vivo', ok: cv.hasChatWidget, impact: 'Sin respuesta inmediata: dudas no resueltas = usuarios que abandonan' },
] : [];

// ── Personalized CTA data ─────────────────────────────────────────
const trafficGap = Math.max(0, Math.round(avgETV - ownETV));
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex,nofollow" />
  <title>Informe de Diagnóstico — {domain} — AION Growth Studio</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body { font-family: 'Inter', system-ui, sans-serif; background: #f8fafc; color: #0f172a; margin: 0; }
    .report { max-width: 900px; margin: 0 auto; background: #fff; }
    .section { padding: 2rem 2.5rem; border-bottom: 1px solid #e2e8f0; }
    .section:last-child { border-bottom: none; }
    h2 { font-size: 1.25rem; font-weight: 700; color: #0f172a; margin: 0 0 0.25rem; }
    h3 { font-size: 1rem; font-weight: 600; color: #1e293b; margin: 0 0 0.5rem; }
    p { margin: 0 0 0.75rem; line-height: 1.65; }
    table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    th { text-align: left; padding: 0.5rem 0.75rem; background: #f1f5f9; color: #475569; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
    td { padding: 0.625rem 0.75rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    tr.own-row td { background: #eff6ff; font-weight: 600; }
    tr.avg-row td { background: #f8fafc; color: #64748b; font-style: italic; font-size: 0.8rem; }
    .badge { display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.25rem 0.625rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    .badge-green { background: #dcfce7; color: #16a34a; }
    .badge-amber { background: #fef3c7; color: #d97706; }
    .badge-red { background: #fee2e2; color: #dc2626; }
    .badge-blue { background: #dbeafe; color: #1d4ed8; }
    .pillar-card { border-radius: 0.75rem; padding: 1rem; text-align: center; border: 1px solid #e2e8f0; }
    .num { font-family: 'Space Grotesk', system-ui, sans-serif; }
    .pillar-score { font-size: 1.75rem; font-weight: 700; line-height: 1; font-family: 'Space Grotesk', system-ui, sans-serif; }
    .pillar-label { font-size: 0.7rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem; }
    .sub-section { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid #f1f5f9; }
    .diag-text { font-size: 0.9375rem; color: #334155; line-height: 1.7; background: #f8fafc; border-left: 3px solid #1A4B8C; padding: 0.875rem 1rem; border-radius: 0 0.5rem 0.5rem 0; margin: 0.75rem 0 1rem; }
    .initiative-card { border: 1px solid #e2e8f0; border-radius: 0.75rem; padding: 1.25rem; margin-bottom: 1rem; }
    .initiative-num { display: inline-flex; align-items: center; justify-content: center; width: 1.75rem; height: 1.75rem; border-radius: 9999px; background: #1A4B8C; color: #fff; font-size: 0.8rem; font-weight: 700; margin-right: 0.5rem; }
    .check-row { display: flex; align-items: flex-start; gap: 0.5rem; padding: 0.375rem 0; border-bottom: 1px solid #f8fafc; font-size: 0.875rem; }
    .check-row:last-child { border-bottom: none; }
    .check-ok { color: #16a34a; font-size: 1rem; shrink: 0; }
    .check-no { color: #dc2626; font-size: 1rem; shrink: 0; }
    .bar-wrap { display: flex; align-items: center; gap: 0.5rem; }
    .bar-bg { flex: 1; height: 0.5rem; background: #f1f5f9; border-radius: 9999px; overflow: hidden; }
    .bar-fill { height: 100%; border-radius: 9999px; }
    @media print {
      body { background: #fff; }
      .no-print { display: none !important; }
      .report { max-width: 100%; }
      .section { page-break-inside: avoid; }
      .initiative-card { page-break-inside: avoid; }
    }
  </style>
</head>
<body>
  <!-- NAVEGACIÓN (no imprimible) -->
  <div class="no-print" style="background:#0B1B3D;padding:0.75rem 2rem;display:flex;align-items:center;justify-content:space-between;">
    <a href={`/es/audit/${id}`} style="color:#94a3b8;font-size:0.8rem;text-decoration:none;">← Volver al análisis</a>
    <button onclick="window.print()" style="background:#1A4B8C;color:#fff;border:none;padding:0.5rem 1rem;border-radius:0.5rem;font-size:0.8rem;cursor:pointer;display:flex;align-items:center;gap:0.375rem;">
      <svg style="width:14px;height:14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
      Imprimir / PDF
    </button>
  </div>

  <div class="report">
    <!-- ── BLOQUE 0: HERO COMBINADO (Portada + Score) ──────────────── -->
    <div style="background:linear-gradient(135deg,#0B1B3D 0%,#1A4B8C 100%);color:#fff;padding:1.5rem 2rem 2rem;position:relative;overflow:hidden;">
      <!-- Background glow -->
      <div style={`position:absolute;inset:0;background:radial-gradient(ellipse at 80% 20%,${scoreColor(health.total)}15 0%,transparent 50%);pointer-events:none;`}></div>
      
      <!-- Header row: Logo + Date -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;position:relative;">
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:28px;filter:brightness(0) invert(1);opacity:0.9;" />
        <span style="color:#94a3b8;font-size:0.7rem;">{auditDate}</span>
      </div>
      
      <!-- Main content: Left info + Right score -->
      <div style="display:flex;align-items:flex-start;gap:2rem;position:relative;">
        <!-- Left: Domain info -->
        <div style="flex:1;min-width:0;">
          <p style="font-size:0.65rem;font-weight:600;color:#67e8f9;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.35rem;">Informe de Visibilidad Digital</p>
          <h1 style="font-size:1.5rem;font-weight:800;margin:0 0 0.5rem;line-height:1.15;">{domain}</h1>
          <div style="display:flex;align-items:center;flex-wrap:wrap;gap:0.4rem;margin-bottom:1rem;">
            {sector && <span style="color:#cbd5e1;font-size:0.75rem;">{sector}</span>}
            {btLabel && (
              <>
                <span style="color:#475569;font-size:0.7rem;">|</span>
                <span style="color:#94a3b8;font-size:0.7rem;">{btLabel}</span>
              </>
            )}
          </div>
          
          <!-- Quick stats row -->
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;">
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Trafico Est.</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'Space Grotesk',sans-serif;">{fmt(seo?.organicTrafficEstimate)}</p>
            </div>
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Keywords Top10</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'Space Grotesk',sans-serif;">{fmt(seo?.keywordsTop10)}</p>
            </div>
            <div style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:0.5rem;padding:0.6rem 0.75rem;">
              <p style="font-size:0.6rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.05em;margin:0 0 0.15rem;">Keywords Top 3</p>
              <p style="font-size:1rem;font-weight:700;color:#fff;margin:0;font-family:'Space Grotesk',sans-serif;">{fmt(seo?.keywordsTop3)}</p>
            </div>
          </div>
        </div>
        
        <!-- Right: Score gauge -->
        <div style="text-align:center;flex-shrink:0;">
          <div style="position:relative;width:110px;height:110px;">
            <svg viewBox="0 0 36 36" style="width:110px;height:110px;transform:rotate(-90deg);">
              <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="2.5"/>
              <circle cx="18" cy="18" r="15.9" fill="none" stroke={scoreColor(health.total)} stroke-width="2.5" stroke-linecap="round" stroke-dasharray={`${health.total}, 100`}/>
            </svg>
            <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
              <span style="font-size:2rem;font-weight:800;color:#fff;font-family:'Space Grotesk',sans-serif;line-height:1;">{health.total}</span>
              <span style="font-size:0.6rem;color:#94a3b8;">/100</span>
            </div>
          </div>
          <p style="font-size:0.65rem;color:#67e8f9;text-transform:uppercase;letter-spacing:0.08em;margin:0.5rem 0 0;font-weight:600;">AEO Score</p>
        </div>
      </div>
      
      {hreflangAlts.length > 0 && (
        <div style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:0.375rem;padding:0.5rem 0.75rem;font-size:0.7rem;color:#cbd5e1;margin-top:1rem;">
          Este analisis cubre {domain}. Detectadas {hreflangAlts.length} versiones adicionales: {hreflangAlts.slice(0, 3).map((a: any) => a.domain).join(', ')}.
        </div>
      )}
    </div>

    <!-- ── BLOQUE 1: PILARES DE SALUD ──────────────────────────── -->
    <div style="display:grid;grid-template-columns:repeat(4,1fr);border-bottom:1px solid #e2e8f0;">
      {[
        { label: 'Visibilidad', value: health.visibilidad, desc: '¿Te encuentran?', benchmark: null },
        { label: 'Competitividad', value: health.competitividad, desc: 'vs sector', benchmark: sectorAvgKW != null ? `sector KW ~${fmt(sectorAvgKW)}` : null },
        { label: 'Experiencia', value: health.experiencia, desc: 'Cuando llegan', benchmark: null },
        { label: 'Conversión', value: health.conversion, desc: '¿Convierten?', benchmark: null },
      ].map((p, i) => (
        <div style={`padding:1.25rem 1rem;text-align:center;${i < 3 ? 'border-right:1px solid #e2e8f0;' : ''}`}>
          {p.value !== null ? (
            <>
              <div class="pillar-score" style={`color:${scoreColor(p.value)}`}>{p.value}</div>
              <div class="pillar-label">{p.label}</div>
              <div style="font-size:0.65rem;color:#94a3b8;margin-top:0.125rem;">{p.desc}</div>
              {p.benchmark && <div style="font-size:0.6rem;color:#cbd5e1;margin-top:0.25rem;">{p.benchmark}</div>}
            </>
          ) : (
            <>
              <div class="pillar-score" style="color:#94a3b8;">—</div>
              <div class="pillar-label">{p.label}</div>
              <div style="font-size:0.65rem;color:#94a3b8;margin-top:0.125rem;">Sin datos</div>
            </>
          )}
        </div>
      ))}
    </div>

    <!-- ── RESUMEN EJECUTIVO ──────────────────────────────────────── -->
    {(() => {
      const bullets: string[] = insights.bullets?.length > 0
        ? insights.bullets
        : [diagSEO, diagGEO, diagTraffic, diagPS, diagFunnel, diagStack].filter(
            (t) => t && !t.startsWith('No se pudieron') && !t.startsWith('Este dominio no')
          );
      return (
        <div class="section" style="background:#f8fafc;">
          <h2 style="margin:0 0 1rem;">Resumen ejecutivo</h2>
          <div style="display:flex;flex-direction:column;gap:0.125rem;">
            {bullets.map((b: string) => (
              <div style="display:flex;align-items:flex-start;gap:0.75rem;padding:0.625rem 0;border-bottom:1px solid #f1f5f9;">
                <span style="color:#1A4B8C;font-weight:700;font-size:1rem;flex-shrink:0;margin-top:0.1rem;">→</span>
                <p style="margin:0;font-size:0.9375rem;color:#334155;line-height:1.7;">{b}</p>
              </div>
            ))}
          </div>
        </div>
      );
    })()}

    <!-- ── BLOQUE 2: ¿TE ENCUENTRAN? ─────────────────────────────── -->
    <div class="section">
      <h2>¿Te encuentran?</h2>
      <p style="color:#64748b;font-size:0.875rem;margin:0 0 1rem;">Visibilidad en buscadores, IA y canales de adquisición</p>

      <!-- Contexto: propuesta de valor detectada -->
      {content?.valueProposition && content.valueProposition !== 'Could not analyze' && (
        <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:0.5rem;padding:0.75rem 1rem;margin-bottom:1rem;font-size:0.875rem;color:#0369a1;">
          <span style="font-weight:600;">Tu web se presenta como:</span> {content.valueProposition}
          {content.audienceMatch && content.audienceMatch !== 'Unknown' && <span> · Audiencia: {content.audienceMatch}</span>}
        </div>
      )}

      <!-- 2.1 SEO -->
      <h3>🔗 Posicionamiento orgánico (SEO)</h3>
      <div class="diag-text">{diagSEO}</div>

      {/* Trend alert — before the metrics if domain is losing visibility */}
      {hasTrendAlert && (
        <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:0.5rem;padding:0.75rem 1rem;margin-bottom:0.875rem;">
          <p style="color:#dc2626;font-weight:700;margin:0 0 0.25rem;font-size:0.9rem;">📉 Tendencia: pérdida de visibilidad orgánica activa</p>
          <p style="color:#991b1b;font-size:0.85rem;margin:0;line-height:1.6;">
            En el último período, el dominio ha <strong>perdido {fmt(seo!.trendLost)} keywords</strong> de posicionamiento frente a solo {fmt(seo!.trendUp)} ganadas.
            Esta tendencia negativa, si no se corrige, se traduce en caída de tráfico orgánico y pérdida de cuota frente a competidores.
          </p>
        </div>
      )}

      {seo ? (
        <>
          <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:0.75rem;">
            {[
              { label: 'Keywords en 1ª página', value: fmt(seo.keywordsTop10), bench: sectorAvgKW != null ? `sector: ${fmt(sectorAvgKW)}` : null, above: sectorAvgKW != null ? (seo.keywordsTop10 ?? 0) >= sectorAvgKW : null },
              { label: 'Tráf. org. estimado/mes', value: fmt(seo.organicTrafficEstimate), bench: avgETV > 0 ? `sector: ${fmt(Math.round(avgETV))}` : null, above: avgETV > 0 ? ownETV >= avgETV : null },
              { label: 'Total keywords indexadas', value: fmt(seo.organicKeywordsTotal), bench: null, above: null },
            ].map((m) => (
              <div style={`border-radius:0.5rem;padding:0.75rem;text-align:center;border:1px solid ${m.above === true ? '#bbf7d0' : m.above === false ? '#fecaca' : '#e2e8f0'};background:${m.above === true ? '#f0fdf4' : m.above === false ? '#fef2f2' : '#f8fafc'};`}>
                <div style={`font-size:1.25rem;font-weight:700;color:${m.above === true ? '#16a34a' : m.above === false ? '#dc2626' : '#0f172a'}`}>{m.value}</div>
                <div style="font-size:0.7rem;color:#64748b;margin-top:0.125rem;">{m.label}</div>
                {m.bench && <div style="font-size:0.6rem;color:#94a3b8;margin-top:0.2rem;">{m.bench}</div>}
              </div>
            ))}
          </div>

          {/* Ads equivalent value — key urgency driver */}
          {seo.estimatedAdsCost != null && seo.estimatedAdsCost > 0 && (
            <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:0.5rem;padding:0.625rem 0.875rem;margin-bottom:0.875rem;display:flex;align-items:center;gap:0.75rem;">
              <span style="font-size:1.25rem;">💰</span>
              <p style="margin:0;font-size:0.875rem;color:#15803d;line-height:1.5;">
                <strong>Tráfico equivalente en Google Ads: ~{fmt(seo.estimatedAdsCost)}€/mes.</strong>
                {' '}Ese es el valor real del tráfico orgánico que estás generando sin pagar por él.
              </p>
            </div>
          )}

          {/* Quick wins — pos 4-10 keywords */}
          {(seo.keywordsPos4to10 ?? 0) > 0 && (
            <div style="background:#f0f9ff;border:1px solid #bae6fd;border-radius:0.5rem;padding:0.625rem 0.875rem;margin-bottom:0.875rem;display:flex;align-items:center;gap:0.75rem;">
              <span style="font-size:1.25rem;">⚡</span>
              <p style="margin:0;font-size:0.875rem;color:#0369a1;line-height:1.5;">
                <strong>Tienes {fmt(seo.keywordsPos4to10)} keywords en posiciones 4-10</strong> — a un empujón de la primera página.
                {' '}Con optimización moderada de contenido, estas keywords pueden generar tráfico nuevo sin crear páginas desde cero.
              </p>
            </div>
          )}

          {/* Context for keywords top 10 */}
          {seo.keywordsTop10 != null && (
            <p style="font-size:0.8rem;color:#475569;margin-bottom:0.875rem;line-height:1.6;">
              {seo.keywordsTop10 >= 500
                ? `Con ${fmt(seo.keywordsTop10)} keywords en primera página, tienes una presencia orgánica sólida. Es una base competitiva real.`
                : seo.keywordsTop10 >= 50
                ? `${fmt(seo.keywordsTop10)} keywords en primera página es un nivel de posicionamiento moderado — hay margen claro de crecimiento frente a líderes del sector.`
                : seo.keywordsTop10 >= 5
                ? `${fmt(seo.keywordsTop10)} keywords en primera página. Tienes presencia inicial pero la visibilidad orgánica es todavía limitada.`
                : `Muy pocas keywords en primera página de Google. El posicionamiento orgánico es una oportunidad de crecimiento prioritaria.`}
            </p>
          )}
          {totalPlayers > 1 && (
            <p style="font-size:0.8rem;color:#64748b;margin-bottom:1rem;">
              📊 Posición en ranking de tráfico orgánico sectorial: <strong style={`color:${ownRank <= Math.ceil(totalPlayers / 2) ? '#16a34a' : '#dc2626'}`}>#{ownRank} de {totalPlayers}</strong>
            </p>
          )}
        </>
      ) : (
        /* SEO skipped — sales message + technical SEO signals from crawl as fallback */
        <>
          <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.625rem;padding:1.25rem 1.5rem;margin-bottom:0.875rem;">
            <p style="font-weight:600;color:#1e293b;margin:0 0 0.375rem;font-size:0.95rem;">Tu dominio aún no tiene suficiente historial en los índices de búsqueda</p>
            <p style="font-size:0.875rem;color:#475569;margin:0;line-height:1.65;">No se pudieron obtener datos de tráfico orgánico estimado para este dominio. Esto es habitual en dominios recientes, nichos muy locales o webs con poca actividad orgánica — y es precisamente una de las oportunidades que AION puede ayudarte a resolver.</p>
          </div>
          <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:0.75rem;margin-top:0.5rem;">
          {[
            { label: 'Sitemap XML', ok: crawl.hasSitemap, note: crawl.hasSitemap ? 'Presente — Google puede rastrear el sitio' : 'No detectado — dificulta la indexación' },
            { label: 'Etiqueta Canonical', ok: crawl.hasCanonical, note: crawl.hasCanonical ? 'Presente — evita contenido duplicado' : 'No detectada — riesgo de duplicados' },
            { label: 'Datos estructurados', ok: crawl.hasSchemaMarkup, note: crawl.hasSchemaMarkup ? `Schema.org detectado (${(crawl.schemaTypes || []).slice(0,2).join(', ')})` : 'Sin Schema.org — menor visibilidad en rich results' },
            { label: 'Volumen de contenido', ok: (crawl.wordCount || 0) >= 300, note: `${crawl.wordCount || 0} palabras en página principal${(crawl.wordCount || 0) < 300 ? ' — contenido escaso para SEO' : ' — base de contenido aceptable'}` },
            ...(ps?.mobile?.seo != null ? [{ label: 'SEO técnico (Lighthouse)', ok: ps.mobile.seo >= 80, note: `Puntuación ${ps.mobile.seo}/100${ps.mobile.seo < 80 ? ' — hay mejoras técnicas pendientes' : ' — buena salud técnica'}` }] : []),
            ...(traffic?.channels?.organic?.visits ? [{ label: 'Tráfico orgánico', ok: true, note: `~${fmt(traffic.channels.organic.visits)} visitas/mes desde búsquedas orgánicas` }] : []),
          ].map((item) => (
            <div style={`display:flex;gap:0.625rem;align-items:flex-start;padding:0.75rem;border-radius:0.5rem;border:1px solid ${item.ok ? '#bbf7d0' : '#fecaca'};background:${item.ok ? '#f0fdf4' : '#fef2f2'};`}>
              <span style={`font-size:1rem;flex-shrink:0;${item.ok ? 'color:#16a34a' : 'color:#dc2626'}`}>{item.ok ? '✓' : '✗'}</span>
              <div>
                <div style="font-size:0.8rem;font-weight:600;color:#1e293b;">{item.label}</div>
                <div style="font-size:0.75rem;color:#64748b;margin-top:0.125rem;">{item.note}</div>
              </div>
            </div>
          ))}
          </div>
        </>
      )}

      <!-- Top páginas -->
      {seoPages && (
        <div style="margin-top:0.75rem;">
          <p style="font-size:0.8rem;font-weight:600;color:#475569;margin-bottom:0.5rem;text-transform:uppercase;letter-spacing:0.05em;">Top páginas orgánicas</p>
          <table>
            <thead><tr><th>Página</th><th style="text-align:right;">Tráf. est./mo</th><th style="text-align:right;">Keywords</th></tr></thead>
            <tbody>
              {seoPages.pages.map((p: any) => (
                <tr>
                  <td style="font-size:0.8rem;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title={p.pageAddress}>
                    {p.pageAddress.replace(/^https?:\/\/[^/]+/, '') || '/'}
                  </td>
                  <td style="text-align:right;font-size:0.8rem;">{p.trafficEstimate != null ? fmt(p.trafficEstimate) + '/mo' : '—'}</td>
                  <td style="text-align:right;font-size:0.8rem;">{p.keywords ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <!-- 2.2 GEO / IA -->
      <div class="sub-section">
        <h3>🤖 Visibilidad en IA (GEO)</h3>
        <p style="font-size:0.875rem;color:#64748b;margin-bottom:0.75rem;">Cuando alguien le pregunta a ChatGPT o Perplexity por servicios como los tuyos, ¿apareces en la respuesta? Hemos simulado consultas reales.</p>
        {geo && geo.queries?.length > 0 ? (
          <>
            <table style="margin-bottom:0.75rem;">
              <thead><tr><th>Consulta simulada</th><th style="text-align:center;">¿Apareces?</th><th>Score pts</th></tr></thead>
              <tbody>
                {geo.queries.slice(0, 5).map((q: any) => (
                  <tr>
                    <td style="font-size:0.8rem;color:#334155;max-width:280px;">{q.query}</td>
                    <td style="text-align:center;">{q.mentioned ? '✅' : '❌'}</td>
                    <td style="font-size:0.8rem;color:#64748b;">{q.pts ?? '—'} pts</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <div style="display:flex;gap:1rem;margin-bottom:0.75rem;">
              <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.5rem;padding:0.75rem 1rem;flex:1;text-align:center;">
                <div style={`font-size:1.5rem;font-weight:800;color:${scoreColor(geo.overallScore ?? 0)}`}>{geo.overallScore ?? 0}/100</div>
                <div style="font-size:0.7rem;color:#64748b;">Score GEO global</div>
              </div>
              <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.5rem;padding:0.75rem 1rem;flex:1;text-align:center;">
                <div style={`font-size:1.5rem;font-weight:800;color:${scoreColor(geo.sectorScore ?? 0)}`}>{geo.sectorScore ?? 0}</div>
                <div style="font-size:0.7rem;color:#64748b;">Visibilidad espontánea</div>
              </div>
              <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.5rem;padding:0.75rem 1rem;flex:1;text-align:center;">
                <div style={`font-size:1.5rem;font-weight:800;color:${scoreColor(geo.brandScore ?? 0)}`}>{geo.brandScore ?? 0}</div>
                <div style="font-size:0.7rem;color:#64748b;">Reconocimiento de marca</div>
              </div>
            </div>
            <div class="diag-text">{diagGEO}</div>
            {(geo.overallScore ?? 0) < 30 && (
              <div style="background:#fef2f2;border:1px solid #fca5a5;border-radius:0.5rem;padding:0.75rem 1rem;margin-top:0.75rem;">
                <p style="color:#dc2626;font-weight:600;margin:0 0 0.25rem;">⚠️ Nivel crítico de invisibilidad en IA</p>
                <p style="color:#991b1b;font-size:0.8rem;margin:0;">Tus competidores están capturando demanda que antes pasaba por Google y que ahora se resuelve en ChatGPT, Perplexity y similares. Sin presencia en IA, no existes para un segmento creciente de búsquedas informacionales y de comparación.</p>
              </div>
            )}
          </>
        ) : (
          <p style="color:#94a3b8;font-size:0.875rem;">Datos GEO no disponibles para este análisis.</p>
        )}
      </div>

      <!-- 2.2.5 GEO-SEO cross-analysis (only when both modules have data) -->
      {seo?.topKeywords?.length > 0 && geo && geo.queries?.some((q: any) => !q.isBrandQuery && !q.mentioned) && (
        <div class="sub-section">
          <h3>🔍 Gap SEO → IA: Rankeas en Google pero no en ChatGPT</h3>
          <p style="font-size:0.875rem;color:#334155;margin-bottom:0.875rem;line-height:1.65;">
            Google ya confirma tu relevancia en estas búsquedas — apareces en primera página.
            Sin embargo, cuando un usuario hace la misma pregunta en ChatGPT o Perplexity, tu marca no aparece en la respuesta.
            Este es el gap más accionable de tu presencia digital: autoridad ya demostrada en buscadores, aún sin transferir a los motores de IA.
          </p>
          <div style="display:flex;flex-direction:column;gap:0.5rem;margin-bottom:0.875rem;">
            {seo.topKeywords.slice(0, 5).map((kw: any) => (
              <div style="display:flex;align-items:center;gap:0.75rem;padding:0.625rem 0.875rem;background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.5rem;">
                <div style="flex:1;min-width:0;">
                  <span style="font-size:0.875rem;font-weight:600;color:#1e293b;">{kw.keyword}</span>
                  {kw.volume > 0 && <span style="font-size:0.75rem;color:#94a3b8;margin-left:0.5rem;">{fmt(kw.volume)} búsquedas/mes</span>}
                </div>
                <div style="display:flex;gap:0.5rem;align-items:center;flex-shrink:0;">
                  <span style="font-size:0.7rem;background:#dcfce7;color:#16a34a;border-radius:9999px;padding:0.15rem 0.5rem;font-weight:600;">Google #{kw.position}</span>
                  <span style="font-size:0.7rem;background:#fee2e2;color:#dc2626;border-radius:9999px;padding:0.15rem 0.5rem;font-weight:600;">IA ✗</span>
                </div>
              </div>
            ))}
          </div>
          <p style="font-size:0.8rem;color:#64748b;background:#fffbeb;border:1px solid #fde68a;border-radius:0.375rem;padding:0.5rem 0.875rem;margin:0;line-height:1.5;">
            💡 Mejorar tu visibilidad en IA para estos términos es la iniciativa GEO de mayor retorno: la intención de búsqueda ya existe, la demanda ya la captura Google, y tú ya eres relevante. Solo falta que los motores de IA lo sepan.
          </p>
        </div>
      )}

      <!-- 2.3 Mix canales -->
      {traffic && channelSegments.length > 0 && (
        <div class="sub-section">
          <h3>📊 Mix de canales de tráfico</h3>
          <div class="diag-text">{diagTraffic}</div>
          <!-- Stacked bar -->
          <div style="display:flex;height:28px;border-radius:0.5rem;overflow:hidden;margin-bottom:0.75rem;">
            {channelSegments.map((ch) => (
              <div title={`${ch.label}: ${ch.pct}%`} style={`width:${ch.pct}%;background:${ch.color};transition:none;`}></div>
            ))}
          </div>
          <!-- Legend -->
          <div style="display:flex;flex-wrap:wrap;gap:0.75rem;">
            {channelSegments.map((ch) => (
              <div style="display:flex;align-items:center;gap:0.375rem;font-size:0.8rem;color:#475569;">
                <span style={`width:10px;height:10px;border-radius:2px;background:${ch.color};display:inline-block;`}></span>
                {ch.label} <strong>{ch.pct}%</strong>
              </div>
            ))}
          </div>
          {traffic.visitsGrowth != null && (
            <div style={`margin-top:0.75rem;font-size:0.85rem;font-weight:600;color:${traffic.visitsGrowth >= 0 ? '#16a34a' : '#dc2626'}`}>
              {traffic.visitsGrowth > 0 ? '↑' : '↓'} {Math.abs(traffic.visitsGrowth)}% de tráfico total vs año anterior
            </div>
          )}
        </div>
      )}

      <!-- 2.4 GBP -->
      {gbp && (
        <div class="sub-section">
          <h3>📍 Google Business Profile</h3>
          <p style="font-size:0.875rem;color:#334155;">
            <strong>{gbp.name}</strong> · Valoración: <strong>{gbp.rating}/5</strong> ⭐ ({gbp.reviewCount} reseñas) ·
            {gbp.rating >= 4 ? ' Buena reputación en Google Maps.' : gbp.rating >= 3.5 ? ' Reputación mejorable — trabajar las reseñas activamente.' : ' Valoración baja — atención urgente a las reseñas y respuestas.'}
          </p>
        </div>
      )}

      <!-- 2.5 Presencia social -->
      {(linkedin || instagram) && (
        <div class="sub-section">
          <h3>👥 Presencia social</h3>
          {linkedin && (
            <div style="margin-bottom:0.875rem;">
              <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:0.5rem;">
                <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.5rem;padding:0.5rem 0.875rem;text-align:center;">
                  <div style="font-size:1.1rem;font-weight:700;color:#0f172a;">{fmt(liFollowers)}</div>
                  <div style="font-size:0.65rem;color:#64748b;">Seguidores LinkedIn</div>
                </div>
                {liEmployees > 0 && (
                  <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.5rem;padding:0.5rem 0.875rem;text-align:center;">
                    <div style="font-size:1.1rem;font-weight:700;color:#0f172a;">{liEmployees}</div>
                    <div style="font-size:0.65rem;color:#64748b;">Empleados</div>
                  </div>
                )}
                {liEmployees > 0 && (
                  <div style={`background:#f8fafc;border:1px solid ${liRatio >= 200 ? '#bbf7d0' : liRatio >= 50 ? '#fef3c7' : '#fecaca'};border-radius:0.5rem;padding:0.5rem 0.875rem;text-align:center;`}>
                    <div style={`font-size:1.1rem;font-weight:700;color:${liRatio >= 200 ? '#16a34a' : liRatio >= 50 ? '#d97706' : '#dc2626'}`}>{liRatio}%</div>
                    <div style="font-size:0.65rem;color:#64748b;">Ratio seg./emp.</div>
                  </div>
                )}
