      // Always start at first page (Resumen) on mobile
      if (report) {
        setTimeout(() => { report.scrollTo({ left: 0, behavior: 'instant' }); }, 50);
        // Clear URL hash that might scroll to another section
        if (window.location.hash) history.replaceState(null, '', window.location.pathname);
      }
      const sections = ['hero','seo','ia','competidores','experiencia','plan'];

      function updateMobileActive(idx) {
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
        navBtns.forEach((b, i) => b.classList.toggle('active', i === idx));
      }

      // Scroll snap detection
      let scrollTimer;
      report?.addEventListener('scroll', () => {
        clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => {
          const idx = Math.round((report.scrollLeft) / window.innerWidth);
          updateMobileActive(idx);
        }, 50);
      });

      // Nav button clicks → scroll to section
      navBtns.forEach((btn, i) => {
        btn.addEventListener('click', () => {
          report?.scrollTo({ left: i * window.innerWidth, behavior: 'smooth' });
          updateMobileActive(i);
        });
      });
    }
  </script>
</body>
</html>
