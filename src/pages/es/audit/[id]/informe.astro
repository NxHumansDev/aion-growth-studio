            {displayStrategic.length > 0 && (
              <div style="margin-bottom:2rem;">
                <div style="font-size:0.82rem;font-weight:800;color:#aac7ff;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:14px;display:flex;align-items:center;gap:8px;">
                  <span class="material-symbols-outlined" style="color:#aac7ff;">strategy</span>
