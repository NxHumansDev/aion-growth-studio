---
export const prerender = false;
import { getAuditPage } from '../../../../lib/audit/notion';
import { computeHealthScore, scoreColor, scoreLabel, scoreEmoji } from '../../../../lib/audit/report/health-score';
import {
  diagnosisHealthSummary, diagnosisSEO, diagnosisGEO, diagnosisTrafficMix,
  diagnosisPageSpeed, diagnosisFunnel, diagnosisTechStack, diagnosisCompetitiveGap, diagnosisSchema,
} from '../../../../lib/audit/report/diagnostics';

const { id } = Astro.params;
let audit: any = null;
let error = '';
try { audit = await getAuditPage(id!); } catch (e: any) { error = e.message || 'Error.'; }
if (!audit || audit.status !== 'completed') { return Astro.redirect(`/es/audit/${id}`); }

const r = audit.results;
const domain = new URL(audit.url).hostname.replace(/^www\./, '');
const auditDate = new Date().toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
const health = computeHealthScore(r);

// Data shortcuts
const crawl = r.crawl || {};
const seo = (!r.seo?.skipped && r.seo) ? r.seo : null;
const geoTruncated = r.geo?._truncated === true;
const geoApiError = !r.geo?.skipped && r.geo?.error && !geoTruncated ? r.geo.error : null;
const geo = (!r.geo?.skipped && r.geo && !geoTruncated) ? r.geo : null;
const traffic = (!r.traffic?.skipped && r.traffic) ? r.traffic : null;
const ps = (!r.pagespeed?.skipped && r.pagespeed) ? r.pagespeed : null;
const gbp = (!r.gbp?.skipped && r.gbp?.found) ? r.gbp : null;
const ssl = (!r.ssl?.skipped && r.ssl) ? r.ssl : null;
const ctItemsRaw: any[] = r.competitor_traffic?.items || [];
const ctItems: any[] = ctItemsRaw.filter((c: any) => !c.apiError && (c.organicTrafficEstimate != null || c.keywordsTop10 != null));
const hasCompetitorData = ctItems.length > 0;
const competitors: any[] = r.competitors?.competitors || [];
const kg = (!r.keyword_gap?.skipped && r.keyword_gap?.items?.length) ? r.keyword_gap : null;
const ts = (!r.techstack?.skipped && r.techstack) ? r.techstack : null;
const cv = (!r.conversion?.skipped && r.conversion) ? r.conversion : null;
const cc = (!r.content_cadence?.skipped && (r.content_cadence?.totalPosts ?? 0) >= 3) ? r.content_cadence : null;
const rep = (!r.reputation?.skipped && r.reputation?.reputationLevel && r.reputation.reputationLevel !== 'no_data') ? r.reputation : null;
const repRaw = r.reputation || {}; // always available, even when reputationLevel === 'no_data'
const metaAds = (!r.meta_ads?.skipped && r.meta_ads) ? r.meta_ads : null;
const qa = r.qa || null;
const qaSuppressed: string[] = qa?.suppressedSections || [];
const insights = r.insights || {};
const linkedin = (!r.linkedin?.skipped && r.linkedin?.found) ? r.linkedin : null;
const instagram = (!r.instagram?.skipped && r.instagram?.found) ? r.instagram : null;
const content = (!r.content?.skipped && r.content) ? r.content : null;
const sector = r.sector?.sector || audit.sector || '';
const businessType: string = crawl.businessType || 'unknown';

// New module results
const compPS = (r.competitor_pagespeed && !r.competitor_pagespeed?.skipped) ? r.competitor_pagespeed : null;
const kwGap = kg;

// Brand authority: blog + news
const hasBlogEs = !!(crawl.hasBlog || (cc && cc.totalPosts >= 1));
const blogUrlEs: string | undefined = cc?.blogUrl || crawl.blogUrl;
const newsCountEs: number = repRaw.newsCount ?? 0;
const newsHeadlinesEs: Array<{title:string;source:string;date?:string}> = repRaw.newsHeadlines || [];

// Visibility sub-scores (for the Visibilidad Digital block header)
const visSeoSub     = r.score?.breakdown?.seo ?? r.score?.breakdown?.seoVisibility ?? 0;
const visGeoSub     = r.score?.breakdown?.geo ?? geo?.overallScore ?? 0;
const _trafficCh    = (r.traffic?.channels || {}) as Record<string, any>;
const _totalTraf    = Object.values(_trafficCh).reduce((s: number, c: any) => s + (c.visits || 0), 0);
const _organicTraf  = _trafficCh.organic?.visits || 0;
const visTrafficSub = _totalTraf > 0 ? Math.min(100, Math.round((_organicTraf / _totalTraf) * 150)) : 0;

// Brand Authority score (0-100): backlinks + blog + press + GEO visibility + LinkedIn
const brandAuthorityScoreEs = (() => {
  let ba = 0;
  const rd = seo?.referringDomains ?? 0;
  if (rd >= 500) ba += 35;
  else if (rd >= 100) ba += 25;
  else if (rd >= 20) ba += 15;
  else if (rd >= 5) ba += 8;
  else if (rd >= 1) ba += 3;
  const dr = seo?.domainRank ?? 0;
  if (dr > 0) ba += Math.round(Math.min(dr / 100, 1) * 25);
  if (hasBlogEs) {
    ba += 12;
    if ((cc?.totalPosts ?? 0) >= 20) ba += 13;
    else if ((cc?.totalPosts ?? 0) >= 5) ba += 7;
  }
  const nc = newsCountEs;
  if (nc >= 10) ba += 15;
  else if (nc >= 5) ba += 10;
  else if (nc >= 2) ba += 6;
  else if (nc >= 1) ba += 3;
  // GEO: menciones en IA como proxy de reconocimiento de marca (0–15 pts)
  const geoMR = geo?.mentionRate ?? 0;
  if (geoMR >= 70) ba += 15;
  else if (geoMR >= 40) ba += 10;
  else if (geoMR >= 15) ba += 5;
  // LinkedIn: followers como señal de autoridad profesional (0–10 pts)
  const liF = linkedin?.followers ?? 0;
  if (liF >= 10000) ba += 10;
  else if (liF >= 1000) ba += 6;
  else if (liF >= 100) ba += 3;
  return Math.min(100, ba);
})();

const visScore      = health.visibilidad;
const visColor      = scoreColor(visScore);
const visSummaryText = (insights as any)?.visibilitySummary || null;

// Benchmark header vars
const benchScore = health.competitividad;
const benchColor = scoreColor(benchScore);
const benchSummaryText = (insights as any)?.benchmarkSummary || null;

// Experiencia header vars
const expScore = health.experiencia;
const expColor = scoreColor(expScore);
const expSummaryText = (insights as any)?.experienceSummary || null;

// Helpers
function fmt(n: number | undefined | null): string {
  if (n == null) return '—';
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
  if (n >= 1_000) return Math.round(n / 1_000) + 'K';
  return String(n);
}

type AreaStatus = 'good' | 'medium' | 'bad';
const ss = (v: number): AreaStatus => v >= 60 ? 'good' : v >= 35 ? 'medium' : 'bad';

function statusStyle(s: AreaStatus): { bg: string; fg: string; label: string } {
  if (s === 'good') return { bg: '#E1F5EE', fg: '#085041', label: 'Bien' };
  if (s === 'medium') return { bg: '#FAEEDA', fg: '#633806', label: 'Medio' };
  return { bg: '#FCEBEB', fg: '#791F1F', label: 'Mal' };
}

// 7-area semaphore
const statusByArea: { area: string; status: AreaStatus; summary: string; anchor: string }[] = [
  { area: 'SEO Orgánico', status: ss(visSeoSub ?? health.visibilidad ?? 0), summary: seo ? `${fmt(seo.keywordsTop10)} keywords top 10, ~${fmt(seo.organicTrafficEstimate)} visitas/mes` : 'Sin datos SEO', anchor: '#seo' },
  { area: 'Visibilidad IA', status: ss(geo?.mentionRate ?? 0), summary: geo ? `Mencionado en ${geo.mentionRate ?? 0}% de las consultas` : 'Sin datos GEO', anchor: '#ia' },
  { area: 'Reputación', status: ss(brandAuthorityScoreEs), summary: seo?.domainRank != null ? `Domain rank: ${seo.domainRank}/100, ${fmt(seo.referringDomains)} dominios enlazantes` : 'Sin datos de autoridad digital', anchor: '#autoridad' },
  { area: 'Benchmark', status: hasCompetitorData ? ss(health.competitividad ?? 0) : 'bad', summary: hasCompetitorData ? `${ctItems.length} competidores con datos` : 'Sin datos de competidores', anchor: '#competidores' },
  { area: 'Web & Velocidad', status: ss(ps?.mobile?.performance ?? 0), summary: ps ? `Score móvil: ${ps.mobile?.performance ?? '—'}/100` : 'Sin datos PageSpeed', anchor: '#experiencia' },
  { area: 'Conversión', status: ss(cv?.funnelScore ?? health.conversion ?? 0), summary: cv ? `Funnel score: ${cv.funnelScore ?? '—'}/100` : 'Sin datos', anchor: '#experiencia' },
  { area: 'Medición', status: ss(ts?.maturityScore ?? health.measurement ?? 0), summary: ts ? (ts.analytics?.length ? ts.analytics.join(', ') : 'Sin analytics') : 'Sin datos', anchor: '#experiencia' },
];

// Tech stack
const techStackMapped = {
  analytics: { detected: (ts?.analytics?.length ?? 0) > 0, tool: ts?.analytics?.[0] as string|undefined },
  tagManager: { detected: (ts?.tagManager?.length ?? 0) > 0, tool: ts?.tagManager?.[0] as string|undefined },
  metaPixel: { detected: ts?.conversionPixels?.some((p: string) => /meta|facebook|fbq/i.test(p)) ?? false },
  googleAdsPixel: { detected: ts?.conversionPixels?.some((p: string) => /google.*ads|doubleclick/i.test(p)) ?? false },
  chat: { detected: (ts?.chatSupport?.length ?? 0) > 0, tool: ts?.chatSupport?.[0] as string|undefined },
  heatmaps: { detected: (ts?.heatmaps?.length ?? 0) > 0, tool: ts?.heatmaps?.[0] as string|undefined },
};

// Schema
const schemaTypes: string[] = crawl.schemaTypes || [];
const RECOMMENDED_SCHEMAS: Record<string, string[]> = {
  ecommerce: ['Organization','WebSite','Product','Offer','BreadcrumbList'],
  saas: ['Organization','WebSite','SoftwareApplication','FAQPage'],
  b2b: ['Organization','WebSite','Service','FAQPage','BreadcrumbList'],
  local: ['LocalBusiness','Organization','GeoCoordinates','OpeningHoursSpecification'],
  media: ['Organization','WebSite','Article','BreadcrumbList'],
  unknown: ['Organization','WebSite','BreadcrumbList'],
};
const recommendedSchemas = RECOMMENDED_SCHEMAS[businessType] || RECOMMENDED_SCHEMAS.unknown;
const presentLower = schemaTypes.map((t: string) => t.toLowerCase());
const missingSchemas = recommendedSchemas.filter(s => !presentLower.includes(s.toLowerCase()));

// Keyword data
const kwGapItems: any[] = kwGap?.items?.slice(0, 8) || [];
const pos4to10Keywords: any[] = (seo?.topKeywords || []).filter((k: any) => k.position >= 4 && k.position <= 10).slice(0, 5);
// seoToAiGap removed — data was incorrect (all SEO keywords shown as IA misses regardless)

// Paid
const clientPaidKw = seo?.paidKeywordsTotal ?? 0;
const compPaidItems: any[] = ctItems.filter((c: any) => (c.paidKeywordsTotal ?? 0) > 0);

// Traffic channels
const channelLabels: Record<string, string> = { organic:'Orgánico', direct:'Directo', social:'Social', referral:'Referral', paid:'Paid', email:'Email' };
const channelColors: Record<string, string> = { organic:'#1A4B8C', direct:'#5A6478', social:'#7c3aed', referral:'#0891b2', paid:'#D85A30', email:'#16a34a' };
const channels = traffic?.channels || {};
const totalVisits = Object.values(channels).reduce((s: number, c: any) => s + (c.visits || 0), 0);
const channelSegments = Object.entries(channels)
  .sort(([,a]: any,[,b]: any) => (b.visits||0)-(a.visits||0))
  .map(([key, ch]: [string, any]) => ({ key, label: channelLabels[key]||key, visits: ch.visits||0, pct: totalVisits>0 ? Math.round(((ch.visits||0)/totalVisits)*100) : 0, color: channelColors[key]||'#94a3b8' }))
  .filter(c => c.pct > 0);

// SVG builder functions
function polarXY(cx: number, cy: number, r: number, angleDeg: number): [number, number] {
  const rad = (angleDeg - 90) * Math.PI / 180;
  return [cx + r * Math.cos(rad), cy + r * Math.sin(rad)];
}

function buildGauge(score: number, size: 'large'|'small' = 'large'): string {
  const s = size === 'large' ? 120 : 84;
  const cx = s/2, cy = s/2, r = size==='large' ? 44 : 30, sw = size==='large' ? 9 : 7;
  const color = score>=60 ? '#1D9E75' : score>=35 ? '#BA7517' : '#E24B4A';
  const startDeg = 135, totalArc = 270;
  const filledEnd = startDeg + (score/100)*totalArc;
  function arc(from: number, to: number): string {
    const [x1,y1] = polarXY(cx,cy,r,from);
    const [x2,y2] = polarXY(cx,cy,r,to);
    const large = (to-from)>180 ? 1 : 0;
    return `M ${x1.toFixed(2)} ${y1.toFixed(2)} A ${r} ${r} 0 ${large} 1 ${x2.toFixed(2)} ${y2.toFixed(2)}`;
  }
  const fs = size==='large' ? 26 : 18;
  return `<svg width="${s}" height="${s}" viewBox="0 0 ${s} ${s}"><path d="${arc(startDeg, startDeg+totalArc)}" fill="none" stroke="#E5E7EB" stroke-width="${sw}" stroke-linecap="round"/>${score>0?`<path d="${arc(startDeg, filledEnd)}" fill="none" stroke="${color}" stroke-width="${sw}" stroke-linecap="round"/>`:''}
<text x="${cx}" y="${cy + fs*0.38}" text-anchor="middle" font-size="${fs}" font-weight="600" fill="#1A1A2E" font-family="Inter,sans-serif">${score}</text></svg>`;
}

function buildRadarChart(labels: string[], datasets: Array<{label:string;color:string;values:number[]}>): string {
  const cx=130,cy=130,size=260,maxR=90,n=labels.length;
  function pt(value: number, i: number): [number,number] {
    return polarXY(cx, cy, (value/100)*maxR, (i/n)*360);
  }
  let gridSvg = '';
  for (const level of [20,40,60,80,100]) {
    const pts = Array.from({length:n},(_,i)=>{const[x,y]=polarXY(cx,cy,(level/100)*maxR,(i/n)*360);return `${x.toFixed(1)},${y.toFixed(1)}`;}).join(' ');
    gridSvg += `<polygon points="${pts}" fill="none" stroke="#E5E7EB" stroke-width="0.8"/>`;
  }
  let axesSvg = '';
  for (let i=0;i<n;i++) {
    const[x,y]=polarXY(cx,cy,maxR,(i/n)*360);
    axesSvg += `<line x1="${cx}" y1="${cy}" x2="${x.toFixed(1)}" y2="${y.toFixed(1)}" stroke="#E5E7EB" stroke-width="0.8"/>`;
  }
  let labelSvg = '';
  for (let i=0;i<n;i++) {
    const[x,y]=polarXY(cx,cy,maxR+18,(i/n)*360);
    labelSvg += `<text x="${x.toFixed(1)}" y="${y.toFixed(1)}" text-anchor="middle" dominant-baseline="middle" font-size="11" fill="#5A6478" font-family="Inter,sans-serif">${labels[i]}</text>`;
  }
  let dataSvg = '';
  for (const ds of datasets) {
    const pts = ds.values.map((v,i)=>{const[x,y]=pt(Math.min(v,100),i);return `${x.toFixed(1)},${y.toFixed(1)}`;}).join(' ');
    dataSvg += `<polygon points="${pts}" fill="${ds.color}22" stroke="${ds.color}" stroke-width="2" opacity="0.9"/>`;
  }
  return `<svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}">${gridSvg}${axesSvg}${labelSvg}${dataSvg}</svg>`;
}

function buildHorizontalBars(items: Array<{label:string;value:number;color:string}>, unit='%'): string {
  const maxVal = Math.max(...items.map(i=>i.value),1);
  const barH=18, gap=8, labelW=90, totalW=320;
  const h = items.length*(barH+gap)+gap;
  let bars = '';
  items.forEach((item,idx)=>{
    const y=gap+idx*(barH+gap);
    const bw = Math.max((item.value/maxVal)*(totalW-labelW-52), 2);
    bars += `<text x="${labelW-4}" y="${y+barH*0.72}" text-anchor="end" font-size="10" fill="#5A6478" font-family="Inter,sans-serif">${item.label}</text><rect x="${labelW}" y="${y}" width="${bw.toFixed(1)}" height="${barH}" rx="3" fill="${item.color}"/><text x="${labelW+bw+4}" y="${y+barH*0.72}" font-size="10" fill="#1A1A2E" font-family="Inter,sans-serif">${item.value}${unit}</text>`;
  });
  return `<svg width="${totalW}" height="${h}" viewBox="0 0 ${totalW} ${h}">${bars}</svg>`;
}

// displayCompetitors: competitors with actual SEO data (no apiError).
// Fallback: AI-detected competitor names (always populated).
const displayCompetitors: any[] = (() => {
  const seen = new Set<string>();
  const out: any[] = [];
  // Only include ctItems with actual data — hide "sin datos" rows from the benchmark table
  for (const c of ctItems) {
    if (c.domain && !seen.has(c.domain)) { seen.add(c.domain); out.push(c); }
  }
  for (const c of competitors) {
    let d = c.url;
    try { d = new URL(c.url.startsWith('http') ? c.url : `https://${c.url}`).hostname.replace(/^www\./, ''); } catch {}
    if (d && !seen.has(d)) { seen.add(d); out.push({ name: c.name, domain: d, url: c.url }); }
  }
  return out.slice(0, 5);
})();

// Giant competitor context callout (needs displayCompetitors)
const avgCompKWes = hasCompetitorData && seo ? ctItems.reduce((s: number, c: any) => s + (c.keywordsTop10 ?? 0), 0) / ctItems.length : 0;
const showGiantCalloutEs = hasCompetitorData && seo && avgCompKWes > 0 && avgCompKWes >= (seo.keywordsTop10 ?? 0) * 5;
const giantCompNamesEs = displayCompetitors.slice(0, 3).map((c: any) => c.name || c.domain).join(', ');

// Radar datasets
const maxKW = Math.max(seo?.keywordsTop10||0, ...displayCompetitors.map((c:any)=>c.keywordsTop10||0), 1);
const maxFollowers = Math.max(linkedin?.followers||0, instagram?.followers||0, ...(linkedin?.competitors||[]).map((c:any)=>c.followers||0), ...(instagram?.competitors||[]).map((c:any)=>c.followers||0), 1);

const radarColors = ['#1A4B8C','#D85A30','#888780'];
const radarDatasets = [
  { label: domain, color: radarColors[0], values: [
    Math.round(((seo?.keywordsTop10||0)/maxKW)*100),
    geo?.mentionRate??0,
    (seo?.paidKeywordsTotal||0)>0?80:20,
    Math.round((Math.max(linkedin?.followers||0,instagram?.followers||0)/maxFollowers)*100),
    ps?.mobile?.performance??0,
  ]},
  ...displayCompetitors.slice(0,2).map((ct:any, idx:number)=>({
    label: ct.name||ct.domain,
    color: radarColors[idx+1],
    values: [
      ct.keywordsTop10 != null ? Math.round((ct.keywordsTop10/maxKW)*100) : 0,
      geo?.competitorMentions?.[idx]?.mentionRate??0,
      (ct.paidKeywordsTotal||0)>0?80:20,
      Math.round((Math.max((linkedin?.competitors||[])[idx]?.followers||0,(instagram?.competitors||[])[idx]?.followers||0)/maxFollowers)*100),
      compPS?.items?.find((p:any)=>p.domain===ct.domain)?.mobileScore ?? compPS?.items?.[idx]?.mobileScore ?? 0,
    ],
  })),
];
const radarSvg = buildRadarChart(['SEO','GEO/IA','Paid','Social','Web'], radarDatasets);

// Gauge SVGs
const psGaugeMobile = ps ? buildGauge(ps.mobile?.performance??0, 'small') : '';
const psGaugeDesktop = ps ? buildGauge(ps.desktop?.performance??0, 'small') : '';

// Channel bar SVG
const channelBarSvg = channelSegments.length > 0
  ? buildHorizontalBars(channelSegments.slice(0,6).map(c=>({label:c.label,value:c.pct,color:c.color})))
  : '';

// Traffic/competitive data
const ownETV = seo?.organicTrafficEstimate||0;
const avgETV = hasCompetitorData ? ctItems.reduce((s:number,c:any)=>s+(c.organicTrafficEstimate||0),0)/ctItems.length : 0;
const trafficGap = hasCompetitorData ? Math.max(0,Math.round(avgETV-ownETV)) : 0;

// BusinessType
const btLabels: Record<string,string> = { ecommerce:'E-commerce', saas:'SaaS / Software', b2b:'B2B · Captación de leads', local:'Negocio local', media:'Media / Contenido' };
const btLabel = btLabels[businessType]||'';
const btObjectives: Record<string,string> = { ecommerce:'maximizar tus ventas online', saas:'incrementar activaciones y reducir churn', b2b:'generar leads cualificados y acortar el ciclo de venta', local:'capturar demanda local y mejorar tu reputación en Google', media:'crecer tu audiencia orgánica y monetizarla', unknown:'mejorar tu presencia digital y conversión' };
const btObjective = btObjectives[businessType]||btObjectives.unknown;

// CWV
function cwvStatus(metric: string, value: number): {color:string;label:string} {
  const t: Record<string,[number,number]> = { lcp:[2500,4000], cls:[0.1,0.25], fcp:[1800,3000], ttfb:[800,1800] };
  const [good,poor] = t[metric]||[50,90];
  return value<=good ? {color:'#1D9E75',label:'Bueno'} : value<=poor ? {color:'#BA7517',label:'Mejorable'} : {color:'#E24B4A',label:'Lento'};
}

// Insights/Plan
const quickWins: string[] = insights?.bullets?.slice(0,3)||[];
const strategicActions: any[] = insights?.initiatives?.slice(0,4)||[];
interface QuickWin { title: string; problem: string; impact: 'alto' | 'medio'; }
const fallbackQuickWins: QuickWin[] = [
  !techStackMapped.analytics.detected ? { title: 'Instalar Google Analytics 4 y Tag Manager', problem: 'Sin medición activa no puedes saber qué funciona ni optimizar ninguna acción de marketing.', impact: 'alto' } : null,
  ps&&(ps.mobile?.performance||0)<50 ? { title: `Reducir tiempo de carga móvil (ahora ${ps.mobile?.lcp != null ? (ps.mobile.lcp/1000).toFixed(1)+'s' : 'lento'})`, problem: 'Cada segundo de carga adicional reduce las conversiones entre un 10–20%. Tu web móvil necesita optimización urgente de imágenes y código.', impact: 'alto' } : null,
  !crawl.hasRobotsTxt ? { title: 'Añadir robots.txt', problem: 'Sin robots.txt Google puede rastrear páginas innecesarias, diluyendo el presupuesto de rastreo de las páginas que importan.', impact: 'medio' } : null,
  !cv?.hasContactForm ? { title: 'Añadir formulario de contacto visible', problem: 'Sin formulario en la página principal, los visitantes no tienen un camino claro para convertirse en leads.', impact: 'alto' } : null,
  geo&&(geo.mentionRate||0)<30 ? { title: 'Crear FAQ estructuradas para visibilidad en IA', problem: `Tu marca aparece en solo ${geo.mentionRate ?? 0}% de las consultas en motores de IA. Las FAQs son el formato más fácil para conseguir menciones.`, impact: 'medio' } : null,
  missingSchemas.length>0 ? { title: `Implementar Schema Markup (${missingSchemas.slice(0,2).join(', ')})`, problem: 'Sin datos estructurados, Google no puede mostrar tu información enriquecida en resultados de búsqueda.', impact: 'medio' } : null,
  seo&&(seo.keywordsPos4to10||0)>0 ? { title: `Optimizar ${fmt(seo.keywordsPos4to10)} keywords en posición 4–10`, problem: 'Estas keywords ya tienen tracción. Un artículo actualizado o una mejora de contenido puede llevarlas al top 3 sin crear nada nuevo.', impact: 'alto' } : null,
].filter(Boolean) as QuickWin[];
const displayQuickWins: QuickWin[] = quickWins.length>0
  ? quickWins.map((w: string) => ({ title: w, problem: '', impact: 'medio' as const }))
  : fallbackQuickWins.slice(0,4);
const fallbackStrategic = [
  { title:'Estrategia de contenido SEO', description:'Desarrolla un plan de contenido atacando las keywords del gap competitivo para capturar demanda orgánica incremental sin incrementar el presupuesto de paid.' },
  { title:'Presencia en IA generativa', description:'Optimiza tu contenido estructurado para que ChatGPT, Perplexity y Gemini te mencionen en las consultas clave de tu sector antes que a tus competidores.' },
  { title:'Optimización del funnel de conversión', description:'Mejora la tasa de conversión con CTAs más claros, prueba social visible y un formulario de captación A/B testeado.' },
  { title:'Medición y atribución multicanal', description:'Implementa GA4 + píxeles de conversión completos para medir el ROI real de cada canal y tomar decisiones basadas en datos.' },
];
const displayStrategic = strategicActions.length>0 ? strategicActions : fallbackStrategic.slice(0,4);

// GEO cross-model
const crossModel: any[] = geo?.crossModel||[];
const geoEngines = [...new Set(crossModel.map((e:any)=>e.name))];

// Match/Gap/Noise counts from keyword data
const topKeywords: any[] = seo?.topKeywords || [];
const matchCount = kwGapItems.filter((k: any) => k.clientPosition && k.clientPosition <= 10).length || topKeywords.filter((k: any) => k.position <= 10).length;
const gapCount = kwGapItems.filter((k: any) => !k.clientPosition || k.clientPosition > 20).length;
const noiseCount = topKeywords.filter((k: any) => k.position > 10 && k.volume < 50).length;

// Schema businessType label
const btLabelForSchema = businessType !== 'unknown' ? (btLabels[businessType] || businessType) : null;

// Competitor all-zero GEO check
const allCompGeoZero = (geo?.competitorMentions?.length ?? 0) > 0 && geo.competitorMentions.every((cm: any) => (cm.mentionRate ?? 0) === 0);

// ── Organic trend chart data ──────────────────────────────────────
const organicHistory: Array<{month:string;etv:number;keywords:number}> = seo?.organicHistory || [];
const organicTrend: string = seo?.organicTrend || 'stable';
const organicTrendPct: number = seo?.organicTrendPct ?? 0;

// Build SVG path for the trend line
function buildTrendSVG(history: typeof organicHistory): string {
  if (history.length < 3) return '';
  const W = 400, H = 100, PX = 30, PY = 12;
  const values = history.map(p => p.etv);
  const maxV = Math.max(...values, 1);
  const minV = Math.min(...values, 0);
  const range = maxV - minV || 1;
  const points = values.map((v, i) => {
    const x = PX + (i / (values.length - 1)) * (W - PX * 2);
    const y = PY + (1 - (v - minV) / range) * (H - PY * 2);
    return { x, y, v };
  });
  // Area fill
  const areaPath = `M${points[0].x},${points[0].y} ${points.map(p => `L${p.x},${p.y}`).join(' ')} L${points[points.length-1].x},${H-PY} L${points[0].x},${H-PY} Z`;
  // Line
  const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x},${p.y}`).join(' ');
  const color = organicTrend === 'up' ? '#1D9E75' : organicTrend === 'down' ? '#E24B4A' : '#BA7517';
  const fillColor = organicTrend === 'up' ? 'rgba(29,158,117,0.1)' : organicTrend === 'down' ? 'rgba(226,75,74,0.1)' : 'rgba(186,117,23,0.1)';
  // Month labels (show every 3rd)
  const months = history.map((p, i) => {
    const [y, m] = p.month.split('-');
    const label = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'][parseInt(m)-1] || m;
    return { x: PX + (i / (history.length - 1)) * (W - PX * 2), label: `${label} ${y.slice(2)}` };
  });
  const labels = months.filter((_, i) => i % 3 === 0 || i === months.length - 1);
  return `<svg viewBox="0 0 ${W} ${H + 20}" style="width:100%;height:auto;max-height:140px;">
    <path d="${areaPath}" fill="${fillColor}"/>
    <path d="${linePath}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    ${points.map(p => `<circle cx="${p.x}" cy="${p.y}" r="3" fill="${color}" stroke="#fff" stroke-width="1.5"/>`).join('')}
    ${labels.map(l => `<text x="${l.x}" y="${H + 12}" text-anchor="middle" style="font-size:9px;fill:#9CA3AF;font-family:Inter,sans-serif;">${l.label}</text>`).join('')}
  </svg>`;
}
const trendSVG = buildTrendSVG(organicHistory);

// Trend narrative for CEO
function buildTrendNarrative(trend: string, pct: number, history: typeof organicHistory): string {
  if (history.length < 3) return '';
  const recent = history[history.length - 1]?.etv ?? 0;
  const oldest = history[0]?.etv ?? 0;
  const absPct = Math.abs(pct);
  if (trend === 'up' && absPct > 50) {
    return `Vuestra visibilidad orgánica ha crecido un ${absPct}% en los últimos meses — de ${fmt(oldest)} a ${fmt(recent)} visitas estimadas/mes. Es una tendencia positiva que indica que las acciones de posicionamiento están dando resultado.`;
  }
  if (trend === 'up') {
    return `El tráfico orgánico muestra una tendencia de crecimiento moderado (+${absPct}%) en los últimos meses. Reforzar la estrategia de contenido puede acelerar esta curva significativamente.`;
  }
  if (trend === 'down' && absPct > 30) {
    return `Vuestra visibilidad orgánica ha caído un ${absPct}% — de ${fmt(oldest)} a ${fmt(recent)} visitas/mes. Esta tendencia descendente requiere atención inmediata: cada mes que pasa sin actuar, los competidores ocupan las posiciones que perdéis.`;
  }
  if (trend === 'down') {
    return `El tráfico orgánico muestra un descenso del ${absPct}% en los últimos meses. Aunque no es crítico aún, conviene identificar las causas (pérdida de keywords, cambios de algoritmo) y actuar antes de que se consolide la tendencia.`;
  }
  return `El tráfico orgánico se ha mantenido estable en los últimos meses (${fmt(recent)} visitas/mes). La estabilidad es buena base, pero sin crecimiento activo los competidores que sí invierten en SEO acabarán superándoos.`;
}
const trendNarrative = buildTrendNarrative(organicTrend, organicTrendPct, organicHistory);

// ── Brand vs Non-Brand + Indexation ─────────────────────────────
const brandPct = seo?.brandTrafficPct ?? null;
const nonBrandPct = brandPct != null ? 100 - brandPct : null;
const brandEtv = seo?.brandTrafficEtv ?? 0;
const nonBrandEtv = seo?.nonBrandTrafficEtv ?? 0;
const indexedPages = seo?.indexedPages ?? null;
const sitemapPages = seo?.sitemapPages ?? null;
const indexationRatio = seo?.indexationRatio ?? null;

function buildBrandNarrative(): string {
  if (brandPct === null) return '';
  if (brandPct > 70) {
    return `El ${brandPct}% de vuestro tráfico orgánico viene de personas que ya os conocen (buscan vuestro nombre). Solo el ${nonBrandPct}% viene de clientes potenciales nuevos buscando soluciones. Esto significa que no estáis captando demanda nueva — vuestra web funciona como tarjeta de visita, no como motor de captación.`;
  }
  if (brandPct > 40) {
    return `El ${brandPct}% de vuestro tráfico es de marca (gente que ya os conoce) y el ${nonBrandPct}% es captación nueva. Un mix equilibrado, aunque hay margen para captar más demanda genérica con contenido optimizado para búsquedas de sector.`;
  }
  if (brandPct > 0) {
    return `Solo el ${brandPct}% de vuestro tráfico es de marca — el ${nonBrandPct}% viene de búsquedas genéricas. Esto es positivo: vuestra web está captando clientes que no os conocían. El reto es que el reconocimiento de marca es bajo.`;
  }
  return 'Todo vuestro tráfico orgánico proviene de búsquedas genéricas, sin componente de marca. Hay oportunidad de construir reconocimiento de marca digital.';
}
const brandNarrative = buildBrandNarrative();

function buildIndexNarrative(): string {
  if (indexedPages === null) return '';
  if (sitemapPages && indexationRatio !== null) {
    if (indexationRatio >= 90) {
      return `Google tiene indexadas ${fmt(indexedPages)} de las ${fmt(sitemapPages)} páginas de vuestro sitemap (${indexationRatio}%). Excelente cobertura — prácticamente todo vuestro contenido está visible en Google.`;
    }
    if (indexationRatio >= 60) {
      return `Google indexa ${fmt(indexedPages)} de ${fmt(sitemapPages)} páginas (${indexationRatio}%). Hay un ${100 - indexationRatio}% de contenido que habéis creado pero que Google no muestra. Resolver problemas de rastreo o calidad de estas páginas podría aumentar vuestra visibilidad sin crear contenido nuevo.`;
    }
    return `Solo ${fmt(indexedPages)} de ${fmt(sitemapPages)} páginas están indexadas (${indexationRatio}%). Más de la mitad de vuestro contenido es invisible para Google. Esto suele indicar problemas técnicos de rastreo, contenido duplicado o páginas de baja calidad que Google decide no indexar.`;
  }
  return `Google tiene indexadas ${fmt(indexedPages)} páginas de vuestro dominio.`;
}
const indexNarrative = buildIndexNarrative();

// Health summary text — prefer AI-generated summary from insights, fallback to rule-based
const healthSummaryText = (insights as any)?.summary || diagnosisHealthSummary(health);

// Executive bullets — prefer AI-generated, fallback to business-impact messages
const insightBullets: string[] = (insights?.bullets && insights.bullets.length >= 3) ? insights.bullets.slice(0, 3) : [];
const executiveBullets: string[] = insightBullets.length >= 3 ? insightBullets : (() => {
  const eb: string[] = [];

  // ── Bullet 1: Visibilidad → ¿Os encuentran vuestros clientes?
  const kwt = seo?.keywordsTop10 ?? 0;
  const etv = seo?.organicTrafficEstimate ?? 0;
  const geoMR = geo?.mentionRate ?? 0;

  if (kwt === 0 && geoMR === 0) {
    eb.push('Vuestros potenciales clientes no os encuentran ni en Google ni en motores de IA como ChatGPT. Esto significa que toda la demanda que existe en vuestro sector está siendo captada por competidores con presencia digital activa.');
  } else if (kwt > 0 && geoMR === 0) {
    eb.push(`Tenéis cierta presencia en Google con ~${fmt(etv)} visitas orgánicas al mes, pero sois completamente invisibles en los nuevos motores de IA (ChatGPT, Perplexity, Gemini). Cada vez más decisores usan IA para investigar proveedores — no estar ahí es ceder ese canal a la competencia.`);
  } else if (kwt === 0 && geoMR > 0) {
    eb.push(`Aparecéis en el ${geoMR}% de las consultas de IA de vuestro sector, pero no tenéis presencia orgánica en Google. Sin visibilidad en el buscador principal, estáis dejando escapar la mayor fuente de tráfico cualificado.`);
  } else {
    const geoLevel = geoMR < 30 ? 'baja' : geoMR < 60 ? 'moderada' : 'buena';
    eb.push(`Tenéis presencia orgánica activa con ${fmt(etv)} visitas/mes desde Google y una visibilidad ${geoLevel} en motores de IA (${geoMR}% de consultas). ${geoMR < 50 ? 'Hay oportunidad de captar más demanda fortaleciendo el posicionamiento en IA generativa.' : 'Buen punto de partida para consolidar el liderazgo digital.'}`);
  }

  // ── Bullet 2: Experiencia → ¿Vuestra web convierte visitas en negocio?
  const perfScore = ps?.mobile?.performance ?? null;
  const funnelScore = cv?.funnelScore ?? null;
  const lcpSec = ps?.mobile?.lcp ? (ps.mobile.lcp / 1000).toFixed(1) : null;

  if (perfScore !== null && perfScore < 50) {
    eb.push(`Vuestra web tarda ${lcpSec ? lcpSec + ' segundos en cargar' : 'demasiado en cargar'} en móvil. Los estudios muestran que por encima de 3 segundos se pierde más del 50% de los visitantes. ${funnelScore !== null && funnelScore < 40 ? 'Además, la web carece de elementos clave de conversión (CTAs claros, prueba social, formularios visibles) — los visitantes que llegan no tienen un camino claro para contactaros.' : 'Mejorar la velocidad tendría impacto directo en la captación de leads.'}`);
  } else if (funnelScore !== null && funnelScore < 40) {
    eb.push(`La web${perfScore !== null ? ` carga razonablemente (${perfScore}/100 en móvil), pero` : ''} no está diseñada para convertir visitantes en clientes. Faltan elementos clave como CTAs visibles, prueba social o formularios accesibles. Cada visita que no convierte es una oportunidad de negocio perdida.`);
  } else if (perfScore !== null && funnelScore !== null) {
    eb.push(`La experiencia web es ${perfScore >= 75 && funnelScore >= 60 ? 'sólida' : 'aceptable'}: la página carga ${lcpSec ? 'en ' + lcpSec + 's' : 'correctamente'} y tiene los elementos básicos de conversión. ${funnelScore < 70 ? 'Aún hay margen para optimizar el funnel y aumentar la tasa de conversión.' : 'Buena base para escalar el tráfico con confianza.'}`);
  } else {
    eb.push('No se pudo evaluar completamente la experiencia web. Recomendamos revisar que la web cargue en menos de 3 segundos en móvil y tenga un camino claro desde la llegada hasta el contacto.');
  }

  // ── Bullet 3: Posición competitiva → ¿Dónde estáis vs vuestro mercado?
  if (hasCompetitorData && ctItems.length > 0) {
    const avgTraffic = Math.round(ctItems.reduce((s: number, c: any) => s + (c.organicTrafficEstimate || 0), 0) / ctItems.length);
    const leader = ctItems.sort((a: any, b: any) => (b.organicTrafficEstimate||0) - (a.organicTrafficEstimate||0))[0];
    const leaderName = leader?.name || 'el líder del sector';
    const leaderTraffic = leader?.organicTrafficEstimate ?? 0;

    if (etv < avgTraffic * 0.3) {
      eb.push(`Vuestros competidores directos reciben de media ${fmt(avgTraffic)} visitas orgánicas al mes — ${leaderName} lidera con ${fmt(leaderTraffic)}. Con ${fmt(etv)} visitas, estáis captando una fracción muy pequeña de la demanda del sector. La buena noticia: hay un mercado digital activo al que acceder con la estrategia correcta.`);
    } else if (etv < avgTraffic) {
      eb.push(`Estáis por debajo de la media del sector en visibilidad digital. ${leaderName} recibe ${fmt(leaderTraffic)} visitas orgánicas/mes frente a vuestras ${fmt(etv)}. Cerrar esta brecha es alcanzable con una estrategia SEO focalizada en las keywords donde ya tenéis tracción.`);
    } else {
      eb.push(`Vuestra posición competitiva es fuerte: con ${fmt(etv)} visitas orgánicas/mes estáis por encima de la media del sector (${fmt(avgTraffic)}). El reto ahora es consolidar el liderazgo y defender la posición frente a competidores que están invirtiendo en digital.`);
    }
  } else {
    eb.push('No se han podido identificar competidores con datos de tráfico comparables. Recomendamos definir un benchmark competitivo para poder medir el progreso de vuestra estrategia digital de forma objetiva.');
  }

  return eb;
})();

// Hero status
const heroStatus = statusStyle(ss(health.total));
