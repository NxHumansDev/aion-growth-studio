        <a href="#hero" data-section="hero" class="nav-active">Resumen Ejecutivo</a>
        <a href="#seo" data-section="seo" class="nav-parent">Visibilidad Digital</a>
        <a href="#seo" data-section="seo" class="nav-child">SEO Orgánico</a>
        <a href="#ia" data-section="ia" class="nav-child">Visibilidad IA</a>
        <a href="#autoridad" data-section="autoridad" class="nav-child">Auditoría de Marca</a>
        <a href="#competidores" data-section="competidores">Benchmark Competitivo</a>
        <a href="#experiencia" data-section="experiencia">Web & Conversión</a>
        <a href="#plan" data-section="plan">Plan de Acción</a>
      </nav>
      <div class="sidebar-footer">
        <div>{domain}</div>
        <div>{auditDate}</div>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">

      <!-- TOP BAR -->
      <div class="top-bar no-print">
        <div class="top-bar-title">INFORME DE PRESENCIA DIGITAL &mdash; {domain.toUpperCase()}</div>
        <a class="btn-print" href={`/es/audit/${id}/pdf`} target="_blank" style="text-decoration:none;">Exportar PDF</a>
      </div>

      <!-- REPORT AREA -->
      <div class="report">

        <!-- ═══════════════════════════════════════════════════════════
             BLOCK 1 · #hero · Diagnóstico Rápido
        ═══════════════════════════════════════════════════════════ -->
        <div id="hero" class="report-block reveal">

          <!-- Header row -->
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:20px;">
            <div style="display:flex;align-items:center;gap:12px;">
              <img src="/images/aion-logo-transparent.png" height="48" alt="AION Growth Studio" style="height:48px;" />
              <div style="width:1px;height:20px;background:#E5E7EB;"></div>
              <div>
                <div style="font-size:0.72rem;color:#5A6478;">Informe generado el</div>
                <div style="font-size:0.82rem;font-weight:600;color:#1A1A2E;">{auditDate}</div>
              </div>
            </div>
            <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
              <div style="font-size:0.9rem;font-weight:700;color:#1A1A2E;">{domain}</div>
              {sector && (
                <span class="tag" style="background:#EBF2FF;color:#1A4B8C;">{sector}</span>
              )}
              {btLabel && (
                <span class="tag" style="background:#F3F4F6;color:#5A6478;">{btLabel}</span>
              )}
            </div>
          </div>

          <!-- Score + Verdict row -->
          <div style="display:grid;grid-template-columns:auto 1fr;gap:24px;align-items:start;margin-bottom:24px;">

            <!-- Animated gauge -->
            <div style="display:flex;flex-direction:column;align-items:center;gap:8px;">
              <div style="position:relative;width:120px;height:120px;">
                <svg viewBox="0 0 36 36" style="width:120px;height:120px;transform:rotate(-90deg);">
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="2.5"/>
                  <circle id="score-ring" cx="18" cy="18" r="15.9" fill="none" stroke={scoreColor(health.total)} stroke-width="2.5" stroke-linecap="round" stroke-dasharray="0, 100"/>
                </svg>
                <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                  <span id="score-counter" style="font-size:1.75rem;font-weight:700;color:#1A1A2E;line-height:1;">{health.total}</span>
                  <span style="font-size:0.6rem;color:#5A6478;">/100</span>
                </div>
              </div>
              <div style="text-align:center;">
                <div style="font-size:0.72rem;font-weight:600;color:#5A6478;letter-spacing:0.06em;text-transform:uppercase;margin-bottom:4px;">Score de Presencia Digital</div>
                <span class="status-badge" style={`background:${heroStatus.bg};color:${heroStatus.fg};`}>{heroStatus.label}</span>
              </div>
            </div>

            <!-- Executive Summary -->
            <div>
              <h1 style="font-size:1.3rem;font-weight:700;color:#1A1A2E;margin-bottom:6px;line-height:1.3;">
                {scoreLabel(health.total)} — {domain}
              </h1>
              <div style="font-size:0.68rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;">Resumen ejecutivo</div>
              <div style="display:flex;flex-direction:column;gap:8px;">
                {executiveBullets.map((bullet: string, i: number) => (
                  <div style="display:flex;align-items:baseline;gap:10px;font-size:0.82rem;line-height:1.55;">
                    <span style={`flex-shrink:0;width:20px;height:20px;border-radius:50%;background:${i === 0 ? '#1A4B8C' : i === 1 ? '#4A7FD4' : '#7BA3E0'};color:white;font-size:0.6rem;font-weight:700;display:flex;align-items:center;justify-content:center;margin-top:1px;`}>{i + 1}</span>
                    <span style="color:#3A4458;">{bullet}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <!-- Navigation compass -->
          <div style="margin-bottom:20px;">
            <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Secciones del informe</div>
            <div class="grid-4" style="gap:10px;">
              <a href="#seo" class="compass-card">
                <div class="compass-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1A4B8C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg></div>
                <div class="compass-card-title">Visibilidad Digital</div>
                <div class="compass-card-desc">SEO, IA y Autoridad</div>
                <div style="font-size:0.85rem;font-weight:700;color:#1A4B8C;margin-top:4px;">{health.visibilidad ?? 0}<span style="font-size:0.65rem;font-weight:400;color:#5A6478;">/100</span></div>
              </a>
              <a href="#competidores" class="compass-card">
                <div class="compass-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1A4B8C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></div>
                <div class="compass-card-title">Benchmark</div>
                <div class="compass-card-desc">Posición vs competencia</div>
                <div style="font-size:0.85rem;font-weight:700;color:#1A4B8C;margin-top:4px;">{health.competitividad != null ? health.competitividad : 'N/D'}<span style="font-size:0.65rem;font-weight:400;color:#5A6478;">{health.competitividad != null ? '/100' : ''}</span></div>
              </a>
              <a href="#experiencia" class="compass-card">
                <div class="compass-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1A4B8C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></div>
                <div class="compass-card-title">Web & Conversión</div>
                <div class="compass-card-desc">Velocidad, UX y medición</div>
                <div style="font-size:0.85rem;font-weight:700;color:#1A4B8C;margin-top:4px;">{health.experiencia ?? 0}<span style="font-size:0.65rem;font-weight:400;color:#5A6478;">/100</span></div>
              </a>
              <a href="#plan" class="compass-card">
                <div class="compass-card-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1A4B8C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg></div>
                <div class="compass-card-title">Plan de Acción</div>
                <div class="compass-card-desc">Quick wins y estrategia</div>
              </a>
            </div>
          </div>

          <!-- Semáforo por área -->
          <div style="margin-bottom:4px;">
            <div style="font-size:0.78rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Estado por área</div>
            {statusByArea.map(area => {
              const dotColor = area.status === 'good' ? '#1D9E75' : area.status === 'medium' ? '#BA7517' : '#E24B4A';
              return (
                <div class="semaphore-row">
                  <span style={`width:12px;height:12px;border-radius:50%;background:${dotColor};flex-shrink:0;display:inline-block;`}></span>
                  {area.status === 'bad' && <span style="font-size:0.72rem;font-weight:700;color:#E24B4A;white-space:nowrap;">⚠ Crítico</span>}
                  <span class="semaphore-area">{area.area}</span>
                  <span class="semaphore-summary">{area.summary}</span>
                  <a href={area.anchor} class="semaphore-arrow">Ver detalle &#8594;</a>
                </div>
              );
            })}
          </div>

          <!-- Transparency note -->
          <div style="border-left:3px solid #D1D5DB;padding:10px 14px;margin-top:16px;background:transparent;">
            <p style="font-size:11px;color:#9CA3AF;line-height:1.5;font-style:italic;">Este diagnóstico analiza datos observables públicamente (SEO, velocidad web, Schema Markup, redes sociales). Para datos reales de tráfico y rendimiento de campañas, necesitamos acceso a tus herramientas — eso es lo que hace Radar cada mes.</p>
          </div>

        </div>

        <!-- ═══════════════════════════════════════════════════════════
             BLOCK 2 · #seo · Visibilidad Digital
        ═══════════════════════════════════════════════════════════ -->
        <div id="seo" class="report-block reveal">
          <div class="block-title">Visibilidad Digital</div>
          <div class="block-subtitle">Análisis de presencia orgánica, visibilidad en IA y reputación de marca</div>

          <!-- ── Visibility header: gauge + sub-scores + Claude summary ── -->
          <div style="display:flex;align-items:center;gap:32px;background:#F8F9FB;border-radius:14px;padding:20px 24px;margin-bottom:24px;flex-wrap:wrap;">

            <!-- Gauge -->
            <div style="display:flex;flex-direction:column;align-items:center;gap:6px;flex-shrink:0;">
              <div style="position:relative;width:88px;height:88px;">
                <svg viewBox="0 0 36 36" style="width:88px;height:88px;transform:rotate(-90deg);">
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="3"/>
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke={visColor} stroke-width="3" stroke-linecap="round" stroke-dasharray={`${visScore}, 100`}/>
                </svg>
                <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                  <span style={`font-size:1.4rem;font-weight:800;color:${visColor};line-height:1;`}>{visScore}</span>
                  <span style="font-size:0.55rem;color:#5A6478;">/100</span>
                </div>
              </div>
              <span style="font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#5A6478;">Visibilidad</span>
            </div>

            <!-- Sub-scores -->
            <div style="flex:1;min-width:200px;display:flex;flex-direction:column;gap:10px;">
              {[
                { label: 'SEO Orgánico', value: visSeoSub, weight: '35%' },
                { label: 'Visibilidad IA (GEO)', value: visGeoSub, weight: '25%' },
                { label: 'Reputación', value: r.score?.breakdown?.reputation ?? brandAuthorityScoreEs, weight: '10%' },
              ].map(sub => {
                const c = sub.value >= 70 ? '#1D9E75' : sub.value >= 40 ? '#BA7517' : '#E24B4A';
                return (
                  <div>
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;">
                      <span style="font-size:0.75rem;font-weight:600;color:#1A1A2E;">{sub.label}</span>
                      <span style={`font-size:0.75rem;font-weight:700;color:${c};`}>{sub.value}<span style="font-size:0.6rem;color:#5A6478;font-weight:400;">/100</span></span>
                    </div>
                    <div style="height:6px;background:rgba(0,0,0,0.08);border-radius:4px;overflow:hidden;">
                      <div style={`height:100%;width:${sub.value}%;background:${c};border-radius:4px;transition:width 0.6s ease;`}></div>
                    </div>
                    <div style="font-size:0.6rem;color:#9CA3AF;margin-top:2px;">peso {sub.weight}</div>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Claude visibility summary -->
          {visSummaryText && (
            <div style="font-size:0.85rem;color:#434750;font-style:italic;line-height:1.6;margin-bottom:20px;padding-left:4px;border-left:3px solid #4A7FD4;">
              {visSummaryText}
            </div>
          )}

          <!-- Organic trend chart -->
          {trendSVG && (
            <div style="background:#F8F9FB;border-radius:12px;padding:16px 20px;margin-bottom:24px;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap;gap:8px;">
                <div style="font-size:0.78rem;font-weight:700;color:#1A1A2E;display:flex;align-items:center;gap:8px;">
                  Tendencia de tráfico orgánico
                  <span style="font-size:0.7rem;font-weight:400;color:#9CA3AF;">últimos 12 meses</span>
                </div>
                {organicTrend === 'up' && (
                  <span style="font-size:0.72rem;font-weight:700;color:#1D9E75;display:flex;align-items:center;gap:4px;">
                    ↑ +{Math.abs(organicTrendPct)}%
                  </span>
                )}
                {organicTrend === 'down' && (
                  <span style="font-size:0.72rem;font-weight:700;color:#E24B4A;display:flex;align-items:center;gap:4px;">
                    ↓ -{Math.abs(organicTrendPct)}%
                  </span>
                )}
                {organicTrend === 'stable' && (
                  <span style="font-size:0.72rem;font-weight:700;color:#BA7517;display:flex;align-items:center;gap:4px;">
                    → Estable
                  </span>
                )}
              </div>
              <div set:html={trendSVG} />
              {trendNarrative && (
                <p style="font-size:0.8rem;color:#5A6478;line-height:1.55;margin-top:12px;">{trendNarrative}</p>
              )}
            </div>
          )}

          <!-- Brand vs Non-Brand + Indexation -->
          {(brandPct !== null || indexedPages !== null) && (
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:24px;">
              {brandPct !== null && (
                <div style="background:#F8F9FB;border-radius:12px;padding:16px 20px;">
                  <div style="font-size:0.72rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Tráfico de marca vs captación nueva</div>
                  <div style="display:flex;align-items:center;gap:16px;margin-bottom:10px;">
                    <div style="flex:1;">
                      <div style="display:flex;justify-content:space-between;font-size:0.7rem;color:#5A6478;margin-bottom:4px;">
                        <span>Marca ({brandPct}%)</span>
                        <span>No marca ({nonBrandPct}%)</span>
                      </div>
                      <div style="height:8px;background:#E5E7EB;border-radius:4px;overflow:hidden;display:flex;">
                        <div style={`width:${brandPct}%;background:#4A7FD4;`}></div>
                        <div style={`width:${nonBrandPct}%;background:#1D9E75;`}></div>
                      </div>
                      <div style="display:flex;justify-content:space-between;font-size:0.68rem;color:#9CA3AF;margin-top:3px;">
                        <span>~{fmt(brandEtv)} vis/mes</span>
                        <span>~{fmt(nonBrandEtv)} vis/mes</span>
                      </div>
                    </div>
                  </div>
                  {brandNarrative && <p style="font-size:0.75rem;color:#5A6478;line-height:1.5;">{brandNarrative}</p>}
                </div>
              )}
              {indexedPages !== null && (
                <div style="background:#F8F9FB;border-radius:12px;padding:16px 20px;">
                  <div style="font-size:0.72rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Páginas indexadas en Google</div>
                  <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:6px;">
                    <span style="font-size:1.5rem;font-weight:800;color:#1A1A2E;">{fmt(indexedPages)}</span>
                    {sitemapPages && (
                      <span style="font-size:0.82rem;color:#5A6478;">de {fmt(sitemapPages)} en sitemap</span>
                    )}
                  </div>
                  {indexationRatio !== null && (
                    <div style="margin-bottom:8px;">
                      <div style="height:8px;background:#E5E7EB;border-radius:4px;overflow:hidden;">
                        <div style={`width:${Math.min(indexationRatio, 100)}%;background:${indexationRatio >= 80 ? '#1D9E75' : indexationRatio >= 50 ? '#BA7517' : '#E24B4A'};border-radius:4px;`}></div>
                      </div>
                      <div style="font-size:0.68rem;color:#9CA3AF;margin-top:3px;">Ratio de indexación: {indexationRatio}%</div>
                    </div>
                  )}
                  {indexNarrative && <p style="font-size:0.75rem;color:#5A6478;line-height:1.5;">{indexNarrative}</p>}
                </div>
              )}
            </div>
          )}

          <!-- ── Layer 1: SEO Orgánico ── -->
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:12px;">
            <div style="font-size:0.88rem;font-weight:700;color:#1A4B8C;text-transform:uppercase;letter-spacing:0.06em;display:flex;align-items:center;gap:8px;">
              <span style="width:3px;height:16px;background:#1A4B8C;border-radius:2px;display:inline-block;"></span>
              SEO Orgánico
            </div>
            {(() => {
              const s = visSeoSub;
              const c = s >= 70 ? '#1D9E75' : s >= 40 ? '#BA7517' : '#E24B4A';
              const bg = s >= 70 ? '#E1F5EE' : s >= 40 ? '#FAEEDA' : '#FCEBEB';
              const lbl = s >= 70 ? 'Fuerte' : s >= 40 ? 'Moderado' : 'Débil';
              return (
                <div style={`display:flex;align-items:center;gap:10px;background:${bg};border-radius:10px;padding:8px 16px;`}>
                  <div style="width:72px;height:6px;background:rgba(0,0,0,0.1);border-radius:4px;overflow:hidden;">
                    <div style={`height:100%;width:${s}%;background:${c};border-radius:4px;`}></div>
                  </div>
                  <span style={`font-size:1rem;font-weight:800;color:${c};`}>{s}</span>
                  <span style="font-size:0.65rem;color:#5A6478;">/100</span>
                  <span style={`font-size:0.7rem;font-weight:700;color:${c};`}>{lbl}</span>
                </div>
              );
            })()}
          </div>

          {seo ? (
            <div>
              <div class="grid-4" style="margin-bottom:14px;">
                <div class="metric-card">
                  <div class="metric-value">{fmt(seo.keywordsTop10)}</div>
                  <div class="metric-label">Keywords Top 10</div>
                </div>
                <div class="metric-card">
                  <div class="metric-value">{fmt(seo.keywordsTop3)}</div>
                  <div class="metric-label">Keywords Top 3</div>
                </div>
                <div class="metric-card">
                  <div class="metric-value">{fmt(seo.organicTrafficEstimate)}</div>
                  <div class="metric-label">Visitas orgánicas / mes</div>
                </div>
                <div class="metric-card">
                  <div class="metric-value">{seo.keywordsPos4to10 ?? '—'}</div>
                  <div class="metric-label">Keywords posición 4–10</div>
                </div>
              </div>

              {showGiantCalloutEs && (
                <div class="callout callout-amber" style="margin-bottom:10px;">
                  <strong>Contexto del score:</strong> tu visibilidad SEO se mide frente a {giantCompNamesEs} — competidores de referencia del sector con una media de {fmt(Math.round(avgCompKWes))} keywords en top 10. Con {fmt(seo?.keywordsTop10)} keywords y ~{fmt(seo?.organicTrafficEstimate)} visitas/mes, tu posición orgánica es <strong>sólida para tu tamaño</strong>. El score refleja la brecha real que existe en el mercado, no una valoración negativa de tu trabajo SEO.
                </div>
              )}

              {(seo.estimatedAdsCost ?? 0) > 0 && (
                <div class="callout callout-blue" style="margin-bottom:10px;">
                  Tus keywords top 10 equivalen a <strong>~{fmt(seo.estimatedAdsCost)}€/mes</strong> en Google Ads — estás generando tráfico orgánico de alto valor.
                </div>
              )}

              {(seo?.keywordsPos4to10 ?? pos4to10Keywords.length) > 0 && (
                <div class="callout callout-green" style="margin-bottom:10px;">
                  Tienes <strong>{fmt(seo?.keywordsPos4to10 ?? pos4to10Keywords.length)} keywords entre posición 4-10</strong> — a un buen artículo del top 3. Optimizar esas URLs puede multiplicar el tráfico sin coste adicional.
                </div>
              )}

              {(seo.topKeywords?.length ?? 0) > 0 && (
                <div style="margin-top:14px;margin-bottom:4px;">
                  <div style="display:flex;align-items:baseline;gap:8px;margin-bottom:8px;">
                    <span style="font-size:0.75rem;font-weight:600;color:#5A6478;">Top keywords orgánicas</span>
                    <span style="font-size:0.65rem;color:#9CA3AF;">ordenadas por tráfico real estimado (ETV = volumen × CTR según posición)</span>
                  </div>
                  <table>
                    <thead>
                      <tr>
                        <th>Keyword</th>
                        <th>Posición</th>
                        <th>Volumen / mes</th>
                        <th title="Estimated Traffic Value: visitas reales estimadas según la posición">Tráfico est. (ETV)</th>
                      </tr>
                    </thead>
                    <tbody>
                      {seo.topKeywords.slice(0,5).map((kw: any) => (
                        <tr>
                          <td style="font-weight:500;">{kw.keyword}</td>
                          <td>
                            <span style={`font-weight:600;color:${kw.position<=3?'#1D9E75':kw.position<=10?'#BA7517':'#5A6478'};`}>
                              #{kw.position}
                            </span>
                          </td>
                          <td>{fmt(kw.volume)}</td>
                          <td style="font-weight:600;color:#1A4B8C;">{kw.etv ? fmt(kw.etv) : '—'}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}

              {kwGapItems.length > 0 && (
                <div style="margin-top:16px;">
                  <div style="font-size:0.75rem;font-weight:600;color:#5A6478;margin-bottom:8px;">Gap de keywords vs competencia</div>
                  <table>
                    <thead>
                      <tr>
                        <th>Keyword</th>
                        <th>Volumen</th>
                        <th>Tu posición</th>
                        <th>Competidor posición</th>
                      </tr>
                    </thead>
                    <tbody>
                      {kwGapItems.map((kw: any) => (
                        <tr>
                          <td style="font-weight:500;">{kw.keyword}</td>
                          <td>{fmt(kw.volume)}</td>
