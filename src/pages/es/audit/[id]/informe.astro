          {geo && (
            <div style="font-size:0.82rem;color:#5A6478;font-style:italic;border-left:3px solid #7c3aed;padding-left:12px;line-height:1.6;margin-bottom:1.5rem;">{(geo as any)?.executiveNarrative || diagnosisGEO(geo)}</div>
