  <script define:vars={{ scoreTotal: health.total }}>
    const counter = document.getElementById('score-counter');
    const ring = document.getElementById('score-ring');
    if (counter && scoreTotal > 0) {
      const duration = 1400;
      const start = performance.now();
      const animate = (now) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * scoreTotal);
        counter.textContent = current;
        if (ring) ring.setAttribute('stroke-dasharray', eased * scoreTotal + ', 100');
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
    }
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

    // Nav active state tracking
    const navLinks = document.querySelectorAll('#report-nav a[data-section]');
    const sections = ['hero', 'seo', 'ia', 'autoridad', 'competidores', 'experiencia', 'plan'];
    // Note: autoridad was already in the array — all 7 chapters tracked
    const sectionEls = sections.map(id => document.getElementById(id)).filter(Boolean);

    let currentActive = 'hero';
    function setActive(sectionId) {
      if (sectionId === currentActive) return;
      currentActive = sectionId;
      navLinks.forEach(link => {
        const linkSection = link.getAttribute('data-section');
        link.classList.toggle('nav-active', linkSection === sectionId);
      });
    }

    const navObs = new IntersectionObserver((entries) => {
      let topmost = null;
      let topmostTop = Infinity;
      entries.forEach(e => {
        if (e.isIntersecting && e.boundingClientRect.top < topmostTop) {
          topmostTop = e.boundingClientRect.top;
          topmost = e.target.id;
        }
      });
      if (topmost) setActive(topmost);
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });

    sectionEls.forEach(el => navObs.observe(el));
  </script>

