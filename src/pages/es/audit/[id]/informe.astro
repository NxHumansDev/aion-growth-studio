                      <span style={`font-size:0.82rem;font-weight:800;color:${c};`}>{sub.value}<span style="font-size:0.65rem;color:#8d909b;font-weight:400;">/100</span></span>
                    </div>
                    <div style="height:5px;background:rgba(141,144,155,0.12);border-radius:4px;overflow:hidden;">
                      <div style={`height:100%;width:${sub.value}%;background:${c};border-radius:4px;transition:width 0.6s ease;`}></div>
                    </div>
                    <div style="font-size:0.6rem;color:#8d909b;margin-top:3px;">peso {sub.weight}</div>
                  </div>
