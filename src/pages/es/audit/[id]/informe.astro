                  {displayStrategic.map((action: any, idx: number) => (
                    <div class="plan-card" style="border-left:3px solid #aac7ff;">
                      <div class="plan-num" style="background:rgba(170,199,255,0.15);color:#aac7ff;">{idx + 1}</div>
                      <div>
                        <div style="font-size:0.85rem;font-weight:700;color:#e2e0fc;margin-bottom:4px;">{action.title}</div>
