                    <tbody>
                      {kwGapItems.map((kw: any) => (
                        <tr>
                          <td style="font-weight:600;color:#e2e0fc;">{kw.keyword}</td>
                          <td style="text-align:right;">{fmt(kw.volume)}</td>
                          {hasPositions && <td style="text-align:center;color:#69FF87;">posicion #{kw.competitorPosition}</td>}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                  <div class="callout callout-success" style="margin-top:12px;">
                    <strong>Oportunidad:</strong> Estas busquedas suman ~{fmt(kwGapItems.reduce((s: number, k: any) => s + (k.volume || 0), 0))} visitas potenciales al mes. Crear paginas optimizadas para estas keywords puede captar trafico que hoy va a tu competidor.
                  </div>
                </div>
              )}

              {/* Demand capture */}
              {capturePct !== null && (
                <div class="surface-card" style="margin-top:1rem;">
                  <div style="font-size:0.82rem;font-weight:700;color:#e2e0fc;margin-bottom:16px;">Captura de demanda organica</div>
                  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:20px;margin-bottom:16px;">
                    <div>
                      <div style={`font-size:2.2rem;font-weight:900;color:${captureColor === '#1D9E75' ? '#69FF87' : captureColor === '#BA7517' ? '#ffb4ab' : '#ffb4ab'};line-height:1;letter-spacing:-0.02em;`}>{capturePct}%</div>
                      <div style="font-size:0.72rem;font-weight:600;color:#c3c6d2;margin-top:4px;">Cobertura estrategica</div>
                      <div style="font-size:0.65rem;color:#8d909b;margin-top:2px;">Keywords estrategicas donde posicionais en Top 10</div>
                    </div>
                    {uncapturedPct !== null && uncapturedPct > 0 && (
                      <div>
                        <div style="font-size:2.2rem;font-weight:900;color:#ffb4ab;line-height:1;letter-spacing:-0.02em;">{uncapturedPct}%</div>
                        <div style="font-size:0.72rem;font-weight:600;color:#c3c6d2;margin-top:4px;">Demanda no capturada</div>
                        <div style="font-size:0.65rem;color:#8d909b;margin-top:2px;">Busquedas relevantes donde no apareceis en Top 10</div>
                      </div>
                    )}
                    {lowValuePct !== null && lowValuePct > 10 && (
                      <div>
                        <div style="font-size:2.2rem;font-weight:900;color:#ffb4ab;line-height:1;letter-spacing:-0.02em;">{lowValuePct}%</div>
                        <div style="font-size:0.72rem;font-weight:600;color:#c3c6d2;margin-top:4px;">Trafico de bajo valor</div>
                        <div style="font-size:0.65rem;color:#8d909b;margin-top:2px;">Porcentaje del trafico SEO de terminos de baja intencion</div>
                      </div>
                    )}
                  </div>
                  {demandNarrative && (
                    <div style="border-top:1px solid rgba(141,144,155,0.1);padding-top:12px;">
                      <div style="font-size:0.65rem;font-weight:700;color:#8d909b;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;">Lectura ejecutiva</div>
                      <p style="font-size:0.78rem;color:#c3c6d2;line-height:1.55;margin:0;">{demandNarrative}</p>
                    </div>
                  )}
                </div>
              )}
            </div>
          ) : (
            <div class="callout callout-warning">No se han podido obtener datos de SEO organico para este dominio.</div>
          )}
        </div>

        <div class="section-sep"></div>

        <!-- ================================================================
             #ia - Visibilidad IA (White theme section)
        ================================================================ -->
        <div id="ia" class="reveal ia-section" style="margin-bottom:2.5rem;">
          <div class="block-header">
            <div style="font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:#7c3aed;margin-bottom:6px;">VISIBILIDAD IA</div>
            <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;">
              <div>
                <h2 style="font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;color:#1a1a2e;line-height:1.1;letter-spacing:-0.02em;margin-bottom:8px;">Visibilidad en IA</h2>
                <p style="font-size:0.88rem;color:#5A6478;line-height:1.5;margin-bottom:1rem;">¿Los asistentes de IA te recomiendan?</p>
              </div>
              <div style="position:relative;width:72px;height:72px;flex-shrink:0;">
                <svg viewBox="0 0 36 36" style="width:72px;height:72px;transform:rotate(-90deg);">
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="3"/>
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke={scoreColor(chapterScores.ia)} stroke-width="3" stroke-linecap="round" stroke-dasharray={`${chapterScores.ia}, 100`}/>
                </svg>
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
                  <span style={`font-size:1.1rem;font-weight:800;color:${scoreColor(chapterScores.ia)};`}>{chapterScores.ia}<span style="font-size:0.6rem;color:#5A6478;">/100</span></span>
                </div>
              </div>
            </div>
          </div>

          {geo && (
            <div style="font-size:0.82rem;color:#5A6478;font-style:italic;border-left:3px solid #7c3aed;padding-left:12px;line-height:1.6;margin-bottom:1.5rem;">{(geo as any)?.executiveNarrative || diagnosisGEO(geo)}</div>
          )}

          <!-- TOFU/MOFU/BOFU -->
          <div style="background:#f5f2ff;border-radius:12px;padding:20px;margin-bottom:1.5rem;">
            <div style="font-size:0.72rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:12px;">Metodologia: {geo?.queries?.length ?? 30} consultas en 6 categorias de intencion</div>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;">
              <div style="background:#EBF2FF;border-radius:10px;padding:14px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                  <div style="font-size:0.72rem;font-weight:800;color:#1A4B8C;text-transform:uppercase;letter-spacing:0.06em;">TOFU</div>
                  {geo?.funnelBreakdown?.tofu && (
                    <span style={`font-size:0.68rem;font-weight:700;padding:2px 8px;border-radius:6px;background:${tofuBadgeBg};color:${tofuBadgeColor};`}>
                      {geo.funnelBreakdown.tofu.mentioned ?? 0}/{geo.funnelBreakdown.tofu.total ?? 0}
                    </span>
                  )}
                </div>
                <div style="font-size:0.75rem;font-weight:600;color:#1a1a2e;margin-bottom:4px;">Top of Funnel</div>
                <div style="font-size:0.72rem;color:#5A6478;line-height:1.4;">El usuario no te conoce. Busca informacion general sobre tu sector.</div>
              </div>
              <div style="background:#FAEEDA;border-radius:10px;padding:14px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                  <div style="font-size:0.72rem;font-weight:800;color:#BA7517;text-transform:uppercase;letter-spacing:0.06em;">MOFU</div>
                  {geo?.funnelBreakdown?.mofu && (
                    <span style={`font-size:0.68rem;font-weight:700;padding:2px 8px;border-radius:6px;background:${mofuBadgeBg};color:${mofuBadgeColor};`}>
                      {geo.funnelBreakdown.mofu.mentioned ?? 0}/{geo.funnelBreakdown.mofu.total ?? 0}
                    </span>
                  )}
                </div>
                <div style="font-size:0.75rem;font-weight:600;color:#1a1a2e;margin-bottom:4px;">Middle of Funnel</div>
                <div style="font-size:0.72rem;color:#5A6478;line-height:1.4;">El usuario evalua opciones. Compara proveedores y soluciones.</div>
              </div>
              <div style="background:#E1F5EE;border-radius:10px;padding:14px;">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                  <div style="font-size:0.72rem;font-weight:800;color:#1D9E75;text-transform:uppercase;letter-spacing:0.06em;">BOFU</div>
                  {geo?.funnelBreakdown?.bofu && (
                    <span style={`font-size:0.68rem;font-weight:700;padding:2px 8px;border-radius:6px;background:${bofuBadgeBg};color:${bofuBadgeColor};`}>
                      {geo.funnelBreakdown.bofu.mentioned ?? 0}/{geo.funnelBreakdown.bofu.total ?? 0}
                    </span>
                  )}
                </div>
                <div style="font-size:0.75rem;font-weight:600;color:#1a1a2e;margin-bottom:4px;">Bottom of Funnel</div>
                <div style="font-size:0.72rem;color:#5A6478;line-height:1.4;">Alta intencion de compra. Busca directamente tu marca.</div>
              </div>
            </div>
          </div>

          {!qaSuppressed.includes('geo_analysis') && geo ? (
            <div>
              <!-- Mention rate -->
              <div style="display:flex;align-items:center;gap:24px;margin-bottom:1.5rem;flex-wrap:wrap;">
                <div style="position:relative;width:160px;height:160px;flex-shrink:0;">
                  <svg viewBox="0 0 36 36" style="width:160px;height:160px;transform:rotate(-90deg);">
                    <defs>
                      <linearGradient id="geo-gauge-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%" style="stop-color:#69FF87"/>
                        <stop offset="100%" style="stop-color:#5dd1a4"/>
                      </linearGradient>
                    </defs>
                    <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(0,0,0,0.06)" stroke-width="2.5"/>
                    <circle cx="18" cy="18" r="15.9" fill="none" stroke="url(#geo-gauge-grad)" stroke-width="2.5" stroke-linecap="round" stroke-dasharray={`${geo.mentionRate ?? 0}, 100`}/>
                  </svg>
                  <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                    <span style={`font-size:2.2rem;font-weight:900;color:${(geo.mentionRate ?? 0) >= 60 ? '#1D9E75' : (geo.mentionRate ?? 0) >= 30 ? '#BA7517' : '#E24B4A'};line-height:1;`}>{geo.mentionRate ?? 0}%</span>
                    {hasGeoRange && (
                      <span style="font-size:0.62rem;color:#9CA3AF;">rango {geoRangeLow}-{geoRangeHigh}%</span>
                    )}
                  </div>
                </div>
                <div style="flex:1;min-width:200px;">
                  <div style="font-size:0.88rem;font-weight:700;color:#1a1a2e;margin-bottom:6px;">Tasa de mencion en IA</div>
                  <div style="font-size:0.82rem;color:#5A6478;line-height:1.55;">
                    Tu marca aparece en el {geo.mentionRate ?? 0}% de {geo.queries?.length ?? 0} consultas a {geoEngines.length > 0 ? geoEngines.join(', ') : 'motores de IA'}.
                    {hasGeoRange && ` Intervalo de confianza 95%: ${geoRangeLow}%-${geoRangeHigh}%.`}
                  </div>
                </div>
              </div>

              {/* 6 category breakdown */}
              {Object.keys(categoryBreakdown).length > 0 && (
                <div style="margin-bottom:1.5rem;">
                  <div style="font-size:0.72rem;font-weight:700;color:#5A6478;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:10px;">Visibilidad por tipo de consulta</div>
                  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;">
                    {Object.entries(categoryBreakdown).map(([cat, data]) => {
                      const meta = categoryLabels[cat];
                      if (!meta) return null;
                      const d = data as any;
                      const pct = d.total > 0 ? Math.round((d.mentioned / d.total) * 100) : 0;
                      return (
                        <div style={`background:${meta.bg};border-radius:10px;padding:12px 14px;`}>
                          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;">
                            <span style={`font-size:0.68rem;font-weight:800;color:${meta.color};text-transform:uppercase;letter-spacing:0.04em;`}>{meta.label}</span>
                            <span style={`font-size:0.82rem;font-weight:900;color:${pct > 0 ? meta.color : '#9CA3AF'};`}>{pct}%</span>
                          </div>
                          <div style="height:4px;background:rgba(0,0,0,0.06);border-radius:3px;overflow:hidden;">
                            <div style={`height:100%;width:${pct}%;background:${meta.color};border-radius:3px;`}></div>
                          </div>
                          <div style="font-size:0.6rem;color:#9CA3AF;margin-top:3px;">{d.mentioned}/{d.total} consultas</div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}

              {/* Engine breakdown */}
              {crossModel.length > 0 && (
                <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:1.5rem;">
                  {crossModel.map((eng: any) => {
                    const pct = eng.total > 0 ? Math.round((eng.mentioned / eng.total) * 100) : 0;
                    const c = pct >= 50 ? '#1D9E75' : pct >= 25 ? '#BA7517' : '#E24B4A';
                    return (
                      <div style="background:#f5f2ff;border-radius:10px;padding:10px 16px;display:flex;align-items:center;gap:10px;">
                        <span style="font-size:0.82rem;font-weight:700;color:#1a1a2e;">{eng.name}</span>
                        <span style={`font-size:0.88rem;font-weight:900;color:${c};`}>{pct}%</span>
                        <span style="font-size:0.68rem;color:#9CA3AF;">{eng.mentioned}/{eng.total}</span>
                      </div>
                    );
                  })}
                </div>
              )}

              {/* Query table */}
              {(geo.queries?.length ?? 0) > 0 && (() => {
                const STAGE_ORDER = { tofu: 0, mofu: 1, bofu: 2 } as const;
                const sorted = [...geo.queries].sort((a: any, b: any) =>
                  (STAGE_ORDER[a.stage] ?? 3) - (STAGE_ORDER[b.stage] ?? 3)
                );
                const mentionedCount = sorted.filter((q: any) => q.mentioned).length;
                const EXPAND = { G: 'ChatGPT', P: 'Perplexity', C: 'Claude' } as any;
                for (const q of sorted) {
                  if (Array.isArray(q.engines)) {
                    q.engines = q.engines.map((e: any) => ({
                      name: e.name || EXPAND[e.n] || e.n || '?',
                      mentioned: e.mentioned ?? (e.m === 1 || e.m === true),
                    }));
                  }
                }
                const engineNames: string[] = [];
                for (const q of sorted) {
                  if (q.engines) {
                    for (const e of q.engines) {
                      if (!engineNames.includes(e.name)) engineNames.push(e.name);
                    }
                  }
                }
                const hasEngines = engineNames.length > 0;
                return (
                  <div style="margin-bottom:1rem;overflow-x:auto;">
                    <div style="font-size:0.78rem;font-weight:700;color:#1a1a2e;margin-bottom:10px;">
                      Consultas analizadas
                      <span style="font-weight:400;color:#9CA3AF;margin-left:8px;">({mentionedCount} de {sorted.length} con mencion)</span>
                    </div>
                    <table>
                      <thead>
                        <tr>
                          <th style="width:60px;">Etapa</th>
                          <th>Consulta</th>
                          {hasEngines ? engineNames.map((en) => (
                            <th style="text-align:center;width:55px;font-size:0.6rem;padding:6px 2px;">{en}</th>
                          )) : (
                            <th style="text-align:center;width:70px;">Mencion</th>
                          )}
                        </tr>
                      </thead>
                      <tbody>
                        {sorted.map((q: any) => (
                          <tr>
                            <td>
                              <span class="tag" style={`background:${stageTagStyles[q.stage]?.bg || '#F3F4F6'};color:${stageTagStyles[q.stage]?.color || '#5A6478'};`}>
                                {q.stage?.toUpperCase() ?? '—'}
                              </span>
                            </td>
                            <td style="font-size:0.75rem;color:#1a1a2e;">{q.query}</td>
                            {hasEngines ? engineNames.map((en) => {
                              const eng = q.engines?.find((e: any) => e.name === en);
                              const m = eng?.mentioned ?? false;
                              return (
                                <td style="text-align:center;">
                                  <span class="material-symbols-outlined" style={`font-size:18px;color:${m?'#1D9E75':'#E24B4A'};font-variation-settings:'FILL' ${m?1:0};`}>
                                    {m ? 'check_circle' : 'cancel'}
                                  </span>
                                </td>
                              );
                            }) : (
                              <td style="text-align:center;">
                                <span class="material-symbols-outlined" style={`font-size:18px;color:${q.mentioned?'#1D9E75':'#E24B4A'};font-variation-settings:'FILL' ${q.mentioned?1:0};`}>
                                  {q.mentioned ? 'check_circle' : 'cancel'}
                                </span>
                              </td>
                            )}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                );
              })()}

              {(geo.mentionRate ?? 0) < 30 && (
                <div class="callout-warning" style="padding:14px 18px;border-radius:12px;font-size:0.82rem;line-height:1.55;background:rgba(186,117,23,0.08);border-left:3px solid #BA7517;color:#BA7517;">
                  Tu tasa de mencion en IA es baja. Crear contenido estructurado con FAQs, casos de uso y datos propios puede mejorar significativamente tu visibilidad en ChatGPT y Perplexity.
                </div>
              )}
            </div>
          ) : geoTruncated ? (
            <div style="padding:14px 18px;border-radius:12px;font-size:0.82rem;line-height:1.55;background:rgba(186,117,23,0.08);border-left:3px solid #BA7517;color:#BA7517;">
              Los datos de visibilidad en IA de este diagnostico no se pudieron almacenar correctamente (resultado demasiado grande). Re-lanza el diagnostico para obtener los datos completos.
            </div>
          ) : geoApiError ? (
            <div style="padding:14px 18px;border-radius:12px;font-size:0.82rem;line-height:1.55;background:rgba(186,117,23,0.08);border-left:3px solid #BA7517;color:#BA7517;">
              Error al capturar visibilidad en IA: {geoApiError}. Puede deberse a un limite temporal de la API — vuelve a lanzar el diagnostico.
            </div>
          ) : qaSuppressed.includes('geo_analysis') ? (
            <div style="padding:14px 18px;border-radius:12px;font-size:0.82rem;line-height:1.55;background:rgba(186,117,23,0.08);border-left:3px solid #BA7517;color:#BA7517;">El analisis de visibilidad en IA ha sido omitido por falta de datos suficientes.</div>
          ) : (
            <div style="padding:14px 18px;border-radius:12px;font-size:0.82rem;line-height:1.55;background:rgba(186,117,23,0.08);border-left:3px solid #BA7517;color:#BA7517;">No se han podido obtener datos de visibilidad en IA para este dominio.</div>
          )}
        </div>

        <!-- ================================================================
             #autoridad - Reputacion / Autoridad de Marca
        ================================================================ -->
        <div id="autoridad" class="reveal" style="margin-bottom:2.5rem;">
          <div class="block-header">
            <div class="section-label">AUTORIDAD Y REPUTACION</div>
            <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;">
              <div>
                <h2 class="section-title">Autoridad y Reputacion</h2>
                <p class="section-subtitle">¿Confian en ti los que te encuentran?</p>
              </div>
              <div style="position:relative;width:72px;height:72px;flex-shrink:0;">
                <svg viewBox="0 0 36 36" style="width:72px;height:72px;transform:rotate(-90deg);">
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(141,144,155,0.12)" stroke-width="3"/>
                  <circle cx="18" cy="18" r="15.9" fill="none" stroke={scoreColor(chapterScores.autoridad)} stroke-width="3" stroke-linecap="round" stroke-dasharray={`${chapterScores.autoridad}, 100`}/>
                </svg>
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
                  <span style={`font-size:1.1rem;font-weight:800;color:${scoreColor(chapterScores.autoridad)};`}>{chapterScores.autoridad}<span style="font-size:0.6rem;color:#8d909b;">/100</span></span>
                </div>
              </div>
            </div>
          </div>

          <!-- Blog + Press -->
          <div class="grid-2" style="margin-bottom:1.5rem;">
            <div class="glass-card" style={hasBlogEs ? 'border-left:3px solid #69FF87;' : ''}>
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <span class="material-symbols-outlined" style={`color:${hasBlogEs?'#69FF87':'#8d909b'};`}>{hasBlogEs ? 'check_circle' : 'remove_circle_outline'}</span>
                <span style="font-size:0.78rem;font-weight:600;color:#e2e0fc;">Blog / Contenido propio</span>
              </div>
              {hasBlogEs ? (
                <div>
                  {cc?.totalPosts && <div style="font-size:0.85rem;color:#c3c6d2;">{cc.totalPosts} articulos publicados
                    {cc.daysSinceLastPost != null && <span style="color:#8d909b;"> - Ultimo hace {cc.daysSinceLastPost}d</span>}
                  </div>}
                  {blogUrlEs && (
                    <div style="margin-top:6px;">
                      <a href={blogUrlEs} target="_blank" rel="noopener noreferrer" style="font-size:0.75rem;color:#aac7ff;text-decoration:none;">
                        {blogUrlEs.replace(/^https?:\/\//, '')}
                      </a>
                    </div>
                  )}
                  {!cc && <div style="font-size:0.82rem;color:#8d909b;margin-top:4px;">Detectado en la web — sin datos de publicacion</div>}
                </div>
              ) : (
                <div style="font-size:0.82rem;color:#8d909b;">No se ha detectado seccion de blog ni articulos publicados.</div>
              )}
            </div>

            <div class="glass-card" style={newsCountEs > 0 ? 'border-left:3px solid #aac7ff;' : ''}>
              <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px;">
                <span class="material-symbols-outlined" style={`color:${newsCountEs>0?'#aac7ff':'#8d909b'};`}>{newsCountEs > 0 ? 'newspaper' : 'newspaper'}</span>
                <span style="font-size:0.78rem;font-weight:600;color:#e2e0fc;">Apariciones en prensa</span>
              </div>
              <div style="font-size:1.5rem;font-weight:900;color:#e2e0fc;margin-bottom:4px;">{newsCountEs > 0 ? newsCountEs : '—'}</div>
              {newsCountEs > 0 ? (
                <div style="font-size:0.82rem;color:#c3c6d2;">
                  Menciones en Google News en los ultimos 3 meses.
                  {newsCountEs >= 5 ? ' Buena cobertura.' : newsCountEs >= 2 ? ' Cobertura moderada.' : ' Cobertura baja.'}
                </div>
              ) : (
                <div style="font-size:0.82rem;color:#8d909b;">Sin cobertura detectada en Google News.</div>
              )}
            </div>
          </div>

          <!-- Reviews -->
          {(ratingSources.length > 0 || gbp?.rating) && (
            <div class="surface-card" style="margin-bottom:1.5rem;">
              <div style="display:flex;align-items:center;gap:20px;margin-bottom:12px;flex-wrap:wrap;">
                <div>
                  <div style={`font-size:2.5rem;font-weight:900;color:${(avgRating ?? 0) >= 4.0 ? '#69FF87' : (avgRating ?? 0) >= 3.0 ? '#ffb4ab' : '#ffb4ab'};line-height:1;letter-spacing:-0.02em;`}>{avgRating ?? '—'}</div>
