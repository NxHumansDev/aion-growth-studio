      <!-- Footer -->
      <div class="footer-bar" style="background:#111125;padding:16px 2rem;display:flex;align-items:center;justify-content:space-between;">
        <div style="display:flex;align-items:center;gap:10px;">
          <img src="/logo-aion-dark.png" height="18" alt="AION" style="height:18px;filter:brightness(0) invert(1);opacity:0.5;" />
          <span style="color:rgba(226,224,252,0.3);font-size:0.68rem;">Informe confidencial generado el {auditDate}</span>
        </div>
