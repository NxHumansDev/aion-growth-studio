                    <td style="font-size:0.875rem;font-weight:500;">{c.label}</td>
                    <td style="text-align:center;">
                      <span style={`font-weight:700;color:${c.ok ? '#10B981' : '#EF4444'}`}>{c.ok ? '✓' : '✗'}</span>
                    </td>
                    <td style={`font-size:0.8rem;color:${c.ok ? '#10B981' : '#6B7280'};`}>{c.impact}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>

    <!-- ── BLOQUE 5: PLAN DE ACCIÓN ───────────────────────────────── -->
    <div class="section">
      <h2>¿Qué hacer, en qué orden?</h2>
      <p style="color:#6B7280;font-size:0.875rem;margin:0 0 1.5rem;">Iniciativas prioritarias ordenadas por ratio impacto/esfuerzo</p>

      {insights.initiatives?.length > 0 ? (
        insights.initiatives.map((init: any, i: number) => {
          const impactTags = [
            { label: i === 0 ? '🟢 Alto' : i === 1 ? '🟡 Medio-alto' : '🟡 Medio', color: i === 0 ? '#16a34a' : '#d97706', bg: i === 0 ? '#f0fdf4' : '#fffbeb' },
          ];
          return (
            <div class="initiative-card">
              <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.75rem;">
                <span class="initiative-num">{i + 1}</span>
                <h3 style="margin:0;font-size:1rem;">{init.title}</h3>
              </div>
              <p style="font-size:0.9rem;color:#D1D5DB;line-height:1.65;margin:0 0 0.875rem;">{init.description}</p>
              <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                <span style={`font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:${impactTags[0].bg};color:${impactTags[0].color};border:1px solid ${impactTags[0].color}40;`}>Impacto {impactTags[0].label}</span>
                <span style="font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:#1C2333;color:#9CA3AF;border:1px solid #1F2937;">Plazo {i === 0 ? '1-2 meses' : i === 1 ? '2-4 meses' : '3-6 meses'}</span>
              </div>
            </div>
          );
        })
      ) : (
        fallbackInitiatives.map((item, i) => (
          <div class="initiative-card">
            <div style="display:flex;align-items:flex-start;gap:0.75rem;margin-bottom:0.75rem;">
              <span class="initiative-num">{i + 1}</span>
              <h3 style="margin:0;font-size:1rem;">Mejorar: {item.label} ({item.score}/100)</h3>
            </div>
            <p style="font-size:0.75rem;color:#6B7280;margin:0 0 0.5rem;">
              {item.key === 'conversion' ? `Tu funnel score es ${item.score}/100. Cada visita que no convierte es un lead perdido.`
                : item.key === 'visibilidad' ? `Tu score de visibilidad es ${item.score}/100. Estás dejando demanda orgánica a la competencia.`
                : item.key === 'competitividad' ? `Tu posición competitiva es ${item.score}/100. Los competidores superan tus métricas clave.`
                : `Tu score de experiencia es ${item.score}/100. El rendimiento técnico afecta conversión directamente.`}
            </p>
            <p style="font-size:0.9rem;color:#D1D5DB;line-height:1.65;margin:0 0 0.875rem;">{item.action}</p>
            <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
              <span style={`font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:${item.score < 40 ? 'rgba(239,68,68,0.08)' : 'rgba(245,158,11,0.08)'};color:${item.score < 40 ? '#EF4444' : '#F59E0B'};border:1px solid ${item.score < 40 ? 'rgba(239,68,68,0.3)' : 'rgba(245,158,11,0.3)'};`}>Impacto {item.score < 40 ? '🟢 Alto' : '🟡 Medio'}</span>
              <span style="font-size:0.7rem;font-weight:600;padding:0.2rem 0.6rem;border-radius:9999px;background:#1C2333;color:#9CA3AF;border:1px solid #1F2937;">Plazo {i === 0 ? '1-2 meses' : '2-4 meses'}</span>
            </div>
          </div>
        ))
      )}

      {insights.bullets?.length > 0 && (
        <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid #1F2937;">
          <h3 style="margin-bottom:0.75rem;">Hallazgos clave del diagnóstico</h3>
          <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.5rem;">
            {insights.bullets.map((b: string) => (
              <li style="display:flex;align-items:flex-start;gap:0.5rem;font-size:0.9rem;color:#D1D5DB;line-height:1.6;">
                <span style="color:#3B82F6;font-weight:700;margin-top:0.1rem;flex-shrink:0;">→</span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

    <!-- ── BLOQUE 6: PROYECCIÓN DE IMPACTO ───────────────────────── -->
    {hasAnyImpactProjection && (
      <div class="section">
        <h2>📈 Tu potencial de crecimiento detectado</h2>
        <p style="color:#6B7280;font-size:0.875rem;margin:0 0 1.5rem;">Basado exclusivamente en los datos de este análisis, no en estimaciones genéricas.</p>

        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1rem;margin-bottom:1.25rem;">

          {/* Card tráfico orgánico */}
          {projTrafficBase > 0 && (
            <div style="background:#111827;border:1px solid #1F2937;border-top:3px solid #3B82F6;border-radius:0.75rem;padding:1.25rem;">
              <p style="font-size:0.65rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.625rem;">Keywords a un paso</p>
              <p style="font-family:'DM Mono',monospace;font-size:1.625rem;font-weight:500;color:#F9FAFB;margin:0 0 0.375rem;line-height:1;">+{fmt(projTrafficMin)}–{fmt(projTrafficMax)}</p>
              <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 0.75rem;line-height:1.55;">visitas/mes estimadas. Tienes <strong style="color:#D1D5DB;">{fmt(pos4to10)} keywords</strong> en pos. 4-10 optimizables.{projAdsValue != null && projAdsValue > 0 && <> Eq. ads: <strong style="color:#D1D5DB;">~{fmt(projAdsValue)}€/mes</strong>.</>}</p>
              <span style="display:inline-block;background:rgba(59,130,246,0.1);color:#60A5FA;border:1px solid rgba(59,130,246,0.25);border-radius:9999px;font-size:0.65rem;font-weight:600;padding:0.175rem 0.6rem;">60-90 días</span>
            </div>
          )}

          {/* Card visibilidad en IA */}
          {geoMissedQueries > 0 && (
            <div style="background:#111827;border:1px solid #1F2937;border-top:3px solid #6366F1;border-radius:0.75rem;padding:1.25rem;">
              <p style="font-size:0.65rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.625rem;">Invisibilidad en IA</p>
              <p style="font-family:'DM Mono',monospace;font-size:1.625rem;font-weight:500;color:#F9FAFB;margin:0 0 0.375rem;line-height:1;">{geoMissedQueries}/{geoTotalQueries}</p>
              <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 0.75rem;line-height:1.55;">consultas sin respuesta. Con estrategia de contenido GEO estas consultas son alcanzables.</p>
              <span style="display:inline-block;background:rgba(99,102,241,0.1);color:#A5B4FC;border:1px solid rgba(99,102,241,0.25);border-radius:9999px;font-size:0.65rem;font-weight:600;padding:0.175rem 0.6rem;">3-6 meses</span>
            </div>
          )}

          {/* Card reputación */}
          {repTotalReviews > 0 && repTotalReviews < 50 && (
            <div style="background:#111827;border:1px solid #1F2937;border-top:3px solid #F59E0B;border-radius:0.75rem;padding:1.25rem;">
              <p style="font-size:0.65rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.625rem;">Reputación bajo umbral</p>
              <p style="font-family:'DM Mono',monospace;font-size:1.625rem;font-weight:500;color:#F9FAFB;margin:0 0 0.375rem;line-height:1;">{repTotalReviews} → 50</p>
              <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 0.75rem;line-height:1.55;">reseñas actuales. Llegar a 50 te sitúa en el <strong style="color:#D1D5DB;">top 25%</strong> de visibilidad local.</p>
              <span style="display:inline-block;background:rgba(245,158,11,0.1);color:#FCD34D;border:1px solid rgba(245,158,11,0.25);border-radius:9999px;font-size:0.65rem;font-weight:600;padding:0.175rem 0.6rem;">Acción continua</span>
            </div>
          )}

          {/* Card tendencia */}
          {hasTrendLossImpact && seo && (
            <div style="background:#111827;border:1px solid #1F2937;border-top:3px solid #EF4444;border-radius:0.75rem;padding:1.25rem;">
              <p style="font-size:0.65rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.625rem;">Pérdida activa de visibilidad</p>
              <p style="font-family:'DM Mono',monospace;font-size:1.625rem;font-weight:500;color:#F9FAFB;margin:0 0 0.375rem;line-height:1;">−{fmt(seo.trendLost)}</p>
              <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 0.75rem;line-height:1.55;">keywords perdidas vs {fmt(seo.trendUp)} ganadas. Sin intervención la tendencia continúa.</p>
              <span style="display:inline-block;background:rgba(239,68,68,0.1);color:#FCA5A5;border:1px solid rgba(239,68,68,0.25);border-radius:9999px;font-size:0.65rem;font-weight:600;padding:0.175rem 0.6rem;">60 días</span>
            </div>
          )}
        </div>

        <p style="font-size:0.7rem;color:#4B5563;line-height:1.5;background:#111827;border:1px solid #1F2937;border-radius:0.375rem;padding:0.625rem 0.875rem;">
          Las proyecciones son estimaciones basadas en benchmarks del sector y en los datos específicos de este dominio. Los resultados reales dependen de la ejecución y de factores externos como cambios de algoritmo o movimientos de competidores.
        </p>
      </div>
    )}

    <!-- ── CTA PERSONALIZADO ─────────────────────────────────────── -->
    <div class="no-print" style="padding:3.5rem 2.5rem;background:linear-gradient(135deg,#0A0F1E 0%,#1E3A5F 60%,#0e4f6e 100%);text-align:center;color:#fff;">
      <p style="font-size:0.7rem;font-weight:600;color:#67e8f9;text-transform:uppercase;letter-spacing:0.12em;margin:0 0 1rem;">Siguiente paso</p>
      {trafficGap > 500 ? (
        <h2 class="num" style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;line-height:1.2;">
          Tu competencia genera ~{fmt(trafficGap)} visitas/mes más que tú.
        </h2>
      ) : (
        <h2 class="num" style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;line-height:1.2;">
          Este diagnóstico es una foto de hoy.
        </h2>
      )}
      <p style="font-size:1rem;color:rgba(255,255,255,0.75);max-width:520px;margin:0 auto 2rem;line-height:1.6;">
        Podemos ayudarte a {btObjective} con un plan de acción concreto. Sin humo.
      </p>
      <!-- Dos CTAs -->
      <div style="display:flex;align-items:stretch;justify-content:center;gap:1rem;flex-wrap:wrap;max-width:640px;margin:0 auto;">
        <!-- CTA 1: Radar plan -->
        <div style="flex:1;min-width:240px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);border-radius:1rem;padding:1.25rem 1.5rem;text-align:left;">
          <p style="font-size:0.65rem;font-weight:700;color:#67e8f9;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.375rem;">Plan Radar</p>
          <p style="font-size:1.1rem;font-weight:700;color:#fff;margin:0 0 0.5rem;line-height:1.3;">Informe mensual de evolución</p>
          <p style="font-size:0.8rem;color:rgba(255,255,255,0.65);margin:0 0 1rem;line-height:1.5;">GA4 real, benchmark competitivo actualizado, tendencias y deck ejecutivo mensual.</p>
          <a
            href="mailto:hola@aiongrowth.studio?subject=Plan Radar — {domain}"
            style="display:inline-flex;align-items:center;gap:0.375rem;background:#3B82F6;color:#fff;font-weight:700;font-size:0.85rem;padding:0.625rem 1.25rem;border-radius:0.625rem;text-decoration:none;"
          >
            Ver plan Radar →
          </a>
        </div>
        <!-- CTA 2: Growth Advisor -->
        <div style="flex:1;min-width:240px;background:#111827;border-radius:1rem;padding:1.25rem 1.5rem;text-align:left;">
          <p style="font-size:0.65rem;font-weight:700;color:#3B82F6;text-transform:uppercase;letter-spacing:0.1em;margin:0 0 0.375rem;">Growth Advisor</p>
          <p style="font-size:1.1rem;font-weight:700;color:#0B1B3D;margin:0 0 0.5rem;line-height:1.3;">Sesión gratuita de revisión</p>
          <p style="font-size:0.8rem;color:#9CA3AF;margin:0 0 1rem;line-height:1.5;">15 minutos para revisar tu diagnóstico, resolver dudas y explorar cómo avanzar.</p>
          <a
            href="mailto:hola@aiongrowth.studio?subject=Sesión Growth Advisor — {domain}"
            style="display:inline-flex;align-items:center;gap:0.375rem;background:#1E3A5F;color:#fff;font-weight:700;font-size:0.85rem;padding:0.625rem 1.25rem;border-radius:0.625rem;text-decoration:none;"
          >
            Hablar con un advisor →
          </a>
        </div>
      </div>
      <p style="font-size:0.7rem;color:rgba(255,255,255,0.35);margin:1.5rem 0 0;">Sin compromiso · Respuesta en menos de 24h</p>
    </div>

    <!-- ── FOOTER ──────────────────────────────────────────────────── -->
    <div style="padding:1.5rem 2.5rem;background:#0A0F1E;color:#6B7280;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
      <div>
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" style="height:32px;filter:brightness(0) invert(1);margin-bottom:0.25rem;display:block;" />
        <p style="font-size:0.7rem;margin:0;">Diagnóstico generado el {auditDate} · aiongrowth.studio</p>
      </div>
      <div style="text-align:right;">
        <p style="font-size:0.75rem;margin:0 0 0.25rem;">hola@aiongrowth.studio</p>
      </div>
    </div>
  </div>

  <!-- ── ANIMATIONS ─────────────────────────────────────────────── -->
  <script define:vars={{ scoreTotal: health.total }}>
    // 1. Score counter + ring animation
    const counter = document.getElementById('score-counter');
    const ring = document.getElementById('score-ring');
    if (counter && scoreTotal > 0) {
      const duration = 1400;
      const start = performance.now();
      const animate = (now) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = Math.round(eased * scoreTotal);
        counter.textContent = current;
        if (ring) ring.setAttribute('stroke-dasharray', eased * scoreTotal + ', 100');
        if (progress < 1) requestAnimationFrame(animate);
      };
      requestAnimationFrame(animate);
    }

    // 2. Scroll reveal
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

    // 3. Bar fill animation (data-width attr)
    const barObs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.querySelectorAll('.bar-fill[data-width]').forEach(bar => {
            bar.style.width = bar.getAttribute('data-width') + '%';
          });
          barObs.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('table').forEach(t => barObs.observe(t));
  </script>
</body>
</html>
