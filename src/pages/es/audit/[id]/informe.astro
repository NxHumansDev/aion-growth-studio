          )}

          <!-- SEO metrics -->
          {seo ? (
            <div>
              <div class="grid-4" style="margin-bottom:1rem;">
                <div class="metric-card-dark">
                  <div class="metric-value-lg" style="color:#aac7ff;">{fmt(seo.keywordsTop10)}</div>
                  <div class="metric-label-sm">Keywords Top 10</div>
                </div>
                <div class="metric-card-dark">
                  <div class="metric-value-lg" style="color:#aac7ff;">{fmt(seo.keywordsTop3)}</div>
                  <div class="metric-label-sm">Keywords Top 3</div>
                </div>
                <div class="metric-card-dark">
                  <div class="metric-value-lg" style="color:#68dbae;">{fmt(seo.organicTrafficEstimate)}</div>
                  <div class="metric-label-sm">Visitas organicas / mes</div>
                </div>
                <div class="metric-card-dark">
                  <div class="metric-value-lg" style="color:#e2e0fc;">{seo.keywordsPos4to10 ?? '—'}</div>
