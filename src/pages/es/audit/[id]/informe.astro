      </div>
      <!-- END .report -->

      <!-- CTA Section (dark gradient) - desktop only -->
      <div style="background:linear-gradient(135deg,#1a1a2e 0%,#111125 100%);padding:3rem 2rem;" class="no-print cta-section-desktop">
        <div style="max-width:1100px;width:100%;margin:0 auto;">
          <div style="display:grid;grid-template-columns:1fr auto;gap:32px;align-items:center;">
            <div>
              <div style="font-size:1.4rem;font-weight:800;color:#e2e0fc;margin-bottom:10px;letter-spacing:-0.02em;">
