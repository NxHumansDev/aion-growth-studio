          <!-- Claude visibility summary -->
          {visSummaryText && (
            <div style="font-size:0.85rem;color:#c3c6d2;font-style:italic;line-height:1.6;margin-bottom:1.5rem;padding-left:14px;border-left:3px solid #aac7ff;">
              {visSummaryText}
            </div>
