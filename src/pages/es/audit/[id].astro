      const ctItems = results.competitor_traffic?.items || [];
      const ownDomain = domain || '';
      const compTableHtml = ctItems.length > 0 ? (() => {
        const drCol = (dr) => !dr ? 'text-slate-400' : dr >= 50 ? 'text-emerald-400' : dr >= 25 ? 'text-amber-400' : 'text-red-400';
        const ownRow = `<tr class="border-t border-white/5">
          <td class="py-2 pr-3 font-semibold text-cyan-300 text-xs">${ownDomain} ★</td>
          <td class="py-2 text-right text-xs ${drColor}">${s.domainRank ?? '—'}</td>
          <td class="py-2 text-right text-xs text-slate-200">${formatNum(s.organicTrafficEstimate)}</td>
          <td class="py-2 text-right text-xs text-slate-200">${formatNum(s.keywordsTop10)}</td>
        </tr>`;
        const compRows = ctItems.map(c => `<tr class="border-t border-white/5">
          <td class="py-2 pr-3 text-xs"><a href="${c.url}" target="_blank" class="text-slate-300 hover:text-white">${c.domain}</a></td>
          <td class="py-2 text-right text-xs ${drCol(c.domainRank)}">${c.domainRank ?? '—'}</td>
          <td class="py-2 text-right text-xs text-slate-200">${formatNum(c.organicTrafficEstimate)}</td>
          <td class="py-2 text-right text-xs text-slate-200">${formatNum(c.keywordsTop10)}</td>
        </tr>`).join('');
        return `
          <div class="mt-5 pt-4 border-t border-white/8">
            <p class="text-xs font-semibold text-slate-300 mb-3">Comparativa vs competidores</p>
            <div class="overflow-x-auto">
              <table class="w-full text-left">
                <thead><tr class="text-xs text-slate-500 uppercase tracking-wide">
                  <th class="pb-1.5 font-medium">Dominio</th>
                  <th class="pb-1.5 font-medium text-right">DR</th>
                  <th class="pb-1.5 font-medium text-right">Tráf. org./mes</th>
                  <th class="pb-1.5 font-medium text-right">KW top 10</th>
                </tr></thead>
                <tbody>${ownRow}${compRows}</tbody>
              </table>
            </div>
            <p class="text-xs text-slate-500 mt-2 italic">Estimaciones DataForSEO. El tráfico orgánico excluye visitas de pago, social y directo.</p>
          </div>`;
      })() : '';

      sections.push(`
        <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
          <h3 class="text-base font-semibold text-white mb-1">🔍 Visibilidad orgánica</h3>
          <p class="text-xs text-slate-500 mb-4">Datos de DataForSEO · Estimaciones del mercado orgánico</p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
            <div class="bg-white/5 rounded-xl p-3 text-center">
              <div class="text-xl font-bold ${drColor}">${s.domainRank ?? '—'}</div>
              <div class="text-xs text-slate-400 mt-0.5">Domain Rank</div>
              <div class="text-xs ${drColor}">${!s.domainRank ? '' : s.domainRank >= 50 ? 'Alto' : s.domainRank >= 25 ? 'Medio' : 'Bajo'}</div>
            </div>
            <div class="bg-white/5 rounded-xl p-3 text-center">
              <div class="text-xl font-bold text-white">${formatNum(s.organicTrafficEstimate)}</div>
              <div class="text-xs text-slate-400 mt-0.5">Visitas org./mes est.</div>
            </div>
            <div class="bg-white/5 rounded-xl p-3 text-center">
              <div class="text-xl font-bold text-white">${formatNum(s.keywordsTop10)}</div>
              <div class="text-xs text-slate-400 mt-0.5">Keywords top 10</div>
            </div>
            <div class="bg-white/5 rounded-xl p-3 text-center">
              <div class="text-xl font-bold text-white">${formatNum(s.referringDomains)}</div>
              <div class="text-xs text-slate-400 mt-0.5">Dominios referentes</div>
            </div>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div class="bg-white/5 rounded-lg p-2.5 text-center">
              <div class="text-sm font-bold text-cyan-300">${formatNum(s.keywordsTop3)}</div>
              <div class="text-xs text-slate-500">Top 3</div>
            </div>
            <div class="bg-white/5 rounded-lg p-2.5 text-center">
              <div class="text-sm font-bold text-slate-300">${formatNum(s.keywordsTop30)}</div>
              <div class="text-xs text-slate-500">Top 30</div>
            </div>
            <div class="bg-white/5 rounded-lg p-2.5 text-center">
              <div class="text-sm font-bold text-slate-300">${formatNum(s.backlinksTotal)}</div>
              <div class="text-xs text-slate-500">Backlinks totales</div>
            </div>
          </div>
          ${compTableHtml}
          ${(() => {
            const sp = results.seo_pages;
            if (!sp || sp.skipped || !sp.pages?.length) return '';
            const rows = sp.pages.map(p => `<tr class="border-t border-white/5">
              <td class="py-2 pr-2 text-xs text-slate-300 max-w-[140px] truncate" title="${p.pageAddress}">${p.pageAddress.replace(/^https?:\/\/[^/]+/, '') || '/'}</td>
              <td class="py-2 text-right text-xs text-slate-200">${p.trafficEstimate != null ? formatNum(p.trafficEstimate) + '/mo' : '—'}</td>
              <td class="py-2 text-right text-xs text-slate-400">${p.keywords ?? '—'}</td>
            </tr>`).join('');
            return `
              <div class="mt-5 pt-4 border-t border-white/8">
                <p class="text-xs font-semibold text-slate-300 mb-3">Top páginas orgánicas</p>
                <div class="overflow-x-auto">
                  <table class="w-full text-left">
                    <thead><tr class="text-xs text-slate-500 uppercase tracking-wide">
                      <th class="pb-1.5 font-medium">Página</th>
                      <th class="pb-1.5 font-medium text-right">Tráf. est./mo</th>
                      <th class="pb-1.5 font-medium text-right">Keywords</th>
                    </tr></thead>
                    <tbody>${rows}</tbody>
                  </table>
                </div>
              </div>`;
          })()}
        </div>
      `);
    }

    // ── Tech Stack & Medición ──────────────────────────────────────
    if (results.techstack && !results.techstack.skipped) {
      const ts = results.techstack;
      const score = ts.maturityScore ?? 0;
      const scoreColor = score >= 70 ? 'text-emerald-400' : score >= 40 ? 'text-amber-400' : 'text-red-400';
      const scoreLabel = score >= 70 ? 'Stack maduro' : score >= 40 ? 'Configuración básica' : 'Carencias importantes';

      const catRows = [
        { label: '📊 Analytics', tools: ts.analytics },
        { label: '🏷️ Tag Manager', tools: ts.tagManager },
        { label: '💰 Píxeles de conversión', tools: ts.conversionPixels },
        { label: '🤝 CRM / Automatización', tools: ts.crmAutomation },
        { label: '💬 Chat / Soporte', tools: ts.chatSupport },
        { label: '🔥 Mapas de calor', tools: ts.heatmaps },
      ].filter(r => r.tools && r.tools.length > 0);

      const catHtml = catRows.map(row => `
        <div class="flex items-start gap-3 py-2 border-b border-white/5 last:border-0">
          <span class="text-xs text-slate-400 w-40 shrink-0 pt-0.5">${row.label}</span>
          <div class="flex flex-wrap gap-1.5">
            ${(row.tools || []).map(t => `<span class="px-2 py-0.5 bg-cyan-500/10 border border-cyan-400/20 text-cyan-300 text-xs rounded-full">${t}</span>`).join('')}
          </div>
        </div>`).join('');

      const missingCats = [
        { key: 'analytics', label: 'Herramienta de analytics' },
        { key: 'tagManager', label: 'Tag Manager' },
        { key: 'conversionPixels', label: 'Píxeles de conversión' },
        { key: 'crmAutomation', label: 'CRM o automatización de marketing' },
        { key: 'chatSupport', label: 'Chat en vivo' },
      ].filter(c => !ts[c.key]?.length);

      const missingHtml = missingCats.length > 0 ? `
        <div class="mt-3 pt-3 border-t border-white/8">
          <p class="text-xs font-semibold text-slate-400 mb-2">Ausencias detectadas:</p>
          ${missingCats.map(c => `<div class="flex items-center gap-2 text-xs text-slate-500 mb-1"><span class="text-red-400">✗</span>${c.label}</div>`).join('')}
        </div>` : '';

      const scoreExplain = [
        { label: 'Analytics (25 pts)', ok: ts.analytics?.length > 0, value: ts.analytics?.join(', ') || 'No detectado' },
        { label: 'Tag Manager (20 pts)', ok: ts.tagManager?.length > 0, value: ts.tagManager?.join(', ') || 'No detectado' },
        { label: 'Píxeles conversión (20 pts)', ok: ts.conversionPixels?.length > 0, value: ts.conversionPixels?.join(', ') || 'No detectado' },
        { label: 'CRM / Automatización (25 pts)', ok: ts.crmAutomation?.length > 0, value: ts.crmAutomation?.join(', ') || 'No detectado' },
        { label: 'Chat / Soporte (10 pts)', ok: ts.chatSupport?.length > 0, value: ts.chatSupport?.join(', ') || 'No detectado' },
      ];
      const scoreExplainHtml = scoreExplain.map(r => `
        <div class="flex items-start gap-3 py-2 border-b border-white/5 last:border-0">
          <span class="${r.ok ? 'text-emerald-400' : 'text-red-400'} mt-0.5 shrink-0 text-sm">${r.ok ? '✓' : '✗'}</span>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium text-slate-300">${r.label}</p>
            <p class="text-xs text-slate-500">${r.value}</p>
          </div>
        </div>`).join('');

      sections.push(`
        <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
          <h3 class="text-base font-semibold text-white mb-1">🛠️ Stack tecnológico y medición</h3>
          <div class="flex items-center gap-3 mb-1">
            <span class="text-2xl font-bold ${scoreColor}">${score}/100</span>
            <span class="text-xs ${scoreColor}">${scoreLabel}</span>
            ${ts.cms ? `<span class="ml-auto px-2 py-0.5 bg-white/10 text-slate-300 text-xs rounded-full">CMS: ${ts.cms}</span>` : ''}
          </div>
          <p class="text-xs text-slate-500 mb-4">El score refleja qué categorías de herramientas están activas. Cada categoría aporta hasta los puntos indicados.</p>
          ${scoreExplainHtml}
        </div>
      `);
    }

    // ── Conversión ─────────────────────────────────────────────────
    if (results.conversion && !results.conversion.skipped) {
      const cv = results.conversion;
      const score = cv.funnelScore ?? 0;
      const scoreColor = score >= 70 ? 'text-emerald-400' : score >= 40 ? 'text-amber-400' : 'text-red-400';

      const checks = [
        { label: 'Formulario de contacto', ok: cv.hasContactForm, detail: cv.hasContactForm ? `${cv.formCount} formulario(s), ${cv.formFieldCount} campos` : 'No detectado' },
        { label: 'CTAs claros', ok: cv.hasCTA, detail: cv.hasCTA ? `${cv.ctaCount} elemento(s) con intención de conversión` : 'Sin CTAs detectados' },
        { label: 'Lead magnet', ok: cv.hasLeadMagnet, detail: cv.hasLeadMagnet ? 'Detectado (descarga, demo, recurso gratuito…)' : 'No detectado' },
        { label: 'Prueba social / testimonios', ok: cv.hasTestimonials, detail: cv.hasTestimonials ? 'Detectado' : 'Sin testimonios visibles' },
        { label: 'Precios visibles', ok: cv.hasPricing, detail: cv.hasPricing ? 'Sección de precios detectada' : 'Sin página de precios' },
        { label: 'Contenido en vídeo', ok: cv.hasVideo, detail: cv.hasVideo ? 'Presente' : 'Sin vídeo detectado' },
        { label: 'Chat en vivo', ok: cv.hasChatWidget, detail: cv.hasChatWidget ? 'Activo' : 'Sin chat en vivo' },
      ];

      const checksHtml = checks.map(c => `
        <div class="flex items-start gap-3 py-2 border-b border-white/5 last:border-0">
          <span class="${c.ok ? 'text-emerald-400' : 'text-red-400'} mt-0.5 shrink-0 text-sm">${c.ok ? '✓' : '✗'}</span>
          <div>
            <p class="text-xs font-medium text-slate-200">${c.label}</p>
            <p class="text-xs text-slate-500">${c.detail}</p>
          </div>
        </div>`).join('');

      const llmHtml = cv.summary ? `
        <div class="mt-4 pt-4 border-t border-white/10">
          <p class="text-xs text-slate-300 italic leading-relaxed mb-3">${cv.summary}</p>
          ${cv.strengths?.length ? `<p class="text-xs font-semibold text-emerald-400 mb-1">Fortalezas:</p><ul class="mb-3">${cv.strengths.map(s => `<li class="text-xs text-slate-300 mb-0.5">· ${s}</li>`).join('')}</ul>` : ''}
          ${cv.weaknesses?.length ? `<p class="text-xs font-semibold text-amber-400 mb-1">Brechas prioritarias:</p><ul>${cv.weaknesses.map(w => `<li class="text-xs text-slate-300 mb-0.5">· ${w}</li>`).join('')}</ul>` : ''}
        </div>` : '';

      sections.push(`
        <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
          <h3 class="text-base font-semibold text-white mb-1">🎯 Capacidad de conversión</h3>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl font-bold ${scoreColor}">${score}/100</span>
            <span class="text-xs ${scoreColor}">${score >= 70 ? 'Funnel bien configurado' : score >= 40 ? 'Funnel básico, mejoras posibles' : 'Funnel débil — alta prioridad'}</span>
          </div>
          ${checksHtml}
          ${llmHtml}
        </div>
      `);
    }

    container.innerHTML = sections.join('');
  }

  function formatNum(n) {
    if (n == null) return '—';
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
    if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
    return String(n);
  }

  function buildRows(rows) {
    return rows.map(r =>
      `<div class="flex gap-3 py-2 border-b border-white/5 last:border-0">
        <span class="text-xs text-slate-400 w-36 shrink-0">${r.label}</span>
        <span class="text-xs text-slate-200 flex-1">${r.value}</span>
      </div>`
    ).join('');
  }

  function buildSection(title, rows) {
    return `
      <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
        <h3 class="text-base font-semibold text-white mb-4">${title}</h3>
        ${buildRows(rows)}
      </div>
    `;
  }

  function showError() {
    document.getElementById('processing-state').classList.add('hidden');
    document.getElementById('error-state').classList.remove('hidden');
    const navActions = document.querySelector('.nav-actions');
    if (navActions) navActions.style.display = '';
  }

  async function poll() {
    try {
      const res = await fetch(`/api/audit/${auditId}/status`);
      if (!res.ok) {
        showError();
        return;
      }
      const data = await res.json();

      setProgress(data.progress || 0);

      if (data.module_completed) {
        completedModules.add(data.module_completed);
        MODULES.forEach((key, i) => {
          if (completedModules.has(key)) {
            markModule(key, 'done');
          } else if (i === completedModules.size) {
            markModule(key, 'running');
          }
        });
      }

      if (data.status === 'completed') {
        setProgress(100);
        MODULES.forEach(key => markModule(key, 'done'));
        showResults(data);
        return;
      }

      if (data.status === 'error') {
        showError();
        return;
      }

      // Mark next module as running + update narrative
      const nextIdx = completedModules.size;
      if (nextIdx < MODULES.length) {
        markModule(MODULES[nextIdx], 'running');
        setNarrative(MODULES[nextIdx]);
      }

      pollTimer = setTimeout(poll, 2000);
    } catch (err) {
      console.error('Poll error:', err);
      pollTimer = setTimeout(poll, 3000);
    }
  }

  // Start polling
  if (initialStatus === 'completed') {
    // Already done, fetch results immediately
    poll();
  } else if (initialStatus === 'error') {
    showError();
  } else {
    markModule(MODULES[0], 'running');
    setNarrative(MODULES[0]);
    setProgress(2);
    setTimeout(poll, 1500);
  }
</script>
