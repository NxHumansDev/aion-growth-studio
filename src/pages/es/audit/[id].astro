---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { getAuditPage } from '../../../lib/audit/notion';

const { id } = Astro.params;
const lang = 'es';

let auditUrl = '';
let initialStatus = 'processing';

if (id) {
  try {
    const audit = await getAuditPage(id);
    auditUrl = audit.url;
    initialStatus = audit.status;
  } catch {
    // Page not found or Notion error — show loading state
  }
}

const domain = auditUrl ? new URL(auditUrl).hostname.replace(/^www\./, '') : '';

const MODULES = [
  { key: 'crawl',      label: 'Análisis técnico SEO' },
  { key: 'ssl',        label: 'Seguridad SSL/HTTPS' },
  { key: 'pagespeed',  label: 'Rendimiento web (PageSpeed)' },
  { key: 'sector',     label: 'Detección de sector' },
  { key: 'content',    label: 'Análisis de contenido' },
  { key: 'geo',        label: 'Visibilidad en IA (GEO)' },
  { key: 'gbp',        label: 'Google Business Profile' },
  { key: 'traffic',    label: 'Tráfico estimado' },
  { key: 'seo',        label: 'SEO orgánico y backlinks' },
  { key: 'seo_pages',  label: 'Top páginas orgánicas' },
  { key: 'competitors',        label: 'Análisis de competidores' },
  { key: 'competitor_traffic', label: 'Tráfico de competidores' },
  { key: 'keyword_gap',        label: 'Keyword gap vs competidores' },
  { key: 'instagram',          label: 'Instagram y Redes Sociales' },
  { key: 'linkedin',   label: 'LinkedIn Empresa' },
  { key: 'techstack',  label: 'Stack tecnológico y medición' },
  { key: 'conversion', label: 'Capacidad de conversión' },
  { key: 'score',      label: 'Puntuación final' },
  { key: 'insights',   label: 'Diagnóstico ejecutivo' },
];
---

<Layout
  title={`Analizando ${domain || 'tu web'} — AION`}
  description="Análisis de visibilidad digital en curso"
  lang={lang}
>
  <div class="audit-bg min-h-screen text-white flex flex-col">
    <!-- Header -->
    <nav class="flex items-center justify-between px-5 md:px-10 py-3">
      <a href="/es/">
        <img src="/logo-aion-dark.png" alt="AION Growth Studio" class="h-8 md:h-9 w-auto brightness-0 invert" />
      </a>
      <div class="flex items-center gap-2 nav-actions" style="display:none">
        <a href="/es/diagnostico" class="text-sm text-white/60 hover:text-white transition-colors">Nuevo analisis</a>
      </div>
    </nav>

    <div class="flex-1 px-4 py-6 max-w-2xl mx-auto w-full">

      <!-- PROCESSING STATE -->
      <div id="processing-state">
        <!-- Header -->
        <div class="text-center mb-6">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-cyan-500/10 border border-cyan-400/20 rounded-full text-cyan-300 text-xs font-medium mb-4">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-400"></span>
            </span>
            Analisis en curso
          </div>
          <h1 class="text-xl md:text-2xl font-bold text-white mb-1">Analizando tu presencia digital</h1>
          {domain && <p class="text-slate-500 text-sm font-mono">{domain}</p>}
        </div>

        <!-- Progress bar + narrative -->
        <div class="mb-5 p-4 rounded-xl bg-white/3 border border-white/5">
          <div class="flex items-center justify-between gap-4 mb-2">
            <p id="progress-narrative" class="text-sm text-slate-300 transition-all duration-500 truncate"></p>
            <span id="progress-pct" class="text-sm text-cyan-400 font-mono font-medium shrink-0">0%</span>
          </div>
          <div class="h-2 bg-white/10 rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-gradient-to-r from-cyan-500 to-blue-500 rounded-full transition-all duration-700 ease-out" style="width:0%"></div>
          </div>
        </div>

        <!-- Module list -->
        <div class="space-y-2">
          {MODULES.map((mod, index) => (
            <div
              id={`module-${mod.key}`}
              class="module-item flex items-center gap-3 px-4 py-3 rounded-lg bg-white/2 border border-white/5 opacity-40 transition-all duration-300"
              style={`transition-delay: ${index * 30}ms`}
            >
              <div class="module-icon w-5 h-5 rounded-full border-2 border-white/20 flex items-center justify-center shrink-0 transition-all duration-300">
                <div class="w-1.5 h-1.5 rounded-full bg-transparent transition-all duration-300"></div>
              </div>
              <span class="text-sm text-slate-400 transition-colors duration-300">{mod.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- RESULTS STATE (hidden initially) -->
      <div id="results-state" class="hidden">
        <!-- Header with domain -->
        <div class="mb-8">
          <div class="flex items-center justify-between mb-4">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-500/10 border border-emerald-400/20 rounded-full text-emerald-300 text-xs font-medium">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              Completado
            </div>
            {domain && (
              <span class="text-xs text-slate-500 font-mono bg-white/5 px-2 py-1 rounded">{domain}</span>
            )}
          </div>
          <h1 class="text-xl md:text-2xl font-bold text-white">Informe de Visibilidad Digital</h1>
        </div>

        <!-- Score card -->
        <div class="mb-8 p-6 rounded-2xl bg-gradient-to-br from-white/5 to-white/2 border border-white/10">
          <div class="flex items-center gap-6">
            <!-- Score gauge -->
            <div class="relative w-24 h-24 shrink-0">
              <svg class="w-24 h-24 -rotate-90" viewBox="0 0 36 36">
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="2.5"/>
                <circle
                  id="score-ring"
                  cx="18" cy="18" r="15.9"
                  fill="none"
                  stroke="url(#scoreGradient)"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-dasharray="0, 100"
                  class="transition-all duration-1000"
                />
                <defs>
                  <linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="#22d3ee"/>
                    <stop offset="100%" stop-color="#3b82f6"/>
                  </linearGradient>
                </defs>
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span id="score-value" class="text-2xl font-bold text-white">--</span>
              </div>
            </div>
            <!-- Score info -->
            <div class="flex-1">
              <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">AEO Score</p>
              <p id="score-label" class="text-sm text-slate-300">Calculando puntuacion...</p>
            </div>
          </div>
        </div>

        <!-- Score breakdown (7 pilares) -->
        <div class="mb-8">
          <p class="text-xs text-slate-500 uppercase tracking-wider mb-3">Desglose por area</p>
          <div id="score-breakdown" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-7 gap-2"></div>
        </div>

        <!-- Executive insights -->
        <div id="insights-section" class="hidden mb-8"></div>

        <!-- Detailed sections -->
        <div id="detail-sections" class="space-y-3"></div>

        <!-- CTA -->
        <div class="mt-10 p-5 bg-gradient-to-r from-cyan-500/8 to-blue-500/8 border border-white/10 rounded-xl">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h3 class="text-sm font-semibold text-white mb-1">Implementa estas mejoras</h3>
              <p class="text-xs text-slate-400">En AION desplegamos tu infraestructura de crecimiento en 8 semanas.</p>
            </div>
            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2">
              <a
                href="mailto:hola@aiongrowth.studio"
                class="inline-flex items-center justify-center gap-2 px-4 py-2.5 bg-white text-[#0B1B3D] font-medium text-sm rounded-lg hover:bg-cyan-300 transition-all"
              >
                Hablar con AION
              </a>
              <a
                href={`/es/audit/${id}/informe`}
                class="inline-flex items-center justify-center gap-2 px-4 py-2.5 border border-white/20 text-white font-medium text-sm rounded-lg hover:bg-white/5 transition-all"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Ver informe
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- ERROR STATE (hidden initially) -->
      <div id="error-state" class="hidden text-center py-20">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-500/10 border border-red-400/20 flex items-center justify-center">
          <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-white mb-2">El analisis no pudo completarse</h2>
        <p class="text-slate-400 text-sm mb-6">Ha ocurrido un error al analizar tu web. Por favor, inténtalo de nuevo.</p>
        <a
          href="/es/diagnostico"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white text-[#0B1B3D] font-semibold text-sm rounded-xl hover:bg-cyan-300 transition-all duration-300"
        >
          Nuevo análisis
        </a>
      </div>

    </div>

    <!-- Footer -->
    <div class="text-center py-6 text-xs text-slate-500">
      <a href="/es/" class="hover:text-slate-300 transition-colors">AION Growth Studio</a>
      <span class="mx-2">·</span>
      <a href="mailto:hola@aiongrowth.studio" class="hover:text-slate-300 transition-colors">hola@aiongrowth.studio</a>
    </div>
  </div>
</Layout>

<style>
  .audit-bg {
    background: linear-gradient(160deg, #0B1B3D 0%, #0d2347 50%, #0B1B3D 100%);
  }
  .bg-white\/2 {
    background-color: rgba(255,255,255,0.02);
  }
  .bg-white\/3 {
    background-color: rgba(255,255,255,0.03);
  }
  
  /* Module states */
  .module-item.running {
    opacity: 1;
    background: rgba(34, 211, 238, 0.05);
    border-color: rgba(34, 211, 238, 0.2);
  }
  .module-item.running .module-icon {
    border-color: rgb(34, 211, 238);
  }
  .module-item.running .module-icon div {
    background: rgb(34, 211, 238);
    animation: pulse-dot 1s ease-in-out infinite;
  }
  .module-item.running span:last-child {
    color: rgb(226, 232, 240);
  }
  
  .module-item.done {
    opacity: 1;
    background: rgba(16, 185, 129, 0.05);
    border-color: rgba(16, 185, 129, 0.2);
  }
  .module-item.done .module-icon {
    background: rgb(16, 185, 129);
    border-color: rgb(16, 185, 129);
  }
  .module-item.done span:last-child {
    color: rgb(110, 231, 183);
  }
  
  @keyframes pulse-dot {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.7; }
  }
</style>

<script define:vars={{ auditId: id, initialStatus, domain }}>
  const MODULES = [
    'crawl', 'ssl', 'pagespeed', 'sector', 'content', 'geo', 'gbp', 'traffic', 'seo', 'seo_pages', 'competitors', 'competitor_traffic', 'keyword_gap', 'instagram', 'linkedin', 'techstack', 'conversion', 'score', 'insights'
  ];

  const MODULE_NARRATIVE = {
    crawl:               'Escaneando estructura técnica y señales de contenido…',
    ssl:                 'Verificando certificado de seguridad del dominio…',
    pagespeed:           'Midiendo velocidad de carga — cada segundo importa para el SEO…',
    sector:              'Identificando sector y posicionamiento de mercado…',
    content:             'Analizando propuesta de valor y claridad de mensajes…',
    geo:                 'Probando visibilidad en ChatGPT, Perplexity y otros motores de IA…',
    gbp:                 'Buscando y auditando ficha de Google Business Profile…',
    traffic:             'Estimando volumen de tráfico y tendencia anual…',
    seo:                 'Contando keywords en top 10 de Google y midiendo autoridad de dominio…',
    seo_pages:           'Identificando las páginas que más tráfico orgánico generan…',
    competitors:         'Mapeando el territorio competitivo del sector…',
    competitor_traffic:  'Comparando tu tráfico y keywords con la competencia directa…',
    keyword_gap:         'Buscando dónde ganan tus competidores y tú no apareces…',
    instagram:           'Analizando presencia y engagement en redes sociales…',
    linkedin:            'Auditando autoridad profesional en LinkedIn…',
    techstack:           'Detectando herramientas de marketing, analytics y conversión…',
    conversion:          'Evaluando elementos de captación y funnel de conversión…',
    score:               'Calculando puntuación de salud digital…',
    insights:            'Generando diagnóstico ejecutivo personalizado…',
  };

  function setNarrative(moduleKey) {
    const el = document.getElementById('progress-narrative');
    if (!el) return;
    const text = MODULE_NARRATIVE[moduleKey];
    if (!text) return;
    el.style.opacity = '0';
    setTimeout(() => {
      el.textContent = text;
      el.style.opacity = '0.8';
    }, 200);
  }

  let completedModules = new Set();
  let pollTimer = null;

  function setProgress(pct) {
    const bar = document.getElementById('progress-bar');
    const label = document.getElementById('progress-pct');
    if (bar) bar.style.width = `${pct}%`;
    if (label) label.textContent = `${pct}%`;
  }

  function markModule(key, state) {
    const el = document.getElementById(`module-${key}`);
    if (!el) return;
    const icon = el.querySelector('.module-icon');
    
    // Remove previous states
    el.classList.remove('opacity-40', 'running', 'done');
    
    if (state === 'done') {
      el.classList.add('done');
      if (icon) {
        icon.innerHTML = '<svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>';
      }
    } else if (state === 'running') {
      el.classList.add('running');
    }
  }

  function showResults(data) {
    // Redirect to the full rich report
    window.location.href = `/es/audit/${auditId}/informe`;
  }

  function showResults_unused(data) {
    const results = data.results || {};
    const score = results.score?.total ?? data.score ?? 0;

    // Insights section
    const ins = results.insights;
    const insSection = document.getElementById('insights-section');
    if (ins && (ins.skipped || ins.error || (!ins.bullets?.length && !ins.initiatives?.length))) {
      // Insights failed or skipped — show a visible warning
      if (insSection) {
        const reason = ins.reason || ins.error || 'El diagnóstico no pudo generarse';
        insSection.innerHTML = `
          <div class="bg-amber-500/8 border border-amber-400/20 rounded-2xl p-5 text-center">
            <p class="text-sm text-amber-300 font-medium mb-1">⚠️ Diagnóstico ejecutivo no disponible</p>
            <p class="text-xs text-slate-400">${reason}</p>
          </div>`;
        insSection.classList.remove('hidden');
      }
    } else if (ins && (ins.bullets?.length || ins.initiatives?.length)) {
      if (insSection) {
        const bulletsHtml = (ins.bullets || []).map(b =>
          `<li class="flex items-start gap-2.5 text-sm text-slate-200 leading-relaxed">
            <span class="text-cyan-400 mt-0.5 shrink-0">→</span>
            <span>${b}</span>
          </li>`
        ).join('');

        const initiativesHtml = (ins.initiatives || []).map((init, i) =>
          `<div class="flex gap-4 p-4 bg-white/5 border border-white/10 rounded-xl">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center text-white font-bold text-sm shrink-0">${i + 1}</div>
            <div>
              <p class="text-sm font-semibold text-white mb-1">${init.title}</p>
              <p class="text-xs text-slate-300 leading-relaxed">${init.description}</p>
            </div>
          </div>`
        ).join('');

        // GEO mini-card
        const geo = results.geo;
        let geoCardHtml = '';
        if (geo && !geo.skipped) {
          const geoScore = geo.overallScore ?? 0;
          const geoColor = geoScore >= 60 ? '#22c55e' : geoScore >= 30 ? '#f59e0b' : '#ef4444';
          const geoLabel = geoScore >= 60 ? 'Visible en IA' : geoScore >= 30 ? 'Presencia parcial' : 'Invisible para la IA';
          const levels = (geo.queries || []).slice(0, 4).map((q, i) => {
            const icons = ['🌐','💬','🎯','🏷️'];
            const labels = ['Sector','Valor','Keywords','Marca'];
            return `<div class="flex items-center gap-1.5">
              <span class="text-xs">${q.mentioned ? '✅' : '❌'}</span>
              <span class="text-xs text-slate-400">${icons[i]} ${labels[i]}</span>
              ${q.mentioned ? `<span class="text-xs text-slate-500">(${q.pts ?? 0}pts)</span>` : ''}
            </div>`;
          }).join('');
          geoCardHtml = `
            <div class="flex items-center gap-4 p-4 bg-cyan-500/5 border border-cyan-400/20 rounded-xl mb-6">
              <div class="text-center shrink-0">
                <div class="text-3xl font-bold" style="color:${geoColor}">${geoScore}</div>
                <div class="text-xs text-slate-400 leading-tight">GEO /100</div>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-semibold mb-2" style="color:${geoColor}">🤖 Visibilidad en IA — ${geoLabel}</p>
                <div class="flex flex-wrap gap-x-4 gap-y-1">${levels}</div>
              </div>
            </div>`;
        }

        // Social media availability note
        const ig = results.instagram;
        const li = results.linkedin;
        const igHasData = ig?.found === true && ig?.followers != null;
        const liHasData = li?.found === true && li?.followers != null;
        const igHandle = ig?.found === true ? ig.handle : null;
        const liUrl = li?.found === true ? li.url : null;
        let socialNoteHtml = '';
        const missingPlatforms = [];
        if (igHandle && !igHasData) missingPlatforms.push(`@${igHandle} en Instagram`);
        if (liUrl && !liHasData) missingPlatforms.push('LinkedIn');
        if (missingPlatforms.length > 0) {
          socialNoteHtml = `
            <div class="flex items-start gap-2.5 p-3 bg-amber-500/5 border border-amber-400/15 rounded-lg mb-5">
              <span class="text-amber-400 shrink-0 mt-0.5 text-xs">ℹ️</span>
              <p class="text-xs text-slate-400 leading-relaxed">Detectamos ${missingPlatforms.join(' y ')}, pero Instagram no expone métricas de seguidores sin autenticación incluso desde IPs externas de confianza.</p>
            </div>`;
        }

        insSection.innerHTML = `
          <div class="bg-gradient-to-br from-[#0d2347] to-[#0B1B3D] border border-cyan-400/20 rounded-2xl p-6 md:p-8">
            <div class="flex items-center gap-2 mb-5">
              <span class="text-xl">💡</span>
              <h2 class="text-lg font-bold text-white">Diagnóstico de tu presencia digital</h2>
            </div>
            ${geoCardHtml}
            ${socialNoteHtml}
            <ul class="space-y-3 mb-8">${bulletsHtml}</ul>
            ${initiativesHtml.length ? `
              <div class="border-t border-white/10 pt-6 mt-6">
                <h3 class="text-sm font-bold text-white mb-4 flex items-center gap-2">
                  <span class="w-5 h-5 bg-amber-500/20 rounded flex items-center justify-center text-amber-400 text-xs">★</span>
                  Tus 3 próximas iniciativas prioritarias
                </h3>
                <div class="space-y-3">${initiativesHtml}</div>
              </div>
            ` : ''}
          </div>
        `;
        insSection.classList.remove('hidden');
      }
    }

    // Score ring
    const ring = document.getElementById('score-ring');
    const scoreVal = document.getElementById('score-value');
    const scoreLabel = document.getElementById('score-label');
    if (ring) {
      const color = score >= 70 ? '#22c55e' : score >= 40 ? '#f59e0b' : '#ef4444';
      ring.setAttribute('stroke', color);
      ring.setAttribute('stroke-dasharray', `${score}, 100`);
    }
    if (scoreVal) scoreVal.textContent = score;
    if (scoreLabel) {
      const label = score >= 85 ? 'Líder digital' : score >= 70 ? 'Competitivo' : score >= 50 ? 'En desarrollo' : score >= 30 ? 'Básico' : 'Crítico';
      scoreLabel.textContent = `AION Digital Health Score · ${label}`;
    }

    // Score breakdown — 6 pilares + GEO
    const breakdown = results.score?.breakdown;
    if (breakdown) {
      const container = document.getElementById('score-breakdown');
      const geoScore = results.geo?.overallScore ?? null;
      const items = [
        { label: 'IA / GEO',   value: geoScore,                   icon: '🤖',  pct: 'visibilidad' },
        { label: 'Técnico',    value: breakdown.technical,        icon: '⚙️',  pct: '15%' },
        { label: 'SEO',        value: breakdown.seoVisibility,    icon: '🔗',  pct: '25%' },
        { label: 'Contenido',  value: breakdown.content,          icon: '📝',  pct: '20%' },
        { label: 'Social',     value: breakdown.socialReputation, icon: '⭐',  pct: '15%' },
        { label: 'Conversión', value: breakdown.conversion,       icon: '🎯',  pct: '15%' },
        { label: 'Medición',   value: breakdown.measurement,      icon: '📊',  pct: '10%' },
      ];
      container.innerHTML = items.map(item => {
        const v = item.value ?? 0;
        const color = v >= 70 ? 'text-emerald-400' : v >= 40 ? 'text-amber-400' : 'text-red-400';
        const barColor = v >= 70 ? 'bg-emerald-500' : v >= 40 ? 'bg-amber-500' : 'bg-red-500';
        return `<div class="bg-white/5 border border-white/10 rounded-xl p-3 text-center">
          <div class="text-base mb-1">${item.icon}</div>
          <div class="text-xl font-bold ${color} mb-0.5">${v}</div>
          <div class="w-full h-1 bg-white/10 rounded-full mb-1.5 overflow-hidden">
            <div class="h-full ${barColor} rounded-full" style="width:${v}%"></div>
          </div>
