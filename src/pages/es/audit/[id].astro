      const checks = [
        { label: 'Formulario de contacto', ok: cv.hasContactForm, detail: cv.hasContactForm ? `${cv.formCount} formulario(s), ${cv.formFieldCount} campos` : 'No detectado' },
        { label: 'CTAs claros', ok: cv.hasCTA, detail: cv.hasCTA ? `${cv.ctaCount} elemento(s) con intención de conversión` : 'Sin CTAs detectados' },
        { label: 'Lead magnet', ok: cv.hasLeadMagnet, detail: cv.hasLeadMagnet ? 'Detectado (descarga, demo, recurso gratuito…)' : 'No detectado' },
        { label: 'Prueba social / testimonios', ok: cv.hasTestimonials, detail: cv.hasTestimonials ? 'Detectado' : 'Sin testimonios visibles' },
        { label: 'Precios visibles', ok: cv.hasPricing, detail: cv.hasPricing ? 'Sección de precios detectada' : 'Sin página de precios' },
        { label: 'Contenido en vídeo', ok: cv.hasVideo, detail: cv.hasVideo ? 'Presente' : 'Sin vídeo detectado' },
        { label: 'Chat en vivo', ok: cv.hasChatWidget, detail: cv.hasChatWidget ? 'Activo' : 'Sin chat en vivo' },
      ];

      const checksHtml = checks.map(c => `
        <div class="flex items-start gap-3 py-2 border-b border-white/5 last:border-0">
          <span class="${c.ok ? 'text-emerald-400' : 'text-red-400'} mt-0.5 shrink-0 text-sm">${c.ok ? '✓' : '✗'}</span>
          <div>
            <p class="text-xs font-medium text-slate-200">${c.label}</p>
            <p class="text-xs text-slate-500">${c.detail}</p>
          </div>
        </div>`).join('');

      const llmHtml = cv.summary ? `
        <div class="mt-4 pt-4 border-t border-white/10">
          <p class="text-xs text-slate-300 italic leading-relaxed mb-3">${cv.summary}</p>
          ${cv.strengths?.length ? `<p class="text-xs font-semibold text-emerald-400 mb-1">Fortalezas:</p><ul class="mb-3">${cv.strengths.map(s => `<li class="text-xs text-slate-300 mb-0.5">· ${s}</li>`).join('')}</ul>` : ''}
          ${cv.weaknesses?.length ? `<p class="text-xs font-semibold text-amber-400 mb-1">Brechas prioritarias:</p><ul>${cv.weaknesses.map(w => `<li class="text-xs text-slate-300 mb-0.5">· ${w}</li>`).join('')}</ul>` : ''}
        </div>` : '';

      sections.push(`
        <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
          <h3 class="text-base font-semibold text-white mb-1">🎯 Capacidad de conversión</h3>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl font-bold ${scoreColor}">${score}/100</span>
            <span class="text-xs ${scoreColor}">${score >= 70 ? 'Funnel bien configurado' : score >= 40 ? 'Funnel básico, mejoras posibles' : 'Funnel débil — alta prioridad'}</span>
          </div>
          ${checksHtml}
          ${llmHtml}
        </div>
      `);
    }

    container.innerHTML = sections.join('');
  }

  function formatNum(n) {
    if (n == null) return '—';
    if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M';
    if (n >= 1_000) return (n / 1_000).toFixed(1) + 'K';
    return String(n);
  }

  function buildSection(title, rows) {
    const rowsHtml = rows.map(r =>
      `<div class="flex gap-3 py-2 border-b border-white/5 last:border-0">
        <span class="text-xs text-slate-400 w-36 shrink-0">${r.label}</span>
        <span class="text-xs text-slate-200 flex-1">${r.value}</span>
      </div>`
    ).join('');
    return `
      <div class="bg-white/3 border border-white/8 rounded-2xl p-5">
        <h3 class="text-base font-semibold text-white mb-4">${title}</h3>
        ${rowsHtml}
      </div>
    `;
  }

  function showError() {
    document.getElementById('processing-state').classList.add('hidden');
    document.getElementById('error-state').classList.remove('hidden');
  }

  async function poll() {
    try {
      const res = await fetch(`/api/audit/${auditId}/status`);
      if (!res.ok) {
        showError();
        return;
      }
      const data = await res.json();

      setProgress(data.progress || 0);

      if (data.module_completed) {
        completedModules.add(data.module_completed);
        MODULES.forEach((key, i) => {
          if (completedModules.has(key)) {
            markModule(key, 'done');
          } else if (i === completedModules.size) {
            markModule(key, 'running');
          }
        });
      }

      if (data.status === 'completed') {
        setProgress(100);
        MODULES.forEach(key => markModule(key, 'done'));
        showResults(data);
        return;
      }

      if (data.status === 'error') {
        showError();
        return;
      }

      // Mark next module as running
      const nextIdx = completedModules.size;
      if (nextIdx < MODULES.length) {
        markModule(MODULES[nextIdx], 'running');
      }

      pollTimer = setTimeout(poll, 2000);
    } catch (err) {
      console.error('Poll error:', err);
      pollTimer = setTimeout(poll, 3000);
    }
  }

  // Start polling
  if (initialStatus === 'completed') {
    // Already done, fetch results immediately
    poll();
  } else if (initialStatus === 'error') {
    showError();
  } else {
    markModule(MODULES[0], 'running');
    setProgress(2);
    setTimeout(poll, 1500);
  }
</script>
