---
import '../../styles/global.css';

const lang = 'es';
const t: Record<string, string> = {
  'nav.solutions': 'Soluciones',
  'nav.pricing': 'Pricing',
  'nav.blog': 'Blog',
  'nav.contact': 'Contacto',
  'nav.login': 'Iniciar Sesión',
  'nav.free_diagnosis': 'Diagnóstico Gratuito',
  'hero.badge': 'LA ERA DEL MARKETING DE INTUICIÓN HA TERMINADO',
  'hero.title': 'El Growth ya no es marketing. Es',
  'hero.title_ai': 'infraestructura IA.',
  'hero.description': 'Transformamos marcas de legacy hacia ecosistemas de growth autónomos. Procesos. Soluciones. Impulso.',
  'hero.cta_primary': 'Diagnóstico gratuito',
  'hero.cta_secondary': 'Contacta con nosotros',
  'mission.title': 'Transformando el futuro de los negocios digitales',
  'mission.description': 'La era del Marketing basado en la intuición ha terminado. El crecimiento ya no depende de campañas, sino de sistemas. Sustituimos intuición por decisiones basadas en datos y ejecución automatizada con IA. Entregamos herramientas que permiten que las marcas crezcan de manera verdaderamente autónoma.',
  'solutions.title': 'Soluciones de Growth Aumentadas',
  'solutions.diagnosis_tag': 'GRATUITO',
  'solutions.diagnosis_title': 'Diagnóstico AION',
  'solutions.diagnosis_desc': 'Auditoría completa SEO, GEO, Visibilidad y Benchmark competitivo de tu marca. Sabe exactamente dónde estás antes de invertir un euro.',
  'solutions.diagnosis_cta': 'Probar ahora',
  'solutions.radar_title': 'AION Radar',
  'solutions.radar_desc': 'Cada mes, tu empresa genera miles de señales digitales que nadie está leyendo. Radar las captura todas — SEO, visibilidad en IA generativa, competidores, rendimiento web — y las traduce en un informe con veredicto listo para tu comité de dirección.',
  'solutions.signals_title': 'AION Signals',
  'solutions.signals_desc': 'El informe mensual te dice dónde estás. Signals te avisa antes de que sea tarde. Monitorización semanal con alertas accionables: un competidor lanza campaña, una keyword clave cae, tu web se ralentiza.',
  'solutions.levers_title': 'AION Levers',
  'solutions.levers_desc': 'Saber qué hacer no es suficiente si no tienes quién lo ejecute. Levers cierra esa brecha: genera contenido optimizado para Google y ChatGPT, produce instrucciones técnicas exactas y crea schema markup listo para publicar.',
  'custom.badge': 'METODOLOGÍA PATENTADA',
  'custom.title': 'Soluciones a Medida',
  'custom.subtitle': 'Método AION',
  'custom.description': 'Transformamos tus operaciones y personalizamos tu automatización con nuestro método único de transformación con IA — desarrollado, probado y patentado por AION.',
  'custom.cta': 'Despliega tu empresa en modo IA-on',
  'custom.phase1': 'Diagnóstico',
  'custom.phase1_desc': 'Análisis profundo de tu operación actual',
  'custom.phase2': 'Diseño',
  'custom.phase2_desc': 'Arquitectura de automatización personalizada',
  'custom.phase3': 'Implementación',
  'custom.phase3_desc': 'Despliegue con IA integrada',
  'custom.phase4': 'Optimización',
  'custom.phase4_desc': 'Mejora continua con aprendizaje automático',
  'leads.title': '¿Tienes una agencia?',
  'leads.description': 'Ofrece nuestros productos con marca blanca para aportar valor a tus clientes.',
  'leads.subtitle': 'Simplifica tus operaciones y mejora tus resultados con herramientas automatizadas de diagnóstico y recomendación.',
  'leads.benefit1': 'Productos con tu marca',
  'leads.benefit2': 'Diagnósticos automatizados para tus clientes',
  'leads.benefit3': 'Informes personalizables',
  'leads.benefit4': 'Soporte técnico dedicado',
  'leads.cta': 'Contacta con nosotros',
  'cta.title': 'La IA ya está cambiando tu sector',
  'cta.description': 'La pregunta no es si adoptar IA, sino quién diseña la infraestructura operativa sobre la que crecerás los próximos cinco años.',
  'cta.button_diagnosis': 'Haz diagnóstico gratuito',
  'cta.button_contact': 'Contacta con nosotros',
  'footer.tagline': 'Infraestructura de crecimiento con IA agentiva',
  'footer.copyright': '© 2024 AION Growth Studio. Todos los derechos reservados.',
  'footer.privacy': 'Privacidad',
  'footer.terms': 'Términos de Servicio',
  'footer.contact': 'Contacto',
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="description" content="AION Growth Studio — Infraestructura de crecimiento con IA agentiva" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <title>AION Growth Studio — Infraestructura de crecimiento con IA agentiva</title>
</head>
<body class="font-sans antialiased bg-background text-on-surface">
  <main class="min-h-screen bg-background">

    <!-- ═══════════════ NAVBAR ═══════════════ -->
    <nav id="main-nav" class="fixed top-0 w-full z-50 bg-primary">
      <div class="relative flex justify-between items-center px-8 py-3 max-w-7xl mx-auto">
        <!-- Logo -->
        <a href="/es/" class="flex items-center gap-2 h-12 overflow-hidden">
          <img src="/images/aion-logo-dark.png" alt="AION Growth Studio" class="h-24 w-auto" />
        </a>

        <!-- Desktop nav links -->
        <div class="hidden lg:flex items-center gap-8">
          <a href="#solutions" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">{t['nav.solutions']}</a>
          <a href="/es/radar" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">{t['nav.pricing']}</a>
          <a href="/blog" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">{t['nav.blog']}</a>
          <a href="/contacto" class="font-sans tracking-tight font-medium text-sm text-white/80 hover:text-white transition-colors">{t['nav.contact']}</a>
        </div>

        <!-- Right actions -->
        <div class="flex items-center gap-2">
          <!-- Language toggle -->
          <a href="/en/" class="hidden md:flex items-center gap-1.5 text-xs font-semibold text-white/80 hover:text-white px-3 py-2 rounded-full bg-white/10 transition-all hover:bg-white/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z"/></svg>
            <span class="uppercase tracking-widest">EN</span>
          </a>

          <!-- Login → /login -->
          <a href="/login" class="hidden md:flex items-center gap-1.5 text-xs font-semibold text-white/80 hover:text-white px-3 py-2 rounded-full bg-white/10 transition-all hover:bg-white/20">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>{t['nav.login']}</span>
          </a>

          <!-- Free Diagnosis CTA → /es/diagnostico -->
          <a href="/es/diagnostico" class="hidden md:block bg-accent text-primary px-5 py-2.5 rounded-full font-bold text-xs hover:brightness-110 transition-all" style="box-shadow: 0 4px 20px rgba(105,255,135,0.35);">
            {t['nav.free_diagnosis']}
          </a>

          <!-- Mobile hamburger -->
          <button id="mobile-menu-btn" class="lg:hidden flex items-center justify-center w-9 h-9 rounded-full text-white bg-white/10 hover:bg-white/20 transition-all" aria-label="Toggle menu">
            <svg id="menu-icon-open" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
            <svg id="menu-icon-close" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="lg:hidden hidden border-t border-white/10 px-8 py-6 bg-primary">
        <div class="flex flex-col gap-4">
          <a href="#solutions" class="font-sans tracking-tight font-medium text-sm text-white/80 mobile-nav-close">{t['nav.solutions']}</a>
          <a href="/es/radar" class="font-sans tracking-tight font-medium text-sm text-white/80 mobile-nav-close">{t['nav.pricing']}</a>
          <a href="/blog" class="font-sans tracking-tight font-medium text-sm text-white/80 mobile-nav-close">{t['nav.blog']}</a>
          <a href="/contacto" class="font-sans tracking-tight font-medium text-sm text-white/80 mobile-nav-close">{t['nav.contact']}</a>

          <div class="flex items-center gap-3 mt-2 pt-4 border-t border-white/10">
            <a href="/en/" class="flex items-center gap-1.5 text-xs font-semibold text-white/80 px-3 py-2 rounded-full bg-white/10">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z"/></svg>
              <span class="uppercase">EN</span>
            </a>
            <a href="/login" class="flex items-center gap-1.5 text-xs font-semibold text-white/80 px-3 py-2 rounded-full bg-white/10">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>{t['nav.login']}</span>
            </a>
          </div>

          <a href="/es/diagnostico" class="bg-accent text-primary px-6 py-3 rounded-full font-bold text-sm hover:brightness-110 transition-all mt-2 w-full text-center">
            {t['nav.free_diagnosis']}
          </a>
        </div>
      </div>
    </nav>

    <!-- ═══════════════ HERO ═══════════════ -->
    <section class="relative min-h-screen flex items-center pt-20 overflow-hidden bg-primary">
      <!-- Grid pattern -->
      <div class="absolute inset-0 opacity-[0.055]" style="background-image: linear-gradient(rgba(105,255,135,1) 1px, transparent 1px), linear-gradient(90deg, rgba(105,255,135,1) 1px, transparent 1px); background-size: 60px 60px;"></div>

      <!-- Radial depth glows -->
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 20% 50%, rgba(0,31,112,0.5) 0%, transparent 70%), radial-gradient(ellipse 50% 50% at 80% 20%, rgba(0,58,20,0.3) 0%, transparent 70%);"></div>

      <!-- Canvas animated background -->
      <canvas id="hero-canvas" class="absolute inset-0 w-full h-full" style="mix-blend-mode: screen; opacity: 0.75;"></canvas>

      <!-- Vignette -->
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 40%, rgba(0,14,65,0.7) 100%);"></div>

      <!-- Content -->
      <div class="relative max-w-5xl mx-auto px-8 w-full text-center py-24">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/15 border border-accent/20 text-accent text-[10px] uppercase tracking-[0.2em] font-bold mb-10">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          {t['hero.badge']}
        </div>

        <!-- Headline -->
        <h1 class="text-white text-4xl sm:text-5xl md:text-[72px] font-extrabold tracking-tighter leading-[1.08] mb-8 text-balance">
          {t['hero.title']}{" "}
          <span class="text-accent">{t['hero.title_ai']}</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-white/60 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto font-light mb-14">
          {t['hero.description']}
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap justify-center gap-4 sm:gap-5">
          <a href="/es/diagnostico" class="bg-accent text-primary px-8 py-4 rounded-full font-bold uppercase tracking-widest text-xs hover:brightness-110 transition-all inline-block" style="box-shadow: 0 6px 30px rgba(105,255,135,0.4);">
            {t['hero.cta_primary']}
          </a>
          <a href="/contacto" class="border border-white/20 text-white px-8 py-4 rounded-full font-bold uppercase tracking-widest text-xs hover:bg-white/5 transition-all inline-block">
            {t['hero.cta_secondary']}
          </a>
        </div>
      </div>
    </section>

    <!-- ═══════════════ MISSION ═══════════════ -->
    <section class="py-24 md:py-32 bg-surface">
      <div class="max-w-7xl mx-auto px-8">
        <div class="grid md:grid-cols-2 gap-12 md:gap-24 items-start">
          <div>
            <span class="text-on-secondary-container font-sans text-xs tracking-[0.2em] uppercase block mb-6">Our Mission</span>
            <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-on-surface leading-tight mb-8 text-balance">
              {t['mission.title']}
            </h2>
          </div>
          <div class="space-y-8">
            <p class="text-on-surface-variant leading-relaxed text-lg md:text-xl">
              {t['mission.description']}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ SOLUTIONS ═══════════════ -->
    <section id="solutions" class="py-24 md:py-32 bg-surface-container-low">
      <div class="max-w-7xl mx-auto px-8">
        <div class="mb-16 md:mb-20">
          <h2 class="text-3xl md:text-5xl font-bold tracking-tighter text-primary text-balance">{t['solutions.title']}</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
          <!-- Card 1 — Diagnóstico: full width hero -->
          <div class="md:col-span-12 bg-primary rounded-2xl p-8 md:p-12 flex flex-col md:flex-row gap-8 md:gap-16 items-start md:items-center relative overflow-hidden">
            <div class="absolute inset-0 opacity-[0.06]" style="background-image: linear-gradient(rgba(105,255,135,1) 1px, transparent 1px), linear-gradient(90deg, rgba(105,255,135,1) 1px, transparent 1px); background-size: 40px 40px;"></div>
            <div class="relative flex-1">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-11 h-11 bg-accent/20 flex items-center justify-center rounded-xl text-accent">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
                </div>
                <span class="bg-accent text-primary text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-full">{t['solutions.diagnosis_tag']}</span>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-white mb-4">{t['solutions.diagnosis_title']}</h3>
              <p class="text-white/60 leading-relaxed max-w-2xl text-base">{t['solutions.diagnosis_desc']}</p>
            </div>
            <div class="relative shrink-0">
              <a href="/es/diagnostico" class="flex items-center gap-2 bg-accent text-primary px-8 py-4 rounded-xl font-bold text-sm hover:brightness-110 transition-all group" style="box-shadow: 0 4px 24px rgba(105,255,135,0.4);">
                {t['solutions.diagnosis_cta']}
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>

          <!-- Card 2 — Radar: col 5 -->
          <div class="md:col-span-5 bg-surface-container-lowest rounded-2xl p-8 md:p-10 flex flex-col gap-6 hover:shadow-lg transition-shadow group">
            <div class="w-11 h-11 bg-primary/[0.08] flex items-center justify-center rounded-xl text-primary group-hover:bg-primary group-hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 010 8.49m-8.48-.01a6 6 0 010-8.49m11.31-2.82a10 10 0 010 14.14m-14.14 0a10 10 0 010-14.14"/></svg>
            </div>
            <div>
              <h3 class="text-xl md:text-2xl font-bold text-on-surface mb-3">{t['solutions.radar_title']}</h3>
              <p class="text-on-surface-variant leading-relaxed text-sm">{t['solutions.radar_desc']}</p>
            </div>
            <div class="mt-auto pt-4 flex gap-2 flex-wrap">
              {["SEO", "GEO", "GA4", "Benchmark"].map((tag) => (
                <span class="text-[10px] font-bold uppercase tracking-wider text-primary bg-primary/[0.08] px-2.5 py-1 rounded-full">{tag}</span>
              ))}
            </div>
          </div>

          <!-- Card 3 — Signals: col 7, dark -->
          <div class="md:col-span-7 bg-primary rounded-2xl p-8 md:p-10 flex flex-col gap-6 relative overflow-hidden">
            <div class="absolute inset-0 opacity-[0.05]" style="background-image: linear-gradient(rgba(105,255,135,1) 1px, transparent 1px), linear-gradient(90deg, rgba(105,255,135,1) 1px, transparent 1px); background-size: 32px 32px;"></div>
            <div class="relative w-11 h-11 bg-white/10 flex items-center justify-center rounded-xl text-accent">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <div class="relative">
              <h3 class="text-xl md:text-2xl font-bold text-white mb-3">{t['solutions.signals_title']}</h3>
              <p class="text-white/60 leading-relaxed text-sm">{t['solutions.signals_desc']}</p>
            </div>
            <div class="relative mt-auto flex gap-2 flex-wrap">
              {["Meta", "Google", "LinkedIn", "Alertas IA"].map((tag) => (
                <span class="text-[10px] font-bold uppercase tracking-wider text-accent bg-accent/10 px-2.5 py-1 rounded-full">{tag}</span>
              ))}
            </div>
          </div>

          <!-- Card 4 — Levers: full width bottom -->
          <div class="md:col-span-12 bg-surface-container-lowest rounded-2xl p-8 md:p-12 flex flex-col md:flex-row gap-8 md:gap-16 items-start group hover:shadow-lg transition-shadow">
            <div class="flex-1">
              <div class="w-11 h-11 bg-primary/[0.08] flex items-center justify-center rounded-xl text-primary mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 20a8 8 0 100-16 8 8 0 000 16z"/><path d="M12 14a2 2 0 100-4 2 2 0 000 4z"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
              </div>
              <h3 class="text-xl md:text-3xl font-bold text-on-surface mb-3">{t['solutions.levers_title']}</h3>
              <p class="text-on-surface-variant leading-relaxed max-w-2xl text-sm md:text-base">{t['solutions.levers_desc']}</p>
            </div>
            <div class="shrink-0 w-full md:w-64 bg-surface-container-low rounded-xl p-6 flex flex-col gap-4">
              {[
                { label: "SEO Content", w: "80%" },
                { label: "Schema Markup", w: "60%" },
                { label: "GEO Optimisation", w: "92%" },
                { label: "Tech Instructions", w: "67%" },
              ].map((item) => (
                <div>
                  <div class="flex justify-between items-center mb-1.5">
                    <span class="text-[10px] font-semibold text-on-surface-variant uppercase tracking-wide">{item.label}</span>
                  </div>
                  <div class="h-1.5 bg-primary/10 rounded-full w-full overflow-hidden">
                    <div class="h-full bg-primary rounded-full" style={`width: ${item.w}`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════ CASES / METHOD ═══════════════ -->
    <section id="cases" class="py-14 bg-primary relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(105,255,135,1) 1px, transparent 1px), linear-gradient(90deg, rgba(105,255,135,1) 1px, transparent 1px); background-size: 40px 40px;"></div>

      <div class="relative max-w-7xl mx-auto px-8">
        <!-- Header -->
        <div class="text-center mb-10">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/20 text-accent text-xs uppercase tracking-widest font-bold mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
            {t['custom.badge']}
          </div>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white tracking-tight leading-tight mb-2">{t['custom.title']}</h2>
          <p class="text-accent text-xl md:text-2xl font-bold tracking-tight mb-4">{t['custom.subtitle']}</p>
          <p class="text-white/60 text-base md:text-lg leading-relaxed max-w-3xl mx-auto">{t['custom.description']}</p>
        </div>

        <!-- Animation + Phases -->
        <div class="grid lg:grid-cols-2 gap-8 items-center">
          <!-- Canvas -->
          <div class="relative aspect-square max-w-md mx-auto w-full">
            <canvas id="cases-canvas" class="absolute inset-0 w-full h-full"></canvas>
          </div>

          <!-- Phases -->
          <div class="space-y-3">
            {[
              { num: '01', title: t['custom.phase1'], desc: t['custom.phase1_desc'] },
              { num: '02', title: t['custom.phase2'], desc: t['custom.phase2_desc'] },
              { num: '03', title: t['custom.phase3'], desc: t['custom.phase3_desc'] },
              { num: '04', title: t['custom.phase4'], desc: t['custom.phase4_desc'] },
            ].map((phase) => (
              <div class="flex items-start gap-4 p-4 rounded-xl transition-all duration-300 hover:bg-white/5 group">
                <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center text-accent font-black text-base" style="background: rgba(105,255,135,0.1); box-shadow: 0 0 20px rgba(105,255,135,0.1);">
                  {phase.num}
                </div>
                <div>
                  <h3 class="text-white text-base font-bold mb-0.5 group-hover:text-accent transition-colors">{phase.title}</h3>
                  <p class="text-white/50 text-sm leading-relaxed">{phase.desc}</p>
                </div>
              </div>
