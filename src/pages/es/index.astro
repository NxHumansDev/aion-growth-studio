  <!-- ═══════════════ SCRIPTS ═══════════════ -->
  <script>
    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (menuBtn && mobileMenu && iconOpen && iconClose) {
      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
        iconOpen.classList.toggle('hidden');
        iconClose.classList.toggle('hidden');
      });

      mobileMenu.querySelectorAll('.mobile-nav-close').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          iconOpen.classList.remove('hidden');
          iconClose.classList.add('hidden');
        });
      });
    }

    // ─── Hero Canvas Animation ───
    const heroCanvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    if (heroCanvas) {
      const ctx = heroCanvas.getContext('2d')!;
      let animFrameId: number;
      let time = 0;

      const resize = () => {
        heroCanvas.width = heroCanvas.offsetWidth;
        heroCanvas.height = heroCanvas.offsetHeight;
      };
      resize();
      window.addEventListener('resize', resize);

      type Node = { x: number; y: number; vx: number; vy: number; r: number; pulse: number; pulseSpeed: number };
      const nodes: Node[] = Array.from({ length: 55 }, () => ({
        x: Math.random() * heroCanvas.width,
        y: Math.random() * heroCanvas.height,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        r: Math.random() * 1.8 + 0.6,
        pulse: Math.random() * Math.PI * 2,
        pulseSpeed: 0.02 + Math.random() * 0.02,
      }));

      type Orbiter = { cx: number; cy: number; rx: number; ry: number; angle: number; speed: number; size: number; opacity: number };
      const orbiters: Orbiter[] = Array.from({ length: 6 }, (_, i) => ({
        cx: heroCanvas.width * (0.15 + i * 0.14),
        cy: heroCanvas.height * (0.3 + (i % 3) * 0.2),
        rx: 40 + i * 12,
        ry: 18 + i * 6,
        angle: (i / 6) * Math.PI * 2,
        speed: 0.004 + i * 0.0015,
        size: 2.5 + (i % 3),
        opacity: 0.5 + (i % 2) * 0.3,
      }));

      type Ring = { x: number; y: number; radius: number; maxRadius: number; opacity: number; speed: number };
      const rings: Ring[] = [];
      const spawnRing = () => {
        const w = heroCanvas.width, h = heroCanvas.height;
        rings.push({ x: w * (0.15 + Math.random() * 0.7), y: h * (0.15 + Math.random() * 0.7), radius: 0, maxRadius: 120 + Math.random() * 140, opacity: 0.25, speed: 0.7 + Math.random() * 0.5 });
      };
      let lastRingSpawn = 0;

      const draw = (ts: number) => {
        const w = heroCanvas.width, h = heroCanvas.height;
        time = ts * 0.001;
        ctx.clearRect(0, 0, w, h);

        if (ts - lastRingSpawn > 1800) { spawnRing(); lastRingSpawn = ts; }

        for (let i = rings.length - 1; i >= 0; i--) {
          const ring = rings[i];
          ring.radius += ring.speed;
          ring.opacity *= 0.985;
          if (ring.radius > ring.maxRadius || ring.opacity < 0.01) { rings.splice(i, 1); continue; }
          ctx.beginPath(); ctx.arc(ring.x, ring.y, ring.radius, 0, Math.PI * 2);
          ctx.strokeStyle = `rgba(105,255,135,${ring.opacity})`; ctx.lineWidth = 1; ctx.stroke();
          if (ring.radius > 20) {
            ctx.beginPath(); ctx.arc(ring.x, ring.y, ring.radius * 0.6, 0, Math.PI * 2);
            ctx.strokeStyle = `rgba(105,255,135,${ring.opacity * 0.4})`; ctx.lineWidth = 0.5; ctx.stroke();
          }
        }

        for (const n of nodes) { n.x += n.vx; n.y += n.vy; if (n.x < 0 || n.x > w) n.vx *= -1; if (n.y < 0 || n.y > h) n.vy *= -1; n.pulse += n.pulseSpeed; }

        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const dx = nodes[i].x - nodes[j].x, dy = nodes[i].y - nodes[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 140) {
              ctx.beginPath(); ctx.strokeStyle = `rgba(105,255,135,${(1 - dist / 140) * 0.3})`; ctx.lineWidth = 0.5;
              ctx.moveTo(nodes[i].x, nodes[i].y); ctx.lineTo(nodes[j].x, nodes[j].y); ctx.stroke();
            }
          }
        }

        for (const n of nodes) {
          const glow = (Math.sin(n.pulse) + 1) * 0.5;
          ctx.beginPath(); ctx.arc(n.x, n.y, n.r + glow * 1.2, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(105,255,135,${0.5 + glow * 0.4})`; ctx.fill();
        }

        for (const orb of orbiters) {
          orb.angle += orb.speed;
          const px = orb.cx + Math.cos(orb.angle) * orb.rx;
          const py = orb.cy + Math.sin(orb.angle) * orb.ry;
          for (let t2 = 1; t2 <= 6; t2++) {
            const ta = orb.angle - t2 * 0.15;
            const tx = orb.cx + Math.cos(ta) * orb.rx, ty = orb.cy + Math.sin(ta) * orb.ry;
            ctx.beginPath(); ctx.arc(tx, ty, orb.size * (1 - t2 / 8), 0, Math.PI * 2);
            ctx.fillStyle = `rgba(105,255,135,${(orb.opacity * (1 - t2 / 8)) * 0.35})`; ctx.fill();
          }
          ctx.beginPath(); ctx.arc(px, py, orb.size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(105,255,135,${orb.opacity})`; ctx.fill();
          ctx.beginPath(); ctx.ellipse(orb.cx, orb.cy, orb.rx, orb.ry, 0, 0, Math.PI * 2);
          ctx.strokeStyle = 'rgba(105,255,135,0.05)'; ctx.lineWidth = 0.5; ctx.stroke();
        }

        const scanY = (time * 80) % h;
        const grad = ctx.createLinearGradient(0, scanY - 40, 0, scanY + 40);
        grad.addColorStop(0, 'rgba(105,255,135,0)'); grad.addColorStop(0.5, 'rgba(105,255,135,0.04)'); grad.addColorStop(1, 'rgba(105,255,135,0)');
        ctx.fillStyle = grad; ctx.fillRect(0, scanY - 40, w, 80);

        animFrameId = requestAnimationFrame(draw);
      };
      animFrameId = requestAnimationFrame(draw);
    }

    // ─── Cases Canvas Animation ───
    const casesCanvas = document.getElementById('cases-canvas') as HTMLCanvasElement;
    if (casesCanvas) {
      const ctx2 = casesCanvas.getContext('2d')!;
      let animId2: number;
      const dpr = window.devicePixelRatio || 1;

      const resize2 = () => {
        const rect = casesCanvas.getBoundingClientRect();
        casesCanvas.width = rect.width * dpr;
        casesCanvas.height = rect.height * dpr;
        ctx2.scale(dpr, dpr);
      };
      resize2();

      const businessAreas = [
        { label: 'Marketing', color: '#69ff87' },
        { label: 'Operations', color: '#4dd8ff' },
        { label: 'Finance', color: '#ffd54f' },
        { label: 'HR', color: '#ff6b9d' },
        { label: 'Sales', color: '#b388ff' },
        { label: 'Legal', color: '#ff8a65' },
      ];

      const atoms = businessAreas.map((area, i) => ({
        label: area.label, color: area.color, radius: 100 + (i % 2) * 50,
        angle: (Math.PI * 2 * i) / businessAreas.length, speed: 0.003 + (i % 3) * 0.001, size: 28 + (i % 2) * 8,
      }));

      const flowParticles: { fromAtom: number; progress: number; speed: number }[] = [];
      for (let i = 0; i < 18; i++) {
        flowParticles.push({ fromAtom: i % businessAreas.length, progress: Math.random(), speed: 0.008 + Math.random() * 0.006 });
      }

      const ringParticles: { angle: number; radius: number; speed: number }[] = [];
      for (let i = 0; i < 24; i++) {
        ringParticles.push({ angle: (Math.PI * 2 * i) / 24, radius: 180 + Math.random() * 30, speed: 0.001 + Math.random() * 0.0005 });
      }

      let t2 = 0;

      const draw2 = () => {
        const w = casesCanvas.offsetWidth, h = casesCanvas.offsetHeight;
        const cx = w / 2, cy = h / 2;
        ctx2.clearRect(0, 0, w, h);
        t2++;

        const coreGrad = ctx2.createRadialGradient(cx, cy, 0, cx, cy, 60);
        coreGrad.addColorStop(0, 'rgba(105,255,135,0.4)'); coreGrad.addColorStop(0.5, 'rgba(105,255,135,0.15)'); coreGrad.addColorStop(1, 'transparent');
        ctx2.fillStyle = coreGrad; ctx2.beginPath(); ctx2.arc(cx, cy, 60, 0, Math.PI * 2); ctx2.fill();

        const pulse = Math.sin(t2 * 0.04) * 0.3 + 0.7;
        ctx2.fillStyle = `rgba(105,255,135,${0.6 * pulse})`; ctx2.beginPath(); ctx2.arc(cx, cy, 18 + pulse * 4, 0, Math.PI * 2); ctx2.fill();

        ctx2.strokeStyle = 'rgba(105,255,135,0.15)'; ctx2.lineWidth = 1; ctx2.setLineDash([3, 6]);
        ctx2.beginPath(); ctx2.arc(cx, cy, 100, 0, Math.PI * 2); ctx2.stroke();
        ctx2.beginPath(); ctx2.arc(cx, cy, 150, 0, Math.PI * 2); ctx2.stroke();
        ctx2.setLineDash([]);

        atoms.forEach(atom => {
          atom.angle += atom.speed;
          const x = cx + Math.cos(atom.angle) * atom.radius, y = cy + Math.sin(atom.angle) * atom.radius;
          ctx2.strokeStyle = `${atom.color}22`; ctx2.lineWidth = 1;
          ctx2.beginPath(); ctx2.moveTo(cx, cy); ctx2.lineTo(x, y); ctx2.stroke();
        });

        flowParticles.forEach(particle => {
          particle.progress += particle.speed;
          if (particle.progress > 1) { particle.progress = 0; particle.fromAtom = Math.floor(Math.random() * businessAreas.length); }
          const atom = atoms[particle.fromAtom];
          const atomX = cx + Math.cos(atom.angle) * atom.radius, atomY = cy + Math.sin(atom.angle) * atom.radius;
          const px = cx + (atomX - cx) * particle.progress, py = cy + (atomY - cy) * particle.progress;
          ctx2.fillStyle = `${atom.color}88`; ctx2.beginPath(); ctx2.arc(px, py, 2, 0, Math.PI * 2); ctx2.fill();
        });

        ringParticles.forEach(p => {
          p.angle += p.speed;
          const x = cx + Math.cos(p.angle) * p.radius, y = cy + Math.sin(p.angle) * p.radius;
          ctx2.fillStyle = 'rgba(105,255,135,0.3)'; ctx2.beginPath(); ctx2.arc(x, y, 1.5, 0, Math.PI * 2); ctx2.fill();
        });

        atoms.forEach(atom => {
          const x = cx + Math.cos(atom.angle) * atom.radius, y = cy + Math.sin(atom.angle) * atom.radius;
          const ag = ctx2.createRadialGradient(x, y, 0, x, y, atom.size);
          ag.addColorStop(0, `${atom.color}66`); ag.addColorStop(0.6, `${atom.color}22`); ag.addColorStop(1, 'transparent');
          ctx2.fillStyle = ag; ctx2.beginPath(); ctx2.arc(x, y, atom.size, 0, Math.PI * 2); ctx2.fill();
          ctx2.fillStyle = atom.color; ctx2.beginPath(); ctx2.arc(x, y, 8, 0, Math.PI * 2); ctx2.fill();
          ctx2.strokeStyle = `${atom.color}88`; ctx2.lineWidth = 1.5; ctx2.beginPath(); ctx2.arc(x, y, 14, 0, Math.PI * 2); ctx2.stroke();

          ctx2.fillStyle = 'rgba(0,14,65,0.85)';
          const lw = ctx2.measureText(atom.label).width + 16, lh = 20, lx = x - lw / 2, ly = y + 22;
          ctx2.beginPath(); ctx2.roundRect(lx, ly, lw, lh, 10); ctx2.fill();
          ctx2.fillStyle = atom.color; ctx2.font = 'bold 10px Inter, system-ui, sans-serif'; ctx2.textAlign = 'center'; ctx2.textBaseline = 'middle';
          ctx2.fillText(atom.label, x, ly + lh / 2);
        });

        ctx2.fillStyle = '#69ff87'; ctx2.font = 'bold 20px Inter, system-ui, sans-serif'; ctx2.textAlign = 'center'; ctx2.textBaseline = 'middle';
        ctx2.fillText('AION', cx, cy - 4);
        ctx2.fillStyle = 'rgba(255,255,255,0.4)'; ctx2.font = '600 8px Inter, system-ui, sans-serif';
        ctx2.fillText('METHOD', cx, cy + 12);

        animId2 = requestAnimationFrame(draw2);
      };
      draw2();

      window.addEventListener('resize', resize2);
    }
  </script>
</body>
