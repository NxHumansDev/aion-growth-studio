          <!-- Right: Partner card mockup -->
          <div class="relative flex items-center justify-center">
            <div class="absolute inset-0 rounded-3xl" style="background: radial-gradient(ellipse at 60% 50%, rgba(105,255,135,0.08) 0%, transparent 70%);"></div>
            <div class="relative w-full max-w-sm rounded-2xl overflow-hidden border border-gray-100" style="box-shadow: 0 20px 60px rgba(0,14,65,0.10), 0 2px 8px rgba(0,0,0,0.04);">
              <div class="bg-primary px-6 py-5 flex items-center justify-between">
                <span class="text-white text-lg font-semibold tracking-wide">Tu marca</span>
                <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full" style="background: rgba(105,255,135,0.2); color: #69ff87;">White Label</span>
              </div>
              <div class="bg-white px-6 py-6 space-y-4">
                {["Diagnóstico SEO", "GEO Visibility", "Benchmark", "AION Radar"].map((item, i) => (
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <svg class="w-4 h-4 text-primary/40" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
