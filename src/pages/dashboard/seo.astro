        <div style="background:#f7f9ff;border-radius:10px;padding:16px 18px;">
          <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#64748b;margin-bottom:6px;">CTR Medio</p>
          <div style="display:flex;align-items:baseline;gap:6px;">
            <span style={`font-size:26px;font-weight:900;color:${(gsc.avgCtr || 0) > 5 ? GREEN_HERO : (gsc.avgCtr || 0) > 2 ? ORANGE_HERO : RED_HERO};`}>{(gsc.avgCtr || 0).toFixed(1)}<span style="font-size:14px;color:#64748b;font-weight:600;">%</span></span>
          </div>
        </div>
        <div style="background:#f7f9ff;border-radius:10px;padding:16px 18px;">
          <p style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:#64748b;margin-bottom:6px;">Posición Media</p>
          <div style="display:flex;align-items:baseline;gap:6px;">
            <span style={`font-size:26px;font-weight:900;color:${(gsc.avgPosition || 99) <= 10 ? GREEN_HERO : (gsc.avgPosition || 99) <= 20 ? ORANGE_HERO : RED_HERO};`}>{(gsc.avgPosition || 0).toFixed(1)}</span>
            {prevGsc?.avgPosition != null && Math.abs((gsc.avgPosition || 0) - prevGsc.avgPosition) >= 0.5 && (
              <span style={`font-size:11px;font-weight:700;color:${(gsc.avgPosition || 0) < prevGsc.avgPosition ? GREEN_HERO : RED_HERO};`}>
                {(gsc.avgPosition || 0) < prevGsc.avgPosition ? '↑' : '↓'}{Math.abs((gsc.avgPosition || 0) - prevGsc.avgPosition).toFixed(1)}
              </span>
            )}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ══ GSC Top Queries (if available) ══ -->
  {gscQueries.length > 0 && (
    <section style="background:white;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">
      <div style="padding:20px 24px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;gap:8px;">
        <h2 style="font-size:15px;font-weight:800;color:#1a1a2e;">Top Queries — qué buscan para encontrarte</h2>
        <span style="font-size:10px;background:#E1F5EE;color:#1D9E75;padding:2px 8px;border-radius:4px;font-weight:700;">GSC</span>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="background:#f7f9ff;">
              <th style="text-align:left;padding:10px 24px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Query</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Clicks</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Impresiones</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">CTR</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Posición</th>
            </tr>
          </thead>
          <tbody>
            {gscQueries.map((q, i) => (
              <tr style={`border-bottom:1px solid #f0f0f0;${i % 2 === 1 ? 'background:#fafbfd;' : ''}`}>
                <td style="padding:12px 24px;font-weight:600;color:#1a1a2e;">{q.query}</td>
                <td style="text-align:center;padding:12px 16px;font-weight:700;color:#1A4B8C;">{q.clicks}</td>
                <td style="text-align:center;padding:12px 16px;color:#434750;">{q.impressions.toLocaleString()}</td>
                <td style={`text-align:center;padding:12px 16px;font-weight:600;color:${q.ctr > 5 ? '#1D9E75' : q.ctr > 2 ? '#BA7517' : '#E24B4A'};`}>{q.ctr}%</td>
                <td style="text-align:center;padding:12px 16px;">
                  <span style={`font-weight:800;color:${q.position <= 10 ? '#1D9E75' : q.position <= 20 ? '#BA7517' : '#E24B4A'};`}>{q.position}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <!-- ══ GSC Top Pages (if available) ══ -->
  {(gsc?.topPages || []).length > 0 && (
    <section style="background:white;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">
      <div style="padding:20px 24px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;gap:8px;">
        <h2 style="font-size:15px;font-weight:800;color:#1a1a2e;">Top Pages — páginas con más tráfico orgánico</h2>
        <span style="font-size:10px;background:#E1F5EE;color:#1D9E75;padding:2px 8px;border-radius:4px;font-weight:700;">GSC</span>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="background:#f7f9ff;">
              <th style="text-align:left;padding:10px 24px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">URL</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Clicks</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Impresiones</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">CTR</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Posición</th>
            </tr>
          </thead>
          <tbody>
            {(gsc.topPages || []).slice(0, 10).map((p: any, i: number) => {
              // Strip domain for cleaner URL display
              let shortUrl = p.page || '';
              try { shortUrl = new URL(p.page).pathname || '/'; } catch {}
              return (
                <tr style={`border-bottom:1px solid #f0f0f0;${i % 2 === 1 ? 'background:#fafbfd;' : ''}`}>
                  <td style="padding:12px 24px;font-weight:600;color:#1a1a2e;max-width:400px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title={p.page}>{shortUrl}</td>
                  <td style="text-align:center;padding:12px 16px;font-weight:700;color:#1A4B8C;">{p.clicks}</td>
                  <td style="text-align:center;padding:12px 16px;color:#434750;">{(p.impressions || 0).toLocaleString()}</td>
                  <td style={`text-align:center;padding:12px 16px;font-weight:600;color:${p.ctr > 5 ? '#1D9E75' : p.ctr > 2 ? '#BA7517' : '#E24B4A'};`}>{p.ctr}%</td>
                  <td style="text-align:center;padding:12px 16px;">
                    <span style={`font-weight:800;color:${p.position <= 10 ? '#1D9E75' : p.position <= 20 ? '#BA7517' : '#E24B4A'};`}>{p.position}</span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <!-- ══ Keyword Gap (opportunities) ══ -->
  {keywordGap.length > 0 && (
    <section style="background:white;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">
      <div style="padding:20px 24px;border-bottom:1px solid #f0f0f0;">
        <h2 style="font-size:15px;font-weight:800;color:#1a1a2e;">Oportunidades — Keywords de competidores</h2>
        <p style="font-size:12px;color:#64748b;margin-top:2px;">Keywords donde tus competidores rankean y tú no</p>
      </div>
      <div style="overflow-x:auto;">
        <table style="width:100%;border-collapse:collapse;font-size:13px;">
          <thead>
            <tr style="background:#f7f9ff;">
              <th style="text-align:left;padding:10px 24px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Keyword</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Volumen</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Dificultad</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Competidor</th>
              <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Impacto</th>
            </tr>
          </thead>
          <tbody>
            {keywordGap.map((kw, i) => {
              const diff = difficultyColor(kw.difficulty || 50);
              const impactColor = kw.impact === 'high' ? '#1A4B8C' : kw.impact === 'medium' ? '#BA7517' : '#64748b';
              return (
                <tr style={`border-bottom:1px solid #f0f0f0;${i % 2 === 1 ? 'background:#fafbfd;' : ''}`}>
                  <td style="padding:12px 24px;font-weight:600;color:#1a1a2e;">{kw.keyword}</td>
                  <td style="text-align:center;padding:12px 16px;color:#434750;">{kw.volume?.toLocaleString() || '—'}</td>
                  <td style="text-align:center;padding:12px 16px;">
                    <span style={`display:inline-flex;align-items:center;justify-content:center;min-width:28px;height:28px;border-radius:999px;font-size:11px;font-weight:700;background:${diff.bg};color:${diff.fg};padding:0 8px;`}>
                      {kw.difficulty || '—'}
                    </span>
                  </td>
                  <td style="text-align:center;padding:12px 16px;font-size:12px;color:#64748b;">{kw.competitor || '—'}</td>
                  <td style="text-align:center;padding:12px 16px;">
                    <span style={`font-size:10px;font-weight:700;padding:3px 10px;border-radius:999px;color:white;background:${impactColor};text-transform:uppercase;`}>
                      {kw.impact || '—'}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <!-- ══ Evolution Sparklines — desglose de posiciones ══ -->
  <section style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
    <div style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:20px;">
      <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:12px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;color:#64748b;">Keywords Top 3 — evolución</p>
        <span style="font-size:18px;font-weight:900;color:#1D9E75;">{seo.keywordsTop3 ?? 0}</span>
      </div>
      <p style="font-size:11px;color:#64748b;margin-bottom:8px;">Las que ya reciben la mayoría del tráfico (posiciones 1-3)</p>
      <div style="display:flex;align-items:flex-end;gap:4px;height:48px;">
        {top3History.map((v, i) => {
          const max = Math.max(...top3History, 1);
          const h = Math.max(2, Math.round((v / max) * 48));
          const isLast = i === top3History.length - 1;
          return <div style={`flex:1;background:${isLast ? '#1D9E75' : '#e2e8f0'};height:${h}px;border-radius:2px 2px 0 0;`}></div>;
        })}
      </div>
      <div style="display:flex;justify-content:space-between;margin-top:6px;font-size:9px;color:#94a3b8;">
        <span>{top3History[0]}</span>
        <span>{top3History[top3History.length - 1]}</span>
      </div>
    </div>
    <div style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:20px;">
      <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:12px;">
        <p style="font-size:10px;font-weight:700;text-transform:uppercase;color:#64748b;">Keywords posición 4-10 — evolución</p>
        <span style="font-size:18px;font-weight:900;color:#BA7517;">{seo.keywordsPos4to10 ?? Math.max(0, (seo.keywordsTop10 || 0) - (seo.keywordsTop3 || 0))}</span>
      </div>
      <p style="font-size:11px;color:#64748b;margin-bottom:8px;">Oportunidades optimizables — cerca del top 3</p>
      <div style="display:flex;align-items:flex-end;gap:4px;height:48px;">
        {pos4to10History.map((v, i) => {
          const max = Math.max(...pos4to10History, 1);
          const h = Math.max(2, Math.round((v / max) * 48));
          const isLast = i === pos4to10History.length - 1;
          return <div style={`flex:1;background:${isLast ? '#BA7517' : '#e2e8f0'};height:${h}px;border-radius:2px 2px 0 0;`}></div>;
        })}
      </div>
      <div style="display:flex;justify-content:space-between;margin-top:6px;font-size:9px;color:#94a3b8;">
        <span>{pos4to10History[0]}</span>
        <span>{pos4to10History[pos4to10History.length - 1]}</span>
      </div>
    </div>
  </section>

  <!-- ══ Competitor SEO Comparison ══ -->
  {compItems.length > 0 && (
    <section style="background:white;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">
      <div style="padding:20px 24px;border-bottom:1px solid #f0f0f0;">
        <h2 style="font-size:15px;font-weight:800;color:#1a1a2e;">Competidores — SEO</h2>
      </div>
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:#f7f9ff;">
            <th style="text-align:left;padding:10px 24px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Dominio</th>
            <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">KW Top 10</th>
            <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Tráfico</th>
            <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">Domain Rank</th>
            <th style="text-align:center;padding:10px 16px;font-weight:700;font-size:10px;text-transform:uppercase;color:#64748b;">vs Tú</th>
          </tr>
        </thead>
        <tbody>
          <tr style="background:#f0f4ff;font-weight:700;">
            <td style="padding:12px 24px;color:#1A4B8C;">{client.domain}</td>
            <td style="text-align:center;padding:12px 16px;color:#1A4B8C;">{seo.keywordsTop10 || 0}</td>
            <td style="text-align:center;padding:12px 16px;color:#1A4B8C;">{fmtNum(seo.organicTrafficEstimate || 0)}</td>
            <td style="text-align:center;padding:12px 16px;color:#1A4B8C;">{fmtNum(seo.domainRank || 0)}</td>
            <td style="text-align:center;padding:12px 16px;">—</td>
          </tr>
          {compItems.map((c, i) => {
            const kwDiff = (c.keywordsTop10 || 0) - (seo.keywordsTop10 || 0);
            return (
              <tr style={`border-bottom:1px solid #f0f0f0;${i % 2 === 0 ? 'background:#fafbfd;' : ''}`}>
                <td style="padding:12px 24px;font-weight:600;color:#1a1a2e;">{c.domain}</td>
                <td style="text-align:center;padding:12px 16px;">{c.keywordsTop10 || '—'}</td>
                <td style="text-align:center;padding:12px 16px;">{fmtNum(c.organicTrafficEstimate || 0)}</td>
                <td style="text-align:center;padding:12px 16px;">{fmtNum(c.domainRank || 0)}</td>
                <td style="text-align:center;padding:12px 16px;">
                  {kwDiff > 0 ? (
                    <span style="background:#FCEBEB;color:#E24B4A;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700;">+{kwDiff} kw</span>
                  ) : kwDiff < 0 ? (
                    <span style="background:#E1F5EE;color:#1D9E75;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700;">{kwDiff} kw</span>
                  ) : (
                    <span style="color:#94a3b8;">=</span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>
  )}

  <!-- ══ Content Analysis ══ -->
  {content.valueProposition && (
    <section style="background:white;border:1px solid #e2e8f0;border-radius:12px;padding:24px;">
      <h2 style="font-size:15px;font-weight:800;color:#1a1a2e;margin-bottom:12px;">Análisis de contenido</h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div>
          <p style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:6px;">Propuesta de valor</p>
          <p style="font-size:13px;color:#434750;line-height:1.5;">{content.valueProposition}</p>
        </div>
        <div>
          <p style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:6px;">Audiencia detectada</p>
          <p style="font-size:13px;color:#434750;line-height:1.5;">{content.audienceMatch || '—'}</p>
        </div>
      </div>
      {((content.strengths as any[])?.length > 0 || (content.weaknesses as any[])?.length > 0) && (
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px;padding-top:16px;border-top:1px solid #f0f0f0;">
          {(content.strengths as any[])?.length > 0 && (
            <div>
              <p style="font-size:11px;font-weight:700;color:#1D9E75;text-transform:uppercase;margin-bottom:6px;">Fortalezas</p>
              {(content.strengths as string[]).map((s: string) => (
                <div style="display:flex;align-items:flex-start;gap:6px;margin-bottom:4px;">
                  <span class="material-symbols-outlined" style="font-size:14px;color:#1D9E75;margin-top:2px;">check</span>
                  <span style="font-size:12px;color:#434750;">{s}</span>
                </div>
              ))}
            </div>
          )}
          {(content.weaknesses as any[])?.length > 0 && (
            <div>
              <p style="font-size:11px;font-weight:700;color:#E24B4A;text-transform:uppercase;margin-bottom:6px;">Debilidades</p>
              {(content.weaknesses as string[]).map((w: string) => (
                <div style="display:flex;align-items:flex-start;gap:6px;margin-bottom:4px;">
                  <span class="material-symbols-outlined" style="font-size:14px;color:#E24B4A;margin-top:2px;">close</span>
                  <span style="font-size:12px;color:#434750;">{w}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </section>
  )}

  <!-- ══ Generated Fixes (content ready to copy-paste) ══ -->
  {fixes.length > 0 && (
    <section style="background:white;border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;">
      <div style="padding:20px 24px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;gap:10px;">
        <span class="material-symbols-outlined" style="font-size:20px;color:#1D9E75;">auto_fix_high</span>
        <div>
          <h2 style="font-size:15px;font-weight:800;color:#1a1a2e;">Contenido generado por AION — listo para usar</h2>
          <p style="font-size:12px;color:#64748b;margin-top:2px;">Copia y pega directamente en tu web. Adaptado a tu negocio y objetivos.</p>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;">
        {fixes.map((fix, i) => {
          const meta = fixTypeLabels[fix.type] || { label: fix.type, icon: 'code' };
          const isCode = fix.type.startsWith('schema');
          return (
            <div style={`padding:20px 24px;${i < fixes.length - 1 ? 'border-bottom:1px solid #f0f0f0;' : ''}`}>
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
                <div style="display:flex;align-items:center;gap:8px;">
                  <span class="material-symbols-outlined" style="font-size:18px;color:#1A4B8C;">{meta.icon}</span>
                  <h3 style="font-size:14px;font-weight:700;color:#1a1a2e;">{meta.label}</h3>
                </div>
                <button class="btn-copy-fix" data-content={fix.content}
                  style="display:flex;align-items:center;gap:4px;padding:6px 14px;background:#1A4B8C;color:white;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;">
                  <span class="material-symbols-outlined" style="font-size:14px;">content_copy</span>
                  Copiar
                </button>
              </div>
              <p style="font-size:11px;color:#64748b;margin-bottom:8px;">{fix.where}</p>
              <div style={`padding:14px;border-radius:8px;font-size:13px;line-height:1.6;${isCode ? 'background:#1a1a2e;color:#e2e8f0;font-family:monospace;font-size:12px;overflow-x:auto;white-space:pre;' : 'background:#f7f9ff;color:#1a1a2e;border:1px solid #e2e8f0;'}`}>
                {fix.content}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  )}

</div>

<style>
  .onpage-item:hover { background: #f7f9ff; }
  .onpage-item.open .onpage-chevron { transform: rotate(180deg); }
  .onpage-item.open { background: #f7f9ff; }
</style>

<script>
  document.querySelectorAll('.onpage-item').forEach(item => {
    item.addEventListener('click', () => {
      const expanded = item.querySelector('.onpage-expanded') as HTMLElement;
      if (!expanded) return;
      const isOpen = item.classList.contains('open');
      if (isOpen) {
        item.classList.remove('open');
        expanded.style.display = 'none';
      } else {
        item.classList.add('open');
        expanded.style.display = 'block';
      }
    });
  });

  document.querySelectorAll('.btn-copy-fix').forEach(btn => {
    btn.addEventListener('click', async () => {
      const content = (btn as HTMLElement).dataset.content || '';
      await navigator.clipboard.writeText(content);
      const original = btn.innerHTML;
      btn.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px;">check</span> Copiado';
      (btn as HTMLElement).style.background = '#1D9E75';
      setTimeout(() => { btn.innerHTML = original; (btn as HTMLElement).style.background = '#1A4B8C'; }, 2000);
    });
  });
</script>
</DashboardLayout>
