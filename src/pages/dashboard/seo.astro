---
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { getClient, getLatestSnapshot, getAllSnapshots, getClientOnboarding } from '../../lib/db';
import type { Tier } from '../../lib/demo-data';
import { computeKeywordOpportunities, autoSelectPriorities } from '../../lib/seo/keyword-opportunities';
import KeywordConfigurator from '../../components/dashboard/KeywordConfigurator.astro';

const client = Astro.locals.client ?? await getClient();
const tier: Tier = client.tier;
const snapshot = await getLatestSnapshot(client.id);
const hasData = snapshot.id !== 'empty';
if (!hasData) return Astro.redirect('/dashboard');

const allSnapshots = await getAllSnapshots(client.id);
const prevSnap = allSnapshots.length >= 2 ? allSnapshots[allSnapshots.length - 2] : null;

// ─── Priority keywords (business intelligence) ──────────────────────────
const onboarding = await getClientOnboarding(client.id);
const priorityKeywords = onboarding?.priority_keywords || [];
const keywordStrategy = onboarding?.keyword_strategy || {};
const hasPriorityKeywords = priorityKeywords.length > 0;

const keywordOpportunities = computeKeywordOpportunities({
  pipelineOutput: snapshot.pipeline_output || {},
  onboarding,
  strategy: keywordStrategy,
  limit: 15,
});
const autoSelectedKeywords = autoSelectPriorities(keywordOpportunities, 8);

const r = snapshot.pipeline_output || {};
const pr = prevSnap?.pipeline_output || {};
const seo = r.seo || {};
const prevSeo = pr.seo || {};
const gsc = r.analytics?.gsc;
const prevGsc = pr.analytics?.gsc;
const ga4 = r.analytics?.ga4;
const prevGa4 = pr.analytics?.ga4;

// ─── Helper: extract organic sessions from GA4 trafficSources ─────────────
function organicSessionsFromGa4(ga4Data: any): number {
  if (!ga4Data?.trafficSources) return 0;
  return ga4Data.trafficSources
    .filter((t: any) => (t.medium || '').toLowerCase() === 'organic')
    .reduce((sum: number, t: any) => sum + (t.sessions || 0), 0);
}

const ga4OrganicSessions = organicSessionsFromGa4(ga4);
const prevGa4OrganicSessions = organicSessionsFromGa4(prevGa4);

const hasGsc = !!gsc && (gsc.totalClicks ?? 0) > 0;
const hasGa4Organic = ga4OrganicSessions > 0;

// ─── Stat cards data (Keywords Top 10 y Tráfico Orgánico están en el hero) ──
const stats = [
  {
    label: 'Domain Rank',
    value: seo.domainRank || '—',
    prev: prevSeo.domainRank,
    icon: 'shield',
    better: 'up',
    format: 'number',
    tooltip: 'Autoridad de tu dominio (0-100). Cuanto más alto, más fácil rankear. Se calcula en base a la cantidad y calidad de los enlaces que recibes desde otras webs. Fuente: DataForSEO.',
  },
  {
    label: 'Referring Domains',
    value: seo.referringDomains || '—',
    prev: prevSeo.referringDomains,
    icon: 'link',
    better: 'up',
    tooltip: 'Número de dominios únicos distintos que enlazan a tu web. Más diversidad de dominios = mejor señal de autoridad para Google que muchos enlaces desde un mismo sitio.',
  },
  {
    label: 'Backlinks',
    value: seo.backlinksTotal || '—',
    prev: prevSeo.backlinksTotal,
    icon: 'hub',
    better: 'up',
    format: 'number',
    tooltip: 'Total de enlaces externos que apuntan a tu web (incluye varios del mismo dominio). La calidad de los enlaces importa más que la cantidad pura.',
  },
  (() => {
    // Cascada: DFS site: search > GSC topPages (páginas con impresiones reales) > GSC sitemap submitted
    const gscPagesWithImpressions = (gsc?.topPages || []).filter((p: any) => (p.impressions ?? 0) > 0).length;
    let indexedVal: number | string = '—';
    let indexedPrev: number | undefined;
    let indexedTooltip = 'Páginas tuyas que Google tiene en su índice y puede mostrar en resultados de búsqueda.';
    if (seo.indexedPages) {
      indexedVal = seo.indexedPages;
      indexedPrev = prevSeo.indexedPages;
      indexedTooltip += ' Fuente: búsqueda "site:tudominio.com" (DataForSEO).';
    } else if (gscPagesWithImpressions > 0) {
      indexedVal = gscPagesWithImpressions;
      const prevGscPages = (prevGsc?.topPages || []).filter((p: any) => (p.impressions ?? 0) > 0).length;
      indexedPrev = prevGscPages > 0 ? prevGscPages : undefined;
      indexedTooltip += ' Fuente: Search Console (páginas con impresiones en los últimos 7 días — es una muestra, el número real puede ser mayor).';
    } else if (gsc?.indexedPages) {
      indexedVal = gsc.indexedPages;
      indexedTooltip += ' Fuente: Search Console Sitemaps API (URLs enviadas en el sitemap — no necesariamente todas están indexadas).';
    }
    return {
      label: 'Páginas Indexadas',
      value: indexedVal,
      prev: indexedPrev,
      icon: 'description',
      better: 'up',
      tooltip: indexedTooltip,
    };
  })(),
];

// ─── Keywords table ───────────────────────────────────────────────────────
const topKeywords = (seo.topKeywords || []) as Array<{keyword: string; position: number; volume: number; difficulty: number; prevPosition?: number}>;

// Add prev positions
topKeywords.forEach((kw: any) => {
  const prevKw = (prevSeo.topKeywords || []).find((pk: any) => pk.keyword === kw.keyword);
  if (prevKw) kw.prevPosition = prevKw.position;
});

// ─── Keyword gap ──────────────────────────────────────────────────────────
const keywordGap = (r.keyword_gap?.items || []).slice(0, 10) as Array<{keyword: string; volume?: number; difficulty?: number; position?: number; competitor?: string; impact?: string; priority?: string}>;

// ─── Competitor comparison ────────────────────────────────────────────────
const compItems = (r.competitor_traffic?.items || []) as Array<{domain: string; organicTrafficEstimate?: number; keywordsTop10?: number; domainRank?: number}>;

// ─── GSC data ─────────────────────────────────────────────────────────────
const gscQueries = (gsc?.topQueries || []).slice(0, 10) as Array<{query: string; clicks: number; impressions: number; ctr: number; position: number}>;

// ─── Evolution sparklines ─────────────────────────────────────────────────
const kwHistory = allSnapshots.map(s => s.pipeline_output?.seo?.keywordsTop10 || 0);
const trafficHistory = allSnapshots.map(s => s.pipeline_output?.seo?.organicTrafficEstimate || 0);
const top3History = allSnapshots.map(s => s.pipeline_output?.seo?.keywordsTop3 || 0);
const pos4to10History = allSnapshots.map(s => {
  const sseo = s.pipeline_output?.seo || {};
  return sseo.keywordsPos4to10 ?? Math.max(0, (sseo.keywordsTop10 || 0) - (sseo.keywordsTop3 || 0));
});

// ─── Hero metrics ─────────────────────────────────────────────────────────
const seoScoreValue = r.score?.breakdown?.seo ?? 0;
const prevSeoScore = pr.score?.breakdown?.seo;
const seoScoreDelta = prevSeoScore != null ? seoScoreValue - prevSeoScore : null;

const kwTop10Curr = seo.keywordsTop10 || 0;
const kwTop10Prev = prevSeo.keywordsTop10;
const kwTop10Delta = kwTop10Prev != null ? kwTop10Curr - kwTop10Prev : null;

// Tráfico Orgánico — cascada: GSC clicks reales > GA4 organic sessions > DataForSEO estimate
let trafficCurr: number;
let trafficPrev: number | null;
let trafficSource: 'gsc' | 'ga4' | 'dfs';
let trafficSourceLabel: string;
if (hasGsc) {
  trafficCurr = gsc.totalClicks || 0;
  trafficPrev = prevGsc?.totalClicks ?? null;
  trafficSource = 'gsc';
  trafficSourceLabel = 'GSC · clicks reales';
} else if (hasGa4Organic) {
  trafficCurr = ga4OrganicSessions;
  trafficPrev = prevGa4OrganicSessions || null;
  trafficSource = 'ga4';
  trafficSourceLabel = 'GA4 · sesiones orgánicas';
} else {
  trafficCurr = seo.organicTrafficEstimate || 0;
  trafficPrev = prevSeo.organicTrafficEstimate ?? null;
  trafficSource = 'dfs';
  trafficSourceLabel = 'Estimado';
}
const trafficDelta = trafficPrev != null ? trafficCurr - trafficPrev : null;

// Color palette for hero
const GREEN_HERO = '#1D9E75';
const GREEN_BG_HERO = '#E1F5EE';
const ORANGE_HERO = '#BA7517';
const ORANGE_BG_HERO = '#FAEEDA';
const RED_HERO = '#E24B4A';
const RED_BG_HERO = '#FCEBEB';
const SEO_COLOR = '#1A4B8C';
const SEO_BG = '#1A4B8C15';

function seoScoreColor(v: number) { return v >= 50 ? GREEN_HERO : v >= 25 ? ORANGE_HERO : RED_HERO; }

function buildSeoDonut(score: number, radius: number, stroke: number) {
  const circ = 2 * Math.PI * radius;
  const pct = Math.min(score, 100) / 100;
  const offset = circ * (1 - pct);
  const color = seoScoreColor(score);
  const size = (radius + stroke) * 2;
  return `<svg viewBox="0 0 ${size} ${size}" width="${size}" height="${size}" style="transform:rotate(-90deg)">
    <circle cx="${size/2}" cy="${size/2}" r="${radius}" fill="none" stroke="#e2e8f0" stroke-width="${stroke}"/>
    <circle cx="${size/2}" cy="${size/2}" r="${radius}" fill="none" stroke="${color}" stroke-width="${stroke}"
      stroke-dasharray="${circ}" stroke-dashoffset="${offset}" stroke-linecap="round"
      style="transition:stroke-dashoffset 1s ease;"/>
  </svg>`;
}

// ─── Briefing fixes (generated content ready to use) ─────────────────────
const briefing = r.briefing || {};
const fixes = (briefing.fixes || []) as Array<{type: string; content: string; where: string}>;
const fixTypeLabels: Record<string, { label: string; icon: string }> = {
  meta_description: { label: 'Meta Description', icon: 'description' },
  meta_title: { label: 'Meta Title', icon: 'title' },
  schema_organization: { label: 'Schema Organization (JSON-LD)', icon: 'code' },
  schema_faq: { label: 'Schema FAQ (JSON-LD)', icon: 'quiz' },
  schema_product: { label: 'Schema Product', icon: 'shopping_bag' },
  schema_local: { label: 'Schema LocalBusiness', icon: 'location_on' },
};

// ─── Difficulty badge color ───────────────────────────────────────────────
function difficultyColor(d: number): { bg: string; fg: string } {
  if (d <= 20) return { bg: '#dcfce7', fg: '#166534' };
  if (d <= 35) return { bg: '#d9f99d', fg: '#3f6212' };
  if (d <= 50) return { bg: '#fef9c3', fg: '#854d0e' };
  if (d <= 65) return { bg: '#fed7aa', fg: '#9a3412' };
  if (d <= 80) return { bg: '#fecaca', fg: '#991b1b' };
  return { bg: '#fca5a5', fg: '#7f1d1d' };
}

function positionChange(curr: number, prev?: number): { text: string; color: string } {
  if (!prev) return { text: 'new', color: '#1D9E75' };
  const diff = prev - curr;
  if (diff > 0) return { text: `↑${diff}`, color: '#1D9E75' };
  if (diff < 0) return { text: `↓${Math.abs(diff)}`, color: '#E24B4A' };
  return { text: '=', color: '#94a3b8' };
}

function fmtNum(n: number | string): string {
  if (typeof n === 'string') return n;
  return n >= 1000 ? `${(n/1000).toFixed(1)}K` : String(n);
}

// ─── On-page SEO audit ───────────────────────────────────────────────────
const crawl = r.crawl || {};
const content = r.content || {};
const ssl = r.ssl || {};
const pagespeed = r.pagespeed || {};
const techstack = r.techstack || {};
const scoreBreakdown = r.score?.breakdown || {};
const seoSkipped = seo.skipped === true;

interface SeoIssue { severity: 'critical' | 'warning' | 'good'; label: string; detail: string; expanded?: string; }
const onPageIssues: SeoIssue[] = [];

if (crawl.title) {
  const len = (crawl.title as string).length;
  const titleText = crawl.title as string;
  if (len > 60) onPageIssues.push({ severity: 'warning', label: 'Title demasiado largo', detail: `${len} caracteres (recomendado: 50-60)`, expanded: `Tu título actual:\n"${titleText}"\n\nGoogle muestra máximo ~60 caracteres en los resultados. Los últimos ${len - 60} caracteres se cortarán. Pon las keywords principales al inicio y recorta a 50-60 chars.` });
  else if (len < 30) onPageIssues.push({ severity: 'warning', label: 'Title demasiado corto', detail: `${len} caracteres. Usa más espacio para keywords.`, expanded: `Tu título actual:\n"${titleText}"\n\nTienes ${60 - len} caracteres más disponibles. Incluye keywords relevantes y tu marca. El rango óptimo para Google es 50-60 caracteres.` });
  else onPageIssues.push({ severity: 'good', label: 'Title correcto', detail: `${len} caracteres`, expanded: `Tu título actual:\n"${titleText}"\n\nLongitud óptima (50-60 chars). Google lo mostrará completo en los resultados.` });
} else { onPageIssues.push({ severity: 'critical', label: 'Sin meta title', detail: 'Sin título definido — fundamental para SEO', expanded: `Tu web no tiene un <title> definido. Google generará uno automáticamente (y no será bueno).\n\nAñade en el <head>:\n<title>Tu keyword principal — Tu marca</title>\n\nLongitud óptima: 50-60 caracteres.` }); }

if (crawl.description) {
  const len = (crawl.description as string).length;
  const descText = crawl.description as string;
  if (len > 160) onPageIssues.push({ severity: 'warning', label: 'Meta description largo', detail: `${len} chars — Google lo cortará`, expanded: `Tu meta description actual (${len} chars):\n"${descText}"\n\nGoogle muestra máximo ~155-160 caracteres en escritorio y ~120 en móvil. Los últimos ${len - 155} caracteres se perderán.\n\nLongitud óptima: 120-155 caracteres. Incluye tu keyword principal y un CTA claro.` });
  else if (len < 70) onPageIssues.push({ severity: 'warning', label: 'Meta description corto', detail: `${len} chars — aprovecha más espacio`, expanded: `Tu meta description actual (${len} chars):\n"${descText}"\n\nTienes ${155 - len} caracteres más disponibles para convencer al usuario de hacer clic.\n\nLongitud óptima: 120-155 caracteres. Incluye keywords, propuesta de valor y un CTA.` });
  else onPageIssues.push({ severity: 'good', label: 'Meta description ok', detail: `${len} chars`, expanded: `Tu meta description actual (${len} chars):\n"${descText}"\n\nLongitud dentro del rango óptimo (120-155 chars). Google lo mostrará completo.` });
} else { onPageIssues.push({ severity: 'critical', label: 'Sin meta description', detail: 'Google generará una automática — menos clicks', expanded: `Tu web no tiene meta description. Google extraerá texto aleatorio de tu página — lo que reduce el CTR.\n\nAñade en el <head>:\n<meta name="description" content="Tu descripción aquí">\n\nLongitud óptima: 120-155 caracteres. En móvil Google corta a ~120 chars.` }); }

const h1Count = (crawl.h1s as any[])?.length || 0;
if (h1Count === 0) onPageIssues.push({ severity: 'critical', label: 'Sin H1', detail: 'Sin encabezado principal', expanded: 'Tu página no tiene ningún <h1>. El H1 es el encabezado más importante para SEO — Google lo usa para entender de qué trata la página.\n\nAñade un único <h1> con tu keyword principal al inicio de tu contenido.' });
else if (h1Count > 1) onPageIssues.push({ severity: 'warning', label: `${h1Count} H1s`, detail: 'Debería haber solo 1 H1', expanded: `Se encontraron ${h1Count} etiquetas H1:\n${((crawl.h1s as any[]) || []).map((h: string, i: number) => `${i+1}. "${h}"`).join('\n')}\n\nGoogle recomienda un solo H1 por página. Cambia los H1 extra a H2 o H3 según su jerarquía.` });
else onPageIssues.push({ severity: 'good', label: 'H1 correcto', detail: `"${((crawl.h1s as any[])?.[0] || '').slice(0, 40)}"`, expanded: `Tu H1:\n"${(crawl.h1s as any[])?.[0] || ''}"\n\nUn solo H1 bien definido. Asegúrate de que contenga tu keyword principal.` });

if (crawl.imageCount > 0 && (crawl.imagesWithAlt as number) < (crawl.imageCount as number)) {
  const missing = (crawl.imageCount as number) - (crawl.imagesWithAlt as number);
  onPageIssues.push({ severity: 'warning', label: `${missing} imágenes sin alt`, detail: 'Google no puede ver imágenes sin alt text', expanded: `${crawl.imageCount} imágenes en total, ${crawl.imagesWithAlt} con alt text, ${missing} sin él.\n\nEl atributo alt ayuda a Google a indexar las imágenes y mejora la accesibilidad. Describe lo que muestra cada imagen de forma breve y natural, incluyendo keywords cuando tenga sentido.` });
} else if (crawl.imageCount > 0) onPageIssues.push({ severity: 'good', label: 'Imágenes con alt text', detail: 'Todas las imágenes tienen texto alternativo', expanded: `${crawl.imageCount} imágenes encontradas, todas con alt text. Google puede indexarlas y aparecer en Google Images.` });

if (ssl.valid) onPageIssues.push({ severity: 'good', label: 'SSL activo', detail: `${ssl.protocol || 'TLS'} — expira en ${ssl.daysUntilExpiry || '?'} días`, expanded: `Certificado SSL válido.\nProtocolo: ${ssl.protocol || 'TLS'}\nExpira en: ${ssl.daysUntilExpiry || '?'} días\n\nGoogle da prioridad a sitios HTTPS. ${(ssl.daysUntilExpiry as number) < 30 ? '⚠ Renueva pronto — quedan menos de 30 días.' : 'Sin problemas a la vista.'}` });
else onPageIssues.push({ severity: 'critical', label: 'Sin SSL', detail: 'Chrome marca tu web como "No segura"', expanded: 'Tu web no tiene certificado SSL (HTTPS). Chrome y otros navegadores muestran "No segura" en la barra de direcciones, lo que ahuyenta a los visitantes.\n\nAdemás, Google penaliza las webs sin HTTPS en los rankings. Instala un certificado SSL — muchos hostings lo ofrecen gratis con Let\'s Encrypt.' });

if (crawl.hasSchemaMarkup) onPageIssues.push({ severity: 'good', label: 'Schema markup', detail: `Tipos: ${((crawl.schemaTypes as any[]) || []).join(', ')}`, expanded: `Schema detectado: ${((crawl.schemaTypes as any[]) || []).join(', ')}\n\nEl marcado Schema ayuda a Google a mostrar rich snippets (estrellas, precios, FAQ…) que aumentan el CTR. Revisa si cubre los tipos más relevantes para tu negocio.` });
else onPageIssues.push({ severity: 'warning', label: 'Sin schema markup', detail: 'Google y las IAs no entienden tu negocio', expanded: 'No se detectó Schema (JSON-LD) en tu web. Sin Schema, Google no puede generar rich snippets (estrellas, FAQ, precios…) y las IAs no pueden estructurar tu información.\n\nAñade al menos Schema de tipo Organization y, si aplica, LocalBusiness, Product o FAQ.' });

if (crawl.hasSitemap) onPageIssues.push({ severity: 'good', label: 'Sitemap', detail: 'Google descubre tus páginas', expanded: `Se detectó sitemap.xml. Google lo usa para descubrir e indexar todas tus páginas.\n\nVerifica que esté actualizado y que incluya solo URLs canónicas (no duplicados ni páginas con noindex).` });
else onPageIssues.push({ severity: 'warning', label: 'Sin sitemap.xml', detail: 'Google no descubre todas tus páginas', expanded: `No se encontró sitemap.xml. Sin él, Google depende del crawling para descubrir tus páginas — y puede perderse algunas.\n\nCrea un sitemap.xml en la raíz de tu web y envíalo en Google Search Console. La mayoría de CMS lo generan automáticamente.` });

if (crawl.hasCanonical) onPageIssues.push({ severity: 'good', label: 'Canonical', detail: 'Evita duplicados', expanded: 'Se detectó etiqueta canonical. Esto indica a Google cuál es la URL principal de cada página, evitando problemas de contenido duplicado.' });
else onPageIssues.push({ severity: 'warning', label: 'Sin canonical', detail: 'Posible contenido duplicado', expanded: 'No se detectó etiqueta <link rel="canonical">. Sin ella, Google puede indexar múltiples URLs con el mismo contenido (con/sin www, con/sin trailing slash, con parámetros…), diluyendo tu posicionamiento.\n\nAñade en cada página:\n<link rel="canonical" href="https://tudominio.com/pagina" />' });

const mobilePS = pagespeed.mobile?.performance;
if (mobilePS >= 90) onPageIssues.push({ severity: 'good', label: `PageSpeed mobile: ${mobilePS}`, detail: 'Excelente', expanded: `Puntuación PageSpeed Insights para móvil: ${mobilePS}/100.\n\nExcelente rendimiento. Google prioriza la experiencia móvil desde 2021 (mobile-first indexing).` });
else if (mobilePS >= 50) onPageIssues.push({ severity: 'warning', label: `PageSpeed mobile: ${mobilePS}`, detail: 'Mejorable', expanded: `Puntuación PageSpeed Insights para móvil: ${mobilePS}/100.\n\nEl objetivo es superar 90. Revisa LCP (carga del elemento principal), CLS (estabilidad visual) y FID (interactividad).\n\n${pagespeed.mobile?.lcp ? `LCP actual: ${((pagespeed.mobile.lcp as number)/1000).toFixed(1)}s (Google recomienda < 2.5s)` : ''}\n\nAcciones comunes: optimizar imágenes (WebP), reducir JS/CSS no utilizado, usar lazy loading.` });
else if (mobilePS) onPageIssues.push({ severity: 'critical', label: `PageSpeed mobile: ${mobilePS}`, detail: `LCP: ${pagespeed.mobile?.lcp ? ((pagespeed.mobile.lcp as number)/1000).toFixed(1)+'s' : '?'}`, expanded: `Puntuación PageSpeed Insights para móvil: ${mobilePS}/100 — rendimiento pobre.\n\n${pagespeed.mobile?.lcp ? `LCP: ${((pagespeed.mobile.lcp as number)/1000).toFixed(1)}s (Google recomienda < 2.5s)` : ''}\n\nEsto afecta directamente al ranking en Google. Prioriza: optimizar imágenes, reducir JavaScript, mejorar el servidor (TTFB) y habilitar compresión.` });

if ((crawl.wordCount as number) < 300) onPageIssues.push({ severity: 'warning', label: `${crawl.wordCount} palabras`, detail: 'Poco contenido para SEO', expanded: `Tu página tiene ${crawl.wordCount} palabras. Google necesita contenido para entender de qué trata tu web.\n\nEl mínimo recomendado es 300 palabras para tu homepage. Las páginas que rankean en top 10 tienen de media 1.400+ palabras.\n\nAñade secciones con tus servicios, beneficios, casos de uso o FAQ.` });
if ((crawl.internalLinks as number) < 5) onPageIssues.push({ severity: 'warning', label: `${crawl.internalLinks} enlaces internos`, detail: 'Pocos enlaces dificultan el crawling', expanded: `Solo ${crawl.internalLinks} enlaces internos detectados. Los enlaces internos ayudan a Google a descubrir tus páginas y distribuyen la autoridad del dominio.\n\nRecomendación: al menos 5-10 enlaces internos en tu homepage apuntando a tus páginas más importantes (servicios, productos, contacto, blog).` });

const criticals = onPageIssues.filter(i => i.severity === 'critical');
const warnings = onPageIssues.filter(i => i.severity === 'warning');
const goods = onPageIssues.filter(i => i.severity === 'good');

const sevIcon: Record<string, { icon: string; color: string; bg: string }> = {
  critical: { icon: 'error', color: '#E24B4A', bg: '#FCEBEB' },
  warning: { icon: 'warning', color: '#BA7517', bg: '#FAEEDA' },
  good: { icon: 'check_circle', color: '#1D9E75', bg: '#E1F5EE' },
};

// Qualitative assessment
const seoScore = scoreBreakdown.seo ?? 0;
let assessment = '';
if (seoSkipped) {
  assessment = `${client.name} aún no tiene presencia medible en buscadores — no se detectan keywords posicionadas ni tráfico orgánico. ${criticals.length > 0 ? `Hay ${criticals.length} problema${criticals.length > 1 ? 's' : ''} crítico${criticals.length > 1 ? 's' : ''} de SEO on-page que resolver primero.` : ''} ${(crawl.wordCount as number) > 500 ? `La buena noticia: tu web tiene ${crawl.wordCount} palabras de contenido, ${ssl.valid ? 'SSL activo' : ''} y ${crawl.hasSitemap ? 'sitemap' : ''} — hay base para trabajar.` : ''}`;
} else if (seoScore < 30) {
  assessment = `Visibilidad SEO crítica (${seoScore}/100). Con ${seo.keywordsTop10 || 0} keywords en top 10 y ~${seo.organicTrafficEstimate || 0} visitas orgánicas, la web está prácticamente invisible en Google.`;
} else if (seoScore < 60) {
  assessment = `SEO en desarrollo (${seoScore}/100). ${seo.keywordsTop10 || 0} keywords en top 10. Hay base pero la brecha con competidores es grande.`;
} else {
  assessment = `SEO competitivo (${seoScore}/100). ${seo.keywordsTop10 || 0} keywords en top 10 con ~${(seo.organicTrafficEstimate || 0).toLocaleString()} visitas.`;
}
---

<DashboardLayout title="SEO" currentPath="/dashboard/pillar/seo" tier={tier} clientName={client.name} domain={client.domain} lastReportMonth={snapshot.month} lastReportDate={snapshot.date}>

<div style="display:flex;flex-direction:column;gap:24px;">

  <!-- Header -->
  <div style="display:flex;align-items:center;gap:16px;">
    <a href="/dashboard" style="display:flex;align-items:center;color:#64748b;text-decoration:none;font-size:13px;font-weight:600;">
      <span class="material-symbols-outlined" style="font-size:18px;margin-right:4px;">arrow_back</span>
      Resumen
    </a>
  </div>

