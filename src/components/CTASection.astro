---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="diagnostico" class="relative overflow-hidden">
  <div class="cta-bg absolute inset-0"></div>
  <div class="cta-dots absolute inset-0"></div>
  
  <!-- Animated gradient orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 -left-32 w-96 h-96 bg-aion-cyan/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 -right-32 w-96 h-96 bg-aion-emerald/10 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-8 py-24 md:py-36">
    <div class="max-w-4xl mx-auto text-center fade-in">
      
      <!-- Label -->
      <p class="text-sm font-medium text-aion-cyan mb-6 tracking-wide uppercase flex items-center justify-center gap-2">
        <span class="flex h-2 w-2 relative">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-aion-emerald opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-aion-emerald"></span>
        </span>
        {lang === 'es' ? 'Comenzar ahora' : 'Get started'}
      </p>
      
      <h2 class="headline-xl text-white mb-8">
        <span class="block">{t('cta.title.1')}</span>
        <span class="block gradient-text">{t('cta.title.2')}</span>
      </h2>

      <p class="text-lg md:text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto mb-4">
        {t('cta.text')}
      </p>

      <p class="text-base text-slate-400 mb-12">
        {t('cta.text.2')}
      </p>

      <div id="contacto">
        <a
          href={lang === 'es' ? '/es/diagnostico' : '/en/diagnostic'}
          class="cta-premium inline-flex items-center gap-3 text-base md:text-lg"
        >
          <span>{t('cta.button')}</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <p class="mt-6 text-sm text-slate-500">{t('cta.button.note')}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-bg {
    background: linear-gradient(160deg, #0B1B3D 0%, #1A5490 50%, #0B1B3D 100%);
  }

  .cta-dots {
    background-image: radial-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
  }
</style>
