---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const headlineWords = t('about.headline').split(' ');
---

<section class="py-24 md:py-32 bg-white w-full">
  <div class="w-full px-6 md:px-8 lg:px-16">

    <p class="text-sm font-medium text-aion-primary mb-8 md:mb-12 tracking-wide fade-in flex items-center gap-2.5 uppercase">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
      </svg>
      {t('about.label')}
    </p>

    <!-- Right-aligned text with per-word hover effect -->
    <div class="max-w-5xl ml-auto text-right mb-12 md:mb-16 fade-in">
      <h2 class="headline-xl text-aion-dark about-headline">
        {headlineWords.map((word: string, index: number) => (
          <span class="inline-block hover-word mr-[0.25em]" style={`--delay: ${index * 0.05}s`}>
            {word}
          </span>
        ))}
      </h2>
    </div>

    <!-- CTA link -->
    <div class="text-right max-w-5xl ml-auto mb-16 md:mb-20 fade-in">
      <a href="#proceso" class="group inline-flex items-center gap-3 text-aion-dark font-semibold text-lg hover:text-aion-primary transition-colors">
        {t('about.cta')}
        <span class="flex items-center justify-center w-10 h-10 rounded-full bg-aion-dark group-hover:bg-aion-primary transition-colors">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </a>
    </div>

    <!-- Stats cards - without fake metrics -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger-children">
      <!-- Implementation time -->
      <div class="stagger-item p-8 rounded-3xl bg-gradient-to-br from-slate-50 to-white border border-slate-200 card-hover" style="--i: 0">
        <div class="w-12 h-12 rounded-xl bg-aion-dark flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <p class="text-4xl font-display font-bold text-aion-dark mb-2 tracking-tight">{t('about.stat.1.value')}</p>
        <p class="text-slate-600 text-base">{t('about.stat.1.label')}</p>
      </div>

      <!-- Pillars -->
      <div class="stagger-item p-8 rounded-3xl bg-gradient-to-br from-slate-50 to-white border border-slate-200 card-hover" style="--i: 1">
        <div class="w-12 h-12 rounded-xl bg-aion-primary flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
        </div>
        <p class="text-4xl font-display font-bold text-aion-dark mb-2 tracking-tight">{t('about.stat.2.value')}</p>
        <p class="text-slate-600 text-base">{t('about.stat.2.label')}</p>
      </div>

      <!-- Location -->
      <div class="stagger-item p-8 rounded-3xl bg-gradient-to-br from-slate-50 to-white border border-slate-200 card-hover" style="--i: 2">
        <div class="w-12 h-12 rounded-xl bg-aion-blue flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <p class="text-4xl font-display font-bold text-aion-dark mb-2 tracking-tight">{t('about.stat.3.value')}</p>
        <p class="text-slate-600 text-base">{t('about.stat.3.label')}</p>
      </div>
    </div>

  </div>
</section>

<style>
  .hover-word {
    color: rgb(11 27 61);
    transition: color 0.3s ease, transform 0.3s ease;
    cursor: default;
  }

  .hover-word:hover {
    color: #1A5490;
    transform: translateY(-2px);
  }
</style>
