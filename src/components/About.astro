---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const headlineWords = t('about.headline').split(' ');
---

<section class="py-24 md:py-32 bg-surface-container-lowest w-full">
  <div class="w-full px-6 md:px-8 lg:px-16">

    <p class="section-label mb-8 md:mb-12 fade-in">
      <svg class="w-4 h-4 text-aion-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
      </svg>
      {t('about.label')}
    </p>

    <!-- Right-aligned text with per-word hover effect -->
    <div class="max-w-5xl ml-auto text-right mb-12 md:mb-16 fade-in">
      <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-tight tracking-editorial about-headline">
        {headlineWords.map((word: string) => (
          <span class="inline-block hover-word mr-[0.25em]">
            {word}
          </span>
        ))}
      </h2>
    </div>

    <!-- CTA link -->
    <div class="text-right max-w-5xl ml-auto mb-16 md:mb-20 fade-in">
      <a href="#contacto" class="inline-flex items-center gap-2 text-on-surface font-semibold text-lg hover:text-aion-teal transition-colors">
        {t('about.cta')}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Stats cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 fade-in">
      <!-- Rating card -->
      <div class="p-8 rounded-lg bg-surface-container-low">
        <div class="flex items-center gap-1 mb-3">
          {[1,2,3,4,5].map(() => (
            <svg class="w-6 h-6 text-tertiary-fixed-dim" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-on-surface/70 text-sm">{t('about.rating')}</p>
      </div>

      <!-- Revenue card -->
      <div class="p-8 rounded-lg bg-surface-container-low">
        <p class="text-4xl font-bold text-on-surface mb-2">{t('about.stat.1.value')}</p>
        <p class="text-on-surface/70 text-sm">{t('about.stat.1.label')}</p>
      </div>

      <!-- Deployment card -->
      <div class="p-8 rounded-lg bg-surface-container-low">
        <p class="text-4xl font-bold text-on-surface mb-2">{t('about.stat.2.value')}</p>
        <p class="text-on-surface/70 text-sm">{t('about.stat.2.label')}</p>
      </div>
    </div>

  </div>
</section>

<style>
  .hover-word {
    color: rgb(0 29 50);
    transition: color 0.3s ease;
    cursor: default;
  }

  .hover-word:hover {
    color: #00a5b5;
  }
</style>
