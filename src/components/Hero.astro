---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const basePath = `/${lang}`;
---

<section class="relative min-h-screen w-full overflow-hidden hero-section">
  <!-- Background with gradient overlay -->
  <div class="absolute inset-0 z-0 hero-bg"></div>
  <!-- Dot pattern overlay -->
  <div class="absolute inset-0 z-[1] hero-dots"></div>

  <!-- Navigation -->
  <nav class="relative z-50 flex items-start justify-between px-6 md:px-8 lg:px-16 py-5 md:py-6">
    <!-- Logo -->
    <a href={`${basePath}/`} class="flex flex-col items-start">
      <img
        src="/logo-aion-new.png"
        alt="AION Growth Studio"
        class="w-[280px] md:w-[360px] h-auto drop-shadow-lg"
        loading="eager"
      />
    </a>

    <!-- Desktop nav pills -->
    <div class="hidden lg:flex items-center gap-2 mt-2">
      <a href={`${basePath}/#soluciones`} class="nav-pill">{t('nav.soluciones')}</a>
      <a href={`${basePath}/#casos`} class="nav-pill">{t('nav.casos')}</a>
      <a href={lang === 'es' ? '/es/diagnostico' : '/en/diagnostic'} class="nav-pill">{t('nav.diagnostico')}</a>
      <a href={`/${lang === 'es' ? '' : 'en/'}blog`} class="nav-pill">{t('nav.blog')}</a>
      <a href={`${basePath}/#contacto`} class="nav-pill">{t('nav.contacto')}</a>

      <div class="flex items-center gap-1 ml-3 px-4 py-2.5 rounded-full bg-white/10 backdrop-blur-md">
        <a href="/es/" class={`text-sm font-medium transition-colors ${lang === 'es' ? 'text-white' : 'text-white/60 hover:text-white'}`}>ES</a>
        <span class="text-white/40 text-sm">|</span>
        <a href="/en/" class={`text-sm font-medium transition-colors ${lang === 'en' ? 'text-white' : 'text-white/60 hover:text-white'}`}>EN</a>
      </div>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="lg:hidden p-2 -mr-2" aria-label="Menu" aria-expanded="false">
      <svg id="menu-open" class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-close" class="w-7 h-7 text-white hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="lg:hidden hidden absolute top-[100px] left-0 right-0 z-50 bg-primary/90 backdrop-blur-lg">
    <div class="px-6 py-6 flex flex-col gap-2">
      <a href={`${basePath}/#soluciones`} class="mobile-pill">{t('nav.soluciones')}</a>
      <a href={`${basePath}/#casos`} class="mobile-pill">{t('nav.casos')}</a>
      <a href={lang === 'es' ? '/es/diagnostico' : '/en/diagnostic'} class="mobile-pill">{t('nav.diagnostico')}</a>
      <a href={`/${lang === 'es' ? '' : 'en/'}blog`} class="mobile-pill">{t('nav.blog')}</a>
      <a href={`${basePath}/#contacto`} class="mobile-pill">{t('nav.contacto')}</a>
      <div class="flex items-center gap-3 mt-4 pt-4 border-t border-white/10">
        <a href="/es/" class={`text-sm font-medium ${lang === 'es' ? 'text-white' : 'text-white/60'}`}>ES</a>
        <span class="text-white/30">|</span>
        <a href="/en/" class={`text-sm font-medium ${lang === 'en' ? 'text-white' : 'text-white/60'}`}>EN</a>
      </div>
    </div>
  </div>

  <!-- Hero Content -->
  <div class="relative z-10 px-6 md:px-8 lg:px-36 pt-[18vh] md:pt-[calc(22vh-16px)]">
    <!-- Text LEFT -->
    <div class="max-w-[700px]">
      <a
        href={lang === 'es' ? '/es/diagnostico' : '/en/diagnostic'}
        class="inline-block px-8 py-4 bg-white text-primary rounded-md font-semibold text-base hover:bg-tertiary-fixed hover:text-on-surface hover:scale-105 transition-all duration-300 shadow-ambient mb-6"
      >
        {t('hero.cta')}
      </a>

      <h1 class="hero-headline text-white">
        {t('hero.title.1')}<br />
        {t('hero.title.2')}
      </h1>

      <p class="hero-subheadline text-white/70 max-w-[600px] font-semibold">
        {t('hero.subtitle')}
      </p>
    </div>

    <!-- Card RIGHT -->
    <div class="hidden lg:block absolute right-16 bottom-0 w-[280px] bg-surface-container-lowest/95 backdrop-blur-sm rounded-lg p-6 shadow-ambient-lg">
      <img
        src="/projects-placeholder.jpg"
        alt="Projects"
        class="w-full h-[200px] object-cover rounded-md mb-4"
      />
      <h3 class="text-2xl font-bold text-on-surface mb-2">
        {t('hero.card.label')}
      </h3>
      <p class="text-aion-teal text-sm font-medium mb-1">{t('hero.card.project')}</p>
      <p class="text-on-surface/70 text-sm leading-relaxed whitespace-pre-line">
        {t('hero.card.title')}
      </p>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
  }

  .hero-bg {
    background: linear-gradient(135deg, #000e41 0%, #0066cc 40%, #00a5b5 70%, #4cd964 100%);
  }

  .hero-dots {
    background-image: radial-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  .hero-headline {
    font-size: 2.25rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.3em;
    text-shadow: 0 2px 8px rgba(0, 14, 65, 0.4);
    letter-spacing: -0.02em;
  }

  .hero-subheadline {
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .nav-pill {
    padding: 0.625rem 1.5rem;
    border-radius: 0.375rem;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    color: white;
    font-size: 0.875rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .nav-pill:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .mobile-pill {
    display: block;
    padding: 0.75rem 1.25rem;
    border-radius: 0.375rem;
    color: rgba(255, 255, 255, 0.8);
    font-size: 1rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .mobile-pill:hover {
    background: rgba(255, 255, 255, 0.1);
    color: white;
  }

  @media (min-width: 768px) {
    .hero-headline {
      font-size: 3.5rem;
    }
    .hero-subheadline {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpen = document.getElementById('menu-open');
  const menuClose = document.getElementById('menu-close');

  if (menuBtn && mobileMenu && menuOpen && menuClose) {
    menuBtn.addEventListener('click', () => {
      const isOpen = !mobileMenu.classList.contains('hidden');
      mobileMenu.classList.toggle('hidden');
      menuOpen.classList.toggle('hidden');
      menuClose.classList.toggle('hidden');
      menuBtn.setAttribute('aria-expanded', String(!isOpen));
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
        menuOpen.classList.remove('hidden');
        menuClose.classList.add('hidden');
        menuBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }
</script>
