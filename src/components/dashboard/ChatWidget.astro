---
// Floating chat widget available from any dashboard page.
//
// Uses the existing /api/advisor/chat endpoint — which since commit 3/4
// inherits the same persona from AION_SYSTEM_PROMPT and, via
// buildAdvisorContext, now reads the same growth_analysis that the
// dashboard pages show. So when the client chats, the advisor is the
// same voice and sees exactly what the client has already read.
---

<button
  id="chat-fab"
  title="Habla con tu Advisor"
  style="position:fixed;bottom:32px;right:32px;width:56px;height:56px;background:#000e41;color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(0,0,0,0.3);border:none;cursor:pointer;z-index:100;transition:transform 0.2s,box-shadow 0.2s;"
  onmouseover="this.style.transform='scale(1.1)';this.style.boxShadow='0 12px 32px rgba(0,0,0,0.4)';"
  onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.3)';">
  <span class="material-symbols-outlined" style="font-size:24px;">forum</span>
</button>

<aside id="chat-panel" style="position:fixed;top:0;right:-440px;width:420px;max-width:100vw;height:100vh;background:white;box-shadow:-8px 0 32px rgba(0,0,0,0.15);z-index:101;display:flex;flex-direction:column;transition:right 0.3s ease;">
  <!-- Header -->
  <header style="padding:20px 24px;border-bottom:1px solid #f0f0f0;display:flex;align-items:center;justify-content:space-between;gap:12px;flex-shrink:0;">
    <div style="display:flex;align-items:center;gap:12px;min-width:0;">
      <div style="width:40px;height:40px;border-radius:12px;background:#000e41;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span class="material-symbols-outlined" style="font-size:22px;color:#69ff87;">auto_awesome</span>
      </div>
      <div style="min-width:0;">
        <h3 style="font-size:15px;font-weight:800;color:#1a1a2e;margin:0;">Tu advisor</h3>
        <p style="font-size:11px;color:#64748b;margin:0;">Conoce todo tu dashboard. Pregúntale lo que quieras.</p>
      </div>
    </div>
    <button id="chat-close" style="background:#f0f0f0;border:none;border-radius:8px;width:32px;height:32px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <span class="material-symbols-outlined" style="font-size:18px;color:#64748b;">close</span>
    </button>
  </header>

  <!-- Messages -->
  <div id="chat-messages" style="flex:1;overflow-y:auto;padding:20px 24px;display:flex;flex-direction:column;gap:14px;">
    <div class="chat-welcome" style="padding:16px;background:#f7f9ff;border-radius:12px;border-left:3px solid #000e41;">
      <p style="font-size:13px;color:#434750;line-height:1.6;margin:0;">
        Hola. Soy tu advisor de growth. Ya he leído tu análisis completo — puedes preguntarme por cualquier parte del dashboard: el score, las acciones del plan, por qué una recomendación está en el top, o qué pasaría si pruebas algo distinto.
      </p>
      <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:6px;">
        <button class="chat-suggest" data-q="¿Por qué tengo ese score global?" style="font-size:11px;padding:5px 10px;background:white;border:1px solid #e2e8f0;border-radius:999px;cursor:pointer;color:#434750;">¿Por qué tengo ese score?</button>
        <button class="chat-suggest" data-q="¿Cuál es la acción de mayor impacto?" style="font-size:11px;padding:5px 10px;background:white;border:1px solid #e2e8f0;border-radius:999px;cursor:pointer;color:#434750;">¿Cuál es la acción nº1?</button>
        <button class="chat-suggest" data-q="¿Qué pasaría si ejecuto las 3 primeras acciones del plan?" style="font-size:11px;padding:5px 10px;background:white;border:1px solid #e2e8f0;border-radius:999px;cursor:pointer;color:#434750;">Si hago las 3 primeras...</button>
      </div>
    </div>
  </div>

  <!-- Input -->
  <form id="chat-form" style="padding:16px 24px 20px;border-top:1px solid #f0f0f0;flex-shrink:0;">
    <div style="display:flex;gap:8px;align-items:flex-end;">
      <textarea id="chat-input" rows="1" placeholder="Escribe tu pregunta…"
        style="flex:1;padding:10px 14px;border:1px solid #e2e8f0;border-radius:10px;font-size:13px;font-family:inherit;resize:none;max-height:120px;line-height:1.5;"></textarea>
      <button type="submit" id="chat-send"
        style="background:#000e41;color:white;border:none;border-radius:10px;width:42px;height:42px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <span class="material-symbols-outlined" style="font-size:20px;">send</span>
      </button>
    </div>
    <p id="chat-status" style="font-size:10px;color:#94a3b8;margin:6px 2px 0;">Enter envía · Shift+Enter nueva línea</p>
  </form>
</aside>

<script is:inline>
  (function() {
    const fab = document.getElementById('chat-fab');
    const panel = document.getElementById('chat-panel');
    const closeBtn = document.getElementById('chat-close');
    const form = document.getElementById('chat-form');
    const input = document.getElementById('chat-input');
    const sendBtn = document.getElementById('chat-send');
    const messagesEl = document.getElementById('chat-messages');
    const statusEl = document.getElementById('chat-status');
    if (!fab || !panel || !form || !input || !messagesEl) return;

    let currentThreadId = null;
    let isStreaming = false;

    function openPanel() { panel.style.right = '0'; setTimeout(function() { input.focus(); }, 300); }
    function closePanel() { panel.style.right = '-440px'; }
    fab.addEventListener('click', openPanel);
    closeBtn.addEventListener('click', closePanel);

    // Suggest chips fill input and submit
    document.querySelectorAll('.chat-suggest').forEach(function(btn) {
      btn.addEventListener('click', function() {
        input.value = btn.getAttribute('data-q') || '';
        form.requestSubmit();
      });
    });

    // Auto-grow textarea
    input.addEventListener('input', function() {
      input.style.height = 'auto';
      input.style.height = Math.min(120, input.scrollHeight) + 'px';
    });
    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });

    function appendMessage(role, text) {
      // Hide welcome on first real message
      const welcome = messagesEl.querySelector('.chat-welcome');
      if (welcome) welcome.remove();

      const wrap = document.createElement('div');
      wrap.className = 'msg-wrap-' + role;
      wrap.style.cssText = 'display:flex;flex-direction:column;gap:10px;' + (role === 'user' ? 'align-items:flex-end;' : 'align-items:flex-start;');
      const bubble = document.createElement('div');
      bubble.className = 'msg-' + role;
      bubble.style.cssText = role === 'user'
        ? 'max-width:85%;background:#000e41;color:white;padding:10px 14px;border-radius:14px 14px 2px 14px;font-size:13px;line-height:1.5;white-space:pre-wrap;'
        : 'max-width:85%;background:#f7f9ff;color:#1a1a2e;padding:12px 16px;border-radius:14px 14px 14px 2px;font-size:13px;line-height:1.6;white-space:pre-wrap;border:1px solid #e2e8f0;';
      const textEl = document.createElement('span');
      textEl.className = 'msg-text';
      textEl.textContent = text;
      bubble.appendChild(textEl);
      wrap.appendChild(bubble);
      messagesEl.appendChild(wrap);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return { bubble, wrap };
    }

    // Render advisor action cards (Option A: compact) below the message bubble.
    // Each card has title + impact badge + description + "Añadir al plan" / "Descartar" buttons.
    // Both buttons call POST /api/dashboard/update-action with recommendationId + status.
    function renderActionCards(wrap, actions) {
      if (!actions || !actions.length) return;
      const container = document.createElement('div');
      container.className = 'advisor-actions';
      container.style.cssText = 'max-width:100%;display:flex;flex-direction:column;gap:8px;margin-top:2px;';

      const header = document.createElement('p');
      header.style.cssText = 'font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;color:#4338CA;margin:0 0 2px 2px;display:flex;align-items:center;gap:4px;';
      header.innerHTML = '<span class="material-symbols-outlined" style="font-size:13px;">auto_awesome</span>' + actions.length + ' ' + (actions.length === 1 ? 'acción recomendada' : 'acciones recomendadas');
      container.appendChild(header);

      for (const a of actions) {
        const card = document.createElement('div');
        card.className = 'advisor-action-card';
        card.dataset.recommendationId = a.id;
        card.style.cssText = 'background:white;border:1px solid #e2e8f0;border-left:3px solid #4338CA;border-radius:10px;padding:12px 14px;display:flex;flex-direction:column;gap:8px;transition:opacity 0.3s,transform 0.3s,max-height 0.3s;';

        const impactColors = {
          high: { bg: '#FCEBEB', fg: '#E24B4A', label: 'Alto impacto' },
          medium: { bg: '#FAEEDA', fg: '#BA7517', label: 'Impacto medio' },
          low: { bg: '#E0EDFF', fg: '#1A4B8C', label: 'Impacto bajo' },
        };
        const impact = impactColors[a.impact] || impactColors.medium;

        const headRow = document.createElement('div');
        headRow.style.cssText = 'display:flex;align-items:flex-start;justify-content:space-between;gap:8px;';
        const titleEl = document.createElement('p');
        titleEl.style.cssText = 'font-size:13px;font-weight:800;color:#1a1a2e;line-height:1.35;margin:0;flex:1;';
        titleEl.textContent = a.title;
        const badge = document.createElement('span');
        badge.style.cssText = 'font-size:9px;font-weight:800;padding:3px 8px;border-radius:999px;white-space:nowrap;flex-shrink:0;background:' + impact.bg + ';color:' + impact.fg + ';';
        badge.textContent = impact.label;
        headRow.appendChild(titleEl);
        headRow.appendChild(badge);
        card.appendChild(headRow);

        if (a.description) {
          const descEl = document.createElement('p');
          descEl.style.cssText = 'font-size:11px;color:#64748b;line-height:1.45;margin:0;';
          const truncated = a.description.length > 180 ? a.description.slice(0, 180) + '…' : a.description;
          descEl.textContent = truncated;
          card.appendChild(descEl);
        }

        const btnRow = document.createElement('div');
        btnRow.style.cssText = 'display:flex;gap:6px;margin-top:2px;';

        const acceptBtn = document.createElement('button');
        acceptBtn.type = 'button';
        acceptBtn.style.cssText = 'flex:1;background:#1A4B8C;color:white;border:none;border-radius:8px;padding:7px 12px;font-size:11px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:4px;';
        acceptBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px;">add_task</span>Añadir al plan';

        const rejectBtn = document.createElement('button');
        rejectBtn.type = 'button';
        rejectBtn.style.cssText = 'background:white;color:#64748b;border:1px solid #e2e8f0;border-radius:8px;padding:7px 12px;font-size:11px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:4px;';
        rejectBtn.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px;">close</span>Descartar';

        async function decide(status) {
          acceptBtn.disabled = true;
          rejectBtn.disabled = true;
          try {
            const res = await fetch('/api/dashboard/update-action', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ recommendationId: a.id, status: status }),
            });
            if (!res.ok) throw new Error('update failed ' + res.status);
            // Success: show confirmation + fade out
            card.style.borderLeftColor = status === 'accepted' ? '#1D9E75' : '#94a3b8';
            const confirm = document.createElement('p');
            confirm.style.cssText = 'font-size:11px;font-weight:700;color:' + (status === 'accepted' ? '#1D9E75' : '#94a3b8') + ';margin:0;display:flex;align-items:center;gap:4px;';
            confirm.innerHTML = '<span class="material-symbols-outlined" style="font-size:14px;">' + (status === 'accepted' ? 'check_circle' : 'do_not_disturb_on') + '</span>' + (status === 'accepted' ? 'Añadido a tu plan de acción' : 'Descartado');
            btnRow.replaceWith(confirm);
          } catch (err) {
            acceptBtn.disabled = false;
            rejectBtn.disabled = false;
            const errEl = document.createElement('p');
            errEl.style.cssText = 'font-size:10px;color:#E24B4A;margin:2px 0 0;';
            errEl.textContent = 'Error — vuelve a intentarlo';
            card.appendChild(errEl);
          }
        }

        acceptBtn.addEventListener('click', function() { decide('accepted'); });
        rejectBtn.addEventListener('click', function() { decide('rejected'); });

        btnRow.appendChild(acceptBtn);
        btnRow.appendChild(rejectBtn);
        card.appendChild(btnRow);
        container.appendChild(card);
      }

      wrap.appendChild(container);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      const msg = input.value.trim();
      if (!msg || isStreaming) return;

      isStreaming = true;
      input.value = '';
      input.style.height = 'auto';
      sendBtn.disabled = true;
      statusEl.textContent = 'Pensando…';

      appendMessage('user', msg);
      const advisor = appendMessage('advisor', '');
      const advisorBubble = advisor.bubble;
      const advisorWrap = advisor.wrap;
      const textEl = advisorBubble.querySelector('.msg-text');
      textEl.innerHTML = '<span style="color:#94a3b8;">Pensando…</span>';

      try {
        const res = await fetch('/api/advisor/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg, threadId: currentThreadId }),
        });

        if (res.status === 429) {
          const data = await res.json();
          textEl.innerHTML = '<span style="color:#BA7517;">' + (data.message || 'Has alcanzado el límite de mensajes por hoy.') + '</span>';
          isStreaming = false;
          sendBtn.disabled = false;
          statusEl.textContent = 'Enter envía · Shift+Enter nueva línea';
          return;
        }

        if (!res.ok) throw new Error('Chat failed: ' + res.status);

        // Stream SSE — same protocol as /advisor
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';
        let fullText = '';
        textEl.textContent = '';

        // Hide the ```actions / ```learnings fenced blocks from the visible
        // text — they're structured data for the action cards, not for
        // the user. Everything after the first fence marker gets trimmed.
        function visibleText(raw) {
          const markers = ['```actions', '```learnings', '``actions', '``learnings'];
          let cut = raw.length;
          for (const m of markers) {
            const idx = raw.indexOf(m);
            if (idx >= 0 && idx < cut) cut = idx;
          }
          return raw.slice(0, cut).replace(/\s+$/, '');
        }

        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() || '';
          for (const line of lines) {
            if (!line.startsWith('data: ')) continue;
            try {
              const data = JSON.parse(line.slice(6));
              if (data.text) {
                fullText += data.text;
                textEl.textContent = visibleText(fullText);
                messagesEl.scrollTop = messagesEl.scrollHeight;
              }
              if (data.done && data.threadId) {
                currentThreadId = data.threadId;
                // Final safety: force the visible text to the clean version
                textEl.textContent = visibleText(fullText);
                if (Array.isArray(data.actions) && data.actions.length > 0) {
                  renderActionCards(advisorWrap, data.actions);
                }
              }
            } catch (_) {}
          }
        }
      } catch (err) {
        textEl.innerHTML = '<span style="color:#E24B4A;">Error al comunicar con el advisor. Intenta de nuevo.</span>';
      }

      isStreaming = false;
      sendBtn.disabled = false;
      statusEl.textContent = 'Enter envía · Shift+Enter nueva línea';
      messagesEl.scrollTop = messagesEl.scrollHeight;
    });
  })();
</script>

<style>
  @media (max-width: 640px) {
    #chat-panel {
      width: 100vw !important;
      right: -100vw !important;
    }
  }
  #chat-messages::-webkit-scrollbar { width: 6px; }
  #chat-messages::-webkit-scrollbar-track { background: transparent; }
  #chat-messages::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 3px; }
</style>
