---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="casos" class="py-24 md:py-32 bg-gradient-to-b from-slate-50 to-white">
  <div class="w-full px-6 md:px-8 lg:px-16">

    <p class="text-sm font-medium text-aion-cyan mb-6 tracking-wide fade-in flex items-center gap-2.5 uppercase">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
      </svg>
      {t('work.label')}
    </p>

    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12 md:mb-16">
      <div>
        <h2 class="headline-lg text-aion-dark mb-4 fade-in">
          {t('work.title')}
        </h2>
        <p class="text-lg md:text-xl text-slate-600 fade-in max-w-2xl">{t('work.subtitle')}</p>
      </div>
      
      <a href="#contacto" class="group inline-flex items-center gap-3 text-aion-dark font-semibold hover:text-aion-cyan transition-colors fade-in whitespace-nowrap">
        {t('work.cta')}
        <span class="flex items-center justify-center w-10 h-10 rounded-full bg-aion-dark group-hover:bg-aion-cyan transition-colors">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 stagger-children">

      <!-- Case 1: SEO/GEO Editorial Engine -->
      <div class="stagger-item group" style="--i: 0">
        <div class="relative rounded-3xl overflow-hidden mb-6 aspect-[3/4] work-card-1 card-hover">
          <div class="absolute inset-0 work-card-pattern"></div>
          
          <!-- Tag -->
          <div class="absolute top-5 left-5 z-10">
            <span class="px-4 py-2 rounded-full glass text-white text-sm font-medium">
              {t('work.1.tag')}
            </span>
          </div>

          <!-- Mock: Search Results UI -->
          <div class="absolute inset-0 flex items-center justify-center p-6 pt-16">
            <div class="w-full max-w-[240px] space-y-3">
              <!-- Search bar -->
              <div class="glass rounded-xl px-3 py-2.5 flex items-center gap-2">
                <svg class="w-4 h-4 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <div class="h-2 bg-white/20 rounded flex-1"></div>
              </div>
              <!-- Result 1 - Highlighted -->
              <div class="glass border-2 border-aion-cyan/50 rounded-xl p-3.5 relative group-hover:scale-[1.02] transition-transform duration-300">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-[10px] font-bold text-aion-cyan bg-aion-cyan/20 px-2 py-0.5 rounded">#1</span>
                  <div class="h-1.5 bg-white/30 rounded flex-1"></div>
                </div>
                <div class="h-1.5 bg-white/15 rounded w-full mb-1.5"></div>
                <div class="h-1.5 bg-white/10 rounded w-3/4"></div>
              </div>
              <!-- Result 2 -->
              <div class="bg-white/5 border border-white/10 rounded-xl p-3">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-[10px] text-white/40 font-medium">#2</span>
                  <div class="h-1.5 bg-white/15 rounded flex-1"></div>
                </div>
                <div class="h-1.5 bg-white/10 rounded w-full mb-1.5"></div>
                <div class="h-1.5 bg-white/7 rounded w-2/3"></div>
              </div>
            </div>
          </div>

          <!-- Floating SEO Badge -->
          <div class="absolute top-5 right-5 z-10">
            <div class="glass rounded-2xl px-4 py-3 text-center">
              <div class="text-[10px] text-white/60 uppercase tracking-wider mb-1">SEO</div>
              <svg class="w-6 h-6 text-aion-cyan mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
          </div>
        </div>
        <h3 class="headline-md text-aion-dark mb-3 group-hover:text-aion-cyan transition-colors">
          {t('work.1.title')}
        </h3>
        <p class="text-slate-600 leading-relaxed">{t('work.1.desc')}</p>
      </div>

      <!-- Case 2: Lead Generation -->
      <div class="stagger-item group" style="--i: 1">
        <div class="relative rounded-3xl overflow-hidden mb-6 aspect-[3/4] work-card-2 card-hover">
          <div class="absolute inset-0 work-card-pattern"></div>
          
          <!-- Tag -->
          <div class="absolute top-5 left-5 z-10">
            <span class="px-4 py-2 rounded-full glass text-white text-sm font-medium">
              {t('work.2.tag')}
            </span>
          </div>

          <!-- Mock: CRM Pipeline UI -->
          <div class="absolute inset-0 flex items-center justify-center p-6 pt-16">
            <div class="w-full max-w-[240px] space-y-3">
              <!-- Avatars -->
              <div class="flex items-center justify-between mb-2">
                <div class="flex -space-x-2">
                  <div class="w-8 h-8 rounded-full bg-blue-400/40 border-2 border-white/20"></div>
                  <div class="w-8 h-8 rounded-full bg-cyan-400/40 border-2 border-white/20"></div>
                  <div class="w-8 h-8 rounded-full bg-indigo-400/40 border-2 border-white/20"></div>
                  <div class="w-8 h-8 rounded-full bg-white/15 border-2 border-white/20 flex items-center justify-center">
                    <span class="text-[9px] text-white/70 font-medium">+</span>
                  </div>
                </div>
                <span class="text-xs text-white/60 font-medium">{lang === 'es' ? 'Nuevos leads' : 'New leads'}</span>
              </div>
              <!-- Contact Cards -->
              <div class="glass rounded-xl p-3.5 flex items-center gap-3 group-hover:scale-[1.02] transition-transform duration-300">
                <div class="w-9 h-9 rounded-full bg-aion-emerald/30 flex-shrink-0 flex items-center justify-center">
                  <svg class="w-4 h-4 text-aion-emerald" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="h-2 bg-white/25 rounded w-3/4 mb-1.5"></div>
                  <div class="h-1.5 bg-white/10 rounded w-1/2"></div>
                </div>
                <span class="text-[9px] font-semibold text-aion-emerald bg-aion-emerald/20 px-2 py-1 rounded-full flex-shrink-0">Qualified</span>
              </div>
              <div class="glass rounded-xl p-3.5 flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-amber-400/30 flex-shrink-0 flex items-center justify-center">
                  <svg class="w-4 h-4 text-amber-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="h-2 bg-white/25 rounded w-2/3 mb-1.5"></div>
                  <div class="h-1.5 bg-white/10 rounded w-2/5"></div>
                </div>
                <span class="text-[9px] font-semibold text-amber-300 bg-amber-400/20 px-2 py-1 rounded-full flex-shrink-0">Nurture</span>
              </div>
            </div>
          </div>

          <!-- Floating Leads Badge -->
          <div class="absolute top-5 right-5 z-10">
            <div class="glass rounded-2xl px-4 py-3 text-center">
              <div class="text-[10px] text-white/60 uppercase tracking-wider mb-1">Leads</div>
              <svg class="w-6 h-6 text-white mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
          </div>
        </div>
        <h3 class="headline-md text-aion-dark mb-3 group-hover:text-aion-cyan transition-colors">
          {t('work.2.title')}
        </h3>
        <p class="text-slate-600 leading-relaxed">{t('work.2.desc')}</p>
      </div>

      <!-- Case 3: AI Agents & Automation -->
      <div class="stagger-item group" style="--i: 2">
        <div class="relative rounded-3xl overflow-hidden mb-6 aspect-[3/4] work-card-3 card-hover">
          <div class="absolute inset-0 work-card-pattern"></div>
          
          <!-- Tags -->
          <div class="absolute top-5 left-5 z-10 flex gap-2 flex-wrap">
            <span class="px-3 py-1.5 rounded-full glass text-white text-xs font-medium">
              {t('work.3.tag.1')}
            </span>
            <span class="px-3 py-1.5 rounded-full glass text-white text-xs font-medium">
              {t('work.3.tag.2')}
            </span>
          </div>

          <!-- Mock: Agent Workflow UI -->
          <div class="absolute inset-0 flex items-center justify-center p-6 pt-16">
            <div class="w-full max-w-[240px] relative" style="height: 220px;">
              <!-- Trigger Node -->
              <div class="absolute top-0 left-1/2 -translate-x-1/2 glass rounded-xl px-4 py-2.5 flex items-center gap-2 group-hover:scale-[1.05] transition-transform duration-300">
                <div class="w-2 h-2 rounded-full bg-aion-cyan agent-pulse"></div>
                <span class="text-[11px] text-white/80 font-medium">Trigger</span>
              </div>
              <!-- Connector line down -->
              <div class="absolute top-[42px] left-1/2 w-px h-[28px] bg-white/20"></div>
              <!-- Process Node -->
              <div class="absolute top-[70px] left-1/2 -translate-x-1/2 glass border border-aion-cyan/30 rounded-xl px-4 py-2.5 flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-aion-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                <span class="text-[11px] text-white/80 font-medium">Process</span>
              </div>
              <!-- Connector split -->
              <div class="absolute top-[112px] left-1/2 w-px h-[20px] bg-white/20"></div>
              <div class="absolute top-[132px] left-[25%] right-[25%] h-px bg-white/20"></div>
              <div class="absolute top-[132px] left-[25%] w-px h-[20px] bg-white/20"></div>
              <div class="absolute top-[132px] right-[25%] w-px h-[20px] bg-white/20"></div>
              <!-- Branch 1 -->
              <div class="absolute top-[152px] left-0 glass rounded-xl px-4 py-2 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-aion-emerald"></div>
                <span class="text-[10px] text-white/70 font-medium">Email</span>
              </div>
              <!-- Branch 2 -->
              <div class="absolute top-[152px] right-0 glass rounded-xl px-4 py-2 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-aion-emerald"></div>
                <span class="text-[10px] text-white/70 font-medium">CRM</span>
              </div>
              <!-- Status badge -->
              <div class="absolute bottom-0 left-1/2 -translate-x-1/2 bg-aion-emerald/15 border border-aion-emerald/30 rounded-full px-4 py-1.5 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-aion-emerald agent-pulse"></div>
                <span class="text-[10px] text-aion-emerald font-semibold">Running</span>
              </div>
            </div>
          </div>

          <!-- Floating Agents Badge -->
          <div class="absolute top-5 right-5 z-10">
            <div class="glass rounded-2xl px-4 py-2.5 flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-aion-emerald agent-pulse"></div>
              <span class="text-xs text-white/80 font-medium">3 agents</span>
            </div>
          </div>
        </div>
        <h3 class="headline-md text-aion-dark mb-3 group-hover:text-aion-cyan transition-colors">
          {t('work.3.title')}
        </h3>
        <p class="text-slate-600 leading-relaxed">{t('work.3.desc')}</p>
      </div>

    </div>

  </div>
</section>

<style>
  .work-card-1 {
    background: linear-gradient(135deg, #0B1B3D 0%, #1A5490 50%, #0B1B3D 100%);
  }
  .work-card-2 {
    background: linear-gradient(135deg, #0066FF 0%, #00D4FF 100%);
  }
  .work-card-3 {
    background: linear-gradient(135deg, #1e293b 0%, #334155 50%, #0f172a 100%);
  }
  .work-card-pattern {
    background-image:
      radial-gradient(circle at 25% 35%, rgba(255,255,255,0.1) 0%, transparent 50%),
      radial-gradient(circle at 75% 65%, rgba(255,255,255,0.07) 0%, transparent 40%),
      radial-gradient(rgba(255,255,255,0.04) 1px, transparent 1px);
    background-size: 100% 100%, 100% 100%, 24px 24px;
  }

  @keyframes agentPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .agent-pulse {
    animation: agentPulse 2s ease-in-out infinite;
  }
</style>
