---
/**
 * GenerateArticleButton — renders the "Generar automáticamente" CTA.
 *
 * Place inside a recommendation/action card. On click it calls the access
 * check and either:
 *   - redirects to /editorial/new with pre-filled query params
 *   - opens an upsell modal (no editorial flag)
 *   - opens a "contact admin" modal (user is viewer)
 *   - opens a quota-exceeded modal
 *
 * The button self-registers a single modal per page via a data-attribute
 * on the <body>, so multiple instances share one modal.
 */

export interface Props {
  /** Contents of the recommendation's contentGeneration field. */
  contentGeneration: {
    type: 'article_blog' | 'linkedin_post' | 'linkedin_article' | 'newsletter';
    topic: string;
    primary_keyword?: string;
    secondary_keywords?: string[];
    funnel_stage?: 'TOFU' | 'MOFU' | 'BOFU';
    language?: 'es' | 'en';
    rationale: string;
    isRefresh?: boolean;
    refreshArticleId?: string;
  };
  /** recommendations.id or action_plan.id so we can track the loop. */
  sourceActionId?: string;
  /** Estimated expected sessions from article_performance history (if available). */
  performanceHint?: string;
}

const { contentGeneration, sourceActionId, performanceHint } = Astro.props;
const payload = encodeURIComponent(JSON.stringify({ contentGeneration, sourceActionId }));
---

<div style="margin-top:10px;">
  <button
    type="button"
    class="editorial-generate-btn"
    data-payload={payload}
    style="display:inline-flex;align-items:center;gap:6px;padding:8px 14px;background:linear-gradient(135deg,#000e41,#001f70);color:white;border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;transition:transform 0.15s;"
    onmouseover="this.style.transform='translateY(-1px)'"
    onmouseout="this.style.transform='none'"
  >
    <span class="material-symbols-outlined" style="font-size:14px;color:#69ff87;">auto_awesome</span>
    {contentGeneration.isRefresh ? 'Actualizar este artículo' : 'Generar automáticamente'}
  </button>
  {contentGeneration.isRefresh && (
    <span style="margin-left:8px;font-size:10px;color:#BA7517;font-weight:700;background:#fef3c7;padding:2px 8px;border-radius:4px;">Actualización recomendada</span>
  )}
  {performanceHint && (
    <p style="font-size:10px;color:#64748b;margin-top:4px;line-height:1.3;">{performanceHint}</p>
  )}
</div>

<script is:inline>
  // Register the modal + click handler once per page.
  (function () {
    if (document.body.dataset.editorialModalBound === '1') return;
    document.body.dataset.editorialModalBound = '1';

    // ── Modal markup (injected lazily) ───────────────────────────────────
    const modalHtml = `
      <div id="editorial-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(15,27,53,0.72);align-items:center;justify-content:center;padding:16px;">
        <div style="background:white;border-radius:16px;max-width:520px;width:100%;padding:32px;max-height:90vh;overflow-y:auto;">
          <div id="editorial-modal-body"></div>
          <div style="display:flex;justify-content:flex-end;gap:10px;margin-top:20px;">
            <button id="editorial-modal-close" type="button" style="padding:10px 18px;background:transparent;color:#64748b;border:1px solid #e2e8f0;border-radius:8px;font-weight:600;cursor:pointer;">Cerrar</button>
            <a id="editorial-modal-cta" href="#" style="display:none;padding:10px 20px;background:#1A4B8C;color:white;border-radius:8px;font-weight:700;text-decoration:none;">CTA</a>
          </div>
        </div>
      </div>
    `;
    const modalWrap = document.createElement('div');
    modalWrap.innerHTML = modalHtml;
    document.body.appendChild(modalWrap.firstElementChild);

    const modal = document.getElementById('editorial-modal');
    const body = document.getElementById('editorial-modal-body');
    const cta = document.getElementById('editorial-modal-cta');
    document.getElementById('editorial-modal-close').addEventListener('click', () => {
      modal.style.display = 'none';
    });

    function openModal(innerHtml, ctaText, ctaHref) {
      body.innerHTML = innerHtml;
      if (ctaText && ctaHref) {
        cta.textContent = ctaText;
        cta.href = ctaHref;
        cta.style.display = 'inline-flex';
      } else {
        cta.style.display = 'none';
      }
      modal.style.display = 'flex';
    }

    // ── Click handler for all .editorial-generate-btn ─────────────────────
    document.addEventListener('click', async function (e) {
      const btn = e.target.closest('.editorial-generate-btn');
      if (!btn) return;
      e.preventDefault();

      let payload;
      try { payload = JSON.parse(decodeURIComponent(btn.dataset.payload)); }
      catch { return; }

      const cg = payload.contentGeneration;
      btn.disabled = true;
      btn.style.opacity = '0.7';

      try {
        const res = await fetch('/api/editorial/access-check');
        const access = await res.json();

        if (!access.has_access) {
          // Upsell
          openModal(`
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
              <span class="material-symbols-outlined" style="font-size:24px;color:#BA7517;">auto_awesome</span>
              <h3 style="font-size:18px;font-weight:900;color:#1a1a2e;margin:0;">Editorial AI</h3>
            </div>
            <p style="font-size:14px;color:#1a1a2e;margin-bottom:14px;">
              Genera este artículo automáticamente: <strong>"${cg.topic}"</strong>
            </p>
            <ul style="list-style:none;padding:0;margin:0 0 16px;display:flex;flex-direction:column;gap:6px;">
              <li style="font-size:13px;color:#434750;display:flex;gap:8px;"><span style="color:#1D9E75;">✓</span> Redactor con la voz de tu marca</li>
              <li style="font-size:13px;color:#434750;display:flex;gap:8px;"><span style="color:#1D9E75;">✓</span> Editor jefe con fact-check y búsqueda web</li>
              <li style="font-size:13px;color:#434750;display:flex;gap:8px;"><span style="color:#1D9E75;">✓</span> SEO + GEO optimizado con tus keywords</li>
              <li style="font-size:13px;color:#434750;display:flex;gap:8px;"><span style="color:#1D9E75;">✓</span> Medición del impacto en keywords ranking</li>
            </ul>
            <div style="padding:12px 14px;background:#f0f4ff;border-radius:8px;font-size:12px;color:#434750;">
              8 artículos aprobados / mes · incluido en tier Señales
            </div>
          `, 'Activar Señales', '/pricing');
          return;
        }

        if (!access.is_admin) {
          openModal(`
            <h3 style="font-size:18px;font-weight:900;color:#1a1a2e;margin-bottom:12px;">Solo admins pueden generar artículos</h3>
            <p style="font-size:14px;color:#434750;line-height:1.5;">
              Para generar automáticamente <strong>"${cg.topic}"</strong>, pide a un admin de tu equipo que lo lance desde su cuenta.
            </p>
          `);
          return;
        }

        if (!access.can_generate) {
          const q = access.quota;
          openModal(`
            <h3 style="font-size:18px;font-weight:900;color:#1a1a2e;margin-bottom:12px;">Cuota mensual alcanzada</h3>
            <p style="font-size:14px;color:#434750;line-height:1.5;margin-bottom:12px;">
              Has generado ${q.current.generated} de ${q.max.generated} artículos este mes.
              La cuota se reinicia el <strong>${q.resets_on}</strong>.
            </p>
            <p style="font-size:13px;color:#64748b;">
              Te quedan ${q.remaining.approved} aprobaciones disponibles de los artículos ya generados.
            </p>
          `, 'Ver mis artículos', '/editorial/articles');
          return;
        }

        // ALL GOOD — redirect to /editorial/new with pre-filled brief
        const params = new URLSearchParams();
        params.set('topic', cg.topic);
        params.set('type', cg.type);
        if (cg.primary_keyword) params.set('primary_keyword', cg.primary_keyword);
        if (cg.secondary_keywords?.length) params.set('secondary_keywords', cg.secondary_keywords.join(','));
        if (cg.funnel_stage) params.set('funnel_stage', cg.funnel_stage);
        if (cg.language) params.set('language', cg.language);
        if (payload.sourceActionId) params.set('source_action', payload.sourceActionId);
        if (cg.isRefresh && cg.refreshArticleId) {
          params.set('refresh_article_id', cg.refreshArticleId);
        }
        window.location.href = '/editorial/new?' + params.toString();
      } catch (err) {
        console.error('Editorial access check failed', err);
        openModal(`
          <h3 style="font-size:18px;font-weight:900;color:#E24B4A;margin-bottom:12px;">Error</h3>
          <p style="font-size:14px;color:#434750;">
            No se pudo verificar el acceso a Editorial AI. Prueba en unos segundos.
          </p>
        `);
      } finally {
        btn.disabled = false;
        btn.style.opacity = '1';
      }
    });
  })();
</script>
