---
import Sidebar from '../components/dashboard/Sidebar.astro';
import TopBar from '../components/dashboard/TopBar.astro';
import SuperuserBanner from '../components/dashboard/SuperuserBanner.astro';
import ChatWidget from '../components/dashboard/ChatWidget.astro';
import type { Tier } from '../lib/demo-data';
import { getClientOnboarding, isOnboardingComplete } from '../lib/db';

const isSuperuser = Astro.locals.user?.role === 'superuser';
const client = Astro.locals.client;
const onboarding = client ? await getClientOnboarding(client.id) : null;
const profileComplete = isOnboardingComplete(onboarding);

export interface Props {
  title?: string;
  currentPath?: string;
  tier?: Tier;
  clientName?: string;
  domain?: string;
  lastReportMonth?: string;
  lastReportDate?: string;
}

const {
  title = 'AION Dashboard',
  currentPath = '',
  tier = 'señales',
  clientName = 'TechSolutions Barcelona',
  domain = 'techsolutions.es',
  lastReportMonth = 'abril-2026',
  lastReportDate = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — AION Growth Studio</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <style is:global>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }
    .filled-icon {
      font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    * { box-sizing: border-box; }
  </style>
</head>
<body class="bg-background text-on-surface antialiased" style="display:flex;flex-direction:column;height:100vh;overflow:hidden;font-family:'Inter',sans-serif;">

  {isSuperuser && <SuperuserBanner clientName={clientName} />}

  <div style="flex:1;display:flex;overflow:hidden;">
  <!-- Mobile overlay -->
  <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 lg:hidden hidden" onclick="document.getElementById('sidebar').classList.add('-translate-x-full'); this.classList.add('hidden');"></div>

  <Sidebar currentPath={currentPath} tier={tier} clientName={clientName} lastReportMonth={lastReportMonth} />

  <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;margin-left:256px;">
    <TopBar clientName={clientName} domain={domain} tier={tier} lastReportDate={lastReportDate} />
    <main style="flex:1;overflow-y:auto;padding:32px;background:#f7f9ff;position:relative;">
      <div style="max-width:1100px;margin:0 auto;padding-bottom:80px;">
        {!profileComplete && (
          <a href="/dashboard/onboarding" style="display:flex;align-items:center;gap:10px;padding:12px 20px;background:#FFF3E0;border-radius:10px;margin-bottom:24px;text-decoration:none;color:#E65100;font-size:13px;font-weight:600;border:1px solid #FFE0B2;">
            <span class="material-symbols-outlined" style="font-size:18px;">person_edit</span>
            Completa tu perfil de empresa para recibir recomendaciones personalizadas
            <span style="margin-left:auto;font-size:12px;opacity:0.7;">→</span>
          </a>
        )}
        <slot />
      </div>
    </main>
  </div>
  </div>

  <!-- Floating chat widget — same advisor accessible from any dashboard page -->
  <ChatWidget />

  <script>
    // Mobile sidebar toggle
    const hamburger = document.getElementById('hamburger-btn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    if (hamburger && sidebar && overlay) {
      hamburger.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        overlay.classList.toggle('hidden');
      });
    }
  </script>
</body>
</html>
