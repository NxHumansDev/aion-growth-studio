---
import Sidebar from '../components/dashboard/Sidebar.astro';
import TopBar from '../components/dashboard/TopBar.astro';
import SuperuserBanner from '../components/dashboard/SuperuserBanner.astro';
import type { Tier } from '../lib/demo-data';

const isSuperuser = Astro.locals.user?.role === 'superuser';

export interface Props {
  title?: string;
  currentPath?: string;
  tier?: Tier;
  clientName?: string;
  domain?: string;
  lastReportMonth?: string;
}

const {
  title = 'AION Dashboard',
  currentPath = '',
  tier = 'señales',
  clientName = 'Soluciones Verdes',
  domain = 'solucionesverdes.es',
  lastReportMonth = 'Mar 2026',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — AION Growth Studio</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
  <style is:global>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
      vertical-align: middle;
    }
    .filled-icon {
      font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    * { box-sizing: border-box; }
  </style>
</head>
<body class="bg-background text-on-surface antialiased" style="display:flex;flex-direction:column;height:100vh;overflow:hidden;font-family:'Inter',sans-serif;">

  {isSuperuser && <SuperuserBanner clientName={clientName} />}

  <div style="flex:1;display:flex;overflow:hidden;">
  <!-- Mobile overlay -->
  <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 lg:hidden hidden" onclick="document.getElementById('sidebar').classList.add('-translate-x-full'); this.classList.add('hidden');"></div>

  <Sidebar currentPath={currentPath} tier={tier} clientName={clientName} />

  <div style="flex:1;display:flex;flex-direction:column;overflow:hidden;margin-left:256px;">
    <TopBar clientName={clientName} domain={domain} tier={tier} lastReportMonth={lastReportMonth} />
    <main style="flex:1;overflow-y:auto;padding:32px;background:#f7f9ff;position:relative;">
      <div style="max-width:1100px;margin:0 auto;padding-bottom:80px;">
        <slot />
      </div>
    </main>
  </div>
  </div>

  <!-- FAB: Advisor IA -->
  <a
    href="/advisor"
    title="Habla con tu Advisor IA"
    style="position:fixed;bottom:32px;right:32px;width:52px;height:52px;background:#000e41;color:white;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 24px rgba(0,0,0,0.3);text-decoration:none;z-index:100;transition:transform 0.2s,box-shadow 0.2s;"
    onmouseover="this.style.transform='scale(1.1)';this.style.boxShadow='0 12px 32px rgba(0,0,0,0.4)';"
    onmouseout="this.style.transform='scale(1)';this.style.boxShadow='0 8px 24px rgba(0,0,0,0.3)';"
  >
    <span class="material-symbols-outlined" style="font-size:22px;">auto_awesome</span>
  </a>

  <script>
    // Mobile sidebar toggle
    const hamburger = document.getElementById('hamburger-btn');
    const sidebar = document.getElementById('sidebar');
    const overlay = document.getElementById('sidebar-overlay');
    if (hamburger && sidebar && overlay) {
      hamburger.addEventListener('click', () => {
        sidebar.classList.toggle('-translate-x-full');
        overlay.classList.toggle('hidden');
      });
    }
  </script>
</body>
</html>
